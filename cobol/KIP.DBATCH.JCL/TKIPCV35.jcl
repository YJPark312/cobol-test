/*
//*--------*-----------------------------------------------------------
//* STEP_02 : 기업집단신용평가 이행 SAM FILE 삭제
//*--------*-----------------------------------------------------------
//DELETE1  EXEC PGM=IDCAMS
//SYSPRINT DD SYSOUT=*
//SYSIN    DD *
  DELETE   KIP.DT.TKIPB110.UNLOAD
  DELETE   KIP.DT.TKIPB111.UNLOAD
  DELETE   KIP.DT.TKIPB112.UNLOAD
  DELETE   KIP.DT.TKIPB113.UNLOAD
  DELETE   KIP.DT.TKIPB114.UNLOAD
  DELETE   KIP.DT.TKIPB116.UNLOAD
  DELETE   KIP.DT.TKIPB118.UNLOAD
  DELETE   KIP.DT.TKIPB130.UNLOAD
  DELETE   KIP.DT.TKIPC120.UNLOAD
  DELETE   KIP.DT.TKIPC121.UNLOAD
     SET   MAXCC = 00
/*
//*--------*-----------------------------------------------------------
//* STEP_03 : 기업집단신용평가 이행 SAM FILE 생성
//*--------*-----------------------------------------------------------
//*BIP0035  EXEC JZBUEXEC,MBR=BIP0035,OPT=&SYSUID
//BIP0035  EXEC PGM=IKJEFT01,DYNAMNBR=20,
//         PARM='%JZBDDRUN BIP0035 &SYSUID'
//         INCLUDE MEMBER=$BATEXEC
//SYSOUT   DD SYSOUT=*
//CHGLOG1  DD DSN=KIP.DT.TKIPB110.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//CHGLOG2  DD DSN=KIP.DT.TKIPB111.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//CHGLOG3  DD DSN=KIP.DT.TKIPB112.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//CHGLOG4  DD DSN=KIP.DT.TKIPB113.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//CHGLOG5  DD DSN=KIP.DT.TKIPB114.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//CHGLOG6  DD DSN=KIP.DT.TKIPB116.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//CHGLOG7  DD DSN=KIP.DT.TKIPB118.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//CHGLOG8  DD DSN=KIP.DT.TKIPB130.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//CHGLOG9  DD DSN=KIP.DT.TKIPC120.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//CHGLOG10 DD DSN=KIP.DT.TKIPC121.UNLOAD,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,SPACE=(CYL,(100,100),RLSE)
//SYSIN    DD *
01-01
/*