//TKIPCV35 JOB NOTIFY=&SYSUID,CLASS=A,MSGCLASS=X
//*--------*-----------------------------------------------------------
//*배치프로그램 기업집단평가 테이블 이행  SAM FILE 생성*
//*--------*-----------------------------------------------------------
//* STEP_01 : 기업집단신용평가 메인 포함 8개 테이블전환 *
//* IN-01   : THKIIL112->THKIPB110     *
//*         : THKIIL114->THKIPB111     *
//*         : THKIIL210->THKIPB112     *
//*         : THKIIL118->THKIPB113     *
//*         : THKIIL214->THKIPB114     *
//*         : THKIIL113->THKIPB116     *
//*         : THKIIL312->THKIPB118     *
//*         : THKIIL117->THKIPB130     *
//*         : 01(THKIIL314->THKIPC120) *
//*         : 02(THKIIL315->THKIPC121) *
//* EXAMPLE : 01-01                    *
//*--------*-----------------------------------------------------------
//* STEP_01: 기존 THKIPB118 테이블 정리
//*--------*-----------------------------------------------------------
//KIPB118  EXEC DSNUPROC,PARM='DATG,THKIPB118'
//DSNTRACE DD  SYSOUT=*
//SORTLIB  DD  DSN=SYS1.SORTLIB,DISP=SHR
//SORTWK01 DD  UNIT=SYSDA,SPACE=(CYL,(20,20),,,ROUND)
//SORTWK02 DD  UNIT=SYSDA,SPACE=(CYL,(20,20),,,ROUND)
//SORTWK03 DD  UNIT=SYSDA,SPACE=(CYL,(20,20),,,ROUND)
//SORTWK04 DD  UNIT=SYSDA,SPACE=(CYL,(20,20),,,ROUND)
//SYSUT1   DD  UNIT=SYSDA,SPACE=(CYL,(100,100),,,ROUND)
//SORTOUT  DD  UNIT=SYSDA,SPACE=(CYL,(100,100),,,ROUND)
//SYSREC00 DD  DUMMY
//SYSIN    DD  *
 LOAD DATA LOG NO
 NOCOPYPEND
 RESUME NO REPLACE
 STATISTICS TABLE(ALL) INDEX(ALL)
 INDDN SYSREC00 INTO TABLE
   DB2DBA.THKIPB118
/*
