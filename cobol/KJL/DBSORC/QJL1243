           EXEC  SQL
           DECLARE CUR_SQL  CURSOR WITH HOLD
                                       WITH ROWSET POSITIONING FOR
       SELECT B.ПЕОїСЁФкЕх
             ,B.КЮСЁИэ
             ,B.АэАДНФКАРк
             ,B.УЄЙЋРкИэ       AS ТїСжИэ
             ,B.АшП­Иэ         AS БзЗьИэ
             ,B.НХУЛНУНХПыЕюБо
             ,B.БтОїЕюБо       AS НХПыЕюБо
             ,B.НХУЛНУБзЗьЕюБо
             ,B.БзЗьЕюБо
             ,B.АќИЎЧбЕЕМГСЄГтПљРЯ
             ,B.МГСЄЛѓХТ
             ,B.РЏШПБтРЯ
             ,B.ПЉНХМКЧбЕЕ
             ,B.АЃСЂРЭНКЦїСЎ
             ,CASE WHEN B.БтОїЕюБо IN ('AAA','AA+','AA','AA-',
                                       'A+','A','A-','BBB+')
                   THEN B.ЦїА§ЧбЕЕ
                   ELSE 0
              END AS ЦїА§ЧбЕЕ
             ,CASE WHEN B.БтСиГтПљРЯ < HEX(CURRENT DATE - 1 MONTH)
                   THEN B.ПљИЛБтЛчПыОз
                   ELSE B.БтЛчПыОз
              END              AS БтЛчПыОз
             ,' ' AS СЁАЫНТРЮГтПљРЯ
         FROM (SELECT A.БзЗьШИЛчФкЕх
                     ,A.АэАДАќИЎКЮСЁФкЕх   AS ПЕОїСЁФкЕх
                     ,VALUE(
                      (SELECT КЮСЁЧбБлИэ
                         FROM        THKJIBR01
                        WHERE БзЗьШИЛчФкЕх = A.БзЗьШИЛчФкЕх
                          AND КЮСЁФкЕх     = A.АэАДАќИЎКЮСЁФкЕх
                        ORDER BY РћПыСОЗсГтПљРЯ DESC
                        FETCH FIRST 1 ROWS ONLY
                       ), ' ') AS КЮСЁИэ
                     ,VALUE(C.АэАДНФКАРк,'')     AS АэАДНФКАРк
                     ,VALUE(C.УЄЙЋРкИэ,'')       AS УЄЙЋРкИэ
                     ,VALUE(C.АшП­БтОїБКИэ,'')   AS АшП­Иэ
                     ,VALUE(
                      (SELECT SUBSTR(MAX(БтСиГтПљРЯ||
                                         ГЛКЮНХПыЦђАЁЕюБоБИКа),9,4)
                         FROM        THKJL0010
                        WHERE БзЗьШИЛчФкЕх  = A.БзЗьШИЛчФкЕх
                          AND БтСиГтПљРЯ    < A.АќИЎЧбЕЕМГСЄГтПљРЯ
                          AND АэАДНФКАРк    = A.АэАДНФКАРк
                       ),'') AS НХУЛНУНХПыЕюБо
                     ,VALUE(CASE WHEN C.ГЛКЮНХПыЦђАЁЕюБоБИКа = '0000'
                                 THEN ' '
                                 ELSE C.ГЛКЮНХПыЦђАЁЕюБоБИКа
                            END,'')                  AS БтОїЕюБо
                     ,VALUE(
                      (SELECT CASE WHEN БзЗьЛчНХПыЕюБоБИКа = '000'
                                   THEN ' '
                                   ELSE БзЗьЛчНХПыЕюБоБИКа
                              END AS БзЗьЕюБо
                         FROM        THKJL0013
                        WHERE БзЗьШИЛчФкЕх    = A.БзЗьШИЛчФкЕх
                          AND БтСиГтПљ        =
                              SUBSTR(A.АќИЎЧбЕЕМГСЄГтПљРЯ,1,6)
                          AND АшП­РћПыБИКа    = '1'
                          AND АшП­БтОїБКФкЕх  = C.АшП­БтОїБКФкЕх
                       ),' ') AS НХУЛНУБзЗьЕюБо
                     ,VALUE(
                      (SELECT CASE WHEN БзЗьЛчНХПыЕюБоБИКа = '000'
                                   THEN ' '
                                   ELSE БзЗьЛчНХПыЕюБоБИКа
                              END AS БзЗьЕюБо
                         FROM        THKJL0013
                        WHERE БзЗьШИЛчФкЕх    = A.БзЗьШИЛчФкЕх
                          AND БтСиГтПљ = SUBSTR(A.БтСиГтПљРЯ,1,6)
                          AND АшП­РћПыБИКа   = '1'
                          AND АшП­БтОїБКФкЕх = C.АшП­БтОїБКФкЕх
                       ),' ')  AS БзЗьЕюБо
                     ,A.АќИЎЧбЕЕМГСЄГтПљРЯ
                     ,CASE WHEN A.АќИЎЧбЕЕ = 0
                           THEN 'ЙЬМГСЄ'
                           ELSE 'МГСЄ'
                      END                  AS МГСЄЛѓХТ
                     ,A.АќИЎЧбЕЕРЏШПГтПљРЯ AS РЏШПБтРЯ
                     ,VALUE(
                      (SELECT CASE WHEN АќИЎЧбЕЕРЏШПГтПљРЯ >=
                                        A.БтСиГтПљРЯ
                                   THEN ПЉНХМКАќИЎЧбЕЕ
                                   ELSE 0
                              END
                         FROM        THKJL0011
                        WHERE БзЗьШИЛчФкЕх    = A.БзЗьШИЛчФкЕх
                          AND БтСиГтПљ = SUBSTR(A.БтСиГтПљРЯ,1,6)
                          AND АэАДНФКАРк      = A.АэАДНФКАРк
                       ),0)                AS ПЉНХМКЧбЕЕ
                     ,VALUE(
                      (SELECT SUM(АЃСЂРЭНКЦїСЎБнОз) AS АЃСЂРЭНКЦїСЎ
                         FROM        THKJL0027
                        WHERE БзЗьШИЛчФкЕх     = A.БзЗьШИЛчФкЕх
                          AND БтСиРЯ    = SUBSTR(A.БтСиГтПљРЯ,7,2)
                          AND БтСиГтПљ  = SUBSTR(A.БтСиГтПљРЯ,1,6)
                          AND ДуКИКИСѕАэАДНФКАРк = A.АэАДНФКАРк
                       ),0)                AS АЃСЂРЭНКЦїСЎ
                     ,A.АќИЎЧбЕЕ           AS ЦїА§ЧбЕЕ
                     ,VALUE(
                      (SELECT SUM(A1."ЧбЕЕБтСиTEБнОз")
                         FROM        THKJL0129 A1
                             ,       THKJL0118 C1
                        WHERE A1.БзЗьШИЛчФкЕх = A.БзЗьШИЛчФкЕх
                          AND A1.БтСиРЯ       =
                                 SUBSTR(A.БтСиГтПљРЯ,7,2)
                          AND A1.БтСиГтПљ     =
                                 SUBSTR(A.БтСиГтПљРЯ,1,6)
                          AND A1.ТїСжАэАДНФКАРк = A.АэАДНФКАРк
                          AND A1.БзЗьШИЛчФкЕх   = C1.БзЗьШИЛчФкЕх
                          AND A1.БтСиГтПљ       = C1.БтСиГтПљ
                          AND A1.ЛѓЧАДыКаЗљФкЕх = C1.ЛѓЧАДыКаЗљФкЕх
                          AND A1.ЛѓЧАСпКаЗљФкЕх = C1.ЛѓЧАСпКаЗљФкЕх
                          AND A1.ЛѓЧАХлЧУИДФкЕх = C1.ЛѓЧАХлЧУИДФкЕх
                          AND A1.ЛѓЧАЙјШЃ       = C1.ЛѓЧАЙјШЃ
                          AND C1."CPДыЛѓАшСЄПЉКЮ" = '1'
                        GROUP BY A1.ТїСжАэАДНФКАРк
                       ),0)                AS БтЛчПыОз
                     ,VALUE(
                      (SELECT SUM(A2."ЧбЕЕБтСиTEБнОз")
                         FROM        THKJL0130 A2
                             ,       THKJL0118 C2
                        WHERE A2.БзЗьШИЛчФкЕх = A.БзЗьШИЛчФкЕх
                          AND A2.БтСиГтПљ     =
                                 SUBSTR(A.БтСиГтПљРЯ,1,6)
                          AND A2.ТїСжАэАДНФКАРк = A.АэАДНФКАРк
                          AND A2.БзЗьШИЛчФкЕх   = C2.БзЗьШИЛчФкЕх
                          AND A2.БтСиГтПљ       = C2.БтСиГтПљ
                          AND A2.ЛѓЧАДыКаЗљФкЕх = C2.ЛѓЧАДыКаЗљФкЕх
                          AND A2.ЛѓЧАСпКаЗљФкЕх = C2.ЛѓЧАСпКаЗљФкЕх
                          AND A2.ЛѓЧАХлЧУИДФкЕх = C2.ЛѓЧАХлЧУИДФкЕх
                          AND A2.ЛѓЧАЙјШЃ       = C2.ЛѓЧАЙјШЃ
                          AND C2."CPДыЛѓАшСЄПЉКЮ" = '1'
                        GROUP BY A2.ТїСжАэАДНФКАРк
                       ),0)                AS ПљИЛБтЛчПыОз
                     ,A.БтСиГтПљРЯ
                 FROM        THKJL0010 A LEFT OUTER JOIN
                             THKJL0015 C
                   ON A.БзЗьШИЛчФкЕх = C.БзЗьШИЛчФкЕх
                  AND A.АэАДНФКАРк   = C.АэАДНФКАРк
                WHERE A.БзЗьШИЛчФкЕх = :XQJL1243-I-GROUP-CO-CD
                  AND A.БтСиГтПљРЯ   = :XQJL1243-I-BASE-YMD
                  AND A.АэАДАќИЎКЮСЁФкЕх BETWEEN :XQJL1243-I-BRNCD1
                                             AND :XQJL1243-I-BRNCD2
                  AND A.АќИЎЧбЕЕ     = 0
               ) B
        WHERE ((B.МГСЄЛѓХТ    = :XQJL1243-I-STUP-STUS
          AND   B.АэАДНФКАРк >= :XQJL1243-I-CUST-IDNFR)
           OR   B.МГСЄЛѓХТ   <  :XQJL1243-I-STUP-STUS)
        ORDER BY B.МГСЄЛѓХТ DESC
               , B.АэАДНФКАРк
         WITH UR
      *
           END-EXEC
