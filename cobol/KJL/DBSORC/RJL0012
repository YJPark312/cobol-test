      *ЛшСІНУ OLD РЬЙЬСіИІ БтЗЯЧЯБт РЇЧиМ­ УпАЁ
      *ЛшСІРкЗсИІ ЛчПыРкАЁ КЏАцЧЯДТ АЭРЛ ДыРР
      *TEMP/STOPИ№ЕхДТ УГИЎЧЯДТ АїПЁМ­ SELECT Чд
           IF SICOM-OPER-DSTCD             =    CONT-DAY
           THEN
               PERFORM  S8700-SEL-NOLOCK-RTN THRU S8700-SEL-NOLOCK-EXT
           END-IF
      *
           MOVE  LENGTH OF DBIO-RECORD      TO   DBIO-TABLE-LEN
           MOVE  DBIO-RECORD                TO   WORK-CORRECTION
      *
           EXEC SQL
           INSERT INTO        THKLA9020  (
                  "БзЗьШИЛчФкЕх",
                  "УГИЎРЯ",
                  "ХзРЬКэИэ",
                  "УГИЎХАИэ",
                  "УГИЎНУАЂ",
                  "УГИЎХАБцРЬ",
                  "УГИЎЕЅРЬХЭБцРЬ",
                  "УГИЎЕЅРЬХЭГЛПы",
                  "НУНКХлУжСОУГИЎРЯНУ",
                  "НУНКХлУжСОЛчПыРкЙјШЃ"
                      )
           VALUES     (
                 :BICOM-GROUP-CO-CD,
                 :BICOM-TRAN-BASE-YMD,
                 :DBIO-TABLE-NM,
                 :DBIO-KEY,
                 :BICOM-TRAN-BASE-HMS,
