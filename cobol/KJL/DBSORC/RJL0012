      *  УГИЎБтДЩ : CURSORИІ Л§МКЧЯАэ OPENНУХВДй.
      *-----------------------------------------------------------------
      *
      *DECLARE & OPENРЛ ACCESS-KEYКАЗЮ ЙнКЙРћРИЗЮ СЄРЧ
      *
       S8110-DECLARE-KEY0-RTN.
           EXEC SQL DECLARE CUR_MODE_KEY0 CURSOR FOR
           SELECT
                  "БзЗьШИЛчФкЕх",
                  "БтСиГтПљ",
                  "АшП­БтОїБКФкЕх",
                  "БзЗьЛчНХПыЕюБоБИКа",
                  "НХПыЦђАЁГтПљРЯ",
                  "БтСиЧбЕЕ",
                  "БтСиЧбЕЕЛъУтГтПљРЯ",
                  "АќИЎЧбЕЕ",
                  "АќИЎЧбЕЕМГСЄГтПљРЯ",
                  "АќИЎЧбЕЕРЏШПГтПљРЯ",
                  "ПЉНХМКАќИЎЧбЕЕ",
                  "НУРхМКАќИЎЧбЕЕ",
                  "НУНКХлУжСОУГИЎРЯНУ",
                  "НУНКХлУжСОЛчПыРкЙјШЃ"
             FROM        THKJL0012
            WHERE ( 'PK' = :WORK-ACCECODE AND 1 <= :WORK-ACCESS-COND
              AND "БзЗьШИЛчФкЕх" = :GROUP-CO-CDP0
              AND "БтСиГтПљ" = :BASE-YMP0
              AND "АшП­БтОїБКФкЕх" > :AFFLT-CORP-GROUP-CDP0 )
            ORDER BY
                  "БзЗьШИЛчФкЕх" ASC
                 ,"БтСиГтПљ" ASC
                 ,"АшП­БтОїБКФкЕх" ASC
           END-EXEC
      *
           IF  SQLCODE                      =    ZERO
           THEN
               CONTINUE
           ELSE
               MOVE  CONT-SQLER            TO   DBIO-STAT
               PERFORM  S9100-ERROR-END-RTN
                  THRU  S9100-ERROR-END-EXT
           END-IF
      *
           EXEC SQL OPEN  CUR_MODE_KEY0 END-EXEC
      *
           IF  SQLCODE                      =    -502
           THEN
               EXEC SQL CLOSE  CUR_MODE_KEY0 END-EXEC
               EXEC SQL OPEN   CUR_MODE_KEY0 END-EXEC
           END-IF
           .
       S8110-DECLARE-KEY0-EXT.
           EXIT.
      *

      *
      *-----------------------------------------------------------------
