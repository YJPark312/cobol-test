      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : TEMP,STOP MODE РЯЖЇ РЬЙЬСіКЙПјРЛ
      *             РЇЧи НЧЧрЧбДй.
      *  УГИЎБтДЩ : АХЗЁИ№ЕхАЁ TEMP/STOPРЬИч
      *             INSERT,UPDATE,DELETE АЁ ЙпЧрЧЯИщ
      *             ПјРхКИСЄЗЮБз/ПјРхЙнПЕЗЮБз
      *             ПЁ INSERT ЧЯПЉ БтЗЯРЛ ГВБфДй.
      *-----------------------------------------------------------------
       S8800-IMAGE-INSERT-RTN.
      *
           MOVE  "S8800"                    TO   BSGEROR-PARA
      *
           STRING  BICOM-TRAN-BASE-YMD
                   BICOM-TRAN-BASE-HMS      DELIMITED BY SIZE
             INTO  WORK-LAST-DT
      *
           MOVE    BICOM-TRAN-START-YMS     TO   WORK-STRT-DT
      *    MOVE    DBIO-KEY                 TO   WORK-DBIO-KEY
      *PK ПЕПЊПЁ "'" ЕЅРЬХЭ СИРчАЫСѕ
           INSPECT  PK-THKJL0012   TALLYING
                    WORK-QUOTA-CNT FOR  ALL CONT-QUOTA
      *
           IF  WORK-QUOTA-CNT > ZERO
           THEN
                   MOVE  ZERO               TO  SQLCODE
                   MOVE  CONT-SYSERROR      TO  DBIO-STAT
      *{E} PK ПЕПЊПЁ "'" ЕЅРЬХЭ СИРч
                   MOVE  "S9000099"         TO   XZUGEROR-I-ERRCD
                   MOVE  "UKLA0002"         TO   XZUGEROR-I-TREAT-CD
                   MOVE   9904              TO   XZUGEROR-I-LINE
                   MOVE  SPACE              TO   XZUGEROR-I-MSG
                   STRING  'PK ПЕПЊПЁ "'
                           CONT-QUOTA
                           '" ЕЅРЬХЭ СИРч'  DELIMITED BY SIZE
                     INTO  XZUGEROR-I-MSG
                   PERFORM  S9100-ERROR-END-RTN
                      THRU  S9100-ERROR-END-EXT
           END-IF
      *
           MOVE  SPACE                      TO   WORK-COND-DESC
           MOVE  1                          TO   WORK-STRT-POINT
           MOVE 'WHERE "БзЗьШИЛчФкЕх" = '
             TO  WORK-COND-DESC(WORK-STRT-POINT:00029)
           ADD   00029                      TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
           MOVE  LENGTH OF GROUP-CO-CDP0
             TO  WORK-LEN
           MOVE  GROUP-CO-CDP0
             TO  WORK-COND-DESC(WORK-STRT-POINT:WORK-LEN)
           ADD   WORK-LEN                  TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
           MOVE ' AND "БтСиГтПљ" = '
             TO  WORK-COND-DESC(WORK-STRT-POINT:00022)
           ADD   00022                      TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
           MOVE  LENGTH OF BASE-YMP0
             TO  WORK-LEN
           MOVE  BASE-YMP0
             TO  WORK-COND-DESC(WORK-STRT-POINT:WORK-LEN)
           ADD   WORK-LEN                  TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
           MOVE ' AND "АшП­БтОїБКФкЕх" = '
             TO  WORK-COND-DESC(WORK-STRT-POINT:00031)
           ADD   00031                      TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
           MOVE  LENGTH OF AFFLT-CORP-GROUP-CDP0
             TO  WORK-LEN
           MOVE  AFFLT-CORP-GROUP-CDP0
             TO  WORK-COND-DESC(WORK-STRT-POINT:WORK-LEN)
           ADD   WORK-LEN                  TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
      *

      *
      *VARMOV
      *
           INITIALIZE  XZSFDBLG-CA

           MOVE  LENGTH OF DBIO-RECORD      TO   DBIO-TABLE-LEN
      *
           EVALUATE  SICOM-OPER-DSTCD
      *
               WHEN  CONT-TEMP
                     PERFORM  S8810-TEMP-INSERT-RTN
                        THRU  S8810-TEMP-INSERT-EXT
               WHEN  CONT-STOP
                     PERFORM  S8820-STOP-SELECT-RTN
                        THRU  S8820-STOP-SELECT-EXT
               WHEN  OTHER
                     CONTINUE
           END-EVALUATE
           .
       S8800-IMAGE-INSERT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : TEMP MODE РЯЖЇ ПјРхКЙПјРЛ РЇЧи НЧЧрЧбДй.
      *  УГИЎБтДЩ : АХЗЁИ№ЕхАЁ TEMPРЬИч
      *             INSERT,UPDATE,DELETE АЁ ЙпЧрЧЯИщ
      *             ПјРхКИСЄЗЮБз
      *             ПЁ INSERT ЧЯПЉ БтЗЯРЛ ГВБфДй.
      *-----------------------------------------------------------------

       S8810-TEMP-INSERT-RTN.

           MOVE  DB-TABLE                   TO   WORK-CORRECTION
      *
           ADD   LENGTH OF YCCOMMON-CA
                 LENGTH OF YCDBIOCA-CA
                 LENGTH OF XZSFDBLG-CA
                 LENGTH OF WORK-CORRECTION
                 LENGTH OF WORK-COND-DESC
            GIVING  COMM-CALLG-SCOP-LEN
      *
           MOVE  "ZSFDBLG"                  TO   YCFCTLAR-CALL-PGM
           CALL  YCFCTLAR-CALL-PGM        USING  DFHEIBLK
                                                 YCCOMMON-CA
                                                 YCDBIOCA-CA
                                                 XZSFDBLG-CA
                                                 WORK-CORRECTION
                                                 WORK-COND-DESC
           END-CALL
      *
           MOVE  DBIO-SQLCODE               TO   SQLCODE
      *
           EVALUATE  SQLCODE
               WHEN  ZERO
                     CONTINUE
               WHEN  -803
                     MOVE  ZERO             TO   SQLCODE
               WHEN  -805
                     MOVE  "ZSFDBLG"        TO   CONT-PROGRAM-ID
                     MOVE  CONT-SQLER       TO   DBIO-STAT
                     PERFORM  S9100-ERROR-END-RTN
                        THRU  S9100-ERROR-END-EXT
               WHEN  OTHER
                     MOVE  CONT-SQLER       TO   DBIO-STAT
                     PERFORM  S9100-ERROR-END-RTN
                        THRU  S9100-ERROR-END-EXT
           END-EVALUATE
           .
       S8810-TEMP-INSERT-EXT.
           EXIT.
      *
       S8820-STOP-SELECT-RTN.
      *

      *
           IF  COND-DBIO-INSERT OR COND-DBIO-UPDATE OR COND-DBIO-LKUPDT
           THEN
               MOVE  BICOM-TRAN-START-YMS   TO   SYS-LAST-PRCSS-YMS
                                                 OF DBIO-RECORD
           END-IF

           MOVE  DBIO-RECORD                TO   WORK-CORRECTION
      *
           ADD   LENGTH OF YCCOMMON-CA
                 LENGTH OF YCDBIOCA-CA
                 LENGTH OF XZSFDBLG-CA
                 LENGTH OF WORK-CORRECTION
                 LENGTH OF WORK-COND-DESC
            GIVING  COMM-CALLG-SCOP-LEN
      *
           MOVE  "ZSFDBLG"                  TO   YCFCTLAR-CALL-PGM
           CALL  YCFCTLAR-CALL-PGM        USING  DFHEIBLK
                                                 YCCOMMON-CA
                                                 YCDBIOCA-CA
                                                 XZSFDBLG-CA
                                                 WORK-CORRECTION
                                                 WORK-COND-DESC
           END-CALL
      *
           MOVE  DBIO-SQLCODE               TO   SQLCODE
      *
           EVALUATE  SQLCODE
               WHEN  ZERO
                     CONTINUE
               WHEN  -805
                     MOVE  "ZSFDBLG"        TO   CONT-PROGRAM-ID
                     MOVE  CONT-SQLER       TO   DBIO-STAT
                     PERFORM  S9100-ERROR-END-RTN
                        THRU  S9100-ERROR-END-EXT
               WHEN  OTHER
                     MOVE  CONT-SQLER       TO   DBIO-STAT
                     PERFORM  S9100-ERROR-END-RTN
                        THRU  S9100-ERROR-END-EXT
           END-EVALUATE

           .
       S8820-STOP-SELECT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *   КЏАцРќШФ СЄКИИІ WRITEЧбДй.
      *-----------------------------------------------------------------
       S8850-UPDATE-DELETE-WRITE-RTN.
      *
           IF  COMM-ONLINE-YN NOT = '1'
               AND   COND-DBIO-CHGLOG-YES
               PERFORM S8700-SEL-NOLOCK-RTN THRU S8700-SEL-NOLOCK-EXT
      *        УжСОРЯКЏАц
               MOVE  SYS-LAST-PRCSS-YMS OF DBIO-RECORD  TO SAVE-LAST-DT
               MOVE  SYS-LAST-UNO OF DBIO-RECORD TO SAVE-LAST-CHNG-USID
               MOVE  BICOM-TRAN-START-YMS   TO XZSFDBUD-I-TRAN-START-YMS
                                       SYS-LAST-PRCSS-YMS OF DBIO-RECORD
               MOVE  BICOM-USER-EMPID   TO  SYS-LAST-UNO OF DBIO-RECORD
               MOVE  LENGTH OF DBIO-RECORD    TO    DBIO-TABLE-LEN
               MOVE  "ZSFDBUD"                TO    YCFCTLAR-CALL-PGM
               CALL  YCFCTLAR-CALL-PGM        USING DFHEIBLK
                                                    YCCOMMON-CA
                                                    XZSFDBUD-CA
                                                    YCDBIOCA-CA
                                                    DB-TABLE
                                                    DBIO-RECORD
               END-CALL
               MOVE  SAVE-LAST-DT  TO SYS-LAST-PRCSS-YMS OF DBIO-RECORD
               MOVE  SAVE-LAST-CHNG-USID TO SYS-LAST-UNO OF DBIO-RECORD
               IF    XZSFDBUD-R-STAT NOT = CONT-OK
                     MOVE  "ZSFDBUD"        TO   CONT-PROGRAM-ID
                     MOVE  CONT-ABNORMAL    TO   DBIO-STAT
                     PERFORM  S9100-ERROR-END-RTN
                        THRU  S9100-ERROR-END-EXT
               END-IF
           END-IF
           .
       S8850-UPDATE-DELETE-WRITE-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : ЧСЗЮБзЗЅРЛСЄЛѓРћРИЗЮМіЧрШФСЄЛѓСОЗсИІЧд
      *  УГИЎБтДЩ : УГИЎАсАњИІСЄЛѓРИЗЮMOVEЧбШФСОЗсRTNШЃУт
      *-----------------------------------------------------------------
       S9000-NOMAL-END-RTN.
      *
           MOVE  CONT-OK                    TO DBIO-STAT
                                               XZUGEROR-I-STAT
           IF      COMM-START-EIO-DSTCD = '9'
           THEN
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE 999999              TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END OK :'
                           'STAT=' XZUGEROR-I-STAT    DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF
      *
           GOBACK
           .
       S9000-NOMAL-END-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : ЧСЗЮБзЗЅГЛКЮПЁМ­ПЁЗЏЙпЛ§НУУГИЎЧд
      *  УГИЎБтДЩ : ПЁЗЏПЁАќЗУЕШСЄКИИІXZUGEROR-CAПЁMOVEШФ
      *             XZUGERORРЛШЃУтЧЯАэПЁЗЏСЄКИИІDISPLAYЧбДй.
      *-----------------------------------------------------------------
       S9100-ERROR-END-RTN.
      *
           MOVE  CONT-Y                     TO   WORK-ERR-SET-YN
      *
           MOVE  DBIO-CALL-PGM-ID           TO   XZUGEROR-I-TBL-ID
           MOVE  DBIO-FUNCTION              TO   XZUGEROR-I-FUNC-CD

           MOVE  SQLCODE                    TO   XZUGEROR-I-SQL-CD
                                                 DBIO-SQLCODE
      *
           IF    XZUGEROR-I-TREAT-CD = SPACE
           THEN
                 MOVE  "UKLA0002"           TO   XZUGEROR-I-TREAT-CD
           END-IF

           MOVE  SPACE                      TO   XZUGEROR-I-MULT
      *
           EVALUATE  SQLCODE
               WHEN  ZERO
                     MOVE  ZERO             TO   XZUGEROR-I-SQL-CD
               WHEN  +100
                     MOVE  CONT-MRNF        TO   DBIO-STAT
                     INITIALIZE                  DBIO-RECORD
      *{E} DBПЁ ЕЅРЬХИАЁ ОјНРДЯДй.
      *              MOVE  "D9900100"       TO   XZUGEROR-I-ERRCD
               WHEN  -803
                     MOVE  CONT-DUPM        TO   DBIO-STAT
      *{E} DBПЁ ЕЅРЬХИАЁ СИРч ЧеДЯДй.
      *              MOVE  "D9900803"       TO   XZUGEROR-I-ERRCD
               WHEN  OTHER
                     IF  DBIO-SQLCODE(4:1) = "9" OR DBIO-SQLCODE = -805
                     THEN
                         MOVE CONT-SYSERROR TO   DBIO-STAT
                     ELSE
                         MOVE CONT-SQLER    TO   DBIO-STAT
                     END-IF
      *{E} DBIO SQL ПЁЗЏРдДЯДй
                     MOVE  "D9900000"       TO   XZUGEROR-I-ERRCD
                     MOVE  XZUGEROR-I-SQL-CD(2:)
                                            TO   XZUGEROR-I-ERRCD(4:)
                     MOVE  "UKLA0002"       TO   XZUGEROR-I-TREAT-CD
                     MOVE
           " DBIO SQL ПЁЗЏРдДЯДй"
                                            TO   XZUGEROR-I-MSG
           END-EVALUATE
      *
           IF  XZUGEROR-I-TREAT-CD          =    "UKLA9999"
           THEN
               MOVE  "DBIO    "             TO   XZUGEROR-I-PGM-ID
           ELSE
      *        MOVE  DBIO-CALL-PGM-ID       TO   XZUGEROR-I-PGM-ID
               MOVE  CONT-PROGRAM-ID        TO   XZUGEROR-I-PGM-ID
           END-IF
      *
           IF  XZUGEROR-I-ERRCD         =    SPACE
           THEN
      *{E} DBIOИ№ЕтПЁМ­ ПЁЗЏСОЗс ЕЧОњНРДЯДй.
               MOVE  "S9000017"             TO   XZUGEROR-I-ERRCD
                     MOVE
           "DBIOИ№ЕтПЁМ­ПЁЗЏСОЗсЕЧОњНРДЯДй"
                                            TO   XZUGEROR-I-MSG
           ELSE
               CONTINUE
           END-IF
      *
           IF  COND-DBIO-DUPM               OR
               COND-DBIO-MRNF
           THEN
               MOVE  CONT-N                 TO   WORK-ERR-SET-YN
      *        MOVE "АсАњФкЕх{01}Ањ{02}ДТПЁЗЏУГИЎИІЧЯСіОЪНРДЯДй."
           ELSE
               CONTINUE
           END-IF
      *
           IF  COMM-DB-II-OUTPT-DSTCD            =    "1" OR "9"
           THEN
               PERFORM  S7900-BSGTRCE-RTN THRU S7900-BSGTRCE-EXT
               IF  WORK-ERR-SET-YN = CONT-Y
               THEN
                   MOVE  XZUGEROR-I-MSG     TO   BSGDISP-TEXT
                   PERFORM  S7900-BSGTRCE-RTN    THRU S7900-BSGTRCE-EXT
               END-IF
           END-IF
      *

      *
           MOVE  DBIO-STAT                  TO   XZUGEROR-I-STAT
      *
           IF  WORK-ERR-SET-YN              =    CONT-Y
           THEN
               IF  (XZUGEROR-I-SQL-CD NOT = ZERO)  AND
                   (XZUGEROR-I-SQL-CD NOT = -805)
               THEN
                   IF  WORK-MSG-GET-FLAG = SPACE
                   THEN
                       PERFORM  S9300-SQL-MSG-GET-RTN
                          THRU  S9300-SQL-MSG-GET-EXT
                   END-IF
                   PERFORM  S9400-SQL-MSG-DIS-RTN
                      THRU  S9400-SQL-MSG-DIS-EXT
               END-IF
               MOVE    'ZUGEROR'            TO   YCFCTLAR-CALL-LOG
               CALL    YCFCTLAR-CALL-LOG USING   YCCOMMON-CA
                                                 XZUGEROR-CA
               END-CALL
           END-IF
      *
           IF      COMM-START-EIO-DSTCD = '9'
           THEN
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE 999999              TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END ER :'
                           'STAT=' XZUGEROR-I-STAT  DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF

           GOBACK
           .
       S9100-ERROR-END-EXT.
           EXIT.
      *
       S9300-SQL-MSG-GET-RTN.
           CALL    'DSNTIAR'    USING    SQLCA
                                         ERROR-MESSAGE
                                         ERROR-TEXT-LEN
           END-CALL

           MOVE  CONT-Y             TO   WORK-MSG-GET-FLAG
           .
       S9300-SQL-MSG-GET-EXT.
           EXIT.
      *
       S9400-SQL-MSG-DIS-RTN.
      *
           PERFORM VARYING ERR-IDX FROM 1 BY 1
             UNTIL ERR-IDX > 10
                   MOVE '13'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE 999999              TO   YCFCTLAR-LOG-LINE-NO
                   STRING  ERROR-TEXT(ERR-IDX)   DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-PERFORM
           .
       S9400-SQL-MSG-DIS-EXT.
           EXIT.
