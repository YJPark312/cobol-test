             TO  AFFLT-CORP-GROUP-CDP0 OF KEY-DB-TABLE

           MOVE  PK-THKJL0012               TO   DBIO-KEY


      *    IF  GROUP-CO-CD OF DBIO-RECORD NOT = "KB0"
           IF  GROUP-CO-CD OF DBIO-RECORD NOT = BICOM-GROUP-CO-CD
           THEN
               MOVE  CONT-SYSERROR  TO   DBIO-STAT
               MOVE  "S9000099"     TO   XZUGEROR-I-ERRCD
               MOVE  "UKLA0002"     TO   XZUGEROR-I-TREAT-CD
               MOVE   9901          TO   XZUGEROR-I-LINE
               MOVE
                     "БзЗьШИЛчФкЕхИІ 'KB0' ЗЮ ЛчПыЧЯММПф!!!"
                                    TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN
                  THRU  S9100-ERROR-END-EXT
           END-IF

           END-IF
      *
           EVALUATE  TRUE
               WHEN  COND-DBIO-PK
                     MOVE  DBIO-KEY         TO
                                            PK-THKJL0012
                     MOVE  GROUP-CO-CDP0 OF KEY-DB-TABLE
                       TO  GROUP-CO-CD  OF  DBIO-RECORD
                     MOVE  BASE-YMP0 OF KEY-DB-TABLE
                       TO  BASE-YM  OF  DBIO-RECORD
                     MOVE  AFFLT-CORP-GROUP-CDP0 OF KEY-DB-TABLE
                       TO  AFFLT-CORP-GROUP-CD  OF  DBIO-RECORD
           END-EVALUATE
           .
       S0130-KEYVALUE-MOVE-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : DBIOCAИІХыЧиЙоРКDBIO-ХАСпСЂБйСЖАЧЙќРЇПЁЧи
      *             ЧЪЕхРЧ АЊРЛ УЃОЦМ­ MOVE
      *  УГИЎБтДЩ : DBIO-ACCESS-KEYПЁЕћЖѓ KEY VALUEИІ MOVE
      *-----------------------------------------------------------------
       S0140-KEYVALUE-DISP-RTN.
      *
           MOVE  "S0140"                    TO   BSGEROR-PARA
      *
           IF  COMM-DB-II-OUTPT-DSTCD       =    "1" OR "9"
           THEN
               CONTINUE
           ELSE
               GO TO S0140-KEYVALUE-DISP-EXT
           END-IF
      *
           IF  COND-DBIO-FETCH   OR  COND-DBIO-CLOSE
           THEN
               GO TO S0140-KEYVALUE-DISP-EXT
           END-IF
      *
           EVALUATE  TRUE
               WHEN  COND-DBIO-PK
                     MOVE  "PK:БзЗьШИЛчФкЕх                ="
                                            TO BSGDISP-TEXT(1:34)
                     MOVE  GROUP-CO-CDP0 OF KEY-DB-TABLE
                                            TO BSGDISP-TEXT(35:)
                     PERFORM  S7700-BSGDISP-RTN
                        THRU  S7700-BSGDISP-EXT
                     MOVE  "PK:БтСиГтПљ                    ="
                                            TO BSGDISP-TEXT(1:34)
                     MOVE  BASE-YMP0 OF KEY-DB-TABLE
                                            TO BSGDISP-TEXT(35:)
                     PERFORM  S7700-BSGDISP-RTN
                        THRU  S7700-BSGDISP-EXT
                     MOVE  "PK:АшП­БтОїБКФкЕх              ="
                                            TO BSGDISP-TEXT(1:34)
                     MOVE  AFFLT-CORP-GROUP-CDP0 OF KEY-DB-TABLE
                                            TO BSGDISP-TEXT(35:)
                     PERFORM  S7700-BSGDISP-RTN
                        THRU  S7700-BSGDISP-EXT
           END-EVALUATE
      *
           MOVE  SPACE                      TO   BSGDISP-TEXT
      *
           .
       S0140-KEYVALUE-DISP-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : ЧСЗЮБзЗЅ НУРлРќ БтКЛМГСЄ Йз УЪБтШ­
      *  УГИЎБтДЩ : ЛчПыРкСЄКИ КЏМі SET
      *-----------------------------------------------------------------
       S0150-USID-INFO-SET-RTN.
      *
      *    MOVE  "S0150"                    TO   BSGEROR-PARA
      *
      *VARLEN
      *
           IF  BICOM-TRAN-START-YMS = SPACE
           THEN
               MOVE  CONT-SYSERROR  TO   DBIO-STAT
               MOVE  "S9000099"     TO   XZUGEROR-I-ERRCD
               MOVE  "UKLA0002"     TO   XZUGEROR-I-TREAT-CD
               MOVE   9902          TO   XZUGEROR-I-LINE
               MOVE
                     "BICOM-TRAN-START-YMS ЙЬРдЗТ"
                                    TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN
                  THRU  S9100-ERROR-END-EXT
           END-IF
      *
           IF  BICOM-USER-EMPID     = SPACE
           THEN
               MOVE  CONT-SYSERROR  TO   DBIO-STAT
               MOVE  "S9000099"     TO   XZUGEROR-I-ERRCD
               MOVE  "UKLA0002"     TO   XZUGEROR-I-TREAT-CD
               MOVE   9903          TO   XZUGEROR-I-LINE
               MOVE
                     "BICOM-USER-EMPID ЙЬРдЗТ"
                                    TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN
                  THRU  S9100-ERROR-END-EXT
           END-IF
      *
      *
           IF  COND-DBIO-INSERT OR COND-DBIO-UPDATE
                                OR COND-DBIO-LKUPDT
           THEN
               MOVE  DBIO-RECORD    TO   DB-TABLE
           END-IF
      *
      *-----------------------------------------------------------------
      *    РЬЧЯ ЧСЗЮБзЗЅРК
      *    ШЃУтЧб ЧСЗЮБзЗЅПЁМ­SETЕШ
      *    SYS-LAST-PRCSS-YMS, SYS-LAST-UNOИІ
      *    КЏАцЧЯСі ОЪАэ INSERTИІ УГИЎЧбДй
      *-----------------------------------------------------------------
      *-- ZBD0500 : ЙшФЁПјРх КЙПјРлОї
      *-- ZBD0510 : ЙшФЁПјРх ЙнПЕРлОї
      *-- ZBD0550 : АшШЙСЄСіШФ КЛПјРхЙнПЕРлОї(ОїЙЋКА)
      *-- ZBD0560 : АшШЙСЄСіШФ КЛПјРхЙнПЕРлОї(ХзРЬКэКА)
      *---ZXXXXXX : КёЛѓ ПЙКёПы
      *
           IF DBIO-CALL-PGM-ID = "ZBD0500" OR "ZBD0510" OR
                                 "ZBD0550" OR "ZBD0560" OR
                                 "ZXXXXXX"
           THEN
              CONTINUE
           ELSE
      *
              IF  COND-DBIO-INSERT OR COND-DBIO-UPDATE
                                   OR COND-DBIO-LKUPDT
              THEN
                  MOVE  BICOM-USER-EMPID
                    TO  SYS-LAST-UNO OF DB-TABLE
                        SYS-LAST-UNO OF DBIO-RECORD
      *
                  IF    COND-DBIO-INSERT
                  THEN
                        MOVE  BICOM-TRAN-START-YMS
                          TO  SYS-LAST-PRCSS-YMS OF DB-TABLE
                              SYS-LAST-PRCSS-YMS OF DBIO-RECORD
                  END-IF
              END-IF
      *
           END-IF
           .
       S0150-USID-INFO-SET-EXT.
           EXIT.
      *
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : РдЗТСЄКИ Йз БтКЛСЄКИ АЫСѕ
      *  УГИЎБтДЩ : БтКЛЧзИёАЫСѕ
      *-----------------------------------------------------------------
       S0500-CHECK-RTN.
      *
           MOVE  "S0500"                    TO   BSGEROR-PARA
      *
           IF  SICOM-OPER-DSTCD             =    CONT-TEMP  OR
                                                 CONT-DAY   OR
                                                 CONT-STOP
           THEN
               CONTINUE
           ELSE
               MOVE  CONT-SYSERROR          TO   DBIO-STAT
      *{E} СЄРЧЕЧСі ОЪРК АХЗЁИ№ЕхРдДЯДй.(АХЗЁИ№ЕхБИКа)
               MOVE  "S9000002"             TO   XZUGEROR-I-ERRCD
      *{E} BIАХЗЁИ№ЕхБИКа ПРЗљ РдДЯДй.(@1@)
               MOVE  "UKLA0002"             TO   XZUGEROR-I-TREAT-CD
               MOVE
           "СЄРЧЕЧСі ОЪРК АХЗЁИ№ЕхРдДЯДй.(АХЗЁИ№ЕхБИКа)"
                                            TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN
                  THRU  S9100-ERROR-END-EXT
           END-IF
      *
      * DBIO-ХА РдЗТ АЫСѕ
           IF  COND-DBIO-INSERT  OR
               COND-DBIO-LKUPDT  OR
               COND-DBIO-FETCH   OR
               COND-DBIO-CLOSE
           THEN
               CONTINUE
           ELSE
               IF  DBIO-KEY                 =    SPACE
               THEN
                   MOVE  CONT-SYSERROR      TO   DBIO-STAT
      *{E} DBIO-KEY ЙЬРдЗТ ПРЗљРдДЯДй.
                   MOVE  "S9000003"         TO   XZUGEROR-I-ERRCD
                   MOVE  "UKLA0002"         TO   XZUGEROR-I-TREAT-CD
                   MOVE   0301              TO   XZUGEROR-I-LINE
                   MOVE
           "DBIO-KEY ЙЬРдЗТ ПРЗљРдДЯДй."
                                            TO   XZUGEROR-I-MSG
                   PERFORM  S9100-ERROR-END-RTN
                      THRU  S9100-ERROR-END-EXT
               END-IF
           END-IF
      *
      * DBIO-FUNCTION ФкЕх СЄЧеМК АЫСѕ
           IF      COND-DBIO-SELECT  OR  COND-DBIO-UPDATE
               OR  COND-DBIO-INSERT
               OR  COND-DBIO-DELETE  OR  COND-DBIO-DELFRC
               OR  COND-DBIO-SELFST  OR  COND-DBIO-LKUPDT
               OR  COND-DBIO-OPEN    OR  COND-DBIO-FETCH
               OR  COND-DBIO-CLOSE
           THEN
               CONTINUE
           ELSE
               MOVE  CONT-SYSERROR          TO   DBIO-STAT
      *{E} DBIO-FUNCTIONФкЕх ПРЗљРдДЯДй.
               MOVE  "S9000001"             TO   XZUGEROR-I-ERRCD
      *{E} DBIO-FUNCTIONФкЕх ПРЗљ РдДЯДй.(@1@)
               MOVE  "UKLA0002"             TO   XZUGEROR-I-TREAT-CD
               MOVE   0102                  TO   XZUGEROR-I-LINE
               MOVE
           "DBIO-FUNCTIONФкЕх ПРЗљРдДЯДй."
                                            TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN
                  THRU  S9100-ERROR-END-EXT
           END-IF
      *
      * DBIO-ACCESS-KEY СЄЧеМК АЫСѕ
           IF  COND-DBIO-PK
           THEN
               CONTINUE
           ELSE
               MOVE  CONT-SYSERROR          TO   DBIO-STAT
      *{E} DBIOРдЗТЧзИё АЫСѕПРЗљРдДЯДй(DBIO-ACCESS-KEY)
               MOVE  "S9000004"             TO   XZUGEROR-I-ERRCD
      *{E} DBIO-ACCESS-KEY ПРЗљ РдДЯДй.(@1@)
               MOVE  "UKLA0002"             TO   XZUGEROR-I-TREAT-CD
               MOVE
           "DBIOРдЗТЧзИё АЫСѕПРЗљРдДЯДй(DBIO-ACCESS-KEY)"
                                            TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN
                  THRU  S9100-ERROR-END-EXT
           END-IF
      *
      * DBIO-ACCESS-COND СЄЧеМК АЫСѕ
           IF  COND-DBIO-0  OR  COND-DBIO-1  OR
               COND-DBIO-2  OR  COND-DBIO-3  OR
               COND-DBIO-4
           THEN
               IF  COND-DBIO-SELFST  OR COND-DBIO-OPEN    OR
      *            COND-DBIO-FETCH   OR COND-DBIO-CLOSE
                   COND-DBIO-FETCH
      *PKРЧSELECT_CURSORИІCLOSEЧЯБтРЇЧиCOND-DBIO-0ИІЛчПыЧд
               THEN
                   IF  COND-DBIO-0
                   THEN
                       MOVE  CONT-SYSERROR  TO   DBIO-STAT
      *{E} DBIO-ACCESS-COND ПРЗљРдДЯДй
                       MOVE  "S9000005"     TO   XZUGEROR-I-ERRCD
      *{E} DBIO-ACCESS-COND ПРЗљ РдДЯДй.(@1@)
                       MOVE  "UKLA0002"     TO   XZUGEROR-I-TREAT-CD
                       MOVE   0501          TO   XZUGEROR-I-LINE
                       MOVE
           "DBIO-ACCESS-COND ПРЗљРдДЯДй"
                                            TO   XZUGEROR-I-MSG
                       PERFORM  S9100-ERROR-END-RTN
                          THRU  S9100-ERROR-END-EXT
                   ELSE
                       CONTINUE
                   END-IF
               ELSE
                   CONTINUE
               END-IF
           ELSE
               IF  COND-DBIO-SELECT  OR COND-DBIO-INSERT  OR
                   COND-DBIO-UPDATE  OR COND-DBIO-LKUPDT  OR
                   COND-DBIO-DELETE  OR COND-DBIO-DELFRC
               THEN
                   CONTINUE
               ELSE
                   MOVE  CONT-SYSERROR      TO   DBIO-STAT
      *{E} DBIO-ACCESS-COND ПРЗљРдДЯДй
                   MOVE  "S9000005"         TO   XZUGEROR-I-ERRCD
      *{E} DBIO-ACCESS-COND ПРЗљРдДЯДй.(@1@)
                   MOVE  "UKLA0002"         TO   XZUGEROR-I-TREAT-CD
                   MOVE   0502              TO   XZUGEROR-I-LINE
                   MOVE
           "DBIO-ACCESS-COND ПРЗљРдДЯДй"
                                            TO   XZUGEROR-I-MSG
                   PERFORM  S9100-ERROR-END-RTN
                      THRU  S9100-ERROR-END-EXT
               END-IF
           END-IF
      *
      * DBIO-LOCK-YN СЄЧеМКАЫСѕ
           IF  COND-DBIO-LOCK      OR
               COND-DBIO-UNLOCK
           THEN
               CONTINUE
           ELSE
      *        MOVE  "N"                    TO   DBIO-LOCK-YN
      *{E} DBIO-LOCK-YN(СЖАЧ) ПРЗљРдДЯДй
               MOVE  "S9000006"             TO   XZUGEROR-I-ERRCD
      *{E} DBIO-LOCK-YN ПРЗљ РдДЯДй.(@1@)
               MOVE  "UKLA0002"             TO   XZUGEROR-I-TREAT-CD
               MOVE   0601                  TO   XZUGEROR-I-LINE
               MOVE
           "DBIO-LOCK-YN(СЖАЧ) ПРЗљРдДЯДй"
                                            TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN
                  THRU  S9100-ERROR-END-EXT
           END-IF
      *
           IF  COND-DBIO-LOCK AND
               DBIO-ACCESS-KEY(1:2)  NOT =  CONT-PK
           THEN
      *{E} DBIO-LOCK-YN(СЖАЧ) ПРЗљРдДЯДй
               MOVE  "S9000006"             TO   XZUGEROR-I-ERRCD
      *{E} DBIO-LOCK-YN ПРЗљ РдДЯДй.(@1@)
               MOVE  "UKLA0002"             TO   XZUGEROR-I-TREAT-CD
               MOVE   0602                  TO   XZUGEROR-I-LINE
               MOVE
           "DBIO-LOCK-YN(СЖАЧ) ПРЗљРдДЯДй"
                                            TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN
                  THRU  S9100-ERROR-END-EXT
           END-IF
      *
      * РдЗТАЊРЧ СЖЧеАЫСѕ
           IF  DBIO-ACCESS-KEY(1:2)           =    CONT-PK
           THEN
               CONTINUE
           ELSE
               IF  COND-DBIO-INSERT         OR
                   COND-DBIO-UPDATE         OR
                   COND-DBIO-DELETE         OR
                   COND-DBIO-DELFRC
               THEN
                   MOVE  CONT-SYSERROR      TO   DBIO-STAT
      *{E} DBIO-FUNCTION ЖЧДТ DBIO-ACCESS-KEY ПРЗљРдДЯДй
                   MOVE  "S9000007"         TO   XZUGEROR-I-ERRCD
      *{E} DBIO-FUNCTION ЖЧДТ DBIO-ACCESS-KEY ПРЗљ РдДЯДй.(@1@)
                   MOVE  "UKLA0002"         TO   XZUGEROR-I-TREAT-CD
                   MOVE
           "DBIO-FUNCTION ЖЧДТ DBIO-ACCESS-KEY ПРЗљРдДЯДй"
                                            TO   XZUGEROR-I-MSG
                   PERFORM  S9100-ERROR-END-RTN
                      THRU  S9100-ERROR-END-EXT
               ELSE
                   CONTINUE
               END-IF
           END-IF
      *
           IF  COND-DBIO-DELETE OR COND-DBIO-DELFRC
           THEN
               IF  COND-DBIO-LOCK
               THEN
                   CONTINUE
               ELSE
                   MOVE  CONT-SYSERROR      TO   DBIO-STAT
      *{E} DBIO-LOCK-YN(СЖАЧ) ПРЗљРдДЯДй
                   MOVE  "S9000006"         TO   XZUGEROR-I-ERRCD
      *{E} DBIO-FUNCTION(@1@)НУ РсБнСЖАЧ ПРЗљ РдДЯДй.
                   MOVE  "UKLA0002"         TO   XZUGEROR-I-TREAT-CD
                   MOVE   0603              TO   XZUGEROR-I-LINE
                   MOVE
           "DBIO-LOCK-YN(СЖАЧ) ПРЗљРдДЯДй"
                                            TO   XZUGEROR-I-MSG
                   PERFORM  S9100-ERROR-END-RTN
                      THRU  S9100-ERROR-END-EXT
               END-IF
           ELSE
               IF  COND-DBIO-LOCK
               THEN
                   IF  COND-DBIO-OPEN       OR
                       COND-DBIO-FETCH      OR
                       COND-DBIO-SELFST
                   THEN
                       MOVE  CONT-SYSERROR  TO   DBIO-STAT
      *{E} DBIO-LOCK-YN(СЖАЧ) ПРЗљРдДЯДй
                       MOVE  "S9000006"     TO   XZUGEROR-I-ERRCD
      *{E} DBIO-FUNCTION(@1@)НУ РсБнСЖАЧ ПРЗљ РдДЯДй.
                       MOVE  "UKLA0002"     TO   XZUGEROR-I-TREAT-CD
                       MOVE   0604          TO   XZUGEROR-I-LINE
                       MOVE
           "DBIO-LOCK-YN(СЖАЧ) ПРЗљРдДЯДй"
                                            TO   XZUGEROR-I-MSG
                       PERFORM  S9100-ERROR-END-RTN
                          THRU  S9100-ERROR-END-EXT
                   ELSE
                       CONTINUE
                   END-IF
               ELSE
                   CONTINUE
               END-IF
           END-IF
      *
           IF  COND-DBIO-SELECT  OR COND-DBIO-INSERT  OR
               COND-DBIO-UPDATE  OR
               COND-DBIO-DELETE  OR COND-DBIO-DELFRC  OR
               COND-DBIO-SELFST  OR COND-DBIO-OPEN
           THEN
               PERFORM  S0510-IN-CHECK-RTN THRU S0510-IN-CHECK-EXT
           ELSE
               CONTINUE
           END-IF
           .
       S0500-CHECK-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : DBIO-ХА АЊ АЫСѕ
      *  УГИЎБтДЩ : DBIO-ХА АЊПЁ NULL РдЗТНУ ПЁЗЏУГИЎ
      *-----------------------------------------------------------------
       S0510-IN-CHECK-RTN.
      *
           MOVE  "S0510"                    TO   BSGEROR-PARA
      *
           EVALUATE  TRUE
               WHEN  COND-DBIO-PK
                     IF  GROUP-CO-CDP0  =  SPACE
                     THEN
                         MOVE  "COL-NM: GROUP-CO-CD"
                           TO   BSGDISP-TEXT
                         PERFORM  S0511-ERROR-SET-RTN
                            THRU  S0511-ERROR-SET-EXT
                     ELSE
                         CONTINUE
                     END-IF
                     IF  BASE-YMP0  =  SPACE
                     THEN
                         MOVE  "COL-NM: BASE-YM"
                           TO   BSGDISP-TEXT
                         PERFORM  S0511-ERROR-SET-RTN
                            THRU  S0511-ERROR-SET-EXT
                     ELSE
                         CONTINUE
                     END-IF
                     IF  AFFLT-CORP-GROUP-CDP0  =  SPACE
                     THEN
                         MOVE  "COL-NM: AFFLT-CORP-GROUP-CD"
                           TO   BSGDISP-TEXT
                         PERFORM  S0511-ERROR-SET-RTN
                            THRU  S0511-ERROR-SET-EXT
                     ELSE
                         CONTINUE
                     END-IF
                     IF  1 < DBIO-ACCESS-COND
                     THEN
                         PERFORM  S0512-ERROR-SET-RTN
                            THRU  S0512-ERROR-SET-EXT
                     END-IF
           END-EVALUATE
      *

           .
       S0510-IN-CHECK-EXT.
           EXIT.

      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : DBIO-ХА АЊ АЫСѕ
      *  УГИЎБтДЩ : DBIO-ХА АЊПЁ NULL РдЗТНУ ПЁЗЏУГИЎ
      *-----------------------------------------------------------------
       S0511-ERROR-SET-RTN.

      *    MOVE  "S0511"                    TO   BSGEROR-PARA

           MOVE  CONT-SYSERROR              TO   DBIO-STAT
           MOVE  "S9000003"                 TO   XZUGEROR-I-ERRCD
           MOVE  "UKLA0002"                 TO   XZUGEROR-I-TREAT-CD
           MOVE   0302                      TO   XZUGEROR-I-LINE
           MOVE
           "DBIO-KEY ЙЬРдЗТ ПРЗљРдДЯДй."
                                            TO   XZUGEROR-I-MSG
           PERFORM  S9100-ERROR-END-RTN
              THRU  S9100-ERROR-END-EXT
           .
       S0511-ERROR-SET-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : DBIO-ACCESS-COND АЊ АЫСѕ
      *  УГИЎБтДЩ : DBIO-ACCESS-COND АЊРЬ > МГСЄАЊ ПЁЗЏУГИЎ
      *-----------------------------------------------------------------
       S0512-ERROR-SET-RTN.

      *    MOVE  "S0512"                    TO   BSGEROR-PARA

           MOVE  CONT-SYSERROR              TO   DBIO-STAT
      *{E} DBIO-ACCESS-COND ПРЗљРдДЯДй
           MOVE  "S9000005"                 TO   XZUGEROR-I-ERRCD
      *{E} DBIO-ACCESS-COND ПРЗљ РдДЯДй.(@1@)
           MOVE  "UKLA0002"                 TO   XZUGEROR-I-TREAT-CD
           MOVE   0503                      TO   XZUGEROR-I-LINE
           MOVE
           "DBIO-ACCESS-COND(MAX) ПРЗљРдДЯДй"
                                            TO   XZUGEROR-I-MSG

           MOVE
           "BPG/DBIO/НУРлСЖАЧРћПыУжДыФУЗГАЙМі ЧзИёРЛ МГСЄЧЯММПф"
                                            TO   BSGDISP-TEXT
           PERFORM  S9100-ERROR-END-RTN
              THRU  S9100-ERROR-END-EXT
           .
       S0512-ERROR-SET-EXT.
           EXIT.

      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : DBIO-FUNCTION БИКаРЬ SELECTРЯЖЇ НЧЧрЕШДй.
      *  УГИЎБтДЩ : DBIO-ACCESS-KEYПЭ DBIO-LOCK-YNПЁЕћЖѓ
      *             ДйИЅ СЖАЧРИЗЮ SELECTИІ ЧбДй.
      *-----------------------------------------------------------------
       S1000-SELECT-RTN.
      *
           MOVE  "S1000"                    TO   BSGEROR-PARA
      *
           IF  DBIO-LOCK-YN                 =    CONT-Y
           THEN
      *        IF  DBIO-KEY = SAVE-PK
               IF  DBIO-KEY       = SAVE-PK
               AND BICOM-GU-ID-NO = SAVE-GUID
               THEN
                   PERFORM  S8720-SEL-NOLOCK0-RTN
                      THRU  S8720-SEL-NOLOCK0-EXT
