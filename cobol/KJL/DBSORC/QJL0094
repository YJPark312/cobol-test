            ,:XQJL0094-O-Y-3-AVG-ASALE-AMT
            ,:XQJL0094-O-Y-3-AVG-SALEPR-RATO
            ,:XQJL0094-O-ASALE-WGHT-VAL
            ,:XQJL0094-O-BF-PAB-ROTAT-RATO
            ,:XQJL0094-O-PYY-AB-ROTAT-RATO
            ,:XQJL0094-O-ASALE-B-ROTAT-RATO
            ,:XQJL0094-O-ASALE-BRR-WGHT-VAL
            ,:XQJL0094-O-Y-3ABRR-WGHT-VAL
            ,:XQJL0094-O-ASALE-BSAMT
