            ,:XQJL0094-O-BASE-BP-TOTAL-ASST
            ,:XQJL0094-O-BASE-PYY-TOTAL-ASST
            ,:XQJL0094-O-PYY-TOTAL-ASST
            ,:XQJL0094-O-TOTAL-AI-APLY-RATO
            ,:XQJL0094-O-AMBR-T-ASST-RATO
            ,:XQJL0094-O-NEW-AT-ASST-RATO
            ,:XQJL0094-O-Y-3NAT-ASST-RATO
            ,:XQJL0094-O-BF-PC-INCLIN-ASAM
            ,:XQJL0094-O-PYY-CSH-INCLIN-ASAM
            ,:XQJL0094-O-CSH-INCLIN-ASAM
            ,:XQJL0094-O-AVG-CSH-INCLIN-ASAM
            ,:XQJL0094-O-AVG-TOTAL-ASAM
            ,:XQJL0094-O-AVG-CI-ASST-RATO
            ,:XQJL0094-O-BRRW-AR-WGHT-VAL
            ,:XQJL0094-O-Y-3BA-RATO-WGHT-VAL
            ,:XQJL0094-O-CSH-IAR-WGHT-VAL
