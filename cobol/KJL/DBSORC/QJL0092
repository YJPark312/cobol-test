           THEN
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE 999999              TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END OK :'
                           'STAT=' XZUGEROR-I-STAT    DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF
      *
           GOBACK
           .
       S9000-NOMAL-END-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  수행조건 : 프로그램 내부에서 에러발생시 처리함
      *  처리기능 : 에러에 관련된 정보를 ZUGERORCA에 MOVE후
      *             ZUGEROR을 호출하고 에러정보를 DISPLAY한다.
      *-----------------------------------------------------------------
       S9100-ERROR-END-RTN.
      *
           MOVE  CONT-PROGRAM-ID            TO   XZUGEROR-I-PGM-ID
           MOVE  "UKLA0002"                 TO   XZUGEROR-I-TREAT-CD
      *
           MOVE  CONT-SYSERROR              TO   DBSQL-STAT
                                                 XZUGEROR-I-STAT
      *
           MOVE  "ZUGEROR"                  TO   YCFCTLAR-CALL-LOG
           CALL  YCFCTLAR-CALL-LOG       USING   YCCOMMON-CA
                                                 XZUGEROR-CA
           END-CALL
      *
           IF  BSGDISP-TEXT NOT = SPACE
           THEN
               #USRLOG "ERR-TXT : " BSGDISP-TEXT
           END-IF
      *
           IF  XZUGEROR-I-MSG NOT = SPACE
           THEN
               #USRLOG "XZUGEROR-MSG : " XZUGEROR-I-MSG
           END-IF
      *
           PERFORM  S8200-RESULT-DISPLAY-RTN
              THRU  S8200-RESULT-DISPLAY-EXT
      *
           IF      COMM-START-EIO-DSTCD = '9'
           THEN
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE XZUGEROR-I-LINE     TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END ER :'
                           'STAT=' XZUGEROR-I-STAT  DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF

           GOBACK
           .
       S9100-ERROR-END-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *  수행조건 : 프로그램 내부에서 SQL 에러발생시 처리함
      *  처리기능 : 에러에 관련된 정보를 ZUGERORCA에 MOVE후
      *             ZUGEROR을 호출하고 에러정보를 DISPLAY한다.
      *-----------------------------------------------------------------
       S9200-SQL-ERR-RTN.
      *
           MOVE  CONT-PROGRAM-ID            TO   XZUGEROR-I-PGM-ID
      *
           MOVE  SQLCODE                    TO   DBSQL-SQLCODE
                                                 XZUGEROR-I-SQL-CD
      *
           EVALUATE  SQLCODE
               WHEN  +100
                     MOVE  CONT-MRNF        TO   DBSQL-STAT
                     MOVE  "NO DATA FOUND"  TO   XZUGEROR-I-MSG
               WHEN  OTHER
                     IF DBSQL-SQLCODE(4:1) = "9" OR DBSQL-SQLCODE = -805
                     THEN
                         MOVE CONT-SYSERROR TO   DBSQL-STAT
                     ELSE
                         MOVE CONT-SQLER    TO   DBSQL-STAT
                     END-IF
                     MOVE  "D9900000"       TO   XZUGEROR-I-ERRCD
                     MOVE  XZUGEROR-I-SQL-CD(2:)
                                            TO   XZUGEROR-I-ERRCD(4:)
           END-EVALUATE
      *
           MOVE  ZERO                       TO   XZUGEROR-I-LINE
           MOVE  "UKLA0002"                 TO   XZUGEROR-I-TREAT-CD
           MOVE  SPACE                      TO   XZUGEROR-I-MULT
                                                 XZUGEROR-I-TBL-ID
                                                 XZUGEROR-I-FUNC-CD
           MOVE  DBSQL-STAT                 TO   XZUGEROR-I-STAT
      *
           IF  DBSQL-STAT               =    CONT-MRNF OR
               DBSQL-STAT               =    CONT-DUPM
           THEN
                CONTINUE
           ELSE
      *
               MOVE  DBSQL-PROGRAM-ID       TO   XZUGEROR-I-TBL-ID
               MOVE  DBSQL-SQLCODE          TO   XZUGEROR-I-SQL-CD
      *
               MOVE    "ZUGEROR"            TO   YCFCTLAR-CALL-LOG
               CALL    YCFCTLAR-CALL-LOG USING   YCCOMMON-CA
                                                 XZUGEROR-CA
               END-CALL

               IF  XZUGEROR-I-SQL-CD NOT = -805
               THEN
                   PERFORM  S8300-SQL-MSG-RTN THRU   S8300-SQL-MSG-EXT
               END-IF
           END-IF
      *
           PERFORM  S8200-RESULT-DISPLAY-RTN
              THRU  S8200-RESULT-DISPLAY-EXT
      *

      *
           IF      COMM-START-EIO-DSTCD = '9'
           THEN
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE XZUGEROR-I-LINE     TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END ER :'
                           'STAT=' XZUGEROR-I-STAT  DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF

           GOBACK
           .
       S9200-SQL-ERR-EXT.
           EXIT.
