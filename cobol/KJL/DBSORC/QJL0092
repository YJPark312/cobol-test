      *-----------------------------------------------------------------
      *  수행조건 : DBPCO-SELECT일때 실행된다.
      *  처리기능 : 단건 SELECT
      *-----------------------------------------------------------------
       S3000-SELECT-RTN.

           MOVE  "S3000"                    TO   BSGEROR-PARA

           PERFORM  S8100-FIELD-DISPLAY-RTN THRU S8100-FIELD-DISPLAY-EXT

           EXEC  SQL
       SELECT

       ROUND(VALUE(A.자기자본기준금액,0)/1000000,0)
       AS 자기자본기준금액,

       VALUE(CASE
        WHEN B.관리한도유효년월일 >= :XQJL0092-I-TRAN-BASE-YMD
        THEN B.관리한도설정년월일
        ELSE ' '
       END,' ')
       AS 관리한도설정년월일,

       VALUE(CASE
        WHEN B.관리한도유효년월일 >= :XQJL0092-I-TRAN-BASE-YMD
        THEN B.관리한도유효년월일
        ELSE ' '
       END,' ')
       AS 관리한도유효년월일,

       ROUND(VALUE(CASE
        WHEN B.관리한도유효년월일 >= :XQJL0092-I-TRAN-BASE-YMD
        THEN B.관리한도
        ELSE 0
       END,0)/1000000,0)
       AS 관리한도,

       ROUND(VALUE(CASE
        WHEN B.관리한도유효년월일 >= :XQJL0092-I-TRAN-BASE-YMD
        THEN B.여신성관리한도
        ELSE 0
       END,0)/1000000,0)
       AS 여신성관리한도,

       ROUND(VALUE(CASE
        WHEN B.관리한도유효년월일 >= :XQJL0092-I-TRAN-BASE-YMD
        THEN B.시장성관리한도
        ELSE 0
       END,0)/1000000,0)
       AS 시장성관리한도,

       ROUND(VALUE(A.자기자본기준금액,0)/1000000,0) * 0.1
       AS 개별기업최고한도,

       ROUND(VALUE(A.자기자본기준금액,0)/1000000,0) * 0.25
       AS 그룹별최고한도,

       ROUND(VALUE(A.자기자본기준금액,0)/1000000,0) * 0.2
       AS 자기자본기준적용한도

       INTO
             :XQJL0092-O-ONCP-BSAMT
            ,:XQJL0092-O-MGT-LIMT-STUP-YMD
            ,:XQJL0092-O-MGT-LIMT-VALD-YMD
            ,:XQJL0092-O-MGT-CLAM
            ,:XQJL0092-O-LNBZ-I-MGT-CLAM
            ,:XQJL0092-O-MRKTY-MGT-CLAM
            ,:XQJL0092-O-CORP-HGST-LIMT
            ,:XQJL0092-O-GROUP-HGST-LIMT
            ,:XQJL0092-O-ONCP-BASE-APLY-CLAM
       FROM DB2DBA.THKJL0049 A LEFT OUTER JOIN DB2DBA.THKJL0012 B
       ON (A.그룹회사코드 = B.그룹회사코드
       AND B.계열기업군코드 = :XQJL0092-I-AFFLT-CORP-GROUP-CD
       AND A.기준년월 = B.기준년월)

       WHERE A.그룹회사코드 = :XQJL0092-I-GROUP-CO-CD
         AND A.기준년월 = SUBSTR(:XQJL0092-I-TRAN-BASE-YMD,1,6)
         AND A.자기자본구분 = '1'
           FETCH FIRST 1 ROWS ONLY
           END-EXEC

           IF  SQLCODE NOT = ZERO
               PERFORM S9200-SQL-ERR-RTN    THRU S9200-SQL-ERR-EXT
           END-IF
           MOVE  1                          TO   DBSQL-SELECT-CNT
           .
       S3000-SELECT-EXT.
           EXIT.
