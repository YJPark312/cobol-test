           EXEC  SQL
           DECLARE CUR_SQL  CURSOR WITH HOLD
                                       WITH ROWSET POSITIONING FOR
       SELECT
              JL18.한도신청번호
             ,JL18.고객식별자
             ,JL18.한도점검진행상태구분
             ,JL18.신청년월일
             ,JL18.신청부점코드
             ,JL18.신청직원번호
             ,VALUE((SELECT 직원한글성명
                      FROM        THKJIHR01
                     WHERE 그룹회사코드 = JL18.그룹회사코드
                       AND 직원번호     = JL18.신청직원번호
              ),'')                            AS 신청직원명
             ,JL18.최종승인년월일
             ,JL18.최종승인직원번호
             ,JL18.최종한도승인구분
             ,JL18.적정성점검구분
             ,JL18.적정구분                    AS 적정성여부
             ,VALUE(JL05.한도승인구분,' ')     AS 진행구분
             ,VALUE(JL05.승인의견내용,' ')     AS 승인의견내용
             ,(CASE WHEN TRIM(JL05.승인의견내용) = '' THEN 'N'
               ELSE 'Y' END) AS 의견등록여부
             ,VALUE(JL05.승인위원직원번호,' ') AS 승인위원직원번호
        FROM        THKJL0018 JL18
        LEFT OUTER JOIN        THKJL0005 JL05
           ON JL18.그룹회사코드    = JL05.그룹회사코드
           AND JL18.한도신청번호   = JL05.한도신청번호
       WHERE JL18.그룹회사코드     = :XQJL2761-I-GROUP-CO-CD
         AND JL18.고객식별자    LIKE :XQJL2761-I-CUST-IDNFR
         AND JL18.최종한도승인구분
                                BETWEEN
                                     :XQJL2761-I-LAST-L-ATHOR-DSTCD1
                                AND  :XQJL2761-I-LAST-L-ATHOR-DSTCD2
         AND JL18.신청년월일    BETWEEN
                                     :XQJL2761-I-APLCN-YMD1
                                AND  :XQJL2761-I-APLCN-YMD2
         AND JL05.승인위원직원번호
                                LIKE :XQJL2761-I-ATHOR-CMMB-EMPID
       -- NEXT KEY
         AND ((JL18.한도신청번호     = :XQJL2761-I-LIMT-APLCN-NO
           AND JL05.승인위원직원번호 > :XQJL2761-I-ATHOR-CMMB-EMPID2)
            OR JL18.한도신청번호     > :XQJL2761-I-LIMT-APLCN-NO)
       ORDER BY JL18.한도신청번호,JL05.승인위원직원번호
       WITH UR
      *
           END-EXEC
