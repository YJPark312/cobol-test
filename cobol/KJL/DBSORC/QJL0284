      *
       S0000-START-RTN.

           SET     ADDRESS OF YCCSICOM-CA  TO  COMM-SICOM-ADDR
           SET     ADDRESS OF YCCBICOM-CA  TO  COMM-BICOM-ADDR
      *    SET     ADDRESS OF YCCBOCOM-CA  TO  COMM-BOCOM-ADDR
           PERFORM S0000-MAIN-RTN        THRU  S0000-MAIN-EXT
           .
       S0000-START-EXT.
           EXIT.

      *
       S0000-MAIN-RTN.
      *
           MOVE  "14"                       TO YCFCTLAR-USR-LOG-CD
      *
           PERFORM S0100-INITIAL-RTN      THRU S0100-INITIAL-EXT
      *
           PERFORM S0500-CHECK-RTN        THRU S0500-CHECK-EXT
      *
      * SQLIO-FUNCTION OF YCDBSQLA
           EVALUATE  TRUE
               WHEN  COND-DBSQL-SELECT
                     PERFORM S1000-SELECT-RTN THRU S1000-SELECT-EXT
      *

      *
               WHEN  OTHER
      *{E} SQLIOРдЗТЧзИё АЫСѕПРЗљРдДЯДй(SQLIO-FUNCTION)
                     MOVE  "S9000050"     TO   XZUGEROR-I-ERRCD
      *{E} SQLIO-FUNCTIONФкЕх ПРЗљ РдДЯДй.(@1@)
                     MOVE
           "SQLIOРдЗТЧзИё АЫСѕПРЗљРдДЯДй(SQLIO-FUNCTION)"
                                          TO   XZUGEROR-I-MSG
                     PERFORM  S9100-ERROR-END-RTN
                        THRU  S9100-ERROR-END-EXT
           END-EVALUATE
      *
           PERFORM S9000-NOMAL-END-RTN    THRU S9000-NOMAL-END-EXT
           .
       S0000-MAIN-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : ЧСЗЮБзЗЅ НУРлРќ БтКЛМГСЄ Йз УЪБтШ­
      *  УГИЎБтДЩ : ЧСЗЮБзЗЅУЪБтШ­
      *-----------------------------------------------------------------
       S0100-INITIAL-RTN.
      *
           MOVE  "S0100"                    TO   BSGEROR-PARA

           INITIALIZE                            WORK
                                                 XQJL0284-OUT
                                                 DBSQL-OUT
                                                 DBSQL-RESULT
                                                 BSGDISP-TEXT
                                                 XZUGEROR-CA
                                                 WORK-DIAG-MESSAGE
      *
           MOVE  CONT-ABNORMAL              TO   DBSQL-STAT
      *
           MOVE  ZERO                       TO   SQLCODE
      *
           MOVE  SPACE                      TO   SQLERRMC
      *
           IF    DBSQL-SELECT-REQ-X  =  SPACE OR ZERO OR LOW-VALUE
           THEN
                 MOVE  CONT-ARR-CNT         TO   WORK-SELECT-REQ
           ELSE
                 MOVE  DBSQL-SELECT-REQ     TO   WORK-SELECT-REQ
           END-IF
      *
           .
       S0100-INITIAL-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : РдЗТСЄКИ Йз БтКЛСЄКИ АЫСѕ
      *  УГИЎБтДЩ : БтКЛЧзИёАЫСѕ
      *-----------------------------------------------------------------
       S0500-CHECK-RTN.
      *
           MOVE  "S0500"                    TO   BSGEROR-PARA
      *
      * SQLIO-FUNCTION OF YCDBSQLA
           EVALUATE  TRUE
               WHEN  COND-DBSQL-SELECT
               WHEN  COND-DBSQL-OPEN
                     CONTINUE
               WHEN  OTHER
                     GO TO S0500-CHECK-EXT
           END-EVALUATE
      *
           IF  DBSQL-CALL-PGM-ID = SPACE
           THEN
      *{E} DBSQL-CALL-PGM-ID ЙЬРдЗТ.
               MOVE  "S9000051"             TO   XZUGEROR-I-ERRCD
               MOVE
           "DBSQL-CALL-PGM-ID ЙЬРдЗТ"
                                            TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN THRU S9100-ERROR-END-EXT
           END-IF

           IF  DBSQL-PROGRAM-ID  = SPACE
           THEN
      *{E} DBSQL-PROGRAM-ID ЙЬРдЗТ.
               MOVE  "S9000052"             TO   XZUGEROR-I-ERRCD
               MOVE
           "DBSQL-PROGRAM-ID ЙЬРдЗТ"
                                            TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN THRU S9100-ERROR-END-EXT
           END-IF

      * PCOCPY-ХА РдЗТ АЫСѕ
      *("S9000053":"РдЗТЧзИёПЁ ЕЅРЬХЭ ЙЬРдЗТ ПРЗљ")
      *
      *
           IF  DBSQL-SELECT-REQ > CONT-ARR-CNT
           THEN
      *
           PERFORM  S8100-FIELD-DISPLAY-RTN THRU S8100-FIELD-DISPLAY-EXT
      *
      *{E} DBSQL-SELECT-REQ УжДыАЧМі УЪАњ.
               MOVE  "S9000054"             TO   XZUGEROR-I-ERRCD
               MOVE
           "DBSQL-SELECT-REQ УжДыАЧМі УЪАњ"
                                            TO   XZUGEROR-I-MSG
               PERFORM  S9100-ERROR-END-RTN THRU S9100-ERROR-END-EXT
           END-IF
           .
       S0500-CHECK-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : DBPCO-SELECTРЯЖЇ НЧЧрЕШДй.
      *  УГИЎБтДЩ : DBPCO-SELECT
      *-----------------------------------------------------------------
       S1000-SELECT-RTN.
      *
           IF  CONT-ARR-CNT  =  1
           THEN
              PERFORM S3000-SELECT-RTN  THRU S3000-SELECT-EXT

           END-IF
           .
       S1000-SELECT-EXT.
           EXIT.


      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : DBPCO-SELECTРЯЖЇ НЧЧрЕШДй.
      *  УГИЎБтДЩ : ДмАЧ SELECT
      *-----------------------------------------------------------------
       S3000-SELECT-RTN.

           MOVE  "S3000"                    TO   BSGEROR-PARA

           PERFORM  S8100-FIELD-DISPLAY-RTN THRU S8100-FIELD-DISPLAY-EXT

           EXEC  SQL
       SELECT 'X' AS CHECK
       INTO
             :XQJL0284-O-CHECK
          FROM DB2DBA.THKJL0014
         WHERE БзЗьШИЛчФкЕх =  :XQJL0284-I-GROUP-CO-CD
           AND БтСиГтПљ = :XQJL0284-I-BF-MONTH
           AND АшП­РћПыБИКа = '2'
           AND КЏАцПЉКЮ = '1'
           FETCH FIRST 1 ROWS ONLY
           END-EXEC

           IF  SQLCODE NOT = ZERO
               PERFORM S9200-SQL-ERR-RTN    THRU S9200-SQL-ERR-EXT
           END-IF
           MOVE  1                          TO   DBSQL-SELECT-CNT
           .
       S3000-SELECT-EXT.
           EXIT.
      *================================================================*
      * Е№НКЧУЗЙРЬ УГИЎ РЏЦПИЎЦМ ШЃУт
      *================================================================*
       S8000-BSGDISP-RTN.

               #USRLOG BSGDISP-TEXT
           .
       S8000-BSGDISP-EXT.
           EXIT.


      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : ЧСЗЮБзЗЅ ГЛКЮПЁМ­ ПРЗљЙпЛ§НУ НЧЧрЕЪ
      *  УГИЎБтДЩ : ЧСЗЮБзЗЅИэАњ БтДЩ, АХЗЁФкЕхИІ DISPLAYЧбДй.
      *-----------------------------------------------------------------
       S8100-FIELD-DISPLAY-RTN.
      *
           IF  COMM-SQL-II-OUTPT-DSTCD     =    "1" OR "9"
           THEN
               MOVE  SPACE                      TO   BSGDISP-TEXT

               STRING  "ШЃУтЧСЗЮБзЗЅИэ {"       DELIMITED BY SIZE
                       DBSQL-CALL-PGM-ID        DELIMITED BY SIZE
                       "} DBSQL-PROGRAM-ID {"   DELIMITED BY SIZE
                       DBSQL-PROGRAM-ID         DELIMITED BY SIZE
                       "} DBSQL-FUNCTION {"     DELIMITED BY SIZE
                       DBSQL-FUNCTION           DELIMITED BY SIZE
                       "} ARR-CNT {"            DELIMITED BY SIZE
                       CONT-ARR-CNT             DELIMITED BY SIZE
                       "} REQ-CNT {"            DELIMITED BY SIZE
                       DBSQL-SELECT-REQ         DELIMITED BY SIZE
                       "}"                      DELIMITED BY SIZE
                 INTO  BSGDISP-TEXT
               END-STRING

               PERFORM  S8000-BSGDISP-RTN     THRU   S8000-BSGDISP-EXT
           END-IF

           IF  COMM-SQL-II-OUTPT-DSTCD     =    "1" OR "9"
           THEN

           MOVE "XQJL0284-I-GROUP-CO-CD        = "
             TO  BSGDISP-TEXT(1:32)
           MOVE  XQJL0284-I-GROUP-CO-CD
             TO  BSGDISP-TEXT(33:)
           PERFORM  S8000-BSGDISP-RTN THRU S8000-BSGDISP-EXT
           MOVE "XQJL0284-I-BF-MONTH           = "
             TO  BSGDISP-TEXT(1:32)
           MOVE  XQJL0284-I-BF-MONTH
             TO  BSGDISP-TEXT(33:)
           PERFORM  S8000-BSGDISP-RTN THRU S8000-BSGDISP-EXT


           END-IF
           .
       S8100-FIELD-DISPLAY-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : ЧСЗЮБзЗЅ ГЛКЮПЁМ­ ПРЗљЙпЛ§НУ НЧЧрЕЪ
      *  УГИЎБтДЩ : S8100-FIELD-DISPLAY-RTNКИДй ЛѓММЧб СЄКИСІАј.
      *-----------------------------------------------------------------
       S8200-RESULT-DISPLAY-RTN.
      *
           IF  COMM-SQL-II-OUTPT-DSTCD     =    "1" OR "9"
           THEN
               MOVE  SPACE                      TO   BSGDISP-TEXT

               STRING "АЫЛіАЧМі="               DELIMITED BY SIZE
                      DBSQL-SELECT-CNT          DELIMITED BY SIZE
                      "/SQLCODE="               DELIMITED BY SIZE
                      DBSQL-SQLCODE             DELIMITED BY SIZE
                      "/АсАњФкЕх="              DELIMITED BY SIZE
                      DBSQL-STAT                DELIMITED BY SIZE
                 INTO  BSGDISP-TEXT
               END-STRING
      *
               PERFORM  S8000-BSGDISP-RTN     THRU   S8000-BSGDISP-EXT
           END-IF
           .
       S8200-RESULT-DISPLAY-EXT.
           EXIT.

       S8300-SQL-MSG-RTN.
           CALL    'DSNTIAR'    USING    SQLCA
                                         ERROR-MESSAGE
                                         ERROR-TEXT-LEN
           END-CALL
           PERFORM VARYING ERR-IDX FROM 1 BY 1
             UNTIL ERR-IDX > 10
                   MOVE '14'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE 999999              TO   YCFCTLAR-LOG-LINE-NO
                   STRING  ERROR-TEXT(ERR-IDX)   DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-PERFORM
           .
       S8300-SQL-MSG-EXT.
           EXIT.
      *
       S8400-DIAG-ERR-RTN.
      *
           EXEC SQL
                GET DIAGNOSTICS :WORK-DIAG-ERRORS = NUMBER
           END-EXEC
      *
           IF  WORK-DIAG-ERRORS > 1
           THEN
               PERFORM S8410-DIAG-MSG-RTN THRU S8410-DIAG-MSG-EXT
               IF  WORK-DB2-SERCH-SQLCODE NOT = ZERO
               THEN
                   MOVE  DBSQL-SQLCODE         TO SQLCODE
                   PERFORM S9200-SQL-ERR-RTN THRU S9200-SQL-ERR-EXT
               END-IF
           END-IF
           .
       S8400-DIAG-ERR-EXT.
           EXIT.
      *
       S8410-DIAG-MSG-RTN.
           PERFORM  VARYING WORK-ERROR-CNT FROM 1 BY 1
                      UNTIL WORK-ERROR-CNT > WORK-DIAG-ERRORS
             EXEC SQL
                  GET DIAGNOSTICS CONDITION :WORK-ERROR-CNT
                      :WORK-DB2-RERURN-SQLCODE = DB2_RETURNED_SQLCODE,
                      :WORK-DB2-MESSAGE-ID     = DB2_MESSAGE_ID,
                      :WORK-MESSAGE-TEXT       = MESSAGE_TEXT,
                      :WORK-DB2-ROW-NUMBER     = DB2_ROW_NUMBER
             END-EXEC
      *
             IF  WORK-DB2-MESSAGE-ID NOT = SPACE
             THEN
                 IF  WORK-DB2-ROW-NUMBER > ZERO
                 THEN
                     MOVE WORK-DB2-RERURN-SQLCODE
                                              TO WORK-DB2-SERCH-SQLCODE
                 END-IF
                 MOVE WORK-ERROR-CNT          TO EDIT-ERROR-CNT
                 MOVE WORK-DB2-RERURN-SQLCODE TO EDIT-DB2-RERURN-SQLCODE
                 MOVE WORK-DB2-ROW-NUMBER     TO EDIT-DB2-ROW-NUMBER
      *
                 MOVE SPACE                   TO BSGDISP-TEXT
      *
                 STRING "ERR-CNT="              DELIMITED BY SIZE
                        EDIT-ERROR-CNT          DELIMITED BY SIZE
                        "/SQLCODE="             DELIMITED BY SIZE
                        EDIT-DB2-RERURN-SQLCODE DELIMITED BY SIZE
                        "/ROW-NUM="             DELIMITED BY SIZE
                        EDIT-DB2-ROW-NUMBER     DELIMITED BY SIZE
                        "/MSG-ID="              DELIMITED BY SIZE
                        WORK-DB2-MESSAGE-ID     DELIMITED BY SIZE
                   INTO BSGDISP-TEXT
                 END-STRING
      *
                 PERFORM  S8000-BSGDISP-RTN     THRU S8000-BSGDISP-EXT
      *
                 MOVE  SPACE                    TO   BSGDISP-TEXT
      *
                 STRING "MSG-TXT="              DELIMITED BY SIZE
      *                 WORK-MSG-TXT(1:WORK-MSG-LEN)
                        WORK-MSG-TXT
                                                DELIMITED BY SIZE
                   INTO  BSGDISP-TEXT
                 END-STRING
      *
                 PERFORM  S8000-BSGDISP-RTN     THRU S8000-BSGDISP-EXT
             END-IF
      *
           END-PERFORM
      *
           .
       S8410-DIAG-MSG-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : ЧСЗЮБзЗЅРЛ СЄЛѓРћРИЗЮ СОЗсЧд
      *  УГИЎБтДЩ : УГИЎАсАњИІ СЄЛѓРИЗЮ MOVEЧбШФ СОЗс
      *-----------------------------------------------------------------
       S9000-NOMAL-END-RTN.
      *
           MOVE  CONT-OK                    TO   DBSQL-STAT
                                                 XZUGEROR-I-STAT

           MOVE  CONT-ARR-CNT               TO   DBSQL-ARRAY-CNT
      *
           MOVE  ZERO                       TO   SQLCODE
      *
           PERFORM  S8200-RESULT-DISPLAY-RTN
              THRU  S8200-RESULT-DISPLAY-EXT

           IF      COMM-START-EIO-DSTCD = '9'
           THEN
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE 999999              TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END OK :'
                           'STAT=' XZUGEROR-I-STAT    DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF
      *
           GOBACK
           .
       S9000-NOMAL-END-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : ЧСЗЮБзЗЅ ГЛКЮПЁМ­ ПЁЗЏЙпЛ§НУ УГИЎЧд
      *  УГИЎБтДЩ : ПЁЗЏПЁ АќЗУЕШ СЄКИИІ ZUGERORCAПЁ MOVEШФ
      *             ZUGERORРЛ ШЃУтЧЯАэ ПЁЗЏСЄКИИІ DISPLAYЧбДй.
      *-----------------------------------------------------------------
       S9100-ERROR-END-RTN.
      *
           MOVE  CONT-PROGRAM-ID            TO   XZUGEROR-I-PGM-ID
           MOVE  "UKLA0002"                 TO   XZUGEROR-I-TREAT-CD
      *
           MOVE  CONT-SYSERROR              TO   DBSQL-STAT
                                                 XZUGEROR-I-STAT
      *
           MOVE  "ZUGEROR"                  TO   YCFCTLAR-CALL-LOG
           CALL  YCFCTLAR-CALL-LOG       USING   YCCOMMON-CA
                                                 XZUGEROR-CA
           END-CALL
      *
           IF  BSGDISP-TEXT NOT = SPACE
           THEN
               #USRLOG "ERR-TXT : " BSGDISP-TEXT
           END-IF
      *
           IF  XZUGEROR-I-MSG NOT = SPACE
           THEN
               #USRLOG "XZUGEROR-MSG : " XZUGEROR-I-MSG
           END-IF
      *
           PERFORM  S8200-RESULT-DISPLAY-RTN
              THRU  S8200-RESULT-DISPLAY-EXT
      *
           IF      COMM-START-EIO-DSTCD = '9'
           THEN
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE XZUGEROR-I-LINE     TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END ER :'
                           'STAT=' XZUGEROR-I-STAT  DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF

           GOBACK
           .
       S9100-ERROR-END-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *  МіЧрСЖАЧ : ЧСЗЮБзЗЅ ГЛКЮПЁМ­ SQL ПЁЗЏЙпЛ§НУ УГИЎЧд
      *  УГИЎБтДЩ : ПЁЗЏПЁ АќЗУЕШ СЄКИИІ ZUGERORCAПЁ MOVEШФ
      *             ZUGERORРЛ ШЃУтЧЯАэ ПЁЗЏСЄКИИІ DISPLAYЧбДй.
      *-----------------------------------------------------------------
       S9200-SQL-ERR-RTN.
      *
           MOVE  CONT-PROGRAM-ID            TO   XZUGEROR-I-PGM-ID
      *
           MOVE  SQLCODE                    TO   DBSQL-SQLCODE
                                                 XZUGEROR-I-SQL-CD
      *
           EVALUATE  SQLCODE
               WHEN  +100
                     MOVE  CONT-MRNF        TO   DBSQL-STAT
                     MOVE  "NO DATA FOUND"  TO   XZUGEROR-I-MSG
               WHEN  OTHER
                     IF DBSQL-SQLCODE(4:1) = "9" OR DBSQL-SQLCODE = -805
                     THEN
                         MOVE CONT-SYSERROR TO   DBSQL-STAT
                     ELSE
                         MOVE CONT-SQLER    TO   DBSQL-STAT
                     END-IF
                     MOVE  "D9900000"       TO   XZUGEROR-I-ERRCD
                     MOVE  XZUGEROR-I-SQL-CD(2:)
                                            TO   XZUGEROR-I-ERRCD(4:)
           END-EVALUATE
      *
           MOVE  ZERO                       TO   XZUGEROR-I-LINE
           MOVE  "UKLA0002"                 TO   XZUGEROR-I-TREAT-CD
           MOVE  SPACE                      TO   XZUGEROR-I-MULT
                                                 XZUGEROR-I-TBL-ID
                                                 XZUGEROR-I-FUNC-CD
           MOVE  DBSQL-STAT                 TO   XZUGEROR-I-STAT
      *
           IF  DBSQL-STAT               =    CONT-MRNF OR
               DBSQL-STAT               =    CONT-DUPM
           THEN
                CONTINUE
           ELSE
      *
               MOVE  DBSQL-PROGRAM-ID       TO   XZUGEROR-I-TBL-ID
               MOVE  DBSQL-SQLCODE          TO   XZUGEROR-I-SQL-CD
      *
               MOVE    "ZUGEROR"            TO   YCFCTLAR-CALL-LOG
               CALL    YCFCTLAR-CALL-LOG USING   YCCOMMON-CA
                                                 XZUGEROR-CA
               END-CALL

               IF  XZUGEROR-I-SQL-CD NOT = -805
               THEN
                   PERFORM  S8300-SQL-MSG-RTN THRU   S8300-SQL-MSG-EXT
               END-IF
           END-IF
      *
           PERFORM  S8200-RESULT-DISPLAY-RTN
              THRU  S8200-RESULT-DISPLAY-EXT
      *

      *
           IF      COMM-START-EIO-DSTCD = '9'
           THEN
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE XZUGEROR-I-LINE     TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END ER :'
                           'STAT=' XZUGEROR-I-STAT  DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF

           GOBACK
           .
       S9200-SQL-ERR-EXT.
           EXIT.
