           EXEC  SQL
       SELECT CASE WHEN 내부신용평가등급구분 = '0000'
                   THEN ' '
                   ELSE 내부신용평가등급구분
              END AS 내부신용평가등급구분
            , 결산년월
            , 한신평재무업종구분
            , CASE 한신평재무업종구분 WHEN '00' THEN '제조'
                                      WHEN 'AA' THEN '은행'
                                      WHEN 'BB' THEN '증권'
                                      WHEN 'CC' THEN '생명보험'
                                      WHEN 'DD' THEN '손해보험'
                                      WHEN 'EE' THEN '상호저축'
                                      WHEN 'FF' THEN '종금'
                                      WHEN 'GG' THEN '투신'
                                      WHEN 'HH' THEN '리스'
                                      WHEN 'II' THEN '카드'
                                      WHEN 'JJ' THEN '창투'
                                      WHEN 'KK' THEN '할부금융'
                                      WHEN 'ZZ' THEN '기타금융'
                                      ELSE '기타금융'
              END AS 한신평재무업종구분명
            , 업종평균적용년
            , 신용등급지원비율
            , ROUND(전전년사업이익  /1000000,0) AS 전전년사업이익
            , ROUND(  전년사업이익  /1000000,0) AS 전년사업이익
            , ROUND(기준년사업이익  /1000000,0) AS 기준년사업이익
            , CASE WHEN (전전년사업이익  +
                           전년사업이익  +
                         기준년사업이익) = 0
                   THEN 0
                   ELSE MAX(MIN(
                        DOUBLE(기준년사업이익)/
                        ROUND((전전년사업이익 +
                                 전년사업이익 +
                               기준년사업이익)/3) * 100,
                                999.99),-999.99)
              END AS 평균사업이익비율
            , 이익가중치값
            , 금융자기자본비율
            , ROUND(상환능력기준한도/1000000,0) AS 상환능력기준한도
            , ROUND(전전년자기자본금/1000000,0) AS 전전년자기자본금
            , ROUND(  전년자기자본금/1000000,0) AS 전년자기자본금
            , ROUND(기준년자기자본금/1000000,0) AS 기준년자기자본금
            , CASE WHEN (전전년자기자본금  +
                           전년자기자본금  +
                         기준년자기자본금) = 0
                   THEN 0
                   ELSE MAX(MIN(
                        DOUBLE(기준년자기자본금)/
                        ROUND((전전년자기자본금 +
                                 전년자기자본금 +
                               기준년자기자본금)/3) * 100,
                                999.99),-999.99)
              END AS 평균자기자본비율
            , 자본가중치값
            , ROUND(규모기준한도    /1000000,0) AS 규모기준한도
            , ROUND(기준한도        /1000000,0) AS 기준한도
       INTO
             :XQJL0096-O-INTNL-CV-GRD-DSTCD
            ,:XQJL0096-O-STLACC-YM
            ,:XQJL0096-O-KIS-F-BZTYP-DSTCD
            ,:XQJL0096-O-KIS-FB-DSTIC-NAME
            ,:XQJL0096-O-BZTYP-AVG-APLY-YR
            ,:XQJL0096-O-CRDRAT-SPORT-RATO
            ,:XQJL0096-O-BF-PYY-BIZ-PRFT
            ,:XQJL0096-O-PYY-BIZ-PRFT
            ,:XQJL0096-O-BASE-YR-BIZ-PRFT
            ,:XQJL0096-O-AVG-BIZ-PRFT-RATO
            ,:XQJL0096-O-PRFT-WGHT-VAL
            ,:XQJL0096-O-FINAC-ONCP-RATO
            ,:XQJL0096-O-SOLVN-BASE-CLAM
            ,:XQJL0096-O-BF-PYY-ONCP-AMT
            ,:XQJL0096-O-PYY-ONCP-AMT
            ,:XQJL0096-O-BASE-YR-ONCP-AMT
            ,:XQJL0096-O-AVG-ONCP-RATO
            ,:XQJL0096-O-CAPTL-WGHT-VAL
            ,:XQJL0096-O-SCAL-BASE-CLAM
            ,:XQJL0096-O-BASE-CLAM
         FROM        THKJL0001
        WHERE 그룹회사코드 = :XQJL0096-I-GROUP-CO-CD
          AND 고객식별자   = :XQJL0096-I-KB-PIN
          AND 기준년월     = :XQJL0096-I-BASE-YM
          AND 한신평재무업종구분 <> '00'
         WITH UR
