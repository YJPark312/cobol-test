           EXEC  SQL
           DECLARE CUR_SQL  CURSOR WITH HOLD
                                       WITH ROWSET POSITIONING FOR
       SELECT 고객식별자
             ,채무자명
             ,"KB신용공여금액"
             ,"FS신용공여금액"
             ,제외대상금액
         FROM (SELECT A.고객식별자
                     ,B.계열기업군명          AS 채무자명
                     ,SUM(A."KB신용공여금액") AS "KB신용공여금액"
                     ,SUM(A."FS신용공여금액") AS "FS신용공여금액"
                     ,SUM(A.제외대상금액)     AS 제외대상금액
                 FROM        THKJL0041 A
                     ,       THKJL0013 B
                WHERE A.그룹회사코드 = :XQJL0352-I-GROUP-CO-CD
                  AND A.기준년월일   = :XQJL0352-I-BASE-YMD
                  AND A.그룹회사코드 = B.그룹회사코드
                  AND A.고객식별자   = B.계열기업군코드
                  AND B.기준년월     = SUBSTR(A.기준년월일,1,6)
                  AND A.한도기업구분 = '2'
                  AND B.계열적용구분 = '2'
                GROUP BY A.고객식별자
                       , B.계열기업군명
                UNION
               SELECT VALUE((SELECT 고객식별자
                               FROM        THKJL0015
                              WHERE 그룹회사코드 = A.그룹회사코드
                                AND 고객식별자   = A.고객식별자
                             ),'')  AS 고객식별자
                     ,VALUE((SELECT 채무자명
                               FROM        THKJL0015
                              WHERE 그룹회사코드 = A.그룹회사코드
                                AND 고객식별자   = A.고객식별자
                             ),'')            AS 채무자명
                     ,SUM(A."KB신용공여금액") AS "KB신용공여금액"
                     ,SUM(A."FS신용공여금액") AS "FS신용공여금액"
                     ,SUM(A.제외대상금액)     AS 제외대상금액
                 FROM        THKJL0041 A
                WHERE A.그룹회사코드 = :XQJL0352-I-GROUP-CO-CD
                  AND A.기준년월일   = :XQJL0352-I-BASE-YMD
                  AND A.한도기업구분 = '1'
                GROUP BY A.그룹회사코드
                       , A.고객식별자
               ) A
       ORDER BY 고객식별자
        WITH UR
      *
           END-EXEC
