            , 0   AS 통화한도
            , 0   AS 통화잔액
            , 0   AS "BS기준한도"
            , 0   AS "BS기준잔액"
            , ''  AS 시작년월일
            , ''  AS 만기년월일
            , VALUE(SUM(TBL1.신용공여익스포져금액),0)
              AS 신용공여익스포져금액
            , ''  AS 금리내용
            , ''  AS 담보형태구분
            , 0   AS 담보설정금액
            , ''  AS 취급부점코드
            , ''  AS 취급부점명
            , ''  AS 대출취급형태구분
            , ''  AS 수기계좌여부
            , ''  AS 자회사대주주구분
         FROM        THKJL0042 B
             ,       THKJL0081 A
              LEFT OUTER JOIN TBL1
           ON A.그룹회사코드   = :XQJL4137-I-GROUP-CO-CD
          AND A.고객식별자     = TBL1.고객식별자
          AND A.이사회승인번호 = TBL1.이사회승인번호
        WHERE B.그룹회사코드   = A.그룹회사코드
          AND B.고객식별자     = A.고객식별자
          AND B.그룹회사코드   = :XQJL4137-I-GROUP-CO-CD
          AND B.기준년월       = :XQJL4137-I-BASE-YM
          AND B.해제년월일     = ' '
          AND (('1'               = :XQJL4137-I-BRN-DSTIC
          AND   A.소관부점코드 LIKE :XQJL4137-I-JRSDZ-BRNCD)
           OR  ('2'               = :XQJL4137-I-BRN-DSTIC
          AND   A.소관부점코드  IN (:XQJL4137-I-JRSDZ-BRNCD1
                                  , :XQJL4137-I-JRSDZ-BRNCD2)))
        ORDER BY 고객식별자
                ,소관부점코드
                ,이사회승인번호
                ,관련여신일련번호
         WITH UR
      *
           END-EXEC
      *
           EXEC SQL OPEN  CUR_SQL END-EXEC
      *
           IF  SQLCODE                      =    -502
               PERFORM Z9900-CLOSE-RTN
                  THRU Z9900-CLOSE-EXT
               EXEC SQL OPEN  CUR_SQL END-EXEC
           END-IF

           IF  SQLCODE = ZERO
               SET   COND-DBSQL-OK    TO   TRUE
           ELSE
               PERFORM Z9900-SQLCODE-CHECK-RTN
                  THRU Z9900-SQLCODE-CHECK-EXT
           END-IF
           .
       Z9900-OPEN-EXT.
           EXIT.

