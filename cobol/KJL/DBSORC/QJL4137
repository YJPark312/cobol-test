           EXEC  SQL
           DECLARE CUR_SQL  CURSOR WITH HOLD
                                       WITH ROWSET POSITIONING FOR
       WITH TBL1 AS (
       -- 수기계좌
       SELECT A.이사회승인번호
            , A.고객식별자
            , '' AS 고객명
            , '' AS 소관부점코드
            , '' AS 소관부점명
            , '' AS "통화코드1"
            , 0  AS 이사회승인금액
            , '' AS 이사회승인년월일
            , '' AS 이사회승인유효년월일
            , A.관련여신일련번호
            , '' AS 신용공여중분류코드
            , A.계좌번호
            , A.약정계좌번호
            , A.통합계정과목코드
            , B.계정과목명 AS 상품명
            , A.통화코드 AS "통화코드2"
            , A.통화한도
            , A.통화잔액
            , 0  AS "BS기준한도"
            , 0  AS "BS기준잔액"
            , A.시작년월일
            , A.만기년월일
            , A.신용공여익스포져금액
            , A.금리내용
            , A.담보형태구분
            , A.담보설정금액
            , A.취급부점코드
            , A.대출취급형태구분
            , A.수기계좌여부
         FROM        THKJL0082 A
             ,       THKJL0119 B
        WHERE A.그룹회사코드     = B.그룹회사코드
          AND A.통합계정과목코드 = B.통합계정과목코드
          AND B.그룹회사코드     = :XQJL4137-I-GROUP-CO-CD
          AND B.기준년월         = :XQJL4137-I-BASE-YM
          AND A.통합계정과목코드 > ''
          AND A.수기계좌여부     = '1'
        UNION
       --외화콜론,외화대여금 0125 계좌
       SELECT D.이사회승인번호
            , D.고객식별자
            , ''  AS 고객명
            , ''  AS 소관부점코드
            , ''  AS 소관부점명
            , ''  AS "통화코드1"
            , 0   AS 이사회승인금액
            , ''  AS 이사회승인년월일
            , ''  AS 이사회승인유효년월일
            , D.관련여신일련번호 AS 관련여신일련번호
            , ''  AS 신용공여중분류코드
            , MIN(D.계좌번호)     AS 계좌번호
            , MIN(D.약정계좌번호) AS 약정계좌번호
            , MIN(D.통합계정과목코드) AS 통합계정과목코드
            , MIN(B."TE상품명")       AS 상품명
            , A.통화코드 AS "통화코드2"
            , SUM(A.통화한도) AS 통화한도
            , SUM(A.통화잔액) AS 통화잔액
            , SUM(C."BS기준한도") AS "BS기준한도"
            , SUM(C."BS기준잔액") AS "BS기준잔액"
            , MIN(A.시작년월일) AS 시작년월일
            , MAX(A.만기년월일) AS 만기년월일
            , VALUE(SUM(C.신용공여익스포져금액),0)
                       AS 신용공여익스포져금액
            , MIN(D.금리내용    ) AS 금리내용
            , MIN(D.담보형태구분) AS 담보형태구분
            , MAX(D.담보설정금액) AS 담보설정금액
            , D.취급부점코드
            , D.대출취급형태구분
            , '0' AS 수기계좌여부
         FROM        THKJL0082 D
             ,       THKJL0118 B
             ,       THKJL0125 A
              LEFT OUTER JOIN
                     THKJL0076 C
           ON A.그룹회사코드   = C.그룹회사코드
          AND A.기준일         = C.기준일
          AND A.기준년월       = C.기준년월
          AND A.차주고객식별자 = C.차주고객식별자
       --   AND A.한도계좌번호   = C.한도계좌번호
          AND A.한도상품대분류코드 = C.한도상품대분류코드
          AND A.한도상품중분류코드 = C.한도상품중분류코드
          AND A.한도상품템플릿코드 = C.한도상품템플릿코드
          AND A.한도상품번호       = C.한도상품번호
        WHERE A.그룹회사코드       = B.그룹회사코드
          AND A.기준년월           = B.기준년월
          AND A.한도상품대분류코드 = B.상품대분류코드
          AND A.한도상품중분류코드 = B.상품중분류코드
          AND A.한도상품템플릿코드 = B.상품템플릿코드
          AND A.한도상품번호       = B.상품번호
          AND A.그룹회사코드       = D.그룹회사코드
          AND A.한도계좌번호       = D.계좌번호
          AND A.차주고객식별자     = D.고객식별자
          AND A.그룹회사코드  = :XQJL4137-I-GROUP-CO-CD
          AND A.기준일        = :XQJL4137-I-BASE-DD
          AND A.기준년월      = :XQJL4137-I-BASE-YM
          AND A."TE계좌구분"        <> '2'
          AND B.신용익스포져대상여부 = '1'
          AND B."한도기준TE환산율"   > 0
          AND D.계좌번호             > ''
          AND D.수기계좌여부         = '0'
          AND B.상품대분류코드||B.상품중분류코드||
              B.상품템플릿코드||B.상품번호 IN
             ('KT01000F2330','KT01000F2349')
        GROUP BY D.이사회승인번호
                ,D.고객식별자
                ,D.관련여신일련번호
                ,A.통화코드
                ,D.취급부점코드
                ,D.대출취급형태구분
        UNION
       --외화콜론,외화대여금 이외 0125 계좌
       SELECT D.이사회승인번호
            , D.고객식별자
            , ''  AS 고객명
            , ''  AS 소관부점코드
            , ''  AS 소관부점명
            , ''  AS "통화코드1"
            , 0   AS 이사회승인금액
            , ''  AS 이사회승인년월일
            , ''  AS 이사회승인유효년월일
