      *---ZXXXXXX : 비상 예비용
           IF      DBIO-CALL-PGM-ID = "ZBD0500" OR "ZBD0510" OR
                                      "ZBD0550" OR "ZBD0560" OR
                                      "ZXXXXXX"
                   CONTINUE
           ELSE
             IF    COND-DBIO-UPDATE
                OR COND-DBIO-INSERT  OR COND-DBIO-LKUPDT
                   MOVE    BICOM-TRAN-START-YMS
                     TO    SYS-LAST-PRCSS-YMS OF DBIO-REC
                   MOVE    BICOM-USER-EMPID
                     TO    SYS-LAST-UNO       OF DBIO-REC
             END-IF
           END-IF
           .
       S0140-USID-INFO-SET-EXT.
           EXIT.
      *
      *
      *-----------------------------------------------------------------
      *  수행조건 : 입력정보 및 기본정보 검증
      *  처리기능 : 기본항목검증
      *-----------------------------------------------------------------
       S0150-CHECK-RTN.
      *
      *
           EVALUATE  TRUE
             WHEN  NOT (SICOM-OPER-DSTCD = CO-TEMP OR CO-DAY OR CO-STOP)
                   STRING "정의되지 않은 거래모드입니다.("
                          "거래모드구분=" SICOM-OPER-DSTCD ")"
                          DELIMITED BY SIZE INTO  XZUGEROR-I-MSG
                   #ERROR  CO-S9000002 CO-UKLA0002 CO-STAT-SYSERROR
             WHEN  BICOM-TRAN-START-YMS = SPACE
                   MOVE   "BICOM-TRAN-START-YMS 미입력"
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000099 CO-UKLA0002 CO-STAT-SYSERROR
             WHEN  BICOM-USER-EMPID     = SPACE
                   MOVE   "BICOM-USER-EMPID 미입력"
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000099 CO-UKLA0002 CO-STAT-SYSERROR
           END-EVALUATE

      * DBIO-FUNCTION 코드 정합성 검증
           IF      COND-DBIO-SELECT  OR  COND-DBIO-UPDATE
               OR  COND-DBIO-INSERT
               OR  COND-DBIO-DELETE  OR  COND-DBIO-DELFRC
               OR  COND-DBIO-SELFST  OR  COND-DBIO-LKUPDT
               OR  COND-DBIO-OPEN    OR  COND-DBIO-FETCH
               OR  COND-DBIO-CLOSE
                   CONTINUE
           ELSE
                   MOVE    "DBIO-FUNCTION코드 오류입니다."
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000001 CO-UKLA0002 CO-STAT-SYSERROR
           END-IF

           IF      COND-DBIO-FETCH   OR  COND-DBIO-CLOSE
                   CONTINUE
           ELSE
               IF  DBIO-KEY                 =    SPACE
      *{E} DBIO-KEY 미입력 오류입니다.
                   MOVE    "DBIO-KEY 미입력 오류입니다."
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000003 CO-UKLA0002 CO-STAT-SYSERROR
               END-IF
           END-IF
      *
      * DBIO-ACCESS-KEY 정합성 검증
           IF      COND-DBIO-PK

                   CONTINUE
           ELSE
                   MOVE    "DBIO입력항목 검증오류입니다(ACCESS-KEY)"
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000004 CO-UKLA0002 CO-STAT-SYSERROR
           END-IF
      *
      * DBIO-ACCESS-COND 정합성 검증
           IF  COND-DBIO-0  OR  COND-DBIO-1  OR
               COND-DBIO-2  OR  COND-DBIO-3  OR
               COND-DBIO-4
               IF  COND-DBIO-SELFST  OR COND-DBIO-OPEN    OR
                   COND-DBIO-FETCH

      *PK의SELECT_CURSOR를CLOSE하기위해COND-DBIO-0를사용함
                   IF  COND-DBIO-0
                       MOVE    "DBIO-ACCESS-COND 오류입니다"
                                            TO   XZUGEROR-I-MSG
                       #ERROR  CO-S9000005 CO-UKLA0002 CO-STAT-SYSERROR
                   END-IF
               END-IF
           ELSE
               IF  COND-DBIO-SELECT  OR COND-DBIO-INSERT  OR
                   COND-DBIO-UPDATE  OR COND-DBIO-LKUPDT  OR
                   COND-DBIO-DELETE  OR COND-DBIO-DELFRC
                   CONTINUE
               ELSE
                   MOVE    "DBIO-ACCESS-COND 오류입니다"
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000005 CO-UKLA0002 CO-STAT-SYSERROR
               END-IF
           END-IF
      *
      * DBIO-LOCK-YN 정합성검증
           IF      COND-DBIO-LOCK      OR
                   COND-DBIO-UNLOCK
                   CONTINUE
           ELSE
                   MOVE   "DBIO-LOCK-YN(조건) 오류입니다"
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000006 CO-UKLA0002 CO-STAT-SYSERROR
           END-IF
      *
           IF      COND-DBIO-LOCK AND
                   DBIO-ACCESS-KEY(1:2)  NOT =  CO-PK
                   MOVE   "DBIO-LOCK-YN(조건) 오류입니다"
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000006 CO-UKLA0002 CO-STAT-SYSERROR
           END-IF
      *
      * 입력값의 조합검증
           IF      DBIO-ACCESS-KEY(1:2)     NOT =  CO-PK
             IF    COND-DBIO-UPDATE
                OR COND-DBIO-INSERT
                OR COND-DBIO-DELETE
                OR COND-DBIO-DELFRC
                   MOVE
                     "DBIO-FUNCTION 또는 DBIO-ACCESS-KEY 오류입니다"
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000007 CO-UKLA0002 CO-STAT-SYSERROR
             END-IF
           END-IF
      *
           IF      COND-DBIO-DELETE OR COND-DBIO-DELFRC
               IF  NOT COND-DBIO-LOCK
                   MOVE "DBIO-LOCK-YN(조건) 오류입니다"
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000006 CO-UKLA0002 CO-STAT-SYSERROR
               END-IF
           ELSE
             IF    COND-DBIO-LOCK
               IF  COND-DBIO-OPEN       OR
                   COND-DBIO-FETCH      OR
                   COND-DBIO-SELFST
                   MOVE "DBIO-LOCK-YN(조건) 오류입니다"
                                            TO   XZUGEROR-I-MSG
                   #ERROR  CO-S9000006 CO-UKLA0002 CO-STAT-SYSERROR
               END-IF
             END-IF
           END-IF
      *
           IF      COND-DBIO-FETCH OR COND-DBIO-CLOSE
                   GO   TO S0150-CHECK-EXT
           END-IF

           PERFORM S0151-IN-CHECK-RTN
              THRU S0151-IN-CHECK-EXT
           .
       S0150-CHECK-EXT.
           EXIT.

      *
      *-----------------------------------------------------------------
      *  수행조건 : DBIO-키 값 검증
      *  처리기능 : DBIO-키 값에 NULL 입력시 에러처리
      *-----------------------------------------------------------------
       S0151-IN-CHECK-RTN.

           EVALUATE  TRUE
             WHEN  COND-DBIO-PK
                   EVALUATE  TRUE
                     WHEN  GROUP-CO-CD OF PK0 = SPACE
                           MOVE DOC-PK0(01) TO   XZUGEROR-I-MSG
                     WHEN  BASE-YM OF PK0 = SPACE
                           MOVE DOC-PK0(02) TO   XZUGEROR-I-MSG
                     WHEN  GRNTY-INSTI-NO OF PK0 = SPACE
                           MOVE DOC-PK0(03) TO   XZUGEROR-I-MSG
                     WHEN  T-E-GRNTY-INSTI-CD OF PK0 = SPACE
                           MOVE DOC-PK0(04) TO   XZUGEROR-I-MSG
                     WHEN  1 < DBIO-ACCESS-COND
                           MOVE '1 < DBIO-ACCESS-COND오류입니다.'
                                            TO XZUGEROR-I-MSG
                   END-EVALUATE
           END-EVALUATE
      *


           IF      XZUGEROR-I-MSG NOT = SPACE
             IF    XZUGEROR-I-MSG(2:1) = 'K'
                   MOVE    SPACE                TO   XZUGEROR-I-MSG(35:)
                   #ERROR  CO-S9000003 CO-UKLA0002 CO-STAT-SYSERROR
             ELSE
                   #ERROR  CO-S9000005 CO-UKLA0002 CO-STAT-SYSERROR
             END-IF
           END-IF
           .
       S0151-IN-CHECK-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION 구분이 SELECT일때 실행된다.
      *  처리기능 : DBIO-ACCESS-KEY와 DBIO-LOCK-YN에따라
      *             다른 조건으로 SELECT를 한다.
      *-----------------------------------------------------------------
       S1000-SELECT-RTN.
      *
           INITIALIZE         TBL-REC
           IF      COND-DBIO-LOCK
               IF  DBIO-KEY       = SAVE-PK
               AND BICOM-GU-ID-NO = SAVE-GUID
                   PERFORM S8720-SELECT0-RTN
                      THRU S8720-SELECT0-EXT
               ELSE
                   PERFORM S8710-SEL-LOCK-RTN
                      THRU S8710-SEL-LOCK-EXT
               END-IF
           ELSE
                   PERFORM S8720-SELECT0-RTN THRU S8720-SELECT0-EXT
           END-IF

           IF      SQLCODE                   NOT =    ZERO
                   MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                   MOVE  #SLINE             TO    XZUGEROR-I-LINE
                   PERFORM Z9900-MSG-ERROR-RTN
                      THRU Z9900-MSG-ERROR-EXT
           END-IF

120104     MOVE  SYS-LAST-PRCSS-YMS  OF  TBL-REC
120104       TO  DBIO-LAST-PRCSS-YMS
120104     MOVE  SYS-LAST-UNO        OF  TBL-REC
120104       TO  DBIO-LAST-UNO
           .
       S1000-SELECT-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION이 SELFST 일때 실행한다
      *  처리기능 : 조건에 해당하는 첫번째 ROW를 RETURN 한다
      *-----------------------------------------------------------------
       S2000-SELFST-RTN.
      *
           INITIALIZE         TBL-REC

           PERFORM S8740-SEL-FIRST0-RTN THRU S8740-SEL-FIRST0-EXT

           IF      SQLCODE                   NOT =    ZERO
                   MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                   MOVE  #SLINE             TO    XZUGEROR-I-LINE
                   PERFORM Z9900-MSG-ERROR-RTN
                      THRU Z9900-MSG-ERROR-EXT
           END-IF
           .
       S2000-SELFST-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION 구분이 INSERT 일때 실행된다.
      *  처리기능 : ST-BI거래모드구분에따라 분기하여 실행한다.
      *-----------------------------------------------------------------
       S3000-INSERT-RTN.
      *
110830*    직전 정보를 읽을필요없음
110830     MOVE     CO-YES                TO    WK-BEFOR-SELECT-YN
110830     PERFORM S8850-BATCH-IUD-WRITE-RTN
110830        THRU S8850-BATCH-IUD-WRITE-EXT
      *
           PERFORM S8400-INSERT-RTN
              THRU S8400-INSERT-EXT
      *
           IF       SQLCODE                       =   ZERO
      * 24-365 거래
               IF (SICOM-OPER-DSTCD          =   CO-TEMP OR CO-STOP)

                   MOVE    TBL-REC          TO    OLD-REC
                   PERFORM S8800-IMAGE-INSERT-RTN
                      THRU S8800-IMAGE-INSERT-EXT
               END-IF
           ELSE
                   MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                   MOVE  #SLINE             TO    XZUGEROR-I-LINE
                   PERFORM Z9900-MSG-ERROR-RTN
                      THRU Z9900-MSG-ERROR-EXT
           END-IF
           .
       S3000-INSERT-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION 구분이 UPDATE 일때 실행된다.
      *  처리기능 : ST-BI거래모드구분에따라 분기하여 실행한다.
      *-----------------------------------------------------------------
       S4000-UPDATE-RTN.
      *
      *
           PERFORM S7500-BEFOR-CHECK-RTN
              THRU S7500-BEFOR-CHECK-EXT
      *
           PERFORM S8500-UPDATE-RTN
              THRU S8500-UPDATE-EXT

           IF      SQLCODE  NOT =    ZERO
                   MOVE  CO-YES             TO    WK-LKSEL-CLOSE-YN
                   MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                   MOVE  #SLINE             TO    XZUGEROR-I-LINE
                   PERFORM Z9900-MSG-ERROR-RTN
                      THRU Z9900-MSG-ERROR-EXT
           ELSE
                   PERFORM S8711-LKSEL-CLOSE-RTN
                      THRU S8711-LKSEL-CLOSE-EXT
           END-IF

           .
       S4000-UPDATE-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION구분이LOCK-UPDATE(LKUPDT)일때
      *  처리기능 : UPDATE하기전읽은DATA와UPATE하기위해읽은
      *             DATA의최종갱신일을비교하여같지않으면오류
      *             처리하고같으면실행한다.
      *-----------------------------------------------------------------
       S5000-LKUPDT-RTN.
      *
      *
           IF      DBIO-KEY       = SAVE-PK
               AND BICOM-GU-ID-NO = SAVE-GUID
                   PERFORM S7400-BEFOR-SEL-RTN
                      THRU S7400-BEFOR-SEL-EXT
           ELSE
                 SET  ADDRESS OF TBL-REC      TO   ADDRESS OF OLD-REC
                 INITIALIZE TBL-REC
                 PERFORM S8710-SEL-LOCK-RTN
                    THRU S8710-SEL-LOCK-EXT
                 SET  ADDRESS OF TBL-REC      TO   ADDRESS OF DBIO-REC
           END-IF

      *    직전 정보를 읽음
           MOVE     CO-YES                TO    WK-BEFOR-SELECT-YN

           PERFORM S4000-UPDATE-RTN
              THRU S4000-UPDATE-EXT

           .
       S5000-LKUPDT-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION 구분이 DELETE 일때 실행된다.
      *  처리기능 : DBIO-ACCESS-KEY와 DBIO-LOCK-YN에따라
      *             실행 또는 오류 처리 한다.
      *-----------------------------------------------------------------
       S6000-DELETE-RTN.
      *
           IF      COMM-DELETE-LOG-YN  = "1"
              IF   SICOM-OPER-DSTCD             =    CO-DAY
                   PERFORM S7400-BEFOR-SEL-RTN
                      THRU S7400-BEFOR-SEL-EXT
              END-IF
           END-IF

           PERFORM S7500-BEFOR-CHECK-RTN
              THRU S7500-BEFOR-CHECK-EXT

      *    삭제전 내용 로그생성
           IF      COMM-DELETE-LOG-YN  = "1"
                   MOVE  LENGTH OF DBIO-REC      TO   DBIO-TABLE-LEN
             IF    DBIO-TABLE-LEN < LENGTH OF WK-CORRECTION
                   MOVE  SPACE TO  WK-CORRECTION(DBIO-TABLE-LEN + 1:)
             END-IF
      *
             EXEC SQL
                   INSERT INTO        THKLA9020  (
                          "그룹회사코드",
                          "처리일",
                          "테이블명",
                          "처리키명",
                          "처리시각",
                          "처리키길이",
                          "처리데이터길이",
                          "처리데이터내용",
                          "시스템최종처리일시",
                          "시스템최종사용자번호"
                              )
                   VALUES     (
                         :BICOM-GROUP-CO-CD,
                         :BICOM-TRAN-BASE-YMD,
                         :DBIO-TABLE-NM,
                         :DBIO-KEY,
                         :BICOM-TRAN-BASE-HMS,
                          LENGTH(:DBIO-KEY),
                         :DBIO-TABLE-LEN,
                          RTRIM(:WK-CORRECTION),
                         :BICOM-TRAN-START-YMS,
                         :BICOM-USER-EMPID
                              )
             END-EXEC
             IF    SQLCODE                NOT =    ZERO
                   MOVE    "S6000:S6000-DELETE-RTN(INSERT THKLA9020)"
                                            TO    XZUGEROR-I-MSG
                   MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                   MOVE  #SLINE             TO    XZUGEROR-I-LINE
                   PERFORM Z9900-MSG-ERROR-RTN
                      THRU Z9900-MSG-ERROR-EXT
             END-IF
           END-IF

           EXEC SQL
           DELETE
             FROM THKJL0071
            WHERE "그룹회사코드" =  :PK0.GROUP-CO-CD
              AND "기준년월" =  :PK0.BASE-YM
              AND "보증기관번호" =  :PK0.GRNTY-INSTI-NO
              AND "TE보증기관코드" =  :PK0.T-E-GRNTY-INSTI-CD

           END-EXEC
      *
           IF      SQLCODE NOT  =    ZERO
                   MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                   MOVE  #SLINE             TO    XZUGEROR-I-LINE
                   PERFORM Z9900-MSG-ERROR-RTN
                      THRU Z9900-MSG-ERROR-EXT
           END-IF
           .
       S6000-DELETE-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION 구분이 OPEN 일때 실행된다.
      *  처리기능 : CURSOR를 생성하고 OPEN하는 RTN으로 분기.
      *-----------------------------------------------------------------
       S7100-OPEN-RTN.
      *
      *
           PERFORM S8100-DECLARE-RTN
              THRU S8100-DECLARE-EXT

           IF      SQLCODE NOT = ZERO
                   MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                   MOVE  #SLINE             TO    XZUGEROR-I-LINE
                   PERFORM Z9900-MSG-ERROR-RTN
                      THRU Z9900-MSG-ERROR-EXT
           END-IF
           .
       S7100-OPEN-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION 구분이 FETCH 일때 실행된다.
      *  처리기능 : DATA를 FETCH 하는 RTN으로 분기한다.
      *-----------------------------------------------------------------
       S7200-FETCH-RTN.
      *
      *
           PERFORM S8200-FETCH-RTN
              THRU S8200-FETCH-EXT

           IF      SQLCODE NOT = ZERO
                   MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                   MOVE  #SLINE             TO    XZUGEROR-I-LINE
                   PERFORM Z9900-MSG-ERROR-RTN
                      THRU Z9900-MSG-ERROR-EXT
           END-IF
           .
       S7200-FETCH-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION 구분이 CLOSE 일때 실행된다.
      *  처리기능 : CURSOR를 CLOSE 하는 RTN으로 분기한다.
      *-----------------------------------------------------------------
       S7300-CLOSE-RTN.
      *
           PERFORM S8300-CLOSE-RTN
              THRU S8300-CLOSE-EXT

           IF      SQLCODE NOT = ZERO
                   MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                   MOVE  #SLINE             TO    XZUGEROR-I-LINE
                   PERFORM Z9900-MSG-ERROR-RTN
                      THRU Z9900-MSG-ERROR-EXT
           END-IF
           .
       S7300-CLOSE-EXT.
           EXIT.
      *
      *
      *-----------------------------------------------------------------
      *  수행조건 :  UPDATE, DELETE, LKUPDT, DELFRC시　
      *  처리기능 : 테이블의　직전정보를　NOLOCK으로　읽는다
      *-----------------------------------------------------------------
       S7400-BEFOR-SEL-RTN.

           IF    WK-BEFOR-SELECT-YN NOT = CO-YES
                 SET  ADDRESS OF TBL-REC      TO   ADDRESS OF OLD-REC
                 INITIALIZE TBL-REC
                 PERFORM S8720-SELECT0-RTN
                    THRU S8720-SELECT0-EXT
                 MOVE CO-YES               TO  WK-BEFOR-SELECT-YN
                 IF  SQLCODE           NOT =    ZERO
                     MOVE   "S8700:S8720-S8720-SELECT0-RTN"
                                              TO    XZUGEROR-I-MSG
                     MOVE  CO-STAT-ERROR      TO    DBIO-STAT
                     MOVE  #SLINE             TO    XZUGEROR-I-LINE
                     PERFORM Z9900-MSG-ERROR-RTN
                        THRU Z9900-MSG-ERROR-EXT
                 END-IF

                 SET  ADDRESS OF TBL-REC      TO   ADDRESS OF DBIO-REC
           END-IF
           .
       S7400-BEFOR-SEL-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *  수행조건 : DBIO-FUNCTION 구분이 UPDATE 일때 실행된다.
      *  처리기능 : ST-BI거래모드구분에따라 분기하여 실행한다.
      *-----------------------------------------------------------------
       S7500-BEFOR-CHECK-RTN.

110830*    BATCH이고 갱신이면 전후 정보저장
110830     PERFORM S8850-BATCH-IUD-WRITE-RTN
110830        THRU S8850-BATCH-IUD-WRITE-EXT

      *DBIO-DELFRC시 시스템최종처리일시,시스템최종사용자번호
      *SELECT SKIP 처리합니다
           IF    COND-DBIO-DELFRC
                 GO TO    S7500-BEFOR-CHECK-EXT
           END-IF

      * TEMP MODE 이면서 UPDATE, LKUPDT 거래인경우
      * 원장보정로그 를 생성 한다.
      * (INSERT, DELETE시는 거래 종료전 로그를 생성)
      * 24-365 거래
           IF  (SICOM-OPER-DSTCD      =    CO-TEMP OR CO-STOP)


               PERFORM S7400-BEFOR-SEL-RTN
                  THRU S7400-BEFOR-SEL-EXT
               PERFORM S7510-CHK-LAST-YMS-UNO-RTN
                  THRU S7510-CHK-LAST-YMS-UNO-EXT
               PERFORM S8800-IMAGE-INSERT-RTN
                  THRU S8800-IMAGE-INSERT-EXT

           ELSE
               IF  WK-BEFOR-SELECT-YN NOT = CO-YES
                   PERFORM S8730-SEL-LAST-YMS-UNO-RTN
                      THRU S8730-SEL-LAST-YMS-UNO-EXT
               END-IF
               PERFORM S7510-CHK-LAST-YMS-UNO-RTN
                  THRU S7510-CHK-LAST-YMS-UNO-EXT
           END-IF
           .
       S7500-BEFOR-CHECK-EXT.
           EXIT.

      *
      *-----------------------------------------------------------------
      *  처리기능 : UPDATE DELETE시 개신 정합성 검증
      *-----------------------------------------------------------------
       S7510-CHK-LAST-YMS-UNO-RTN.

           IF      WK-IN-LAST-PRCSS-YMS  = SYS-LAST-PRCSS-YMS OF OLD-REC
             IF    BICOM-TRAN-START-YMS  = SYS-LAST-PRCSS-YMS OF OLD-REC
               IF  BICOM-USER-EMPID  NOT = SYS-LAST-UNO       OF OLD-REC
                   MOVE "타사용자가 자료를 변경하였습니다"
                                            TO   XZUGEROR-I-MSG
                   #ERROR CO-S9000008 CO-UKLA0002 CO-STAT-SYSERROR
               END-IF
