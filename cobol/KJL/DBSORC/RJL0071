      *
           MOVE  "ZSFDBLG"                  TO   YCFCTLAR-CALL-PGM
           CALL  YCFCTLAR-CALL-PGM        USING  DFHEIBLK
                                                 YCCOMMON-CA
                                                 YCDBIOCA-CA
                                                 XZSFDBLG-CA
                                                WK-CORRECTION
                                                WK-COND-DESC
           END-CALL
      *
           MOVE  DBIO-SQLCODE               TO   SQLCODE
           .
       S8810-IMAGE-INSERT-EXT.
           EXIT.
      *
      *-----------------------------------------------------------------
      *   변경전후 정보를 WRITE한다.
      *-----------------------------------------------------------------
       S8850-BATCH-IUD-WRITE-RTN.
      *
           IF  COMM-ONLINE-YN NOT = CO-YES
               AND   COND-DBIO-CHGLOG-YES
               PERFORM S7400-BEFOR-SEL-RTN THRU S7400-BEFOR-SEL-EXT
      *        최종일변경
               MOVE  BICOM-TRAN-START-YMS   TO XZSFDBUD-I-TRAN-START-YMS
               MOVE  LENGTH OF DBIO-REC     TO    DBIO-TABLE-LEN
               MOVE  "ZSFDBUD"              TO    YCFCTLAR-CALL-PGM
               CALL  YCFCTLAR-CALL-PGM      USING DFHEIBLK
                                                  YCCOMMON-CA
                                                  XZSFDBUD-CA
                                                  YCDBIOCA-CA
                                                  OLD-REC
                                                  DBIO-REC
               END-CALL
               IF    XZSFDBUD-R-STAT NOT = CO-STAT-OK
                     MOVE   "S8850-BATCH-IUD-WRITE-RTN ZSFDBUD"
                                               TO    XZUGEROR-I-MSG
                     #ERROR CO-S9000099 CO-UKLA0002 CO-STAT-SYSERROR
               END-IF
           END-IF
           .
       S8850-BATCH-IUD-WRITE-EXT.
           EXIT.

      *
      *-----------------------------------------------------------------
      *  수행조건 : 프로그램을정상적으로수행후정상종료를함
      *  처리기능 : 처리결과를정상으로MOVE한후종료RTN호출
      *-----------------------------------------------------------------
       S9000-NOMAL-END-RTN.

           MOVE  CO-STAT-OK                    TO DBIO-STAT
           IF      COMM-START-EIO-DSTCD = '9'
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE 999999              TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END OK :'
                           'STAT=' DBIO-STAT    DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF
           GOBACK.
       S9000-NOMAL-END-EXT.
           EXIT.

      *-----------------------------------------------------------------
       Z9900-SQL-ERROR-MSG-RTN.

           IF      NOT (SQLCODE = -805 OR 0 OR  -803 OR 100)
             CALL  'DSNTIAR'    USING    SQLCA
                                         ERROR-MESSAGE
                                         ERROR-TEXT-LEN
             END-CALL

             PERFORM VARYING ERR-IDX FROM 1 BY 1
               UNTIL ERR-IDX > 10
                   MOVE '13'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE 999999              TO   YCFCTLAR-LOG-LINE-NO
                   STRING  ERROR-TEXT(ERR-IDX)   DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
             END-PERFORM
           END-IF
           .
       Z9900-SQL-ERROR-MSG-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *  수행조건 : 프로그램내부에서에러발생시처리함
      *  처리기능 : 에러에관련된정보를XZUGEROR-CA에MOVE후
      *             XZUGEROR을호출하고에러정보를DISPLAY한다.
      *-----------------------------------------------------------------
       Z9900-MSG-ERROR-RTN.

           MOVE  CO-YES                     TO  WK-ERR-SET-YN
           IF    XZUGEROR-I-STAT NOT = CO-STAT-SYSERROR
             MOVE  SQLCODE                  TO   XZUGEROR-I-SQL-CD
                                                 DBIO-SQLCODE
             EVALUATE  SQLCODE
               WHEN  ZERO
                     MOVE  ZERO             TO   XZUGEROR-I-SQL-CD
                     MOVE  CO-STAT-SYSERROR TO   XZUGEROR-I-STAT
               WHEN  +100
                     MOVE  CO-STAT-NOTFOUND TO   XZUGEROR-I-STAT
                     MOVE  CO-NO            TO   WK-ERR-SET-YN
                     INITIALIZE                  DBIO-REC
               WHEN  -803
                     MOVE  CO-STAT-DUPM     TO   XZUGEROR-I-STAT
                     MOVE  CO-NO            TO   WK-ERR-SET-YN
               WHEN  OTHER
                     IF  DBIO-SQLCODE(4:1) = "9" OR DBIO-SQLCODE = -805
                         MOVE CO-STAT-SYSERROR TO   XZUGEROR-I-STAT
                     ELSE
                         MOVE CO-STAT-ERROR TO   XZUGEROR-I-STAT
                     END-IF
                     MOVE  "D9900000"       TO   XZUGEROR-I-ERRCD
                     MOVE  XZUGEROR-I-SQL-CD(2:)
                                            TO   XZUGEROR-I-ERRCD(4:)
                     MOVE  CO-UKLA0002      TO   XZUGEROR-I-TREAT-CD
                     PERFORM Z9900-SQL-ERROR-MSG-RTN
                        THRU Z9900-SQL-ERROR-MSG-EXT
             END-EVALUATE
           END-IF

      *    LOCK SELECT CURSUR CLOSE
           IF    WK-LKSEL-CLOSE-YN = CO-YES
                 PERFORM S8711-LKSEL-CLOSE-RTN
                    THRU S8711-LKSEL-CLOSE-EXT
                 IF      SQLCODE              NOT  =   ZERO
                        #USRLOG "(S8710) CLOSE SELECT_CURSOR SQLCODE : "
                                %08 SQLCODE
                 END-IF
           END-IF
      *
           MOVE  XZUGEROR-I-STAT            TO   DBIO-STAT

           IF   WK-ERR-SET-YN = CO-YES
                 MOVE  YCFCTLAR-PGM-ID      TO   XZUGEROR-I-PGM-ID
                 MOVE  DBIO-CALL-PGM-ID     TO   XZUGEROR-I-TBL-ID
                 MOVE  DBIO-FUNCTION        TO   XZUGEROR-I-FUNC-CD
                 MOVE  'ZUGEROR'            TO   YCFCTLAR-CALL-LOG
                 CALL    YCFCTLAR-CALL-LOG USING YCCOMMON-CA
                                                 XZUGEROR-CA
                 END-CALL
           END-IF
           MOVE    YCFCTLAR-PGM-ID         TO    COMM-LAST-EXE-PGM-NAME
      *
           IF      COMM-START-EIO-DSTCD = '9'
                   MOVE '11'                TO   YCFCTLAR-USR-LOG-CD
                   MOVE 999999              TO   YCFCTLAR-LOG-LINE-NO
                   STRING  'PGM END ER :'
                           'STAT=' XZUGEROR-I-STAT  DELIMITED BY SIZE
                     INTO  YCFCTLAR-LOG-CTNT  POINTER YCFCTLAR-LOG-PTR
                   PERFORM Z9990-USER-LOG-RTN THRU    Z9990-USER-LOG-EXT
           END-IF

           GOBACK
           .
       Z9900-MSG-ERROR-EXT.
           EXIT.
