      *             에 INSERT 하여 기록을 남긴다.
      *-----------------------------------------------------------------
       S8800-IMAGE-INSERT-RTN.
      *PK 영역에 "'" 데이터 존재검증
           MOVE     CORR PK0                TO CVT-PK0.
           INSPECT  CVT-PK0   TALLYING
                    WK-QUOTA-CNT FOR  ALL CO-QUOTA

      *
           IF WK-QUOTA-CNT > ZERO
                   STRING  'PK 영역에 "'
                           CO-QUOTA
                           '" 데이터 존재'  DELIMITED BY SIZE
                     INTO  XZUGEROR-I-MSG
                   #ERROR CO-S9000099 CO-UKLA0002 CO-STAT-SYSERROR
           END-IF
      *
           MOVE  SPACE                      TO   WK-COND-DESC
           STRING
                  'WHERE "그룹회사코드" = '
                         "'" GROUP-CO-CD OF CVT-PK0 "'"
                  '  AND "기준년월" = '
                         "'" BASE-YM OF CVT-PK0 "'"
                  '  AND "보증기관번호" = '
                         "'" GRNTY-INSTI-NO OF CVT-PK0 "'"
                  '  AND "TE보증기관코드" = '
                         "'" T-E-GRNTY-INSTI-CD OF CVT-PK0 "'"

                    DELIMITED BY SIZE       INTO WK-COND-DESC

      *
           EVALUATE  SICOM-OPER-DSTCD
      *
               WHEN  CO-TEMP
                     PERFORM S8810-IMAGE-INSERT-RTN
                        THRU S8810-IMAGE-INSERT-RTN
                 IF  SQLCODE  NOT = ZERO
                   IF SQLCODE   = -803
                     MOVE ZERO              TO    SQLCODE
                   ELSE
                     MOVE   "S8800-TEMP-INSERT-RTN ZSFDBLG "
                                            TO    XZUGEROR-I-MSG
                     MOVE   SQLCODE         TO    XZUGEROR-I-SQL-CD
                     #ERROR CO-S9000099 CO-UKLA0002 CO-STAT-SYSERROR
                   END-IF
                 END-IF
               WHEN  CO-STOP
                     MOVE  DBIO-REC                  TO  WK-CORRECTION
                     PERFORM S8810-IMAGE-INSERT-RTN
                        THRU S8810-IMAGE-INSERT-RTN
                 IF  SQLCODE  NOT = ZERO
                     MOVE   "S8800-STOP-SELECT-RTN ZSFDBLG "
                                            TO    XZUGEROR-I-MSG
                     MOVE   SQLCODE         TO    XZUGEROR-I-SQL-CD
                     #ERROR CO-S9000099 CO-UKLA0002 CO-STAT-SYSERROR
                 END-IF
               WHEN  OTHER
