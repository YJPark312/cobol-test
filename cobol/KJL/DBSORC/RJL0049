           IF  WORK-ERR-SET-YN              =    CONT-Y
           THEN
               IF  (XZUGEROR-I-SQL-CD NOT = ZERO)  AND
                   (XZUGEROR-I-SQL-CD NOT = -805)
               THEN
                   IF  WORK-MSG-GET-FLAG = SPACE
                   THEN
