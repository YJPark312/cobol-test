             TO  WORK-COND-DESC(WORK-STRT-POINT:00029)
           ADD   00029                      TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
           MOVE  LENGTH OF GROUP-CO-CDP0
             TO  WORK-LEN
           MOVE  GROUP-CO-CDP0
             TO  WORK-COND-DESC(WORK-STRT-POINT:WORK-LEN)
           ADD   WORK-LEN                  TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
           MOVE ' AND "기준년월" = '
             TO  WORK-COND-DESC(WORK-STRT-POINT:00022)
           ADD   00022                      TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
           MOVE  LENGTH OF BASE-YMP0
             TO  WORK-LEN
           MOVE  BASE-YMP0
             TO  WORK-COND-DESC(WORK-STRT-POINT:WORK-LEN)
           ADD   WORK-LEN                  TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
           MOVE ' AND "자기자본구분" = '
             TO  WORK-COND-DESC(WORK-STRT-POINT:00028)
