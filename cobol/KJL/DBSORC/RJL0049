           MOVE  LENGTH OF ONCP-DSTCDP0
             TO  WORK-LEN
           MOVE  ONCP-DSTCDP0
             TO  WORK-COND-DESC(WORK-STRT-POINT:WORK-LEN)
           ADD   WORK-LEN                  TO   WORK-STRT-POINT
           MOVE  "'"       TO  WORK-COND-DESC(WORK-STRT-POINT:1)
           ADD   1                          TO   WORK-STRT-POINT
      *

