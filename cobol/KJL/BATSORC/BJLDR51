      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *   삭제대상 - 매일 삭제 후 등록
           EXEC SQL
            DECLARE  KJLR005_DEL_CUR   CURSOR  WITH HOLD FOR
             SELECT  그룹회사코드
                  ,  기준년월일
                  ,  관리부점코드
                  ,  계좌번호
               FROM  DB2DBA.THKJLR005
              WHERE  그룹회사코드           = :WK-H-I-GROUP-CO-CD
                AND  SUBSTR(기준년월일,7,2) = :WK-H-I-BASE-DD
           END-EXEC

210218*   재작업용 삭제대상
           EXEC SQL
            DECLARE  THKJLRM05_DEL_CUR   CURSOR  WITH HOLD FOR
             SELECT  그룹회사코드
                  ,  기준년월
                  ,  관리부점코드
                  ,  계좌번호
               FROM  DB2DBA.THKJLRM05
              WHERE  그룹회사코드  = :WK-H-I-GROUP-CO-CD
                AND  기준년월      = :WK-H-I-BASE-YM
           END-EXEC

           EXEC SQL
            DECLARE  THKJLR005_CUR   CURSOR  WITH HOLD FOR
             SELECT  그룹회사코드
                  ,  SUBSTR(기준년월일,1,6)
                  ,  관리부점코드
                  ,  계좌번호
                  ,  "ISO국가코드"
                  ,  신규년월일
                  ,  만기년월일
                  ,  현지취급통화코드
                  ,  현지한도약정금액
                  ,  현지통화대출잔액
                  ,  계정과목코드
                  ,  계정세과목코드
                  ,  해외점포영업년월일
                  ,  원화환산잔액
                  ,  해외점포계좌구분
                  ,  국제한도구분
                  ,  "USD한도약정금액"
                  ,  "USD대출잔액"
                  ,  통합계정과목코드
                  ,  고객식별자
                  ,  고객관리번호
                  ,  "고객식별자1"
                  ,  "고객관리번호1"
                  ,  "고객식별자2"
                  ,  "고객관리번호2"
                  ,  한도계좌번호
                  ,  지급보증신용장번호
                  ,  대출취급형태구분
                  ,  약정계좌번호
               FROM  DB2DBA.THKJLR005
              WHERE  그룹회사코드  = :WK-H-I-GROUP-CO-CD
                AND  기준년월일    = :WK-H-I-BASE-YMD
           END-EXEC

