      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKJL0037_CUR1    CURSOR WITH HOLD FOR
             SELECT  계열기업군코드
                  ,  SUM("CA담보환산금액")
               FROM  DB2DBA.THKJL0037
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월일   = :WK-H-I-BASE-YMD
           GROUP BY  계열기업군코드
           END-EXEC.

           EXEC SQL
            DECLARE  THKJL0037_CUR2    CURSOR WITH HOLD FOR
             SELECT  기준년월일
                  ,  계열기업군코드
                  ,  한도기업구분
                  ,  회계구분
                  ,  SUM(은행신용공여금액)
                  ,  SUM(금감신용공여금액)
                  ,  SUM(제외대상금액)
               FROM
            (SELECT  A.기준년월일       AS 기준년월일
                  ,  A.계열기업군코드   AS 계열기업군코드
                  ,  '2'                  AS 한도기업구분
                  ,  B."TE회계구분"     AS 회계구분
                  ,  A."BS기준잔액 "    AS 은행신용공여금액
                  ,  A."CA담보환산금액" AS 금감신용공여금액
                  ,  A.제외자산금액     AS 제외대상금액
               FROM  DB2DBA.THKJL0037 A,
180914               DB2DBA.THKJL0118 B
              WHERE  A.그룹회사코드   = :WK-H-I-GROUP-CO-CD
                AND  A.기준년월일     = :WK-H-I-BASE-YMD
                AND  A.계열기업군코드 = :WK-H-I-AFFLT-CORP-GROUP-CD
                AND  B.기준년월       = :WK-H-I-BASE-YM
                AND  A.그룹회사코드   = B.그룹회사코드
                AND  A.상품대분류코드 = B.상품대분류코드
                AND  A.상품중분류코드 = B.상품중분류코드
                AND  A.상품템플릿코드 = B.상품템플릿코드
                AND  A.상품번호       = B.상품번호) CAL1
           GROUP BY  기준년월일
                  ,  계열기업군코드
                  ,  한도기업구분
                  ,  회계구분
           END-EXEC.

           EXEC SQL
            DECLARE  THKJL0033_CUR1    CURSOR WITH HOLD FOR
             SELECT  고객식별자
                  ,  SUM("CA담보환산금액")
               FROM  DB2DBA.THKJL0033
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준일       = :WK-H-I-BASE-DD
                AND  기준년월     = :WK-H-I-BASE-YM
           GROUP BY  고객식별자
           END-EXEC.

           EXEC SQL
            DECLARE  THKJL0033_CUR2    CURSOR WITH HOLD FOR
             SELECT  기준년월일
                  ,  고객식별자
                  ,  한도기업구분
                  ,  회계구분
                  ,  SUM(은행신용공여금액)
                  ,  SUM(금감신용공여금액)
                  ,  SUM(제외대상금액)
               FROM
            (SELECT  A.기준년월 || A.기준일 AS 기준년월일
                  ,  A.고객식별자       AS 고객식별자
                  ,  '1'                  AS 한도기업구분
                  ,  B."TE회계구분"     AS 회계구분
                  ,  A."BS기준잔액 "    AS 은행신용공여금액
                  ,  A."CA담보환산금액" AS 금감신용공여금액
                  ,  A.제외자산금액     AS 제외대상금액
               FROM  DB2DBA.THKJL0033 A
                  ,  DB2DBA.THKJL0118 B
              WHERE  A.그룹회사코드   = B.그룹회사코드
                AND  A.기준년월       = B.기준년월
                AND  A.그룹회사코드   = :WK-H-I-GROUP-CO-CD
                AND  A.기준일         = :WK-H-I-BASE-DD
                AND  A.기준년월       = :WK-H-I-BASE-YM
                AND  A.고객식별자     = :WK-H-I-CUST-IDNFR
                AND  A.그룹회사코드   = B.그룹회사코드
                AND  A.상품대분류코드 = B.상품대분류코드
                AND  A.상품중분류코드 = B.상품중분류코드
                AND  A.상품템플릿코드 = B.상품템플릿코드
                AND  A.상품번호       = B.상품번호) CAL2
           GROUP BY  기준년월일
                  ,  고객식별자
                  ,  한도기업구분
                  ,  회계구분
           END-EXEC.
