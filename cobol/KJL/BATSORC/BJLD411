      *-----------------------------------------------------------------
       S3000-KJL0049-SELECT-RTN.

           INITIALIZE    TKJL0049-KEY
                         TRJL0049-REC

      *    경영지표　자기자본기준금액　산출
           EXEC SQL
             SELECT  기준년월
                  ,  자기자본기준금액
               INTO  :RJL0049-BASE-YM
                  ,  :RJL0049-ONCP-BSAMT
               FROM  DB2DBA.THKJL0049
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월     = :WK-H-I-BASE-YM
                AND  자기자본구분 = '4'
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
      *              경영지표자기자본 *0.1
                     COMPUTE  WK-ONCP-BSAMT
                           =  RJL0049-ONCP-BSAMT
                           *  0.1
               WHEN  CO-NOT-FOUND
                     MOVE  ZERO        TO  WK-ONCP-BSAMT
               WHEN  OTHER
                     MOVE 'KJL0049'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
      *에러메시지:내부 본 처리
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
