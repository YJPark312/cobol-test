           PERFORM  UNTIL  EOF-Y

                    PERFORM  S3300-DATA-MOVE-RTN
                       THRU  S3300-DATA-MOVE-EXT

      ****************************************
      *통화한도금금액，통화금일금액        *
      * B/S 　잔액（매매기준적용）         *
      *명목액기준한도,명목액기준잔액     *
      ****************************************
                    IF  RJL0025-CRNCY-CLAM        = ZERO AND
                        RJL0025-CRNCY-BAL         = ZERO AND
                        RJL0025-BS-BASE-BAL       = ZERO AND
                        RJL0025-TTL-AMT-BASE-CLAM = ZERO AND
                        RJL0025-TTL-AMT-BASE-BAL  = ZERO
                    THEN
                         ADD   CO-NUM-1    TO  WK-AC-SKIP-CNT
                    ELSE
                        IF  WK-H-O-GUBUN  = 'AA'
                        THEN
                             ADD   CO-NUM-1    TO  WK-AC-SKIP-CNT
                        ELSE
                            PERFORM  S3400-DATA-WRITE-RTN
                               THRU  S3400-DATA-WRITE-EXT
                        END-IF
                    END-IF

                    PERFORM  S3200-KHC0401-FETCH-RTN
                       THRU  S3200-KHC0401-FETCH-EXT
           END-PERFORM

           PERFORM  S3500-KHC0401-CLOSE-RTN
              THRU  S3500-KHC0401-CLOSE-EXT
           .
       S3000-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR OPEN
      *-----------------------------------------------------------------
       S3100-KHC0401-OPEN-RTN.

           INITIALIZE    WK-SWITCHES

           EXEC SQL
               OPEN  THKHC0401_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KHC0401'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'OPEN'       TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR OPEN시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
            END-EVALUATE.
           .
       S3100-KHC0401-OPEN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR FETCH
      *-----------------------------------------------------------------
       S3200-KHC0401-FETCH-RTN.

           INITIALIZE    WK-HOST-OUT

           EXEC SQL
              FETCH  THKHC0401_CUR
               INTO  :WK-HOST-OUT
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     ADD   CO-NUM-1    TO  WK-AC-FETCH-CNT
               WHEN  CO-NOT-FOUND
                     SET   EOF-Y       TO  TRUE
               WHEN  OTHER
                     MOVE 'KHC0401'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR FETCH시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
            END-EVALUATE.
           .
       S3200-KHC0401-FETCH-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   DATA MOVE
      *-----------------------------------------------------------------
       S3300-DATA-MOVE-RTN.

           INITIALIZE    OT-REC

      *    그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  RJL0025-GROUP-CO-CD

      *    계좌번호＝상품대＋상품중＋템플릿＋상번번호＋대출자격구분
           STRING WK-H-O-PRDCT-LAG-CLSFI-CD
                  WK-H-O-PRDCT-MEDM-CLSFI-CD
                  WK-H-O-PRDCT-TMPLT-CD
                  WK-H-O-PRDCT-NO
                  WK-H-O-GUBUN
           DELIMITED BY SIZE INTO  RJL0025-ACNO

      *    기준일
           MOVE  WK-H-I-BASE-DD
             TO  RJL0025-BASE-DD

      *    기준년월
           MOVE  WK-H-I-BASE-YM
             TO  RJL0025-BASE-YM

      *    계좌중복일련번호
           MOVE  CO-NUM-1
             TO  RJL0025-ACN-DUP-SERNO

      *기업（수요자금융）
           EVALUATE  WK-PRDCT-KEY
      *삼성캐피탈
               WHEN  CO-CHA-11
      *              고객식별자
                     MOVE  CO-IDNFR-NO1
                       TO  RJL0025-CUST-IDNFR
      *              고객관리번호
                     MOVE  CO-CHA-00000
                       TO  RJL0025-CUST-MGT-NO
      *              차주번호
                     MOVE  CO-CORP-NO1
                       TO  RJL0025-BRWR-NO
      *엘지캐피탈
               WHEN  CO-CHA-12
      *              고객식별자
                     MOVE  CO-IDNFR-NO2
                       TO  RJL0025-CUST-IDNFR
      *              고객관리번호
                     MOVE  CO-CHA-00000
                       TO  RJL0025-CUST-MGT-NO
      *              차주번호
                     MOVE  CO-CORP-NO2
                       TO  RJL0025-BRWR-NO
      *현대캐피탈
               WHEN  CO-CHA-13
      *              고객식별자
                     MOVE  CO-IDNFR-NO3
                       TO  RJL0025-CUST-IDNFR
      *              고객관리번호
                     MOVE  CO-CHA-00000
                       TO  RJL0025-CUST-MGT-NO
      *              차주번호
                     MOVE  CO-CORP-NO3
                       TO  RJL0025-BRWR-NO
      *동양파이낸셜＝롯데카드
               WHEN  CO-CHA-14
      *              고객식별자
                     MOVE  CO-IDNFR-NO4
                       TO  RJL0025-CUST-IDNFR
      *              고객관리번호
                     MOVE  CO-CHA-00000
                       TO  RJL0025-CUST-MGT-NO
      *              차주번호
                     MOVE  CO-CORP-NO4
                       TO  RJL0025-BRWR-NO
               WHEN  OTHER
                     CONTINUE
           END-EVALUATE

      *    해외현지법인여부
           MOVE  CO-CHA-0
             TO  RJL0025-OVSES-LCAL-COPR-YN

      *    관리부점코드
           MOVE  SPACE
             TO  RJL0025-MGT-BRNCD

      *    계좌적용구분
           MOVE  CO-CHA-1
             TO  RJL0025-ACN-APLY-DSTCD

      *    한도계좌여부
           MOVE  CO-CHA-0
             TO  RJL0025-LIMT-ACN-YN

      *    상품대분류코드
           MOVE  WK-H-O-PRDCT-LAG-CLSFI-CD
             TO  RJL0025-PRDCT-LAG-CLSFI-CD

      *    상품중분류코드
           MOVE  WK-H-O-PRDCT-MEDM-CLSFI-CD
             TO  RJL0025-PRDCT-MEDM-CLSFI-CD

      *    상품템플릿코드
           MOVE  WK-H-O-PRDCT-TMPLT-CD
             TO  RJL0025-PRDCT-TMPLT-CD

      *    상품번호
           MOVE  WK-H-O-PRDCT-NO
             TO  RJL0025-PRDCT-NO

      *    시작년월일
           MOVE  SPACE
             TO  RJL0025-START-YMD

      *    만기년월일
           MOVE  SPACE
             TO  RJL0025-EXPIR-YMD

      *    종료년월일
           MOVE  SPACE
             TO  RJL0025-END-YMD

      *    상품계약상태구분
           MOVE  CO-CHA-1
             TO  RJL0025-PRDCT-C-STUS-DSTCD

      *    통화코드
           MOVE  CO-CHA-KRW
             TO  RJL0025-CNCYCD

      *    통화한도
           MOVE  WK-H-O-JANNEK
             TO  RJL0025-CRNCY-CLAM

      *    통화잔액
           MOVE  WK-H-O-JANNEK
             TO  RJL0025-CRNCY-BAL

      *    BS기준잔액
           MOVE  WK-H-O-JANNEK
             TO  RJL0025-BS-BASE-BAL

      *    명목액기준한도
           MOVE  WK-H-O-JANNEK
             TO  RJL0025-TTL-AMT-BASE-CLAM

      *    명목액기준잔액
           MOVE  WK-H-O-JANNEK
             TO  RJL0025-TTL-AMT-BASE-BAL

      *    TE한도환산금액
           MOVE  ZERO
             TO  RJL0025-TE-LIMT-AUC

      *    TE잔액환산금액
           MOVE  ZERO
             TO  RJL0025-TE-BAL-AUC

      *    CP한도환산금액
           MOVE  ZERO
             TO  RJL0025-INLS-GRCR-LIMT-AUC

      *    CP잔액환산금액
           MOVE  ZERO
             TO  RJL0025-INLS-GRCR-BAL-AUC

      *    CA담보제외금액
           MOVE  ZERO
             TO  RJL0025-CA-SCURTY-ECLUD-AMT

      *    CA담보환산금액
           MOVE  ZERO
             TO  RJL0025-CA-SCURTY-AUC

      *    관련테이블명
           MOVE  CO-TBL-ID
             TO  RJL0025-RELATD-TBL-NAME

      *    과목코드
           MOVE  CO-CHA-SOO
             TO  RJL0025-SBJCT-CD

      *    시스템최종처리일시
           MOVE  BICOM-TRAN-BASE-YMS
             TO  RJL0025-SYS-LAST-PRCSS-YMS

      *    시스템최종사용자번호
           MOVE  BICOM-USER-EMPID
             TO  RJL0025-SYS-LAST-UNO
           .
       S3300-DATA-MOVE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   DATA WRITE
      *-----------------------------------------------------------------
       S3400-DATA-WRITE-RTN.

           WRITE  OT-REC

           IF  WK-OT-F-ST NOT = CO-STAT-OK
               MOVE 'OT-FILE WRITE ERROR : FILE-ST IS '
                                       TO  XZUGEROR-I-MSG
               MOVE  WK-OT-F-ST        TO  XZUGEROR-I-MSG(34:2)
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

           ADD   CO-NUM-1              TO  WK-AC-WRITE-CNT
           .
       S3400-DATA-WRITE-EXT.
           EXIT.
