      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *  수요자금융관련　개인여신부분
           EXEC SQL
            DECLARE  THKHC0401_CUR     CURSOR FOR
             SELECT  AA.대출자격구분
                  ,  AA.상품대분류코드
                  ,  AA.상품중분류코드
                  ,  AA.상품템플릿코드
                  ,  AA.상품번호
                  ,  SUM(AA.현한도금액)
                  ,  SUM(AA.잔액)
               FROM
            (SELECT (CASE
                     WHEN  A.대출자격구분 = '081' THEN '11'
                     WHEN  A.대출자격구분 = '307' THEN '12'
                     WHEN  A.대출자격구분 = '082' THEN '13'
                     WHEN  A.대출자격구분 = '000' THEN '14'
                     ELSE 'AA'
                     END)   AS 대출자격구분
                  , 'CF'    AS 상품대분류코드
                  , '01'    AS 상품중분류코드
                  , '001'   AS 상품템플릿코드
                  , '00001' AS 상품번호
                  ,  A.한도사용금액 AS 현한도금액
                  ,  A.계약금액 AS 잔액
               FROM  DB2DBA.THKHC0401 A
              WHERE  A.그룹회사코드   = :WK-H-I-GROUP-CO-CD
                AND  A.한도계좌여부   = '0'
                AND (A.상품계약폐기년월일 >= :WK-H-I-BASE-YMD
                 OR  A.상품계약폐기년월일  = ' ')
                AND  A.관리부점코드 NOT IN
                    (SELECT  부점코드
                       FROM  DB2DBA.THKJIBR01
                      WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                        AND  부점구분     = '19')
                AND  A.상품대분류코드  = '25'
                AND  A.상품중분류코드  = '32'
                AND  A.상품템플릿코드  = '113'
                AND  A.상품번호 = '00001'
                AND  A.대출자격구분IN ('081','082','307','000')
                AND  A.상품계약상태구분 <> '3') AA
           GROUP BY  AA.대출자격구분
                  ,  AA.상품대분류코드
                  ,  AA.상품중분류코드
                  ,  AA.상품템플릿코드
                  ,  AA.상품번호
           END-EXEC.
