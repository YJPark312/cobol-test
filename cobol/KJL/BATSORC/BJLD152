      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *  고객유형분류구분
      *  - 1 :개인
      *    3 :법인
      *    5 :임의단체　
      *    6 :해외현지법인
      *    7 :외국기업
      *-----------------------------------------------------------------
130705     EXEC SQL
           DECLARE  KAABPCN_CUR   CURSOR FOR
           SELECT BPCN.법인고객식별자
                 ,BPCN.기업규모구분
                 ,BPCN.표준산업분류코드
                 ,BPCB.고객고유번호구분
                 ,BPCB.고객유형분류구분
                 ,BPCB."고객명1"
                 ,BPCB.관리부점코드
                 ,BPCB."국적ISO국가코드"
             FROM DB2DBA.THKAABPCN BPCN
                 ,DB2DBA.THKAABPCB BPCB
            WHERE BPCN.그룹회사코드     =  BPCB.그룹회사코드
              AND BPCN.법인고객식별자   =  BPCB.고객식별자
              AND BPCN.그룹회사코드     = :WK-H-I-GROUP-CO-CD
              AND BPCB.고객유형분류구분 = '3'
             WITH UR
           END-EXEC.
