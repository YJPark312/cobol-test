      *-----------------------------------------------------------------
      *@  신용평가정보 조회
      *-----------------------------------------------------------------
       S3310-KIIK616-SELECT-RTN.

           EXEC SQL
                SELECT SUBSTR(MAX(CASE WHEN 신용평가구분 IN
                                            ('02','13','15','22')
                                       THEN '1'
                                       ELSE '2'
                                  END                 ||
                                  평가년월일        ||
                                  신용평가보고서번호||
140721                            CASE WHEN 영업신용등급구분 IN
                                            ('    ','0000')
                                       THEN 최종신용등급구분
                                       ELSE 영업신용등급구분
                                  END                 ||
                                  유효년월일),23,4)
                       AS 영업신용등급구분
                      ,SUBSTR(MAX(CASE WHEN 신용평가구분 IN
                                            ('02','13','15','22')
                                       THEN '1'
                                       ELSE '2'
                                  END                 ||
                                  평가년월일        ||
                                  신용평가보고서번호||
140721                            CASE WHEN 영업신용등급구분 IN
                                            ('    ','0000')
                                       THEN 최종신용등급구분
                                       ELSE 영업신용등급구분
                                  END                 ||
                                  유효년월일), 2,8)
                       AS 평가년월일
                      ,SUBSTR(MAX(CASE WHEN 신용평가구분 IN
                                            ('02','13','15','22')
                                       THEN '1'
                                       ELSE '2'
                                  END                 ||
                                  평가년월일        ||
                                  신용평가보고서번호||
140721                            CASE WHEN 영업신용등급구분 IN
                                            ('    ','0000')
                                       THEN 최종신용등급구분
                                       ELSE 영업신용등급구분
                                  END                 ||
                                  유효년월일),27,8)
                       AS 유효년월일
                  INTO :WK-H-O-CJSIDGB
                     , :WK-H-O-PNGADAY
                     , :WK-H-O-UUHODAY
                  FROM DB2DBA.THKIIK616
                 WHERE 그룹회사코드       = :WK-H-I-GROUP-CO-CD
                   AND 심사고객식별자     = :WK-H-O-CUSTSID
                   AND 기업신용등급원천지 = '3'
                   AND 신용평가구분IN ('01','03','04','05',
                                         '06','07','08','09',
                                         '10','11','14','16',
                                         '17','18','19','20','99',
                                         '02','13','15','22')
                 GROUP BY 심사고객식별자
                 WITH  UR
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE '0000'       TO  WK-H-O-CJSIDGB
                     MOVE '00010101'   TO  WK-H-O-PNGADAY
                     MOVE '00010101'   TO  WK-H-O-UUHODAY

               WHEN  OTHER
                     MOVE 'KIIK616'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #USRLOG 'KIIK616 SELECT ERROR KB-PIN :'
                              WK-H-O-CUSTSID
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

           .
       S3310-KIIK616-SELECT-EXT.
           EXIT.


      *-----------------------------------------------------------------
      *@  법인대표자명 조회
      *-----------------------------------------------------------------
       S3320-KAACRER-SELECT-RTN.

           EXEC SQL
                SELECT  BPCB."고객명1"
                  INTO  :WK-H-O-DPJANAM
                  FROM  DB2DBA.THKAACRER  CRER
                       ,DB2DBA.THKAABPCB  BPCB
                 WHERE  CRER.그룹회사코드     =  BPCB.그룹회사코드
                   AND  CRER.그룹회사코드     = :WK-H-I-GROUP-CO-CD
                   AND  CRER.주고객식별자     = :WK-H-O-CUSTSID
                   AND  CRER.부고객식별자     =  BPCB.고객식별자
                   AND  CRER.부고객관리번호   = '00000'
                   AND  CRER.기타관계구분     = '01'
                   AND  CRER.주대표자여부     = '1'
                   AND  CRER.기타관계해제여부 = '0'
                 ORDER  BY  CRER.등록년월일  DESC
                 FETCH  FIRST 1 ROWS ONLY
                  WITH  UR
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  SPACES      TO  WK-H-O-DPJANAM
               WHEN  OTHER
                     MOVE 'KAACRER'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #USRLOG 'KAACRER SELECT ERROR KB-PIN :'
                              WK-H-O-CUSTSID
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

           .
       S3320-KAACRER-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  대표사업자번호 조회
      *-----------------------------------------------------------------
       S3330-KAABPCO-SELECT-RTN.

           EXEC SQL
           SELECT  BPCB.고객고유번호  AS 대표사업자번호
                  ,CASE WHEN BPCO."SPC여부" = '1'
                        THEN BPCO.모기업법인등록번호
                        ELSE ' '
                   END  AS 모기업법인등록번호
             INTO  :WK-H-O-DPSUNUM
                  ,:WK-H-O-MACORNO
             FROM  DB2DBA.THKAABPCO BPCO
                  ,DB2DBA.THKAABPCB BPCB
            WHERE  BPCO.그룹회사코드     =  BPCB.그룹회사코드
              AND  BPCO.고객식별자       =  BPCB.고객식별자
              AND  BPCO.그룹회사코드     = :WK-H-I-GROUP-CO-CD
              AND  BPCO.법인고객식별자   = :WK-H-O-CUSTSID
              AND  BPCO.대표사업자여부   = '1'
            ORDER  BY BPCO.시스템최종처리일시 DESC
            FETCH  FIRST 1 ROWS ONLY
             WITH  UR
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  SPACE      TO  WK-H-O-DPSUNUM
                     MOVE  SPACE      TO  WK-H-O-MACORNO
               WHEN  OTHER
                     MOVE 'KAABPCO'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #USRLOG 'KAABPCO SELECT ERROR KB-PIN :'
                              WK-H-O-CUSTSID
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *모기업법인등록번호 정보가 없을 경우
      *해당 고객식별자를 모기업법인식별자로 처리

           EVALUATE  WK-H-O-MACORNO
               WHEN '0000000000000'
                     MOVE  WK-H-O-CUSTSID
                       TO  WK-H-O-MACUSID
               WHEN  SPACE
                     MOVE  WK-H-O-CUSTSID
                       TO  WK-H-O-MACUSID
               WHEN  OTHER
                     PERFORM  S3340-KAABPCB-SELECT-RTN
                        THRU  S3340-KAABPCB-SELECT-EXT

           END-EVALUATE

               .
       S3330-KAABPCO-SELECT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  모기업법인등록번호의 모기업법인식별자 조회
      *-----------------------------------------------------------------
       S3340-KAABPCB-SELECT-RTN.

           EXEC SQL
                SELECT 고객식별자
                  INTO :WK-H-O-MACUSID
                  FROM  DB2DBA.THKAABPCB  BPCB
                 WHERE  BPCB.그룹회사코드     = :WK-H-I-GROUP-CO-CD
                   AND  BPCB.고객고유번호     = :WK-H-O-MACORNO
                 ORDER  BY 고객식별자 DESC
                 FETCH  FIRST 1 ROWS ONLY
                  WITH  UR
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  WK-H-O-CUSTSID  TO  WK-H-O-MACUSID
               WHEN  OTHER
                     MOVE 'MACUSID'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #USRLOG 'MACUSID SELECT ERROR KB-PIN :'
                              WK-H-O-CUSTSID  '-'  WK-H-O-MACORNO
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3340-KAABPCB-SELECT-EXT.
           EXIT.


