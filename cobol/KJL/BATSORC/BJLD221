             TO  RJL0022-BRWR-NO

      *    차주번호구분
           MOVE  IN-BRWR-NO-DSTCD
             TO  RJL0022-BRWR-NO-DSTCD

      *    카드여신식별자
           MOVE  IN-CARD-LNBZ-IDNFR
             TO  RJL0022-CARD-LNBZ-IDNFR

      *   통합계정과목코드
           MOVE IN-INTGRA-TIACC-CD
             TO RJL0022-INTGRA-TIACC-CD

      *    대출한도
           MOVE  IN-LN-CLAM
             TO  RJL0022-LN-CLAM

      *    총대출잔액
           MOVE  IN-TOTAL-LN-BAL
             TO  RJL0022-TOTAL-LN-BAL

           #DYDBIO  INSERT-CMD-Y TKJL0022-PK TRJL0022-REC

           EVALUATE  TRUE
               WHEN  COND-DBIO-OK
                     ADD   CO-NUM-1    TO  WK-AC-INSERT-CNT
               WHEN  OTHER
                     MOVE 'KJL0022'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'INSERT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  DBIO-SQLCODE
                                       TO  XZUGEROR-I-SQL-CD
                     MOVE 'INSERT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR   CO-EBM02001 CO-UBM02001 DBIO-STAT
                     #OKEXIT CO-CHA-08
           END-EVALUATE


      *    1000 건　마다　 COMMIT
      *    10000건　마다　 USRLOG
           IF  FUNCTION MOD(WK-AC-INSERT-CNT,1000) = CO-NUM-0

               IF  FUNCTION MOD(WK-AC-INSERT-CNT,10000) = CO-NUM-0
                   #USRLOG '* WK-AC-INSERT-CNT  = ' WK-AC-INSERT-CNT
               END-IF

               EXEC SQL
                 COMMIT
               END-EXEC

      * Commit 처리결과 SQL-CODE를 확인하여 정상/오류 처리
               EVALUATE  SQLCODE
                   WHEN  CO-OK
                         CONTINUE
                   WHEN  OTHER
                         MOVE 'KJL0022'    TO  XZUGEROR-I-TBL-ID
                         MOVE 'COMMIT'     TO  XZUGEROR-I-FUNC-CD
