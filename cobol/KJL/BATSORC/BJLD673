           EXIT.
      *-----------------------------------------------------------------
      *@SUB-LIMIT한도초과일／예외적용일　갱신
      *-----------------------------------------------------------------
       S3000-KJL0067-UPDATE-RTN.

      *@1 차주일계좌명세(THKJL0067) LOCK처리
           EXEC SQL
               LOCK TABLE DB2DBA.THKJL0067 IN EXCLUSIVE MODE
           END-EXEC

      *@1 산업별규모별익스포져일집계(THKJL0067) 갱신처리
           EXEC SQL
             UPDATE  DB2DBA.THKJL0067
                SET 한도초과년월일= :WK-H-I-LIMT-YMD
                  , 예외적용년월일= :WK-H-I-ECEPT-YMD
                  , 시스템최종처리일시= CHAR(HEX(CURRENT_TIMESTAMP))
                  , 시스템최종사용자번호= :BICOM-USER-EMPID
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월일   = :WK-H-I-BASE-YMD
                AND  대분류업종코드 = :WK-H-I-LAG-CD
                AND "산업TE기업규모구분" = :WK-H-I-IDSTRY-CD
           END-EXEC

      *@  리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
               WHEN  CO-NOT-FOUND
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJL0067'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'DELETE'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'DELETE시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *@1  COMMIT처리
           EXEC SQL
             COMMIT
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJL0067'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'COMMIT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'DB  Commit시오류가발생했습니다 '
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3000-KJL0067-UPDATE-EXT.
           EXIT.
