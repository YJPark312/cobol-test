           INITIALIZE    WK-ENTP-AVG-INT-RT
                         WK-TMP-AMT

           COMPUTE  WK-TMP-AMT
                 = (IN-GBC-AMT-1 + IN-GBC-AMT) / 2

           IF  WK-TMP-AMT = 0
           THEN
               MOVE  ZERO              TO  WK-ENTP-AVG-INT-RT
           ELSE
                COMPUTE  WK-ENTP-AVG-INT-RT
                      = (IN-IJB-AMT + IN-SJB-AMT)
                      /  WK-TMP-AMT
           END-IF

      *-----------------------------------------------------------------
      *@1 여신성자산기준한도계산
      *@  여신성관리한도= 개별기업TE여신성관리한도
      *@                  - 간접익스포져합계액
      *-----------------------------------------------------------------

      *   초기화
           INITIALIZE    WK-LNBZ-I-ASST-CLAM

           EXEC SQL
             SELECT  VALUE(SUM(T.여신성) -
                           SUM(T.간접금액),0)
               INTO  :WK-LNBZ-I-ASST-CLAM
               FROM  (SELECT   VALUE(여신성관리한도,0) 여신성
                           ,   0 간접금액
                        FROM   DB2DBA.THKJL0011
                       WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                         AND  기준년월     = :WK-H-I-BASE-YM
                         AND  고객식별자   = :WK-CUST-IDNFR
                         AND  관리한도유효년월일>= :WK-H-I-BASE-YMD
                   UNION ALL
                      SELECT   0  여신성
                            ,  VALUE(간접익스포져금액,0) 간접금액
                        FROM   DB2DBA.THKJL0031
                       WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                         AND  기준일       = :WK-H-I-BASE-DD
                         AND  기준년월     = :WK-H-I-BASE-YM
                         AND  담보보증고객식별자 = :WK-CUST-IDNFR) T
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     IF  WK-LNBZ-I-ASST-CLAM <= 0
                         MOVE  ZERO    TO  WK-LNBZ-I-ASST-CLAM
                     END-IF
               WHEN  CO-NOT-FOUND
                     MOVE  ZERO        TO  WK-LNBZ-I-ASST-CLAM
               WHEN  OTHER
                     MOVE 'KJL0011'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
            END-EVALUATE

      *-----------------------------------------------------------------
      *@1 자기자본기준한도계산
      *@  자기자본기준한도= | (자기자본* 2(=자기자본적용비율)
      *@      - (금융비용발생차입금-당행차입금) ￠
      *@      * 신용등급별지원비율
      *@  당행차입금------------------------------------
      *@                2005.03.04신용기획팀　하영규대리
      *@  당행차입금은　계산에서　제외------------------
      *-----------------------------------------------------------------

      *   초기화
           INITIALIZE    WK-ONCP-BSAMT

           COMPUTE  WK-ONCP-BSAMT
                 = ((IN-JGJ-AMT * 2)
                 -  (IN-GBC-AMT - 0))
                 *  IN-GWBY

           IF  WK-ONCP-BSAMT < 0
               MOVE  ZERO
                 TO  WK-ONCP-BSAMT
           END-IF

      *-----------------------------------------------------------------
      *@1 영업활동현금흐름액기준한도액계산
      *@               2005.03.04신용기획팀　하영규대리
      *@ 평균이자율이= 0이면
      *@               개별기업여신성TE관리한도로한다
      *-----------------------------------------------------------------

      *   초기화
           INITIALIZE    WK-BZOPR-A-BASE-CLAM

           IF  WK-ENTP-AVG-INT-RT = 0
               MOVE  WK-LNBZ-I-ASST-CLAM
                 TO  WK-BZOPR-A-BASE-CLAM
           ELSE
               COMPUTE  WK-BZOPR-A-BASE-CLAM
                     = (((IN-YHH-AMT / 1.5) / WK-ENTP-AVG-INT-RT)
                     -   (IN-GBC-AMT - 0))
                     *  IN-GWBY
           END-IF

           IF  WK-BZOPR-A-BASE-CLAM  < 0
               MOVE  ZERO
                 TO  WK-BZOPR-A-BASE-CLAM
           END-IF

      *-----------------------------------------------------------------
      *@1 포괄신용공여한도설정가능액
      *@  MIN|{MAX(자기자본기준한도액,영업활동현금흐름액기준한도)
      *@         * 여신성자산배분비율(80%)},여신성자산기준한도￠
      *-----------------------------------------------------------------

      *   초기화
           INITIALIZE    WK-INLS-STUP-ABLAMT

           COMPUTE  WK-INLS-STUP-ABLAMT
                 =  FUNCTION MIN(
                   (FUNCTION MAX(WK-ONCP-BSAMT
                                 WK-BZOPR-A-BASE-CLAM) * 0.8 )
                                 WK-LNBZ-I-ASST-CLAM )

           IF  WK-INLS-STUP-ABLAMT < 0
               MOVE  ZERO
                 TO  WK-INLS-STUP-ABLAMT
           END-IF
           .
       S3400-HANDO-CALCULATE-EXT.
           EXIT.
