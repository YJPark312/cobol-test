       S3100-READ-FILE-RTN.

           READ  IN-FILE     AT  END
            SET  IN-EOF-Y    TO  TRUE
           END-READ

           EVALUATE  WK-IN-F-ST
               WHEN  ZERO
               WHEN  CO-CHA-04
                     IF  WK-SYSIN-BASE-YMD NOT = IN-BASE-YMD
                         STRING '작업기준일과 자료기준일 '
                                '불일치 오류입니다.'
                         DELIMITED BY SIZE INTO  XZUGEROR-I-MSG
                         #ERROR  CO-EBM02001 CO-UBM02001 WK-IN-F-ST
                         #OKEXIT CO-CHA-08
                     ELSE
                         ADD  CO-NUM-1 TO  WK-AC-READ-CNT
                     END-IF
               WHEN  CO-CHA-10
                     SET   IN-EOF-Y    TO  TRUE
               WHEN  OTHER
                     MOVE 'IN-FILE OPEN ERROR : FILE-ST IS '
                                       TO  XZUGEROR-I-MSG
                     MOVE  WK-IN-F-ST  TO  XZUGEROR-I-MSG(34:2)
                     #ERROR  CO-EBM02001 CO-UBM02001 WK-IN-F-ST
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3100-READ-FILE-EXT.
           EXIT.
