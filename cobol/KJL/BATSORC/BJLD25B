      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *외화채권상품　거래정보
           EXEC SQL
            DECLARE  THKJLR012_CUR     CURSOR FOR
             SELECT  A.외화상품유형구분
                  ,  A.통합트레이드번호
                  ,  B.상품대분류코드
                  ,  B.상품중분류코드
                  ,  B.상품템플릿코드
                  ,  B.상품번호
                  ,  A.발행법인등록번호
                  ,  A.고객식별자
                  ,  A.고객관리번호
                  ,  A.매입년월일
                  ,  A.통화코드
                  ,  A.외화장부금액
                  ,  A.만기년월일
                  ,  A.총외환여신금액
                  ,  A.계약한도구분
                  ,  A.국제한도구분
                  ,  A.관리부점코드
               FROM  DB2DBA.THKJLR012  A
                  ,  DB2DBA.THKJL0018  B
              WHERE  A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  A.기준년월일   = :WK-H-I-BASE-YMD
                AND  B.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  B.기준년월     = :WK-H-I-BASE-YM
                AND  B.상품대분류코드   = 'KT'
                AND  A.계정세과목코드= B.상품템플릿코드
                AND  A.계정과목코드  = B.상품번호
           END-EXEC.
