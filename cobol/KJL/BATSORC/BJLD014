      *-----------------------------------------------------------------
211007*@  그룹기준한도산출
      *-----------------------------------------------------------------
       S3160-HANDO-GROUP-CALU-RTN.

      *-----------------------------------------------------------------
      * 그룹의 경우 영업이익, 이자수익, 총자산, 매출액,
      * 자기자본은 70%로 감액 적용(1개년,3개년 동일)
      *-----------------------------------------------------------------
      *                                                   ----1개년---
211007*   영업이익x0.7
           COMPUTE   WK-YYI-AMT  =  IN-YYI-AMT * 0.7
      *   이자수익x0.7
           COMPUTE   WK-IJS-AMT  =  IN-IJS-AMT * 0.7
      *   총자산x0.7
           COMPUTE   WK-JSC-AMT  =  IN-JSC-AMT * 0.7
      *   매출액x0.7
           COMPUTE   WK-MCA-AMT  =  IN-MCA-AMT * 0.7
      *   자기자본x0.7
           COMPUTE   WK-JJB-AMT  =  IN-JJB-AMT * 0.7

      *   단기차입금상환예상액
           COMPUTE   WK-DCI-AMT
                 =   IN-DCI-AMT * (WK-RPAY-ANTICI-RATO / 100)

      *                                                   ----3개년---

      *   영업이익(3개년) x 0.7
           COMPUTE  WK-YYI-AMT-3
                 =  FUNCTION MEAN(IN-YYI-AMT-2, IN-YYI-AMT-1,
                                  IN-YYI-AMT) * 0.7

      *   이자수익(3개년) x 0.7
           COMPUTE  WK-IJS-AMT-3
                 =  FUNCTION MEAN(IN-IJS-AMT-2, IN-IJS-AMT-1,
                                  IN-IJS-AMT) * 0.7

      *   총자산(3개년) x 0.7
           COMPUTE  WK-JSC-AMT-3
                 =  FUNCTION MEAN(IN-JSC-AMT-2, IN-JSC-AMT-1,
                                  IN-JSC-AMT) * 0.7

      *   매출액(3개년) x 0.7
           COMPUTE  WK-MCA-AMT-3
                 =  FUNCTION MEAN(IN-MCA-AMT-2, IN-MCA-AMT-1,
                                  IN-MCA-AMT) * 0.7

      *   자기자본(3개년)x 0.7
           COMPUTE  WK-JJB-AMT-3
                 =  FUNCTION MEAN(IN-JJB-AMT-2, IN-JJB-AMT-1,
                                  IN-JJB-AMT) * 0.7

      *   감가상각비(3개년)
           COMPUTE  WK-GGS-AMT-3
                 =  FUNCTION MEAN(IN-GGS-AMT-2, IN-GGS-AMT-1,
                                  IN-GGS-AMT)
      *   금융비용(3개년)
           COMPUTE  WK-GBY-AMT-3
                 =  FUNCTION MEAN(IN-GBY-AMT-2, IN-GBY-AMT-1,
                                  IN-GBY-AMT)

      *   총차입금(3개년)
           COMPUTE  WK-UCC-AMT-3
                 =  FUNCTION MEAN(IN-UCC-AMT-2, IN-UCC-AMT-1,
                                  IN-UCC-AMT)


      *   단기차입금상환예상액(3개년)
           COMPUTE  WK-DCI-AMT-3
                 =  FUNCTION MEAN(IN-DCI-AMT-2, IN-DCI-AMT-1,
                                  IN-DCI-AMT)
                 * (WK-RPAY-ANTICI-RATO / 100)

      *-----------------------------------------------------------------
211007*@1 캐쉬클러우기준액계산
      *@  = (((영업이익+수입이자+감가상각비) -
      *@      (금융비용+차입금상환예상액) ) /가중평균이자율)
      *@  가중평균이자율 = 0
      *@  =  ((영업이익+수입이자+감가상각비) -
      *@      (금융비용+차입금상환예상액) )
      *-----------------------------------------------------------------

      *                                                   ----1개년---

           IF  WK-BZTYP-WGHTG-AVG-RT = ZERO
               COMPUTE  WK-CSFW-BSAMT
                     = ((WK-YYI-AMT
                     +   WK-IJS-AMT
                     +   IN-GGS-AMT )
                     -  (IN-GBY-AMT + WK-DCI-AMT))

           ELSE
               COMPUTE  WK-CSFW-BSAMT
                     = (((WK-YYI-AMT
                     +    WK-IJS-AMT
                     +    IN-GGS-AMT )
                     -   (IN-GBY-AMT + WK-DCI-AMT))
                     /  ( WK-BZTYP-WGHTG-AVG-RT / 100))

           END-IF

           IF  WK-CSFW-BSAMT < ZERO
               MOVE  ZERO              TO  WK-CSFW-BSAMT
           END-IF

      *                                                   ----3개년---

           IF  WK-BZTYP-WGHTG-AVG-RT = ZERO
               COMPUTE  WK-CSFW-BSAMT-3
                     = ((WK-YYI-AMT-3
                     +   WK-IJS-AMT-3
                     +   WK-GGS-AMT-3 )
                     -  (WK-GBY-AMT-3 + WK-DCI-AMT-3))

           ELSE
               COMPUTE  WK-CSFW-BSAMT-3
                     = (((WK-YYI-AMT-3
                     +    WK-IJS-AMT-3
                     +    WK-GGS-AMT-3 )
                     -   (WK-GBY-AMT-3 + WK-DCI-AMT-3))
                     /  ( WK-BZTYP-WGHTG-AVG-RT / 100))

           END-IF

           IF  WK-CSFW-BSAMT-3 < ZERO
               MOVE  ZERO              TO  WK-CSFW-BSAMT-3
           END-IF


211007*-----------------------------------------------------------------
      *@1 차입금자기자본비율가중치(차입금자본가중치값)
      *@
      *@  차입금= 0 & 자기자본 >  0
      *@   & 업종평균차입금자기자본율 = 0경우 1
      *@  차입금= 0 & 자기자본 >  0
      *@   & 업종평균차입금자기자본율 > 0경우 1.3
      *@  차입금= 0 & 자기자본 <= 0 인 경우 1
      *@  차입금> 0 & 자기자본 <= 0 인 경우 0.7
      *@  그 외 나머지
      *@  {(업종평균차입금자기자본율)÷(총차입금÷자기자본 )}
      *@  단,  최소 0.7 , 최고 1.3을 넘지 않음
      *-----------------------------------------------------------------

      *                                                   ----1개년---
211029*   총차입금자기자본비율
           IF WK-JJB-AMT = ZERO
               MOVE ZERO
                 TO WK-NEW-AMBR-ONCP-RATO
           ELSE
               COMPUTE  WK-NEW-AMBR-ONCP-RATO
                     =  IN-UCC-AMT / WK-JJB-AMT
           END-IF


           EVALUATE  TRUE
               WHEN  (IN-UCC-AMT = 0  AND  WK-JJB-AMT > 0 )
                         AND WK-AMBR-ONCP-RT = 0
                     MOVE  1.0  TO  WK-AMBR-CAPTL-WGHT-VAL

               WHEN  (IN-UCC-AMT = 0  AND  WK-JJB-AMT > 0 )
                         AND WK-AMBR-ONCP-RT > 0
                     MOVE  1.3  TO  WK-AMBR-CAPTL-WGHT-VAL

               WHEN  (IN-UCC-AMT > 0  AND  WK-JJB-AMT > 0 )
                         AND WK-AMBR-ONCP-RT = 0
                     MOVE  1.0  TO  WK-AMBR-CAPTL-WGHT-VAL

               WHEN  IN-UCC-AMT = 0  AND  WK-JJB-AMT <= 0
                     MOVE  1.0  TO  WK-AMBR-CAPTL-WGHT-VAL

               WHEN  IN-UCC-AMT > 0  AND  WK-JJB-AMT <= 0
                     MOVE  0.7  TO  WK-AMBR-CAPTL-WGHT-VAL

               WHEN  WK-NEW-AMBR-ONCP-RATO = ZERO
                     MOVE  1.3  TO  WK-AMBR-CAPTL-WGHT-VAL

               WHEN  OTHER
                     COMPUTE  WK-AMBR-CAPTL-WGHT-VAL
                     =   FUNCTION MIN(
                         FUNCTION MAX(
                         ((WK-AMBR-ONCP-RT / 100 )
                         / WK-NEW-AMBR-ONCP-RATO)
                         , 0.7000 ), 1.3000 )

           END-EVALUATE

      *                                                   ----3개년---
211029*   총차입금자기자본비율
           IF WK-JJB-AMT-3 = ZERO
               MOVE ZERO
                 TO WK-Y-3N-AMBR-ONCP-RATO
           ELSE
               COMPUTE  WK-Y-3N-AMBR-ONCP-RATO
                     =  WK-UCC-AMT-3 / WK-JJB-AMT-3
           END-IF

           EVALUATE  TRUE
               WHEN  (WK-UCC-AMT-3 = 0  AND  WK-JJB-AMT-3 > 0 )
                         AND WK-AMBR-ONCP-RT = 0
                     MOVE  1.0  TO  WK-Y-3A-CAPTL-WGHT-VAL

               WHEN  (WK-UCC-AMT-3 = 0  AND  WK-JJB-AMT-3 > 0 )
                         AND WK-AMBR-ONCP-RT > 0
                     MOVE  1.3  TO  WK-Y-3A-CAPTL-WGHT-VAL

               WHEN  (WK-UCC-AMT-3 > 0  AND  WK-JJB-AMT-3 > 0 )
                         AND WK-AMBR-ONCP-RT = 0
                     MOVE  1.0  TO  WK-Y-3A-CAPTL-WGHT-VAL

               WHEN  WK-UCC-AMT-3 = 0  AND  WK-JJB-AMT-3 <= 0
                     MOVE  1.0  TO  WK-Y-3A-CAPTL-WGHT-VAL

               WHEN  WK-UCC-AMT-3 > 0  AND  WK-JJB-AMT-3 <= 0
                     MOVE  0.7  TO  WK-Y-3A-CAPTL-WGHT-VAL

               WHEN  WK-Y-3N-AMBR-ONCP-RATO = ZERO
                     MOVE  1.3  TO  WK-Y-3A-CAPTL-WGHT-VAL

               WHEN  OTHER
                     COMPUTE  WK-Y-3A-CAPTL-WGHT-VAL
                     =   FUNCTION MIN(
                         FUNCTION MAX(
                         ((WK-AMBR-ONCP-RT / 100 )
                         / WK-Y-3N-AMBR-ONCP-RATO)
                         , 0.7000 ), 1.3000 )

            END-EVALUATE


211007*-----------------------------------------------------------------
      *@   자기자본기준액 = 자기자본 ×산업분류별자기자본비율
      *@                                 × 차입자본가중치
      *-----------------------------------------------------------------
      *                                                   ----1개년---
           COMPUTE  WK-ONCP-BSAMT
                 =  WK-JJB-AMT    * ( WK-ONCP-I-APLY-RATO / 100 )
                                  *   WK-AMBR-CAPTL-WGHT-VAL

           IF  WK-ONCP-BSAMT < ZERO
               MOVE  ZERO              TO  WK-ONCP-BSAMT
           END-IF

      *                                                   ----3개년---
           COMPUTE  WK-ONCP-BSAMT-3
                 =  WK-JJB-AMT-3  * ( WK-ONCP-I-APLY-RATO / 100 )
                                  *   WK-Y-3A-CAPTL-WGHT-VAL

           IF  WK-ONCP-BSAMT-3 < ZERO
               MOVE  ZERO              TO  WK-ONCP-BSAMT-3
           END-IF

      *---삭제--------------------------------------------------------
      *@1 상환능력기준한도계산
      *@  = MIN(MIN(캐쉬플러우기준액,자기자본기준액)
      *@           *신용등급별지원비율,그룹별최고한도)
      *-----------------------------------------------------------------
      *-----------------------------------------------------------------
      *@1 상환능력기준한도계산
      *@  = MIN((캐쉬플러우기준액X 0.4 + 자기자본기준액X 0.2)
      *@          *신용등급별지원비율),그룹별최고한도)
      *-----------------------------------------------------------------
      *                                                   ----1개년---
           COMPUTE  WK-SOLVN-BASE-CLAM
                 =  FUNCTION MIN((((WK-CSFW-BSAMT * 0.4 ) +
                                   (WK-ONCP-BSAMT * 0.2))
                                   * (WK-SPORT-RATO / 100))
                                  , WK-ONCP-BSAMT-GROUP)

           IF  WK-SOLVN-BASE-CLAM < ZERO
               MOVE  ZERO              TO  WK-SOLVN-BASE-CLAM
           END-IF

      *                                                   ----3개년---
           COMPUTE  WK-SOLVN-BASE-CLAM-3
                 =  FUNCTION MIN((((WK-CSFW-BSAMT-3 * 0.4) +
                                   (WK-ONCP-BSAMT-3 * 0.2))
                                   * (WK-SPORT-RATO / 100))
                                  , WK-ONCP-BSAMT-GROUP)

           IF  WK-SOLVN-BASE-CLAM-3 < ZERO
               MOVE  ZERO              TO  WK-SOLVN-BASE-CLAM
           END-IF


211007*-----------------------------------------------------------------
      *@1 매출가중치 (1개년, 3개년 동일)
      *@   3년 평균 매출액 *0.7  = 0 인 경우 0.7
      *@   나머지 3년평균매출액비율=당기매출액/ 3년평균매출액
      *@   단,  최소 0.7 , 최고 1.3을 넘지 않음
      *-----------------------------------------------------------------
      *                                                 ----1/3개년---

      *@   매출액가중치
           IF  WK-MCA-AMT-3 = ZERO
               MOVE  0.7      TO  WK-ASALE-WGHT-VAL
           ELSE

               COMPUTE  WK-ASALE-WGHT-VAL
                     =  FUNCTION MIN(
                        FUNCTION MAX(
                        ( WK-MCA-AMT / WK-MCA-AMT-3 )
                        , 0.7000 ), 1.3000 )

               COMPUTE  WK-Y-3-AVG-SALEPR-RATO
                     =  FUNCTION MIN(
                        FUNCTION MAX(
                        ( WK-MCA-AMT / WK-MCA-AMT-3 )
                        , 0.7000 ), 1.3000 )
           END-IF

211007*----------------------------------------------------------------
      *@  매출액기준액
      *@   = 매출액 × 산업분류별매출액비율 × 매출가중치
      *@  매출액기준액이 마이너스인 경우 '0' 적용
      *-----------------------------------------------------------------
      *                                                   ----1개년---
           COMPUTE  WK-ASALE-BSAMT  =  WK-MCA-AMT
                                    * (WK-SALEPR-I-APLY-RATO / 100)
                                    *  WK-ASALE-WGHT-VAL

           IF  WK-ASALE-BSAMT < ZERO
               MOVE  ZERO              TO  WK-ASALE-BSAMT
           END-IF

      *                                                   ----3개년---
           COMPUTE  WK-Y-3-ASALE-BSAMT =  WK-MCA-AMT-3
                                    *  (WK-SALEPR-I-APLY-RATO / 100)
                                    *  WK-ASALE-WGHT-VAL

           IF  WK-Y-3-ASALE-BSAMT < ZERO
               MOVE  ZERO              TO  WK-Y-3-ASALE-BSAMT
           END-IF

211007*-----------------------------------------------------------------
      *@  차입금총자산비율가중치
      *@  업체총차입금= 0 & 총자산 > 0
      *@   & 업종평균차입금총자산비율=0 경우 1
      *@  업체총차입금= 0 & 총자산 >
      *@   & 업종평균차입금총자산비율> 0경우 1.3
      *@  업체총차입금= 0 & 총자산 <= 0 경우 1
      *@  업체총차입금> 0 & 총자산 <= 0 경우 0.7
      *@  그 외 나머지
      *@  {업종평균차입금총자산비율÷(업체총차입금÷총자산)}
      *@  단,  최소 0.7 , 최고 1.3을 넘지 않음
      *-----------------------------------------------------------------
      *                                                   ----1개년---
211029*   총차입금총자산비율
           IF WK-JSC-AMT = ZERO
               MOVE ZERO
                 TO WK-NEW-AT-ASST-RATO
           ELSE
               COMPUTE  WK-NEW-AT-ASST-RATO
                     =  IN-UCC-AMT / WK-JSC-AMT
           END-IF

           EVALUATE  TRUE
               WHEN  (IN-UCC-AMT = 0  AND  WK-JSC-AMT >  0)
                         AND WK-AMBR-T-ASST-RATO = 0
                     MOVE  1.0  TO  WK-BRRW-AR-WGHT-VAL

               WHEN  (IN-UCC-AMT = 0  AND  WK-JSC-AMT >  0)
                         AND WK-AMBR-T-ASST-RATO > 0
                     MOVE  1.3  TO  WK-BRRW-AR-WGHT-VAL

               WHEN  (IN-UCC-AMT > 0  AND  WK-JSC-AMT >  0)
                         AND WK-AMBR-T-ASST-RATO = 0
                     MOVE  1.0  TO  WK-BRRW-AR-WGHT-VAL

               WHEN  IN-UCC-AMT = 0   AND  WK-JSC-AMT <= 0
                     MOVE  1.0  TO  WK-BRRW-AR-WGHT-VAL

               WHEN  IN-UCC-AMT > 0   AND  WK-JSC-AMT <= 0
                     MOVE  0.7  TO  WK-BRRW-AR-WGHT-VAL

               WHEN  WK-NEW-AT-ASST-RATO = ZERO
                     MOVE  1.3  TO  WK-BRRW-AR-WGHT-VAL

               WHEN  OTHER
                     COMPUTE  WK-BRRW-AR-WGHT-VAL
                     =  FUNCTION MIN(
                        FUNCTION MAX(
                        ((WK-AMBR-T-ASST-RATO / 100)
                        / WK-NEW-AT-ASST-RATO)
                        , 0.7000 ), 1.3000 )

           END-EVALUATE

      *                                                   ----3개년---
211029*    Y3총차입금총자산비율
           IF WK-JSC-AMT-3 = ZERO
               MOVE ZERO
                 TO WK-Y-3NAT-ASST-RATO
           ELSE
               COMPUTE  WK-Y-3NAT-ASST-RATO
                     =  WK-UCC-AMT-3 / WK-JSC-AMT-3
           END-IF

           EVALUATE  TRUE
               WHEN  (WK-UCC-AMT-3 = 0 ) AND  (WK-JSC-AMT-3 > 0 )
                         AND WK-AMBR-T-ASST-RATO = 0
                     MOVE  1.0  TO  WK-Y-3BA-RATO-WGHT-VAL

               WHEN  (WK-UCC-AMT-3 = 0 ) AND  (WK-JSC-AMT-3 > 0 )
                         AND WK-AMBR-T-ASST-RATO > 0
                     MOVE  1.3  TO  WK-Y-3BA-RATO-WGHT-VAL

               WHEN  (WK-UCC-AMT-3 > 0 ) AND  (WK-JSC-AMT-3 > 0 )
                         AND WK-AMBR-T-ASST-RATO = 0
                     MOVE  1.0  TO  WK-Y-3BA-RATO-WGHT-VAL

               WHEN  (WK-UCC-AMT-3 = 0 ) AND  (WK-JSC-AMT-3 <= 0 )
                     MOVE  1.0  TO  WK-Y-3BA-RATO-WGHT-VAL

               WHEN  (WK-UCC-AMT-3 > 0 ) AND  (WK-JSC-AMT-3 <= 0 )
                     MOVE  0.7  TO  WK-Y-3BA-RATO-WGHT-VAL

               WHEN  WK-Y-3NAT-ASST-RATO = ZERO
                     MOVE  1.3  TO  WK-Y-3BA-RATO-WGHT-VAL

               WHEN  OTHER
                     COMPUTE  WK-Y-3BA-RATO-WGHT-VAL
                     =  FUNCTION MIN(
                        FUNCTION MAX(
                        ((WK-AMBR-T-ASST-RATO / 100)
                        / WK-Y-3NAT-ASST-RATO)
                        , 0.7000 ), 1.3000 )

           END-EVALUATE

211007*-----------------------------------------------------------------
      *@  자산기준액 = 총자산 × 산업분류별총자산비율
      *@              × 차입자산가중치
      *@  자산기준액이 마이너스인 경우 '0' 적용
      *-----------------------------------------------------------------
      *                                                   ----1개년---
           COMPUTE  WK-ASST-BSAMT
                 =  WK-JSC-AMT
                 * (WK-TOTAL-AI-APLY-RATO / 100 )
                 *  WK-BRRW-AR-WGHT-VAL

           IF  WK-ASST-BSAMT < ZERO
               MOVE  ZERO        TO  WK-ASST-BSAMT
           END-IF

      *                                                   ----3개년---
           COMPUTE  WK-Y-3-ASST-BSAMT
                 =  WK-JSC-AMT-3
                 * (WK-TOTAL-AI-APLY-RATO / 100 )
                 *  WK-Y-3BA-RATO-WGHT-VAL

           IF  WK-Y-3-ASST-BSAMT < ZERO
               MOVE  ZERO        TO  WK-Y-3-ASST-BSAMT
           END-IF


211007*-----------------------------------------------------------------
      *@  규모기준한도 = {(매출액기준액×0.1) + (자산기준액×0.3)}
      *@               × 신용등급지원비율
      *@  규모기준한도가 마이너스인 경우는 '0'을 적용하고,
      *@  그룹최고한도를 초과할 수 없음
      *-----------------------------------------------------------------
      *                                                   ----1개년---
           COMPUTE  WK-SCAL-BASE-CLAM
           =  FUNCTION MIN(
              ((WK-ASALE-BSAMT * 0.1) + (WK-ASST-BSAMT * 0.3))
              *  (WK-SPORT-RATO / 100), WK-ONCP-BSAMT-GROUP )

           IF  WK-SCAL-BASE-CLAM < ZERO
               MOVE  ZERO        TO  WK-SCAL-BASE-CLAM
           END-IF

      *                                                   ----3개년---
           COMPUTE  WK-SCAL-BASE-CLAM-3
           =  FUNCTION MIN(
              ((WK-Y-3-ASALE-BSAMT * 0.1) + (WK-Y-3-ASST-BSAMT * 0.3))
              *  (WK-SPORT-RATO / 100), WK-ONCP-BSAMT-GROUP )

           IF  WK-SCAL-BASE-CLAM-3 < ZERO
               MOVE  ZERO        TO  WK-SCAL-BASE-CLAM-3
           END-IF

      *-----------------------------------------------------------------
      *@1 기준한도계산
      *@   = 상환능력기준한도 + 규모기준한도
      *@  그룹최고한도를 초과할 수 없음
      *-----------------------------------------------------------------
      *                                                   ----1개년---
           COMPUTE  WK-BASE-CLAM
                 =  FUNCTION MIN(
                    ( WK-SOLVN-BASE-CLAM + WK-SCAL-BASE-CLAM )
                    , WK-ONCP-BSAMT-GROUP )

      *                                                   ----3개년---
           COMPUTE  WK-BASE-CLAM-3
                 =  FUNCTION MIN(
                    ( WK-SOLVN-BASE-CLAM-3 + WK-SCAL-BASE-CLAM-3 )
                    , WK-ONCP-BSAMT-GROUP )

           .
        S3160-HANDO-GROUP-CALU-EXT.
           EXIT.


      *-----------------------------------------------------------------
      *@ 그룹별최고한도조회
      *-----------------------------------------------------------------
       S3200-KJL0049-SELECT-RTN.

      *-----------------------------------------------------------------
      *@1 자기자본기준금액(그룹별최고한도액)조회
      *-----------------------------------------------------------------
      *@2 조건항목:그룹회사코드,기준년월
      *@2 출력항목:자기자본기준금액
      *@2 테이블명:TE자기자본기본(THKJL0049)

      * 자기자본기준금액（그룹별최고한도액）
           EXEC SQL
             SELECT  VALUE(자기자본기준금액, 0)
               INTO  :WK-ONCP-BSAMT-GROUP
               FROM  DB2DBA.THKJL0049
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월     = :WK-H-I-BASE-YM
                AND  자기자본구분 = '1'
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     COMPUTE  WK-ONCP-BSAMT-GROUP
                           =  WK-ONCP-BSAMT-GROUP * 0.25
               WHEN  CO-NOT-FOUND
                     MOVE  ZERO        TO  WK-ONCP-BSAMT-GROUP
               WHEN  OTHER
                     MOVE 'KJL0049'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
            END-EVALUATE
           .
       S3200-KJL0049-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   DATA MOVE
      *-----------------------------------------------------------------
       S3400-DATA-MOVE-RTN.

      *   초기화
           INITIALIZE    OT-REC

      *@1 출력데이터조립:그룹회사코드,차주번호,기준년월,
      *@업종평균적용년,내부신용평가등급구분,신용평가년월일,
