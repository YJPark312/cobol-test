      *-----------------------------------------------------------------
      *@  신용등급별지원비율/단기차입금상환비율조회
      *-----------------------------------------------------------------
       S3120-KJL0045-SELECT-RTN.

      *-----------------------------------------------------------------
      *@1 신용등급별지원비율/단기차입금상환비율조회
      *-----------------------------------------------------------------
      *@2 조건항목:그룹회사코드,기준년월,한도기업구분,
      *@             내부신용평가등급구분
      *@2 출력항목:지원비율,상환예상비율
      *@2 테이블명:신용등급별가중치(THKJL0045)
           EXEC SQL
             SELECT  VALUE(지원비율,0) , VALUE(상환예상비율,0)
               INTO  :WK-SPORT-RATO
                  ,  :WK-RPAY-ANTICI-RATO
               FROM  DB2DBA.THKJL0045
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월     = :WK-H-I-BASE-YM
                AND  한도기업구분 = '2'
                AND  내부신용평가등급구분= :WK-LAST-CRTDSCD
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE ZERO         TO  WK-SPORT-RATO
                     MOVE ZERO         TO  WK-RPAY-ANTICI-RATO
               WHEN  OTHER
                     MOVE 'KJL0045'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
            END-EVALUATE
           .
       S3120-KJL0045-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  업종가중평균이자율등각종이율산출
      *-----------------------------------------------------------------
       S3130-KJL0047-SELECT-RTN.

      *-----------------------------------------------------------------
      *@1 업종가중평균율,차입금매출액비율,
      *@  차입금자기자본율,차입금총자산비율 조회
      *-----------------------------------------------------------------
      *@2 조건항목:그룹회사코드,기준년월,신표준산업분류코드
      *@2 출력항목:업종가중평균율,차입금매출액비율,
      *@             차입금자기자본율,차입금총자산비율
      *@2 테이블명:표준산업코드목록(THKJL0044),
      *@             한은업종가중치(THKJL0047)
           EXEC SQL
             SELECT  VALUE(B.업종가중평균율,0)
                  ,  VALUE(B.차입금매출액비율,0)
                  ,  VALUE(B.차입금자기자본율,0)
                  ,  VALUE(B.차입금총자산비율,0)
               INTO  :WK-BZTYP-WGHTG-AVG-RT
                  ,  :WK-AMBR-SALEPR-RATO
                  ,  :WK-AMBR-ONCP-RT
                  ,  :WK-AMBR-T-ASST-RATO
               FROM  DB2DBA.THKJL0044 A
                  ,  DB2DBA.THKJL0047 B
              WHERE  A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  A.기준년월     = :WK-H-I-BASE-YM
                AND  A.신표준산업분류코드 = :WK-NEW-SI-CLSFI-CD
                AND  A.그룹회사코드 = B.그룹회사코드
                AND  A.기준년월     = B.기준년월
                AND  A.한은매칭코드 = B.한은매칭코드
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE ZERO         TO  WK-BZTYP-WGHTG-AVG-RT
                     MOVE ZERO         TO  WK-AMBR-SALEPR-RATO
                     MOVE ZERO         TO  WK-AMBR-ONCP-RT
                     MOVE ZERO         TO  WK-AMBR-T-ASST-RATO
               WHEN  OTHER
                     MOVE 'KJL0047'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3130-KJL0047-SELECT-EXT.
           EXIT.

