      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *-----------------------------------------------------------------
      *  THKIE0437 (담보여신　계좌연결　정보)
      *  THKIE0436 (담보설정　정보)
      *  THKIE0434 (담보보증인　정보)
      *@자동대출계좌는　수신계좌번호를　여신계좌번호로　변경
      *
      *  B.보증인고객식별자 ==> 보증인(보증채무)
      *  B.담보고객식별자   ==> 차주  (채무자/피보증)
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKIE0434_CUR     CURSOR FOR
            SELECT B.담보설정번호
                ,  B.보증인고객식별자  AS 담보보증고객식별자
                ,  B.보증인고객번호구분
                ,  B.담보고객식별자
                ,  '' 담보고객구분
                ,  B.담보구분
                ,  A.통화코드
                ,  A.설정금액
                ,  B.보증사유구분
                ,  VALUE((SELECT  관련계좌번호
                            FROM   DB2DBA.THKHC0007
                           WHERE  그룹회사코드 = 'KB0'
                             AND  주계좌번호   = C.담보여신계좌번호
                             AND  상품계약간관계구분= '02'
                             AND  상품계약간상태구분='1'
                             FETCH  FIRST 1 ROW ONLY
                          ),C.담보여신계좌번호) AS 담보여신계좌번호
                , A.담보설정비율구분
            FROM  DB2DBA.THKIE0436 A
               ,  DB2DBA.THKIE0434 B
               ,  DB2DBA.THKIE0437 C
             WHERE A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
               AND A.설정상태구분 = '2'
               AND A.담보형태구분 = '6'
               AND A.담보해지구분 <> '2'
               AND A.그룹회사코드 = B.그룹회사코드
               AND A.담보설정번호 = B.담보설정번호
               AND A.담보고객식별자 = B.담보고객식별자
               AND B.보증인고객번호구분 = '07'
               AND B.담보구분 IN ('001','002',
                   '003','004','005','006',
                   '007','008','009','010','011','012','013')
               AND A.설정금액 > 0
               AND A.그룹회사코드 = C.그룹회사코드
               AND A.담보설정번호 = C.담보설정번호
               AND SUBSTR(B.보증인고객식별자,1,1)
                          NOT IN ('N','*',' ')
               AND NOT EXISTS
                   (SELECT 1
                      FROM DB2DBA.THKJL0127
                     WHERE 그룹회사코드   = C.그룹회사코드
                       AND 기준일         = :WK-H-I-BASE-DD
                       AND 기준년월       = :WK-H-I-BASE-YM
                       AND 차주고객식별자 = B.보증인고객식별자
                       AND 한도계좌번호   = C.담보여신계좌번호)
               WITH UR
           END-EXEC.

