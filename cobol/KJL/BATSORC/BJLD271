           ACCEPT  WK-SYSIN            FROM  SYSIN
           #USRLOG '*--------------------------------------*'
           #USRLOG '* BJLD271 PGM START                    *'
           #USRLOG '*--------------------------------------*'
           #USRLOG '* WK-SYSIN = ' WK-SYSIN

      *    그룹회사코드
           MOVE  WK-SYSIN-GROUP-CD
             TO  BICOM-GROUP-CO-CD

      *    구분코드
           MOVE  WK-SYSIN-JOB-YMD
             TO  BICOM-TRAN-BASE-YMD

      *    공통 UTILITY CALL
           #DYCALL  BJISTDT  YCCOMMON-CA  XBJISTDT-CA
      *    RETURN 정보 확인
           IF  XBJISTDT-R-STAT = ZEROS
      *       정상처리
              CONTINUE
           ELSE
      *       에러처리
              #ERROR   XBJISTDT-R-ERRCD
                       XBJISTDT-R-TREAT-CD
                       XBJISTDT-R-STAT
              #OKEXIT  CO-CHA-08
           END-IF

           PERFORM  S1100-FILE-OPEN-RTN
              THRU  S1100-FILE-OPEN-EXT
           .
       S1000-INITIALIZE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *    사용하는 File을 OPEN 함
      *-----------------------------------------------------------------
       S1100-FILE-OPEN-RTN.

           OPEN OUTPUT OT-FILE

           IF  WK-OT-F-ST NOT = CO-STAT-OK
               MOVE 'OT-FILE OPEN ERROR : FILE-ST IS '
                                      TO  XZUGEROR-I-MSG
               MOVE  WK-OT-F-ST       TO  XZUGEROR-I-MSG(34:2)
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF
           .
       S1100-FILE-OPEN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  입력값검증
      *-----------------------------------------------------------------
       S2000-VALIDATION-RTN.

      *   그룹회사구분코드
           IF  WK-SYSIN-GROUP-CD NOT = CO-CHA-KB0
               MOVE '그룹회사구분코드 오류입니다.'
                                       TO  XZUGEROR-I-MSG
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

      *   작업실행일
           IF  WK-SYSIN-JOB-YMD = SPACE
               MOVE '작업실행일 미입력 오류입니다.'
                                       TO  XZUGEROR-I-MSG
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

      *   작업명
           IF  WK-SYSIN-JOB-NAME = SPACE
               MOVE '작업명 미입력 오류입니다.'
                                       TO  XZUGEROR-I-MSG
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

      *   처리회차
           IF  WK-SYSIN-JOB-SEQ = SPACE
               MOVE '처리회차 미입력 오류입니다.'
                                       TO  XZUGEROR-I-MSG
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

      *   배치작업구분
           IF  WK-SYSIN-BATCH-GB = SPACE
               MOVE '배치작업구분 미입력 오류입니다.'
                                       TO  XZUGEROR-I-MSG
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

      *   작업자ID
           IF  WK-SYSIN-WORK-ID = SPACE
               MOVE '작업자ID 미입력 오류입니다.'
                                       TO  XZUGEROR-I-MSG
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

      *   자료기준년월일
           IF  WK-SYSIN-BASE-YMD = SPACE
               MOVE '자료기준년월일 미입력 오류입니다.'
                                       TO  XZUGEROR-I-MSG
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF
           .
       S2000-VALIDATION-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   SYSIN GET MOVE
      *-----------------------------------------------------------------
       S3000-SYSDATA-MOVE-RTN.

           INITIALIZE    WK-HOST-IN

      *    그룹회사구분코드
           MOVE  WK-SYSIN-GROUP-CD
             TO  WK-H-I-GROUP-CO-CD

      *    기준일
           MOVE  WK-SYSIN-BASE-YMD(7:2)
             TO  WK-H-I-BASE-DD

      *    기준년월
           MOVE  WK-SYSIN-BASE-YMD(1:6)
             TO  WK-H-I-BASE-YM

      *    기준년월일
           MOVE  WK-SYSIN-BASE-YMD
             TO  WK-H-I-BASE-YMD
           .
       S3000-SYSDATA-MOVE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  업무처리
      *-----------------------------------------------------------------
       S3000-PROCESS-RTN.

           PERFORM  S3100-KIE0434-OPEN-RTN
              THRU  S3100-KIE0434-OPEN-EXT

           PERFORM  S3200-KIE0434-FETCH-RTN
              THRU  S3200-KIE0434-FETCH-EXT

           PERFORM  UNTIL  EOF-Y

      *@담보고객구분추출
                    PERFORM  S3300-KAABPCB-SELECT-RTN
                       THRU  S3300-KAABPCB-SELECT-EXT

      *@분할대출여신／그외여신으로　구분하여　여신　추출
                    PERFORM  S3400-SUB-PROCESS-RTN
                       THRU  S3400-SUB-PROCESS-EXT

                    IF  WK-EXIST = CO-CHA-Y
                    THEN
                        PERFORM  S3600-DATA-MOVE-RTN
                           THRU  S3600-DATA-MOVE-EXT

                        PERFORM  S3700-DATA-WRITE-RTN
                           THRU  S3700-DATA-WRITE-EXT

                    ELSE
                        ADD  CO-NUM-1   TO  WK-AC-FE-SKIP-CNT
                    END-IF


                    PERFORM  S3200-KIE0434-FETCH-RTN
                       THRU  S3200-KIE0434-FETCH-EXT

           END-PERFORM

           PERFORM  S3800-KIE0434-CLOSE-RTN
              THRU  S3800-KIE0434-CLOSE-EXT
           .
       S3000-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  업무처리－분할대출여신／그외여신으로　구분하여　여신　추출
      *-----------------------------------------------------------------
       S3400-SUB-PROCESS-RTN.

      *@담보설정번호에　해당하는　여신잔액／약정한도　추출
           MOVE  CO-CHA-N     TO  WK-EXIST

      *@분할대출진행구분　추출
           PERFORM  S3410-KHC0402-SELECT-RTN
              THRU  S3410-KHC0402-SELECT-EXT

           EVALUATE  TRUE
      *@분할대출진행= 'Y' AND분할대출진행중／분할대출이자정산완료
               WHEN  WK-PATIN-LP-YN = CO-CHA-Y AND
                     ( WK-PATIN-LP-STUS-DSTCD = CO-CHA-1 OR
                       WK-PATIN-LP-STUS-DSTCD = CO-CHA-3 )

      *@              한도금액　추출
                      PERFORM  S3420-KHC0401-SELECT-RTN
                         THRU  S3420-KHC0401-SELECT-EXT

      *@              계약금액
                      MOVE  WK-TMP-CNPR-BAL
                        TO  WK-TMP-CNPR

      *@              잔액　추출
                      PERFORM  S3430-KHDM100-SELECT-RTN
                         THRU  S3430-KHDM100-SELECT-EXT

      *@설정금액＝계약금액－실행누계금액＋잔액
                      INITIALIZE  WK-IMSI-AMT
                      COMPUTE  WK-IMSI-AMT
                            =  WK-TMP-CNPR
                            -  WK-TMP-LN-EXE-CUTAMT
                            +  WK-TMP-CNPR-BAL

      *@             설정금액
                      INITIALIZE  WK-TMP-CNPR-BAL
                      MOVE  WK-IMSI-AMT
                        TO  WK-TMP-CNPR-BAL

      *@             명목액원천구분- 4
                      MOVE  'THKHC0402-4'
                        TO  WK-GUBUN

      *@분할대출진행= 'Y' AND분할대출완료／해당무
               WHEN  WK-PATIN-LP-YN = CO-CHA-Y AND
                     ( WK-PATIN-LP-STUS-DSTCD = CO-CHA-0 OR
                       WK-PATIN-LP-STUS-DSTCD = CO-CHA-2 )

      *@              잔액　추출
                      PERFORM  S3430-KHDM100-SELECT-RTN
                         THRU  S3430-KHDM100-SELECT-EXT

      *@             명목액원천구분- 5
                      MOVE  'THKHC0402-5'
                        TO  WK-GUBUN

      *@분할대출진행= 'N'이면
               WHEN  OTHER
      *@              한도금액　추출
                      PERFORM  S3420-KHC0401-SELECT-RTN
                         THRU  S3420-KHC0401-SELECT-EXT

      *@한도성여신이　아니면　잔액　추출
      *@한도성여신현한도금액＝０이면　제외
                      IF  WK-EXIST = CO-CHA-Y
                          IF WK-TMP-CNPR-BAL <= 0
                             MOVE  CO-CHA-N  TO  WK-EXIST
                             ADD   CO-NUM-1  TO  WK-AC-NO-CNT2
                          END-IF
                      ELSE
                           PERFORM  S3430-KHDM100-SELECT-RTN
                              THRU  S3430-KHDM100-SELECT-EXT
                      END-IF
           END-EVALUATE

           .
       S3400-SUB-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR OPEN
      *-----------------------------------------------------------------
       S3100-KIE0434-OPEN-RTN.

           EXEC SQL
               OPEN  THKIE0434_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KIE0434'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'OPEN'       TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR OPEN시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3100-KIE0434-OPEN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR FETCH
      *-----------------------------------------------------------------
       S3200-KIE0434-FETCH-RTN.

           INITIALIZE        WK-AREA
                             WK-GUBUN

           EXEC SQL
              FETCH  THKIE0434_CUR
               INTO  :WK-HOST-OUT
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     ADD   CO-NUM-1    TO  WK-AC-FE-CNT
               WHEN  CO-NOT-FOUND
                     SET   EOF-Y       TO  TRUE
               WHEN  OTHER
                     MOVE 'KIE0434'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR FETCH시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

            IF FUNCTION MOD(WK-AC-FE-CNT, 10000) = CO-NUM-0
               #USRLOG 'WK-AC-FE-CNT : ' WK-AC-FE-CNT
            END-IF
           .
       S3200-KIE0434-FETCH-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  담보고객구분　추출
      *-----------------------------------------------------------------
       S3300-KAABPCB-SELECT-RTN.

      * 담보고객식별자－－＞　담보 고객번호구분 조회
      * 간접 상품중분류 01:개인 02:기업 분류기준

           EXEC SQL
             SELECT  고객고유번호구분
               INTO  :WK-DBTR-DSTCD
               FROM   DB2DBA.THKAABPCB
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  고객식별자   = :WK-H-O-SCURTY-CUST-IDNFR
               WITH   UR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     #USRLOG ' THKAABPCB NOT FND 담보고객식별자: '
                               WK-H-O-SCURTY-CUST-IDNFR
                             '설정번호: ' WK-H-O-SCURTY-STUP-NO
                     MOVE  SPACE       TO  WK-DBTR-DSTCD
               WHEN  OTHER
                     MOVE 'KAABPCB'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT 02 S3300시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3300-KAABPCB-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@ 분할대출진행구분추출
      *-----------------------------------------------------------------
       S3410-KHC0402-SELECT-RTN.

      *입력항목:계좌번호
      *출력항목:분할대출진행구분

           INITIALIZE    WK-PATIN-LP-STUS-DSTCD
                         WK-PATIN-LP-YN

           EXEC SQL
             SELECT 분할대출진행구분
               INTO  :WK-PATIN-LP-STUS-DSTCD
               FROM  DB2DBA.THKHC0402
              WHERE 그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND 계좌번호     = :WK-H-O-SCURTY-LNBZ-ACNO
                AND 상품계약회차 IN
                        ( SELECT  MAX(상품계약회차)
                            FROM  DB2DBA.THKHC0402
                           WHERE 그룹회사코드 = :WK-H-I-GROUP-CO-CD
                             AND 계좌번호= :WK-H-O-SCURTY-LNBZ-ACNO
                             AND 상품계약회차상태구분= '1'
                             AND 분할대출진행구분IN ('1','2','3') )
                AND 상품계약회차상태구분= '1'
                AND 분할대출진행구분IN ('1','2','3')
            END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     IF  WK-PATIN-LP-STUS-DSTCD = '1' OR
                         WK-PATIN-LP-STUS-DSTCD = '3'
      *@분할대출진행구분= '1'(분할대출진행중)
      *@                    '3'(분할대출이자정산완료)
                     THEN
                          ADD  CO-NUM-1
                           TO  WK-KHC0402-OK-CNT1
                     ELSE
      *@분할대출진행구분= '2'(분할대출완료)
                          ADD   CO-NUM-1
                           TO   WK-KHC0402-OK-CNT2
                     END-IF
      *@분할대출여신여부= 'Y'
                     MOVE  CO-CHA-Y    TO  WK-PATIN-LP-YN
               WHEN  CO-NOT-FOUND
                     ADD   CO-NUM-1    TO  WK-KHC0402-NFND-CNT
      *@분할대출여신여부= 'N'
                     MOVE  CO-CHA-N    TO  WK-PATIN-LP-YN
               WHEN  OTHER
                     MOVE 'KHC0402'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3410-KHC0402-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   한도성여신의약정한도금액추출
      *-----------------------------------------------------------------
       S3420-KHC0401-SELECT-RTN.

      *입력항목:계좌번호
      *출력항목:통화코드,계약금액,대출실행누계금액
      *상품대분류：３５（신용보증）４０（기금대출）４５（카드대출）
      *재약정한도계좌구분：＇２＇（구한도）제외

           INITIALIZE    WK-TMP-CNCYCD
                         WK-TMP-CNPR-BAL
                         WK-TMP-LN-EXE-CUTAMT

           IF  WK-PATIN-LP-YN = CO-CHA-Y
                EXEC SQL
                  SELECT   VALUE(통화코드,' ')
                       ,   VALUE(계약금액,0)
                       ,   VALUE(대출실행누계금액,0)
                    INTO  :WK-TMP-CNCYCD
                       ,  :WK-TMP-CNPR-BAL
                       ,  :WK-TMP-LN-EXE-CUTAMT
                    FROM   DB2DBA.THKHC0401
                   WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                     AND  계좌번호     = :WK-H-O-SCURTY-LNBZ-ACNO
                     AND (상품계약폐기년월일 >= :WK-H-I-BASE-YMD
                      OR  상품계약폐기년월일  = ' ')
                     AND  상품대분류코드 NOT IN ('35','40','45')
                     AND  상품계약상태구분   <> '3'
                     AND  재약정한도계좌구분 <> '2'
                     AND  계약금액     > 0
                END-EXEC
           ELSE
                EXEC SQL
                  SELECT   VALUE(통화코드,' ')
                       ,   VALUE(계약금액,0)
                       ,   VALUE(대출실행누계금액,0)
                    INTO  :WK-TMP-CNCYCD
                       ,  :WK-TMP-CNPR-BAL
                       ,  :WK-TMP-LN-EXE-CUTAMT
                    FROM   DB2DBA.THKHC0401
                   WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                     AND  계좌번호     = :WK-H-O-SCURTY-LNBZ-ACNO
                     AND  한도계좌여부 = '1'
                     AND (상품계약폐기년월일 >= :WK-H-I-BASE-YMD
                      OR  상품계약폐기년월일  = ' ')
                     AND  상품대분류코드 NOT IN ('35','40','45')
                     AND  상품계약상태구분   <> '3'
                     AND  재약정한도계좌구분 <> '2'
                     AND  계약금액     > 0
                END-EXEC
           END-IF

           EVALUATE  SQLCODE
               WHEN  CO-OK
      *명목액원천구분－２：현한도금액
                     MOVE 'THKHC0401-2'
                       TO  WK-GUBUN
                     MOVE  CO-CHA-Y    TO  WK-EXIST
                     ADD   CO-NUM-1    TO  WK-AC-OK-CNT1
               WHEN  CO-NOT-FOUND
                     MOVE  CO-CHA-N    TO  WK-EXIST
                     ADD   CO-NUM-1    TO  WK-AC-NO-CNT1
               WHEN  OTHER
                     MOVE 'KHC0401'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT S3400시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3420-KHC0401-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   여신계좌의잔액추출
      *-----------------------------------------------------------------
       S3430-KHDM100-SELECT-RTN.

           INITIALIZE    WK-TMP-CNCYCD
                         WK-TMP-CNPR-BAL

      *입력항목:계좌번호
      *출력항목:통화코드,잔액
      *과목코드:２９（기금대출）
           EXEC SQL
             SELECT   VALUE(통화코드,' ')
                  ,   VALUE(잔액,0)
               INTO  :WK-TMP-CNCYCD
                  ,  :WK-TMP-CNPR-BAL
               FROM  DB2DBA.THKHDM100
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  계좌번호     = :WK-H-O-SCURTY-LNBZ-ACNO
                AND  과목코드 NOT IN ('029')
                AND  SUBSTR(금액유형코드,1,2) IN ('41','91')
                AND  잔액         > 0
            END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
      *명목액원천구분－３：대출잔액
                     MOVE 'THKHDM100-3'
                       TO  WK-GUBUN
                     MOVE  CO-CHA-Y    TO  WK-EXIST
                     ADD   CO-NUM-1    TO  WK-AC-OK-CNT2
               WHEN  CO-NOT-FOUND
                     MOVE  CO-CHA-N    TO  WK-EXIST
