210218*   РчРлОїПы ЛшСІДыЛѓ
           EXEC SQL
            DECLARE  THKJL0033_DEL_CUR   CURSOR  WITH HOLD FOR
             SELECT  БзЗьШИЛчФкЕх
                  ,  БтСиРЯ
                  ,  БтСиГтПљ
                  ,  АэАДНФКАРк
                  ,  ЛѓЧАДыКаЗљФкЕх
                  ,  ЛѓЧАСпКаЗљФкЕх
                  ,  ЛѓЧАХлЧУИДФкЕх
                  ,  ЛѓЧАЙјШЃ
               FROM  DB2DBA.THKJL0033
              WHERE  БзЗьШИЛчФкЕх = :WK-H-I-GROUP-CO-CD
                AND  БтСиРЯ       = :WK-H-I-BASE-DD
           END-EXEC

            EXEC SQL
            DECLARE  THKJL0125_CUR   CURSOR  WITH HOLD FOR
             SELECT  AA.БтСиГтПљ
                  ,  AA.БтСиРЯ
                  ,  VALUE( AA.АэАДНФКАРк,'----------') АэАДНФКАРк
                  ,  AA.ЛѓЧАДыКаЗљФкЕх
                  ,  AA.ЛѓЧАСпКаЗљФкЕх
                  ,  AA.ЛѓЧАХлЧУИДФкЕх
                  ,  AA.ЛѓЧАЙјШЃ
                  ,  SUM(AA."BSБтСиРмОз")
                  ,  SUM(AA."CAДуКИШЏЛъБнОз")
                  ,  SUM(AA.СІПмРкЛъБнОз)
               FROM  (
             SELECT  A.БтСиГтПљ
                  ,  A.БтСиРЯ
                  ,  A.АэАДНФКАРк
                  ,  A.ЛѓЧАДыКаЗљФкЕх
                  ,  A.ЛѓЧАСпКаЗљФкЕх
                  ,  A.ЛѓЧАХлЧУИДФкЕх
                  ,  A.ЛѓЧАЙјШЃ
                  ,  A."BSБтСиРмОз"
                  ,  A."CAДуКИШЏЛъБнОз"
                  , (CASE
                     WHEN C."CAДыЛѓАшСЄПЉКЮ" = '1'
                     THEN A."BSБтСиРмОз" - A."CAДуКИШЏЛъБнОз"
                     ELSE 0
                     END) AS СІПмРкЛъБнОз
               FROM  DB2DBA.THKJL0125 A
180914            ,  DB2DBA.THKJL0118 C
              WHERE  A.БзЗьШИЛчФкЕх  = :WK-H-I-GROUP-CO-CD
                AND  A.БтСиРЯ        = :WK-H-I-BASE-DD
                AND  A.БтСиГтПљ      = :WK-H-I-BASE-YM
                AND  A.АэАДНФКАРк
                     NOT IN ( '----------','==========',
                              '          ','**********',
                              '$$$$$$$$$$')
                AND  A."TEАшСТАэАДБИКа"  IN ('1','2')
                AND  A.БзЗьШИЛчФкЕх   = C.БзЗьШИЛчФкЕх
                AND  A.БтСиГтПљ       = C.БтСиГтПљ
                AND  A.ЛѓЧАДыКаЗљФкЕх = C.ЛѓЧАДыКаЗљФкЕх
                AND  A.ЛѓЧАСпКаЗљФкЕх = C.ЛѓЧАСпКаЗљФкЕх
                AND  A.ЛѓЧАХлЧУИДФкЕх = C.ЛѓЧАХлЧУИДФкЕх
                AND  A.ЛѓЧАЙјШЃ       = C.ЛѓЧАЙјШЃ
                  )  AA
           GROUP BY  AA.БтСиГтПљ
                  ,  AA.БтСиРЯ
                  ,  AA.АэАДНФКАРк
                  ,  AA.ЛѓЧАДыКаЗљФкЕх
                  ,  AA.ЛѓЧАСпКаЗљФкЕх
                  ,  AA.ЛѓЧАХлЧУИДФкЕх
                  ,  AA.ЛѓЧАЙјШЃ
           END-EXEC.

