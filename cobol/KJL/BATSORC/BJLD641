      *-----------------------------------------------------------------
      *@   SUB-LIMIT－부동산PF잔액　추출
      *-----------------------------------------------------------------
       S4100-KIBG030-SELECT-RTN.

           INITIALIZE   WK-SUB-PF-BAL

           EXEC SQL
             SELECT VALUE(SUM(대출잔액),0)
               INTO :WK-SUB-PF-BAL
               FROM (
                     SELECT B.대출잔액
                     FROM  DB2DBA.THKIBG030 A
                         , DB2DBA.THKIBG031 B
                     WHERE A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                     AND   A.사업장코드 > ' '
                     AND   A.사업장관리계정구분= '3'
                     AND   A.승인번호여부   = '1'
                     AND   A.그룹회사코드   = B.그룹회사코드
                     AND   A.사업장승인번호 = B.사업장승인번호
                     UNION ALL
                     SELECT B.대출잔액
                     FROM  DB2DBA.THKIBG030 A
                         , DB2DBA.THKIBG031 B
                     WHERE A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                     AND   A.사업장코드   > ' '
                     AND   A.사업장관리계정구분= '3'
                     AND   A.승인번호여부    <> '1'
                     AND   A.그룹회사코드     = B.그룹회사코드
                     AND   A.여신사후계좌번호 = B.여신사후계좌번호
                    ) AA
               WITH UR
           END-EXEC

      *@   결과확인
           EVALUATE SQLCODE
               WHEN CO-OK
                    CONTINUE
               WHEN CO-NOT-FOUND
      *       부동산PF잔액
                    MOVE  ZERO        TO  WK-SUB-PF-BAL
               WHEN OTHER
                    MOVE 'KIB0030'    TO  XZUGEROR-I-TBL-ID
                    MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                    MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                    MOVE 'SELECT시 오류가 발생했습니다'
                      TO  XZUGEROR-I-MSG
                    #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                    #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S4100-KIBG030-SELECT-EXT.
           EXIT.
