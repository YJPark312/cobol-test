      *-----------------------------------------------------------------
      *@   SUB-LIMIT추출
      *-----------------------------------------------------------------
       S5000-KJL0063-SELECT-RTN.

           INITIALIZE   WK-SUB-CLAM1
                        WK-SUB-CLAM2
                        WK-SUB-CLAM3

           EXEC SQL
             SELECT VALUE(SUM(CASE WHEN "SUB한도구분" = '1'
                          THEN "SUB한도"
                          ELSE 0 END),0) AS부동산한도
                  , VALUE(SUM(CASE WHEN "SUB한도구분" = '2'
                          THEN "SUB한도"
                          ELSE 0 END),0) AS장외명목액한도
                  , VALUE(SUM(CASE WHEN "SUB한도구분" = '3'
                          THEN "SUB한도"
                          ELSE 0 END),0) AS "장외CE한도"
               INTO :WK-SUB-CLAM1
                  , :WK-SUB-CLAM2
                  , :WK-SUB-CLAM3
               FROM DB2DBA.THKJL0063
              WHERE 그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND 기준년월         = SUBSTR(:WK-H-I-BASE-YMD,1,6)
                AND "SUB한도구분"    IN ('1','2','3')
               WITH UR FETCH FIRST 1 ROWS ONLY
           END-EXEC

      *@   결과확인
           EVALUATE SQLCODE
               WHEN CO-OK
                    CONTINUE
               WHEN CO-NOT-FOUND
