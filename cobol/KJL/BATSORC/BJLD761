      *-----------------------------------------------------------------
      *@  외화지급보증,무역금융,수출금융  구분
      *-----------------------------------------------------------------
       S4300-CASE2-PROCESS-RTN.

           INITIALIZE                   WK-NUM-VAR
                                        WK-UTCNG-RT

      *   원만기구분 1:1년이하 20%, 2:1년초과 상품별CCF
           IF  WK-H-01-ORGL-EXPIR-DSTCD = '1'
               MOVE  20             TO  WK-UTCNG-RT
           ELSE
               MOVE  WK-H-O1-BSL-B-CRDT-UTCNG-RT
                                    TO  WK-UTCNG-RT
           END-IF

      *① 외화지급보증, 무역금융, 수출금융의 경우
           IF  WK-H-O1-TE-MIDL-CLSFI-DSTCD =
                                 ('004' OR '010' OR '011' OR '012')

      *①-1 한도모계좌
               IF  WK-H-O1-CRACT-M-CLSFI-DSTCD = '999'  OR
                   WK-H-O1-LIMT-ACN-YN         = '1'

                   COMPUTE  WK-NUM-VAR
                         =  WK-H-O1-BS-BASE-CLAM
                         -  WK-H-O1-BS-BASE-BAL

                   IF  WK-NUM-VAR < ZERO
                       MOVE  ZERO  TO  WK-NUM-VAR
                   END-IF


                   COMPUTE  WK-BSM-CCF-AUC
                         =  WK-NUM-VAR
                         *  WK-UTCNG-RT / 100

      *①-2, ①-3  자계좌 익스포져 조회
                   PERFORM  S4310-SUB-SELECT-RTN
                      THRU  S4310-SUB-SELECT-EXT

                   COMPUTE  WK-BSM-CCF-AUC
                         =  WK-BSM-CCF-AUC
                         +  WK-SUB-BSM-CCF-AUC

               ELSE

                   COMPUTE  WK-NUM-VAR
                         =  WK-H-O1-BS-BASE-CLAM
                         -  WK-H-O1-BS-BASE-BAL

                   IF  WK-NUM-VAR < 0
                       MOVE  ZERO  TO WK-NUM-VAR
                   END-IF

                   COMPUTE  WK-BSM-CCF-AUC
                         =  WK-H-O1-BS-BASE-BAL
                         + (WK-NUM-VAR
                         *  WK-H-O1-BSL-B-CRDT-UTCNG-RT) / 100

               END-IF

      *② 외화지급보증,무역금융, 수출금융外 일반
      *  (TE중분류구분 NOT IN (004,010,011,012))

           ELSE

      *②-1 한도계좌
               IF  WK-H-O1-LIMT-ACN-YN  = '1'  AND
                   WK-H-O1-TE-ACN-DSTCD = '1'

                   COMPUTE  WK-NUM-VAR
                         =  WK-H-O1-BS-BASE-CLAM
                         -  WK-H-O1-BS-BASE-BAL

                   IF  WK-NUM-VAR < 0
                       MOVE  ZERO  TO WK-NUM-VAR
                   END-IF


                   IF  WK-UTCNG-RT > 0
                       COMPUTE  WK-BSM-CCF-AUC
                             =  WK-NUM-VAR
                             *  WK-UTCNG-RT
                             /  100
                   ELSE
                       MOVE  ZERO  TO  WK-BSM-CCF-AUC
                   END-IF

      *②-2  자계좌 익스포져 조회
      *     자계좌 BS잔액의 합산이기 때문
      *     한도거액익스포져에  합산
                   COMPUTE  WK-BSM-CCF-AUC
                         =  WK-BSM-CCF-AUC
                         +  WK-H-O1-BS-BASE-BAL

               ELSE

                   COMPUTE  WK-NUM-VAR
                         =  WK-H-O1-BS-BASE-CLAM
                         -  WK-H-O1-BS-BASE-BAL

                   IF  WK-NUM-VAR < 0
                       MOVE  ZERO  TO WK-NUM-VAR
                   END-IF

                   COMPUTE  WK-BSM-CCF-AUC
                         =  WK-H-O1-BS-BASE-BAL
                         + (WK-NUM-VAR
                         *  WK-H-O1-BSL-B-CRDT-UTCNG-RT) / 100

               END-IF
           END-IF
