      *-----------------------------------------------------------------
      *@  자계좌 익스포져 산출
      *   원만기구분 1:1년초과-CCF  2:1년이내-20%
      *-----------------------------------------------------------------
       S4310-SUB-SELECT-RTN.

           INITIALIZE                   WK-SUB-BSM-CCF-AUC

           EXEC SQL
             SELECT
               VALUE(
               SUM(
                CASE WHEN  T."CA중분류구분"
                           IN  ('001','003','006','007')
                       THEN  T."BS기준잔액"
                     ELSE
                       CASE
                         WHEN T.원만기구분 = '1'
                           THEN T."BS기준잔액" * 바젤기준신용환산률
                                                    / 100
                         WHEN T.원만기구분 = '2'
                           THEN T."BS기준잔액" * 20 / 100
                       END
                END),0) AS 익스포져
               INTO  :WK-SUB-BSM-CCF-AUC
               FROM (
               SELECT  A.계좌번호
                      ,A."BS기준잔액"
                      ,B.바젤기준신용환산률
                      ,B."TE중분류구분"
                      ,B."CA중분류구분"
                      ,CASE
                         WHEN A.시작년월일 = '' OR
                              A.만기년월일 = ''
                         THEN '1'
                         WHEN A.시작년월일 = '99991231'
                         THEN '2'
                         ELSE
                           CASE
                             WHEN TO_CHAR(TO_DATE(
                                  A.시작년월일,'YYYYMMDD') +
                                  1 YEAR,'YYYYMMDD')
                                  < A.만기년월일
                             THEN '1'
                             ELSE '2'
                           END
                       END AS 원만기구분
                 FROM  DB2DBA.THKJL0125 A
                      ,DB2DBA.THKJL0118 B
                WHERE  A.그룹회사코드   =  B.그룹회사코드
                  AND  A.기준년월       =  B.기준년월
                  AND  A.상품대분류코드 =  B.상품대분류코드
                  AND  A.상품중분류코드 =  B.상품중분류코드
                  AND  A.상품템플릿코드 =  B.상품템플릿코드
                  AND  A.상품번호       =  B.상품번호
                  AND  A.그룹회사코드   = :WK-H-I-GROUP-CO-CD
                  AND  A.기준년월       = :WK-H-I-BASE-YM
                  AND  A.기준일         = :WK-H-I-BASE-DD
                  AND  A.한도계좌번호   = :WK-H-O1-LIMT-ACNO
                  AND  A.한도계좌여부   = '0'
                    ) T
           END-EXEC


      *   리턴코드가 정상이 아니면 에러처리
           IF  SQLCODE  NOT = CO-SQL-OK
               MOVE 'KJL0125'    TO  XZUGEROR-I-TBL-ID
               MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
               MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
               MOVE 'KJL0125 SELECT 오류가 발생했습니다'
                                 TO  XZUGEROR-I-MSG
