           EXEC SQL
            DECLARE  KJL0127_SEL_CUR   CURSOR  WITH HOLD FOR
            SELECT   A.그룹회사코드
                    ,A.기준일
                    ,A.기준년월
                    ,A.차주고객식별자
                    ,A.한도계좌번호
                    ,A.한도상품대분류코드
                    ,A.한도상품중분류코드
                    ,A.한도상품템플릿코드
                    ,A.한도상품번호
                    ,A."BS기준한도"
                    ,A."BS기준잔액"
                    ,B.바젤기준신용환산률
                    ,B."TE중분류구분"
                    ,B."CA중분류구분"
                    ,VALUE((SELECT '1'
                       FROM DB2DBA.THKJL0125
                      WHERE 그룹회사코드 =  A.그룹회사코드
                        AND 기준년월     =  A.기준년월
                        AND 기준일       = :WK-H-I-BASE-DD
                        AND 계좌번호     =  A.한도계좌번호
                        AND 한도계좌여부 = '1'
                       ORDER BY 계좌중복일련번호 DESC
                       FETCH FIRST 1 ROWS ONLY
                        ), '0')
                     AS 한도계좌여부
                    ,VALUE((SELECT 'TE계좌구분'
                       FROM DB2DBA.THKJL0125
                      WHERE 그룹회사코드 =  A.그룹회사코드
                        AND 기준년월     =  A.기준년월
                        AND 기준일       = :WK-H-I-BASE-DD
                        AND 계좌번호     =  A.한도계좌번호
                       ORDER BY 계좌중복일련번호 DESC
                       FETCH FIRST 1 ROWS ONLY
                       ), '0')
                     AS 계좌구분
                    ,VALUE((SELECT CASE
                                   WHEN 시작년월일 = '' OR
                                        만기년월일 = ''
                                        THEN '1'
                                   WHEN 시작년월일 = '99991231'
                                        THEN '2'
                              ELSE
                                   CASE WHEN TO_CHAR(TO_DATE(
                                             시작년월일,'YYYYMMDD')
                                             + 1 YEAR,'YYYYMMDD')
                                             < 만기년월일
                                       THEN '1'
                                       ELSE '2'
                                   END
                              END AS 원만기구분
                              FROM DB2DBA.THKJL0125
                             WHERE 그룹회사코드 =  A.그룹회사코드
                               AND 기준년월     =  A.기준년월
                               AND 기준일       = :WK-H-I-BASE-DD
                               AND 계좌번호     =  A.한도계좌번호
                             ORDER BY 계좌중복일련번호 DESC
                             FETCH FIRST 1 ROWS ONLY
                            ), '0') AS 원만기구분
                    ,B.거액익스포져대상여부
                    ,B.신용익스포져대상여부
              FROM   DB2DBA.THKJL0127 A
                    ,DB2DBA.THKJL0118 B
             WHERE   A.그룹회사코드       =  B.그룹회사코드
               AND   A.기준년월           =  B.기준년월
               AND   A.한도상품대분류코드 =  B.상품대분류코드
               AND   A.한도상품중분류코드 =  B.상품중분류코드
               AND   A.한도상품템플릿코드 =  B.상품템플릿코드
               AND   A.한도상품번호       =  B.상품번호
               AND   A.한도상품번호      <> 'B0001'
               AND   A.그룹회사코드       = :WK-H-I-GROUP-CO-CD
               AND   A.기준년월           = :WK-H-I-BASE-YM
               AND   A.기준일             = :WK-H-I-BASE-DD
               AND   SUBSTR(A.차주고객식별자,1,1) IN ('7','8')
              WITH  UR
           END-EXEC


