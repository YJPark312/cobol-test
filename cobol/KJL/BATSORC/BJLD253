      *-----------------------------------------------------------------
      *@   계약한도　추출작업（계좌한도인경우만）
      *-----------------------------------------------------------------
       S3310-KHC0007-SELECT-RTN.

           INITIALIZE    WK-KHC0007-CNT

      *----------------------------------------------------------------
      *@백현정20100604: 모계좌　관계여부（관계종료년월일）체크　제외
      *@ -외화는　관계종료년월일이　개설시점에　한번INSERT
      *@  변경사항이　발생해도　관계종료년월일은　변경　적용　없음
      *----------------------------------------------------------------
      *@백현정20100630: 계약관계에서　주계좌번호＝관련계좌번호　제외
      *@ -주계좌번호＝관련계좌번호　중에　한도계약관계（＇０１＇）존재
      *@ -외환계좌　중에　일부　발생（제외로직추가）
      *----------------------------------------------------------------

           EXEC SQL
             SELECT  SUM(A.CNT)
               INTO  :WK-KHC0007-CNT
               FROM  (
                       SELECT  COUNT(*) CNT
                         FROM  DB2DBA.THKHC0007
                        WHERE 그룹회사코드 = :WK-H-I-GROUP-CO-CD
                          AND 주계좌번호   = :WK-H-O-ACNO
                          AND 주계좌번호 <> 관련계좌번호
                          AND 상품계약간관계구분 = '01'
                          AND 상품계약간상태구분 = '1'
                  UNION   ALL
                       SELECT  COUNT(*) CNT
                         FROM  DB2DBA.THKHC0007
                        WHERE 그룹회사코드 = :WK-H-I-GROUP-CO-CD
                          AND 주계좌번호 IN  (
                                 SELECT 관련계좌번호
                                   FROM  DB2DBA.THKHC0007
                                  WHERE 그룹회사코드
                                              = :WK-H-I-GROUP-CO-CD
                                    AND 주계좌번호  = :WK-H-O-ACNO
                                    AND 주계좌번호 <> 관련계좌번호
                                    AND 상품계약간관계구분 = '43'
                                    AND 상품계약간상태구분 = '1' )
                          AND 주계좌번호   <> 관련계좌번호
                          AND 상품계약간관계구분 = '01'
                          AND 상품계약간상태구분 = '1'
                     ) A
            END-EXEC


           EVALUATE  SQLCODE
               WHEN  CO-OK
                     IF  WK-KHC0007-CNT > 0
                     THEN
      *                 한도계좌여부
                         MOVE  CO-CHA-1
                           TO  RJL0025-LIMT-ACN-YN
      *                 통화한도＝０
                         MOVE  ZERO
                           TO  RJL0025-CRNCY-CLAM
                         ADD   CO-NUM-1    TO  WK-KHC0007-OK-CNT
                     ELSE
      *                 한도계좌여부
                         MOVE  CO-CHA-0
                           TO  RJL0025-LIMT-ACN-YN
                         ADD   CO-NUM-1    TO  WK-KHC0007-NFND-CNT
                     END-IF
               WHEN  CO-NOT-FOUND
                     #USRLOG ' NOT FND주계좌번호' WK-H-O-ACNO
                     ADD   CO-NUM-1    TO  WK-KHC0007-NFND-CNT
                     MOVE  CO-CHA-0    TO  WK-H-O-LIMT-ACN-YN
               WHEN  OTHER
                     MOVE 'KHC0007'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-KHC0007-SELECT-EXT.
           EXIT.
