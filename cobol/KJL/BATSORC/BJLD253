               WHEN  'THKFF0201'
                     ADD   CO-NUM-1    TO  WK-THKFF0201-CNT
               WHEN  'THKFE0000'
                     ADD   CO-NUM-1    TO  WK-THKFE0000-CNT
               WHEN  'THKFE0010'
                     ADD   CO-NUM-1    TO  WK-THKFE0010-CNT
               WHEN  'THKHC0401'
                     ADD   CO-NUM-1    TO  WK-THKHC0401-CNT
               WHEN  'THKFFA201'
                     ADD   CO-NUM-1    TO  WK-THKFFA201-CNT
               WHEN  'THKFFA101'
                     ADD   CO-NUM-1    TO  WK-THKFFA101-CNT
