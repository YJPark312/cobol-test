               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

      *   자료기준년월일
           IF  WK-SYSIN-BASE-YMD = SPACE
               MOVE '자료기준년월일 미입력 오류입니다.'
                                       TO  XZUGEROR-I-MSG
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

      *   전영업기준년월일
           IF  WK-SYSIN-BEFORE-YMD = SPACE
               MOVE '전영업기준년월일 미입력 오류입니다.'
                                       TO  XZUGEROR-I-MSG
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF
           .
       S2000-VALIDATION-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   SYSIN GET MOVE
      *-----------------------------------------------------------------
       S3000-SYSDATA-MOVE-RTN.

           INITIALIZE    WK-HOST-IN

      *    그룹회사구분코드
           MOVE  WK-SYSIN-GROUP-CD
             TO  WK-H-I-GROUP-CO-CD

      *    기준일
           MOVE  WK-SYSIN-BASE-YMD(7:2)
             TO  WK-H-I-BASE-DD

      *    기준년월
           MOVE  WK-SYSIN-BASE-YMD(1:6)
             TO  WK-H-I-BASE-YM

      *    기준년월일
           MOVE  WK-SYSIN-BASE-YMD
             TO  WK-H-I-BASE-YMD

      *    전영업기준년월일
           MOVE  WK-SYSIN-BEFORE-YMD
             TO  WK-H-I-BEFORE-YMD
           .
       S3000-SYSDATA-MOVE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   업무처리
      *-----------------------------------------------------------------
       S3000-KJL0067-PROCESS-RTN.

           PERFORM  S3100-KJL0067-OPEN-RTN
              THRU  S3100-KJL0067-OPEN-EXT

           PERFORM  S3200-KJL0067-FETCH-RTN
              THRU  S3200-KJL0067-FETCH-EXT

           PERFORM  UNTIL  EOF-Y

      * 한도초과년월일／예외적용년월일　셋팅
                    PERFORM  S3300-PROCESS-SUB-RTN
                       THRU  S3300-PROCESS-SUB-EXT

                    PERFORM  S3200-KJL0067-FETCH-RTN
                       THRU  S3200-KJL0067-FETCH-EXT
           END-PERFORM

           PERFORM  S3600-KJL0067-CLOSE-RTN
              THRU  S3600-KJL0067-CLOSE-EXT
           .
       S3000-KJL0067-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR OPEN
      *-----------------------------------------------------------------
       S3100-KJL0067-OPEN-RTN.

           INITIALIZE    WK-SWITCHES

           EXEC SQL
               OPEN  THKJL0067_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJL0067'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'OPEN'       TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR OPEN시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
            END-EVALUATE
           .
       S3100-KJL0067-OPEN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR FETCH
      *-----------------------------------------------------------------
       S3200-KJL0067-FETCH-RTN.

           INITIALIZE    WK-HOST-OUT

           EXEC SQL
              FETCH  THKJL0067_CUR
               INTO  :WK-HOST-OUT
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     ADD   CO-NUM-1    TO  WK-AC-FE-CNT
               WHEN  CO-NOT-FOUND
                     SET   EOF-Y       TO  TRUE
               WHEN  OTHER
                     MOVE 'KJL0067'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR FETCH시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3200-KJL0067-FETCH-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   업무처리SUB
      *-----------------------------------------------------------------
       S3300-PROCESS-SUB-RTN.

           INITIALIZE    TKJL0067-KEY
                         TRJL0067-REC

      *    그룹회사코드－조립
           MOVE  WK-H-I-GROUP-CO-CD
             TO  KJL0067-PK-GROUP-CO-CD

      *    기준년월일
           MOVE  WK-H-I-BASE-YMD
             TO  KJL0067-PK-BASE-YMD

      *    대분류업종코드
           MOVE  WK-H-O-LAG-CLSFI-BZTYP-CD
             TO  KJL0067-PK-LAG-CLSFI-BZTYP-CD

      *    산업TE기업규모구분
           MOVE  WK-H-O-IDSTRY-TCS-DSTCD
             TO  KJL0067-PK-IDSTRY-TCS-DSTCD

           #DYDBIO  SELECT-CMD-Y  TKJL0067-PK  TRJL0067-REC

           EVALUATE  TRUE
               WHEN  COND-DBIO-OK
                     PERFORM  S3310-KJL0067-UPDATE-RTN
                        THRU  S3310-KJL0067-UPDATE-EXT
               WHEN  COND-DBIO-MRNF
                     ADD   CO-NUM-1    TO  WK-AC-SKP-CNT
                     #USRLOG '대분류업종코드:'
                               WK-H-O-LAG-CLSFI-BZTYP-CD
                     #USRLOG '기업규모구분  :'
                               WK-H-O-IDSTRY-TCS-DSTCD
               WHEN  OTHER
                     MOVE  'KJL0067'   TO  XZUGEROR-I-TBL-ID
                     MOVE  'SELECT  '  TO  XZUGEROR-I-FUNC-CD
                     MOVE  DBIO-SQLCODE
                                       TO  XZUGEROR-I-SQL-CD
                     MOVE  'DB작업시　오류가　발생'
                                       TO  XZUGEROR-I-MSG
      *사용자정의 에러코드 설정(13: DB작업 오류)
      *@DB작업　오류
                     #ERROR  CO-EBM02001 CO-UBM02001 DBIO-STAT
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3300-PROCESS-SUB-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   산업별규모별익스포져일집계(THKJL0067)추가정보　갱신
      *-----------------------------------------------------------------
       S3310-KJL0067-UPDATE-RTN.

      *  한도초과년월일（최초　한도초과년월일　구함）
           PERFORM  S3311-KJL0067-CALL-RTN
              THRU  S3311-KJL0067-CALL-EXT

      *  전영업일기준에　한도초과가　아니면　
      *  한도초과일／예외적용일　구함
           IF WK-LIMT-EXCS-YMD = SPACE
      *      한도초과년월일＝기준년월일
               MOVE  WK-H-I-BASE-YMD
                 TO  RJL0067-LIMT-EXCS-YMD
      *      예외적용년월일（한도초과년월일＋１０영업일）
               PERFORM  S3312-CJIIL03-CALL-RTN
                  THRU  S3312-CJIIL03-CALL-EXT
      *      예외적용년월일
               MOVE  WK-ECEPT-APLY-YMD
                 TO  RJL0067-ECEPT-APLY-YMD
           ELSE
      *      한도초과년월일（전영업일기준의　한도초과년월일로　갱신）
               MOVE  WK-LIMT-EXCS-YMD
                 TO  RJL0067-LIMT-EXCS-YMD
      *      예외적용년월일（전영업일기준의　예외적용년월일로　갱신）
               MOVE  WK-ECEPT-APLY-YMD
                 TO  RJL0067-ECEPT-APLY-YMD
           END-IF

           #DYDBIO  UPDATE-CMD-Y TKJL0067-PK TRJL0067-REC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  TRUE
               WHEN  COND-DBIO-OK
                     ADD   CO-NUM-1    TO  WK-AC-UPT-CNT
               WHEN  OTHER
                     MOVE 'KJL0067'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'UPDATE'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  DBIO-SQLCODE
                                       TO  XZUGEROR-I-SQL-CD
                     MOVE 'UPDATE시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM02001 CO-UBM02001 DBIO-STAT
                     #OKEXIT CO-CHA-08
            END-EVALUATE
           .
       S3310-KJL0067-UPDATE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   한도초과년월일（최초　한도초과년월일　구함）
      *-----------------------------------------------------------------
       S3311-KJL0067-CALL-RTN.

           INITIALIZE    WK-LIMT-EXCS-YMD
                         WK-ECEPT-APLY-YMD

      * 전영업일에　한도초과년월일／예외적용년월일　추출
           EXEC SQL
             SELECT  VALUE(한도초과년월일,' ')
                  ,  VALUE(예외적용년월일,' ')
               INTO  :WK-LIMT-EXCS-YMD
                  ,  :WK-ECEPT-APLY-YMD
               FROM  DB2DBA.THKJL0067
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월일   = :WK-H-I-BEFORE-YMD
                AND  대분류업종코드= :WK-H-O-LAG-CLSFI-BZTYP-CD
                AND "산업TE기업규모구분" = :WK-H-O-IDSTRY-TCS-DSTCD
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
      *      한도초과년월일
                     MOVE  SPACE
                       TO  WK-LIMT-EXCS-YMD
      *      예외적용년월일
                     MOVE  SPACE
                       TO  WK-ECEPT-APLY-YMD
               WHEN  OTHER
                     MOVE 'KJL0067'     TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE      TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                        TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3311-KJL0067-CALL-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   예외적용년월일＝한도초과년월일＋１０영업일자　구하기
      *-----------------------------------------------------------------
       S3312-CJIIL03-CALL-RTN.

      *   초기화
           INITIALIZE    WK-ECEPT-APLY-YMD
                         XCJIIL03-CA

      *@2 입력파라미터 조립
      *@ (그룹회사코드,구분코드:5,기준년월일,일수:10)

      *   그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD    TO  XCJIIL03-I-GROUP-CO-CD
      *   구분코드
           MOVE  CO-CHA-5              TO  XCJIIL03-I-DSTCD
      *   기준년월일
           MOVE  WK-H-I-BASE-YMD       TO  XCJIIL03-I-YMD
      *   일수（기준년월일　기준　１０영업일　이후　일자　구함）
           MOVE  CO-NUM-10             TO  XCJIIL03-I-NODAY-NOMN

      *@2 프로그램호출:전년월일 추출
           #DYCALL   CJIIL03   YCCOMMON-CA   XCJIIL03-CA

      *   리턴코드가 정상이 아니면 에러처리
           IF  XCJIIL03-R-STAT  =  ZEROS
               MOVE  XCJIIL03-O-YMD    TO  WK-ECEPT-APLY-YMD

           ELSE
               #ERROR  XCJIIL03-R-ERRCD
                       XCJIIL03-R-TREAT-CD
                       XCJIIL03-R-STAT
               #OKEXIT CO-CHA-08
           END-IF
           .
       S3312-CJIIL03-CALL-EXT.
           EXIT.
