      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKJL0067_CUR     CURSOR FOR
             SELECT  대분류업종코드
                  , "산업TE기업규모구분"
               FROM  DB2DBA.THKJL0067
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월일   = :WK-H-I-BASE-YMD
                AND  "산업별규모별SUB한도" > 0
                AND  ("산업별규모별SUB한도" -
                      "산업별규모별TE금액" ) < 0
           END-EXEC.
