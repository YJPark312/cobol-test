             TO  RJL0025-CUST-MGT-NO

      *채무고객정보　추출　 SUB CALL
           PERFORM  S7000-SELECT-GOGAKEX-RTN
              THRU  S7000-SELECT-GOGAKEX-EXT
      *-----------------------------------------------------------
      * SUBPGM에서　차주번호／계좌적용구분／해외현지법인여부　추출
      *    차주번호
      *    MOVE  WK-H-O-ISSU-CPRNO
      *      TO  RJL0025-BRWR-NO
      *    계좌적용구분
      *    MOVE  SPACE
      *      TO  RJL0025-ACN-APLY-DSTCD
      *    해외현지법인여부
      *    MOVE  SPACE
      *      TO  RJL0025-OVSES-LCAL-COPR-YN
      *-----------------------------------------------------------

      *   관리부점코드
           MOVE  WK-H-O2-BRNCD
             TO  RJL0025-MGT-BRNCD

      *   한도계좌여부
           MOVE  CO-CHA-0
             TO  RJL0025-LIMT-ACN-YN

      *    상품대분류코드
           MOVE  WK-H-O-PRDCT-LAG-CLSFI-CD
             TO  RJL0025-PRDCT-LAG-CLSFI-CD

      *    상품중분류코드
           MOVE  WK-H-O-PRDCT-MEDM-CLSFI-CD
             TO  RJL0025-PRDCT-MEDM-CLSFI-CD

      *    상품템플릿코드
           MOVE  WK-H-O-PRDCT-TMPLT-CD
             TO  RJL0025-PRDCT-TMPLT-CD

      *    상품번호
           MOVE  WK-H-O-PRDCT-NO
             TO  RJL0025-PRDCT-NO

      *    대출자격구분
           MOVE  SPACE
             TO  RJL0025-LN-QULFI-DSTCD

      *   시작년월일
           MOVE  WK-H-O1-NEW-YMD
             TO  RJL0025-START-YMD

      *   만기년월일
           MOVE  WK-H-O1-EXPIR-YMD
             TO  RJL0025-EXPIR-YMD

      *   종료년월일
           MOVE  SPACE
             TO  RJL0025-END-YMD

      *   상품계약상태구분
           MOVE  CO-CHA-3
             TO  RJL0025-PRDCT-C-STUS-DSTCD

      *   통화코드
           MOVE  WK-H-O1-LCAL-CNCYCD
             TO  RJL0025-CNCYCD

      *-----------------------------------------------------------------
      *--신용환산율은　REFERENCE ENTITY의　내부신용등급에따라　구분
      *-----------------------------------------------------------------
           PERFORM  S3331-KJL0015-SELECT-RTN
              THRU  S3331-KJL0015-SELECT-EXT

      *------- 외화파생상품 CURRENT EXPOSURE 환산율　계산-----------
      *- 환산율적용해서　통화한도금액　산출한다．
      *- 외환매매익금액은　원화환산금액으로　들어있음．　
      *-----------------------------------------------------------------
      *------ 외환매매익금액이　외화통화이면　역환산율적용
      *------ 외환매매익금액이　０보다　작으면　무조건　０으로적용
           IF  WK-H-O1-FX-PFT-AMT > 0 AND
               WK-H-O1-LCAL-CNCYCD NOT = CO-CHA-KRW
      *외환매매익금액　해당통화　역환산
      *--------------외환매매익　역환산할　금액
               MOVE  '2'               TO  WK-GBCD
               MOVE  WK-H-O1-FX-PFT-AMT
                 TO  WK-TMP-AMT

               PERFORM  S8000-BJLTGEX-CALL-RTN
                  THRU  S8000-BJLTGEX-CALL-EXT

      *              외환매매익　역환산　금액
               MOVE  RJL0025-BS-BASE-BAL
                 TO  WK-H-O1-FX-PFT-AMT
           ELSE
           IF  WK-H-O1-FX-PFT-AMT < 0
               MOVE  ZERO              TO  WK-H-O1-FX-PFT-AMT
           END-IF
           END-IF

      *----------통화한도금액　임시변수　저장
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  WK-TMP-AMT

      *@내부신용평가등급= ('AAA','AA+')이면　우량차주
           IF  RJL0015-INTNL-CV-GRD-DSTCD = 'AAA' OR
               RJL0015-INTNL-CV-GRD-DSTCD = 'AA+'

               COMPUTE  WK-H-O1-LCAL-C-LNAMT-AMT
                     =  WK-TMP-AMT
                     *  0.05
                     +  WK-H-O1-FX-PFT-AMT
           ELSE

               COMPUTE  WK-H-O1-LCAL-C-LNAMT-AMT
                     =  WK-TMP-AMT
                     *  0.01
                     +  WK-H-O1-FX-PFT-AMT
           END-IF

      *          통화한도
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  RJL0025-CRNCY-CLAM
      *          통화잔액
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  RJL0025-CRNCY-BAL

      *@통화별　환산
           IF  WK-H-O1-LCAL-CNCYCD = CO-CHA-KRW

      *              명목액기준한도
               MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
                 TO  RJL0025-TTL-AMT-BASE-CLAM

      *              명목액기준잔액
               MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
                 TO  RJL0025-TTL-AMT-BASE-BAL

      *              BS기준잔액
               MOVE  WK-TMP-AMT
                 TO  RJL0025-BS-BASE-BAL

           ELSE

      *통화별　원화환산금액CALCURATER
              MOVE   CO-CHA-1          TO   WK-GBCD

              PERFORM  S8000-BJLTGEX-CALL-RTN
                 THRU  S8000-BJLTGEX-CALL-EXT

           END-IF

      *    TE한도환산금액
           MOVE  ZERO
             TO  RJL0025-TE-LIMT-AUC

      *    TE잔액환산금액
           MOVE  ZERO
             TO  RJL0025-TE-BAL-AUC

      *    CP한도환산금액
           MOVE  ZERO
             TO  RJL0025-INLS-GRCR-LIMT-AUC

      *    CP잔액환산금액
           MOVE  ZERO
             TO  RJL0025-INLS-GRCR-BAL-AUC

      *    CA담보제외금액
           MOVE  ZERO
             TO  RJL0025-CA-SCURTY-ECLUD-AMT

      *    CA담보환산금액
           MOVE  ZERO
             TO  RJL0025-CA-SCURTY-AUC

      *   관련테이블명
           MOVE  CO-TBL-ID
             TO  RJL0025-RELATD-TBL-NAME

      *   과목코드
           MOVE  CO-CHA-SWP
             TO  RJL0025-SBJCT-CD

      *   시스템최종처리일시
           MOVE  BICOM-TRAN-BASE-YMS
             TO  RJL0025-SYS-LAST-PRCSS-YMS

      *   시스템최종사용자번호
           MOVE  BICOM-USER-EMPID
             TO  RJL0025-SYS-LAST-UNO
           .
       S3330-DATA-CURR-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   채무자고객기본(THKJL0015)내부신용등급　자료　추출
      *-----------------------------------------------------------------
       S3331-KJL0015-SELECT-RTN.

           INITIALIZE    TRJL0015-REC

           EXEC SQL
             SELECT  VALUE(내부신용평가등급구분,'0000')
               INTO  :RJL0015-INTNL-CV-GRD-DSTCD
               FROM  DB2DBA.THKJL0015
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  차주번호     = :WK-H-O1-ISSU-CPRNO
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  '0000'
                       TO  RJL0015-INTNL-CV-GRD-DSTCD
               WHEN  OTHER
                     MOVE 'KJL0015'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
      *에러메시지:내부 본 처리
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3331-KJL0015-SELECT-EXT.
           EXIT.
