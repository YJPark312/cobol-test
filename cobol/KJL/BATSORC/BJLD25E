             TO  WK-AMT-BASE-BAL
           MOVE  XBJLTGEX-O-BS-BASE-BAL
             TO  WK-BS-BASE-BAL
           MOVE  XBJLTGEX-O-BS-BAL
             TO  WK-BS-BAL

           MOVE  XBJLTGEX-O-DEAL-BASE-EXRT
             TO  WK-TMP1
           MOVE  XBJLTGEX-O-TELCHK-SEL-EXRT
             TO  WK-TMP2
           MOVE  XBJLTGEX-O-N100-UNIT-CRNCY-YN
             TO  WK-TMP9

      *    #USRLOG '전신환한도 ' WK-AMT-BASE-CLAM
      *    #USRLOG '전신환잔액 ' WK-AMT-BASE-BAL
      *    #USRLOG '매매잔액   ' WK-BS-BASE-BAL
      *    #USRLOG '매매잔액BS ' WK-BS-BAL

