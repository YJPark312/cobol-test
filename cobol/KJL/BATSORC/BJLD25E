      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *   신용파생상품　거래정보
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKJLR003_CUR     CURSOR FOR
             SELECT  A.외화상품유형구분
                  ,  A.외화거래번호
                  ,  B.상품대분류코드
                  ,  B.상품중분류코드
                  ,  B.상품템플릿코드
                  ,  B.상품번호
                  ,  A.신규년월일
                  ,  A.만기년월일
                  ,  A.현지통화코드
                  ,  A.현지통화대출금액
                  ,  A.외환매매익금액
                  ,  A."CMBS과목중분류구분"
                  ,  A.발행법인등록번호
                  ,  A.관리부점코드
               FROM  DB2DBA.THKJLR003  A
                  ,  DB2DBA.THKJL0018  B
              WHERE  A.그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND  A.기준년월일       = :WK-H-I-BASE-YMD
                AND  A."CMBS과목중분류구분" = '07'
                AND  A."CMBS세분류구분"     = '03'
                AND  A.그룹회사코드     = B.그룹회사코드
                AND  B.기준년월         = :WK-H-I-BASE-YM
                AND  A.통합계정과목코드 = B.통합계정과목코드
           END-EXEC.
      *-----------------------------------------------------------------
      *   준거기업정보
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKJLR004_CUR     CURSOR FOR
             SELECT  준거기업식별차주번호
                  ,  준거기업등급구분
                  ,  트레이딩구분
                  ,  부점코드
               FROM   DB2DBA.THKJLR004
              WHERE  그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND  기준년월일       = :WK-H-I-BASE-YMD
                AND  외화상품유형구분 = :WK-H-I-FC-PRDCT-PTRN-DSTCD
                AND  외화거래번호     = :WK-H-I-FC-TRAN-NO
           END-EXEC.
