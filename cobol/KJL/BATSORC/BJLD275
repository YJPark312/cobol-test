      *-----------------------------------------------------------------
      *@   CURSOR OPEN
      *-----------------------------------------------------------------
       S3100-KIE0431-OPEN-RTN.

           EXEC SQL
               OPEN  THKIE0431_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KIE0431'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'OPEN'       TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR OPEN시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3100-KIE0431-OPEN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR FETCH
      *-----------------------------------------------------------------
       S3200-KIE0431-FETCH-RTN.

           INITIALIZE        WK-AREA
                             WK-GUBUN

           EXEC SQL
              FETCH  THKIE0431_CUR
               INTO  :WK-HOST-OUT
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     ADD   CO-NUM-1    TO  WK-AC-FE-CNT
               WHEN  CO-NOT-FOUND
                     SET   EOF-Y       TO  TRUE
               WHEN  OTHER
                     MOVE 'KIE0431'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR FETCH시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

            IF FUNCTION MOD(WK-AC-FE-CNT, 10000) = CO-NUM-0
               #USRLOG 'WK-AC-FE-CNT : ' WK-AC-FE-CNT
            END-IF
           .
       S3200-KIE0431-FETCH-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  담보고객구분　추출
      *-----------------------------------------------------------------
       S3300-KAABPCB-SELECT-RTN.

      * 담보고객식별자－－＞　담보 고객번호구분 조회
      * 간접 상품중분류 01:개인 02:기업 분류기준

           EXEC SQL
             SELECT  고객고유번호구분
               INTO  :WK-DBTR-DSTCD
               FROM   DB2DBA.THKAABPCB
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  고객식별자   = :WK-H-O-SCURTY-CUST-IDNFR
               WITH   UR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     #USRLOG ' THKAABPCB NOT FND 담보고객식별자: '
                               WK-H-O-SCURTY-CUST-IDNFR
                             '설정번호: ' WK-H-O-SCURTY-STUP-NO
                     MOVE  SPACE       TO  WK-DBTR-DSTCD
               WHEN  OTHER
                     MOVE 'KAABPCB'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT 02 S3300시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3300-KAABPCB-SELECT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   DATA MOVE
      *-----------------------------------------------------------------
       S3600-DATA-MOVE-RTN.

           INITIALIZE                  OT-REC


      *    그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  RJL0027-GROUP-CO-CD

      *    기준일
           MOVE  WK-H-I-BASE-DD
             TO  RJL0027-BASE-DD

      *    기준년월
           MOVE  WK-H-I-BASE-YM
             TO  RJL0027-BASE-YM

      *    담보보증고객식별자＝시공사고객식별자
           MOVE  WK-H-O-CNSC-CUST-IDNFR
             TO  RJL0027-SCURTY-G-CUSZ-IDNFR

      *    계약식별자 = THKIE0431_담보설정번호
           MOVE  WK-H-O-SCURTY-STUP-NO
             TO  RJL0027-CTRC-IDNFR

      *    시공사고객구분 = THKIE0431_시공사고객번호구분
           MOVE  WK-H-O-CNSC-CUNIQNO-DSTIC
             TO  RJL0027-GRNR-CUST-DSTCD

      *    담보고객식별자＝담보고객식별자
           MOVE  WK-H-O-SCURTY-CUST-IDNFR
             TO  RJL0027-SCURTY-CUST-IDNFR

      *    담보고객식별자의 채무자구분
           MOVE  WK-DBTR-DSTCD
             TO  RJL0027-DBTR-DSTCD

      *    담보구분
           MOVE  WK-H-O-SCURTY-DSTCD
             TO  RJL0027-SCURTY-DSTCD

      *@@@ 간접계정코드　중분류코드　세트
           PERFORM  S3610-SELECT-GANCODE-RTN
              THRU  S3610-SELECT-GANCODE-EXT

      *    대출자격구분
           MOVE  SPACE
             TO  RJL0027-LN-QULFI-DSTCD

      *   과목코드
           MOVE  'CNC'
             TO  RJL0027-SBJCT-CD

      *@@@ 보증금액 원화 환산
           PERFORM  S3620-SELECT-GANJAN-RTN
              THRU  S3620-SELECT-GANJAN-EXT

      *@@@간접TE환산율조회
           PERFORM  S3630-KJL0019-SELECT-RTN
              THRU  S3630-KJL0019-SELECT-EXT

           INITIALIZE        WK-INDR-EXPSR-AMT
           COMPUTE  WK-INDR-EXPSR-AMT
                 =  RJL0027-INDR-TTL-AMT
                 *  (WK-INDR-TE-UTCRT / 100)

      *    간접익스포져금액
           MOVE  WK-INDR-EXPSR-AMT
             TO  RJL0027-INDR-EXPSR-AMT

      *    관련테이블명
           MOVE  WK-GUBUN
             TO  RJL0027-RELATD-TBL-NAME

      *    담보계약식별자
           MOVE  SPACE
             TO  RJL0027-SCURTY-CTRC-IDNFR

      *    담보계약계좌번호
           MOVE  WK-H-O-SCURTY-LNBZ-ACNO
             TO  RJL0027-SCURTY-CTRC-ACNO

      *    시스템최종처리일시
           MOVE  BICOM-TRAN-BASE-YMS
             TO  RJL0027-SYS-LAST-PRCSS-YMS

      *    시스템최종사용자번호
           MOVE  BICOM-USER-EMPID
             TO  RJL0027-SYS-LAST-UNO

           .
       S3600-DATA-MOVE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   간접계정코드　중분류코드　세트
      *-----------------------------------------------------------------
       S3610-SELECT-GANCODE-RTN.

      *    상품대분류코드
           MOVE  'GJ'
             TO  RJL0027-PRDCT-LAG-CLSFI-CD

      *    상품중분류코드
           MOVE  '06'
             TO  RJL0027-PRDCT-MEDM-CLSFI-CD

      *    상품템플릿코드 CNC:시공사
           MOVE  'CNC'
             TO  RJL0027-PRDCT-TMPLT-CD

      *    간접중분류구분
           MOVE  '06'
             TO  RJL0027-INDR-M-CLSFI-DSTCD

      *   상품번호＝＇００＇＋담보구분３자리
           MOVE  '00'
             TO  RJL0027-PRDCT-NO(1:2)

      *****담보구분 = 상품번호（３：３）코드 셋팅
      *@   443 주택금융신용보증서(PF보증용)
      *@   473 주택사업금융보증서(주택도시보증공사)
      *@   414 조합사업비대출보증서

           MOVE  WK-H-O-SCURTY-DSTCD
             TO  RJL0027-PRDCT-NO(3:3)

           .
       S3610-SELECT-GANCODE-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   보증금액　원화　환산
      *    설정금액 =  간접명목금액　산출
      *-----------------------------------------------------------------
       S3620-SELECT-GANJAN-RTN.

      *   통화코드
           MOVE  WK-H-O-CNCYCD
             TO  RJL0027-CNCYCD

      *   통화설정금액
           MOVE  WK-H-O-SETAMT
             TO  RJL0027-CRNCY-SETAMT

      *    설정금액　원화환산
           IF  WK-H-O-CNCYCD = CO-CHA-KRW

      *        원화환산금액
                MOVE  WK-H-O-SETAMT
                  TO  RJL0027-WONC-AUC

      *        간접명목금액
                MOVE  WK-H-O-SETAMT
                  TO  RJL0027-INDR-TTL-AMT

           ELSE
      *       통화별　원화환산금액CALCURATER
               PERFORM  S3621-BJLTGEX-CALL-RTN
                  THRU  S3621-BJLTGEX-CALL-EXT

      *        원화환산금액
                MOVE  WK-WONGK
                  TO  RJL0027-WONC-AUC

      *        간접명목금액
                MOVE  WK-WONGK
                  TO  RJL0027-INDR-TTL-AMT

           END-IF

      *    명목액원천구분- 1:설정금액
           MOVE  'THKIE0431-1'
             TO   WK-GUBUN

           .
       S3620-SELECT-GANJAN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  간접익스포져계정코드목록(THKJL0019) 조회
      *-----------------------------------------------------------------
       S3630-KJL0019-SELECT-RTN.

           INITIALIZE    TKJL0019-KEY

      *          그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  KJL0019-PK-GROUP-CO-CD

      *          기준년월
           MOVE  WK-H-I-BASE-YM
             TO  KJL0019-PK-BASE-YM

      *         상품대분류코드
           MOVE  RJL0027-PRDCT-LAG-CLSFI-CD
             TO  KJL0019-PK-PRDCT-LAG-CLSFI-CD

      *         상품중분류코드
           MOVE  RJL0027-PRDCT-MEDM-CLSFI-CD
             TO  KJL0019-PK-PRDCT-MEDM-CLSFI-CD

      *         상품템플릿코드
           MOVE  RJL0027-PRDCT-TMPLT-CD
             TO  KJL0019-PK-PRDCT-TMPLT-CD

      *         상품번호
           MOVE  RJL0027-PRDCT-NO
             TO  KJL0019-PK-PRDCT-NO

           EXEC SQL
             SELECT  VALUE("간접TE환산율",0)
               INTO  :WK-INDR-TE-UTCRT
               FROM  DB2DBA.THKJL0019
              WHERE  그룹회사코드   = :KJL0019-PK-GROUP-CO-CD
                AND  기준년월       = :KJL0019-PK-BASE-YM
                AND  상품대분류코드 = :KJL0019-PK-PRDCT-LAG-CLSFI-CD
                AND  상품중분류코드 = :KJL0019-PK-PRDCT-MEDM-CLSFI-CD
                AND  상품템플릿코드 = :KJL0019-PK-PRDCT-TMPLT-CD
                AND  상품번호       = :KJL0019-PK-PRDCT-NO
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  ZERO        TO  WK-INDR-TE-UTCRT
               WHEN  OTHER
                     MOVE 'KJL0019'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3630-KJL0019-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   통화별원화환산금액 CALCURATER
      *-----------------------------------------------------------------
       S3621-BJLTGEX-CALL-RTN.

           INITIALIZE    XBJLTGEX-CA

      *    처리구분(1:통화별환산2:외환매매익　역환산)
           MOVE  CO-CHA-1
             TO  XBJLTGEX-I-GBCD

      *    유효년월일－기준년월일
           MOVE  WK-H-I-BASE-YMD
             TO  XBJLTGEX-I-BASE-YMD

      *    통화코드
           MOVE  WK-H-O-CNCYCD
             TO  XBJLTGEX-I-CNCYCD

      *    통화한도금액
           MOVE  ZERO
             TO  XBJLTGEX-I-CRNCY-CLAM

      *    통화기준잔액
           MOVE  WK-H-O-SETAMT
             TO  XBJLTGEX-I-CRNCY-BAL

      *    통화기준잔액- 파생상품BS금액용
           MOVE  ZERO
             TO  XBJLTGEX-I-BS-BAL

           #DYCALL  BJLTGEX YCCOMMON-CA XBJLTGEX-CA

           IF  XBJLTGEX-R-STAT = CO-STAT-OK
      *        원화환산금액
               MOVE  XBJLTGEX-O-TTL-AMT-BASE-BAL
                 TO  WK-WONGK
           ELSE
      *        원화환산금액
               MOVE  ZERO
                 TO  WK-WONGK
           END-IF

           .
       S3621-BJLTGEX-CALL-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   DATA WRITE
      *-----------------------------------------------------------------
       S3700-DATA-WRITE-RTN.

           WRITE OT-REC

           IF  WK-OT-F-ST NOT = CO-STAT-OK
               MOVE 'OT-FILE WRITE ERROR : FILE-ST IS '
