      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *-----------------------------------------------------------------
      *  THKIE0437 (담보여신계좌연결　정보)
      *  THKIE0436 (담보설정정보)
      *  THKIE0431 (보증서담보명세)
      *  D.시공사고객식별자 ==> 시공사(보증채무)
      *  B.담보고객식별자   ==> 차주  (채무자/피보증)
      *  KIE 송하종차장 쿼리 작성
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKIE0431_CUR     CURSOR FOR
             SELECT B.담보설정번호
                  , D.시공사고객식별자
                  , E.고객고유번호구분 AS 시공사고객번호구분
                  , B.담보고객식별자
                  , '' 담보고객구분
                  , B.담보구분
                  , A.통화코드
                  , A.설정금액
                  , VALUE((SELECT  관련계좌번호
                             FROM   DB2DBA.THKHC0007
                            WHERE  그룹회사코드 = 'KB0'
                              AND  주계좌번호   = C.담보여신계좌번호
                              AND  상품계약간관계구분= '02'
                              AND  상품계약간상태구분='1'
                              FETCH  FIRST 1 ROW ONLY
                           ),C.담보여신계좌번호) AS 담보여신계좌번호
                  , A.담보설정비율구분
             FROM   DB2DBA.THKIE0436 A
                  , DB2DBA.THKIE0431 B
                  , DB2DBA.THKIE0437 C
                  , DB2DBA.THKIE0455 D
                  , DB2DBA.THKAABPCB E
              WHERE A.그룹회사코드   = 'KB0'
                AND A.그룹회사코드   = B.그룹회사코드
                AND A.그룹회사코드   = C.그룹회사코드
                AND A.그룹회사코드   = D.그룹회사코드
                AND E.그룹회사코드   = D.그룹회사코드
                AND A.설정상태구분   = '2'
                AND A.담보형태구분   = '1'
                AND A.담보해지구분  <> '2'
                AND A.담보설정번호   = B.담보설정번호
                AND A.담보고객식별자 = B.담보고객식별자
                AND A.담보설정번호   = C.담보설정번호
                AND C.대출계좌연결여부 = '1'
                AND A.설정금액       > 0
                AND B.담보구분 IN ('443','473','414')
                AND D.담보설정번호   = A.담보설정번호
                AND D.설정부가정보구분 = '01'
                AND E.고객식별자       = D.시공사고객식별자
                AND NOT EXISTS
                    (SELECT 1
                       FROM DB2DBA.THKJL0127
                      WHERE 그룹회사코드   = C.그룹회사코드
                        AND 기준일         = :WK-H-I-BASE-DD
                        AND 기준년월       = :WK-H-I-BASE-YM
                        AND 차주고객식별자 = D.시공사고객식별자
                        AND 한도계좌번호   = C.담보여신계좌번호)
                WITH UR
           END-EXEC.

