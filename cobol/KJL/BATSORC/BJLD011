                  AS 한신평업체코드
                 ,C.고객식별자
                 ,SUBSTR(MAX(A.최종변경년월일||
                             A.한신평업체코드||
                             A.한신평산업코드||
                             A.한신평재무업종구분),15,5)
                  AS 한신평산업코드
180416           ,VALUE((SELECT 한신평재무업종구분
                           FROM DB2DBA.THKJL0153
                          WHERE 그룹회사코드 = C.그룹회사코드
                            AND 고객식별자   = C.고객식별자
                            AND 한신평재무업종구분 != ''
                         )
                 ,SUBSTR(MAX(A.최종변경년월일||
                             A.한신평업체코드||
                             A.한신평산업코드||
                             A.한신평재무업종구분),20,2))
                  AS 한신평재무업종구분
                 ,VALUE(MAX(B.영업신용등급구분),'0000')
                  AS 영업신용등급구분
                 ,VALUE(MAX(B.평가년월일)      ,'') AS 평가년월일
                 ,VALUE(MAX(B.유효년월일)      ,'') AS 유효년월일
             FROM DB2DBA.THKABCB01 A
                 ,DB2DBA.THKAAADET D
                 ,DB2DBA.THKAABPCB C LEFT OUTER JOIN
17224            (SELECT 심사고객식별자
                        ,SUBSTR(MAX(CASE WHEN 신용평가구분 IN
                                              ('02','13','15','22')
                                         THEN '1'
                                         ELSE '2'
                                    END                 ||
                                    평가년월일        ||
                                    신용평가보고서번호||
140721                              CASE WHEN 영업신용등급구분 IN
                                              ('    ','0000')
                                         THEN 최종신용등급구분
                                         ELSE 영업신용등급구분
                                    END                 ||
                                    유효년월일),23,4)
                         AS 영업신용등급구분
                        ,SUBSTR(MAX(CASE WHEN 신용평가구분 IN
                                              ('02','13','15','22')
                                         THEN '1'
                                         ELSE '2'
                                    END                 ||
                                    평가년월일        ||
                                    신용평가보고서번호||
140721                              CASE WHEN 영업신용등급구분 IN
                                              ('    ','0000')
                                         THEN 최종신용등급구분
                                         ELSE 영업신용등급구분
                                    END                 ||
                                    유효년월일), 2,8)
                         AS 평가년월일
                        ,SUBSTR(MAX(CASE WHEN 신용평가구분 IN
                                              ('02','13','15','22')
                                         THEN '1'
                                         ELSE '2'
                                    END                 ||
                                    평가년월일        ||
                                    신용평가보고서번호||
140721                              CASE WHEN 영업신용등급구분 IN
                                              ('    ','0000')
                                         THEN 최종신용등급구분
                                         ELSE 영업신용등급구분
                                    END                 ||
                                    유효년월일),27,8)
                         AS 유효년월일
                    FROM DB2DBA.THKIIK616
                   WHERE 그룹회사코드       = :WK-H-I-GROUP-CO-CD
                     AND 기업신용등급원천지 = '3'
                     AND 신용평가구분IN ('01','03','04','05',
                                           '06','07','08','09',
                                           '10','11','14','16',
                                           '17','18','19','20','99',
                                           '02','13','15','22')
17224              GROUP BY 심사고객식별자
                  ) B
               ON C.고객식별자    = B.심사고객식별자
            WHERE A.그룹회사코드  = D.그룹회사코드
              AND A.고객식별자    = D.대체번호
              AND D.그룹회사코드  = C.그룹회사코드
170824        AND D.양방향고객암호화번호 = C.양방향고객암호화번호
              AND A.그룹회사코드  = :WK-H-I-GROUP-CO-CD
              AND A.고객식별자   <> ''

120201      GROUP BY C.그룹회사코드,C.고객식별자
             WITH UR
           END-EXEC.

