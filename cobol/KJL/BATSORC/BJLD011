      *한신평에서정의한기업규모구분
      *(0:해당무,1:대기업,2:중소기업,9:기타)이다.
           EXEC SQL
           DECLARE  THKABCB01_CUR     CURSOR FOR
           SELECT SUBSTR(MAX(A.최종변경년월일||
                             A.한신평업체코드||
                             A.한신평산업코드||
