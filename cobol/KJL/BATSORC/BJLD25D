      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
          EXEC SQL
           DECLARE  TKJLR005_CUR      CURSOR FOR
            SELECT  A.그룹회사코드
                 ,  A.기준년월일
                 ,  A.관리부점코드
                 ,  A.계좌번호
                 ,  A."통합CRM번호"
                  ,  A.고객식별자
                  ,  A.고객관리번호
                 ,  A."ISO국가코드"
                 ,  A.신규년월일
                 ,  A.만기년월일
                 ,  A.현지취급통화코드
                 ,  A.현지한도약정금액
                 ,  A.현지통화대출잔액
                 ,  B.상품대분류코드
                 ,  B.상품중분류코드
                 ,  B.상품템플릿코드
                 ,  B.상품번호
                 ,  A.해외점포영업년월일
                 ,  A.원화환산잔액
                 ,  A.해외점포계좌구분
                 ,  A.국제한도구분
                 ,  A."USD한도약정금액"
                 ,  A."USD대출잔액"
              FROM  DB2DBA.THKJLR005 A
                 ,  DB2DBA.THKJL0018 B
             WHERE  A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
               AND  A.그룹회사코드 =  B.그룹회사코드
               AND  A.기준년월일   = :WK-H-I-BASE-YMD
               AND  B.기준년월     = :WK-H-I-BASE-YM
               AND  B.상품대분류코드  = 'FI'
               AND  ((A.통합계정과목코드 <> '4030202000000'
                  AND A.통합계정과목코드 = B.통합계정과목코드 )
                OR   (A.통합계정과목코드 = '4030202000000'
                  AND A.계정과목코드     = B.상품번호))
               AND (A.현지한도약정금액 > 0
                OR  A.현지통화대출잔액 > 0)
              WITH UR
           END-EXEC.
