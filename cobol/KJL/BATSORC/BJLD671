      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
           DECLARE  THKJL0129_CUR     CURSOR WITH HOLD FOR
           SELECT ТїСжАэАДНФКАРк
                 ,CASE WHEN SUM("ЧбЕЕБтСиTEБнОз") >= 0
                       THEN SUM(CASE WHEN ЛѓЧАДыКаЗљФкЕх <> 'FI'
                                     THEN "ЧбЕЕБтСиTEБнОз"
                                     ELSE 0
                                END)
                       ELSE 0
                  END AS "БЙГЛTEБнОз"
200102           ,CASE WHEN SUM("ЧбЕЕБтСиTEБнОз") >= 0
                       THEN SUM(CASE WHEN ЛѓЧАДыКаЗљФкЕх = 'FI'
                                     THEN "ЧбЕЕБтСиTEБнОз"
                                     ELSE 0
                                END)
                       ELSE 0
                  END AS "БЙПмTEБнОз"
             FROM DB2DBA.THKJL0129
            WHERE БзЗьШИЛчФкЕх = :WK-H-I-GROUP-CO-CD
              AND БтСиРЯ       = :WK-H-I-BASE-DD
              AND БтСиГтПљ     = :WK-H-I-BASE-YM
              AND ТїСжАэАДНФКАРк NOT IN
                 (SELECT АэАДНФКАРк
                    FROM DB2DBA.THKJL0059
                   WHERE БзЗьШИЛчФкЕх     = :WK-H-I-GROUP-CO-CD
                     AND ЧбЕЕАќИЎСІПмБИКа = '1'
                  )
            GROUP BY ТїСжАэАДНФКАРк
             WITH UR
           END-EXEC.



