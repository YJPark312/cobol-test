                       THEN SUM(CASE WHEN ЛѓЧАДыКаЗљФкЕх <> 'FI'
                                     THEN "ЧбЕЕБтСиTEБнОз"
                                     ELSE 0
                                END)
                       ELSE 0
                  END AS "БЙГЛTEБнОз"
200102           ,CASE WHEN SUM("ЧбЕЕБтСиTEБнОз") >= 0
                       THEN SUM(CASE WHEN ЛѓЧАДыКаЗљФкЕх = 'FI'
                                     THEN "ЧбЕЕБтСиTEБнОз"
