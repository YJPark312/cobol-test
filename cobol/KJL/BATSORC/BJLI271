      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *@  차주익스포져 일집계 산출시
      *@  TE계좌고객구분 중
      *@  비대상        3:국민은행(국내)
      *@                  4:해외점포(차주:국민은행)
      *@                  6:해외법인(차주:국민은행)
      *@                  7:개인여신
      *@                  9:기타
      *@  대상
      *@                  0:해당무
      *@                  1:법인여신
      *@                  2:개인사업자
      *@                  5:해외법인(차주:기타)
      *@                  8:대한민국정부

           EXEC SQL
           DECLARE  THKJL0125_CUR   CURSOR  WITH HOLD FOR
      *   전체대상
           WITH TBL1 AS (
           SELECT A.그룹회사코드
                 ,A.계좌번호
                 ,A.기준일
                 ,A.기준년월
                 ,A.차주고객식별자
                 ,A.한도계좌번호
                 ,A.한도상품대분류코드
                 ,A.한도상품중분류코드
                 ,A.한도상품템플릿코드
                 ,A.한도상품번호
                 ,A."BS기준잔액"
                 ,A.명목액기준한도
                 ,A.명목액기준잔액
                 ,A.명목액기준한도 - A.명목액기준잔액 AS "EAD한도"
                 ,A."CCF명목잔액환산금액"
                 ,VALUE(B."EAD한도NCCF환산율",0)
                       AS "EAD한도NCCF환산율"
                 ,VALUE(B."EAD한도CCF환산율" ,0)
                       AS "EAD한도CCF환산율"
                 ,VALUE(B."한도기준TE환산율" ,0)
                       AS "한도기준TE환산율"
                 ,VALUE(B."CA대상계정여부" ,'0')
                       AS "CA대상계정여부"
                 ,A."CA담보제외금액"
                 ,A."CA담보환산금액"
                 ,A."BS기준한도" - A."BS기준잔액" AS 신용공여한도
                 ,CASE WHEN A."TE계좌고객구분" IN ('1','2','5')
                        AND A."TE계좌구분"     IN ('1','3','4')
                        AND A.통화코드         <> 'KRW'
                       THEN 1
                       ELSE 0
                  END                             AS 외화신용공여대상
                 ,CASE WHEN A."TE계좌구분" IN ('1','3','4')
                       THEN A.만기년월일
                       ELSE ' '
                  END                             AS 만기년월일
                 ,A."BS기준한도"
                 ,CASE WHEN A."TE계좌구분" IN ('1','3','4')
                       THEN A.시작년월일
                       ELSE ' '
                  END                             AS 시작년월일
             FROM DB2DBA.THKJL0125 A LEFT OUTER JOIN
                  DB2DBA.THKJL0118 B
               ON A.그룹회사코드       = B.그룹회사코드
              AND A.기준년월           = B.기준년월
              AND A.한도상품대분류코드 = B.상품대분류코드
              AND A.한도상품중분류코드 = B.상품중분류코드
              AND A.한도상품템플릿코드 = B.상품템플릿코드
              AND A.한도상품번호       = B.상품번호
            WHERE A.그룹회사코드       = :WK-H-I-GROUP-CO-CD
              AND A.기준일             = :WK-H-I-BASE-DD
              AND A.기준년월           = :WK-H-I-BASE-YM
              AND A."TE계좌고객구분" NOT IN ('3','4','6','7','9')
              AND A.차주고객식별자   NOT IN
                      ('          ', '',
                       '==========','----------')
              AND NOT (A.한도상품대분류코드= ' ' OR
                       A.한도상품중분류코드= ' ' OR
                       A.한도상품템플릿코드= ' ' OR
                       A.한도상품번호      = ' ' )
200102        AND NOT EXISTS (SELECT 1
      *       지급보증신용장번호가 있는 해외여신을 제외
                                FROM DB2DBA.THKJL0125
                               WHERE 그룹회사코드 = A.그룹회사코드
                                 AND 기준일       = A.기준일
                                 AND 기준년월     = A.기준년월
                                 AND 계좌번호 = A.지급보증신용장번호
                              )
200220*      지급보증신용장번호를 가지고 있는 해외여신의
      *      해외한도계좌는 제외
              AND NOT EXISTS (SELECT 1
                                FROM DB2DBA.THKJL0125 C
                               WHERE C.그룹회사코드 = A.그룹회사코드
                                 AND C.기준일       = A.기준일
                                 AND C.기준년월     = A.기준년월
                                 AND C.한도계좌번호 = A.계좌번호
                                 AND A.한도계좌여부 = '1'
                                 AND A."TE계좌구분" = '1'
                                 AND C."TE계좌구분" = '2'
                                 AND EXISTS (SELECT 1
                                               FROM DB2DBA.THKJL0125
                                              WHERE 그룹회사코드 =
                                                  C.그룹회사코드
                                                AND 기준일       =
                                                  C.기준일
                                                AND 기준년월     =
                                                  C.기준년월
                                                AND 계좌번호     =
                                                  C.지급보증신용장번호
                                             )
                              )
           )
      *    한도기준TE금액 산출
           SELECT 그룹회사코드
                 ,기준일
                 ,기준년월
                 ,차주고객식별자
                 ,한도계좌번호
                 ,한도상품대분류코드
                 ,한도상품중분류코드
                 ,한도상품템플릿코드
                 ,한도상품번호
                 ,SUM("BS기준잔액")     AS "BS기준잔액"
                 ,CASE WHEN SUM(명목액기준한도) = 0
                        AND SUM(명목액기준잔액) > 0
                       THEN SUM(명목액기준잔액)
                       ELSE SUM(명목액기준한도)
                  END                     AS 명목액기준한도
                 ,SUM(명목액기준잔액)   AS 명목액기준잔액
                 ,MAX(SUM("EAD한도"),0) AS "EAD한도"
                 ,SUM("CCF명목잔액환산금액")
                                          AS "명목잔액CCF환산금액"
                 ,MAX(SUM("EAD한도"),0) *
                  DOUBLE(MAX("EAD한도NCCF환산율")) / 100 *
                  DOUBLE(MAX("EAD한도CCF환산율" )) / 100
                                          AS "EAD한도CCF환산금액"
                 ,CASE WHEN SUM(명목액기준한도) = 0
                        AND SUM(명목액기준잔액) > 0
                       THEN SUM(명목액기준잔액)
                       ELSE SUM(명목액기준한도)
                  END * DOUBLE(VALUE(MAX("한도기준TE환산율"),0))
                      / 100 AS "한도기준TE금액"
                 ,SUM("CCF명목잔액환산금액") +
                  (MAX(SUM("EAD한도"),0) *
                   DOUBLE(MAX("EAD한도NCCF환산율")) / 100 *
                   DOUBLE(MAX("EAD한도CCF환산율" )) / 100)
                                            AS "잔액기준TE금액"
                 ,CASE MAX("CA대상계정여부") WHEN '1'
                      THEN SUM("CA담보제외금액")
                      ELSE 0
                  END                     AS "CA담보제외금액"
                 ,SUM("CA담보환산금액") AS "CA담보환산금액"
                 ,SUM(신용공여한도)     AS 신용공여한도
                 ,SUM(외화신용공여대상) AS 외화신용공여대상
                 ,MAX(만기년월일)       AS 만기년월일
                 ,SUM("BS기준한도")     AS "BS기준한도"
                 ,MAX(시작년월일)       AS 시작년월일
             FROM TBL1
            GROUP BY 그룹회사코드
                    ,기준일
                    ,기준년월
                    ,차주고객식별자
                    ,한도계좌번호
                    ,한도상품대분류코드
                    ,한도상품중분류코드
                    ,한도상품템플릿코드
                    ,한도상품번호
             WITH UR
           END-EXEC.

           EXEC SQL
            DECLARE  THKJL0127_CUR   CURSOR  WITH HOLD FOR
             SELECT  그룹회사코드
                  ,  기준년월
                  ,  차주고객식별자
                  ,  한도계좌번호
                  ,  한도상품대분류코드
                  ,  한도상품중분류코드
                  ,  한도상품템플릿코드
                  ,  한도상품번호
                  ,   "BS기준잔액"
                  ,  명목액기준한도
                  ,  명목액기준잔액
                  ,   "EAD한도"
                  ,   "명목잔액CCF환산금액"
                  ,   "EAD한도CCF환산금액"
                  ,   "한도기준TE금액"
                  ,   "잔액기준TE금액"
                  ,   "CA담보제외금액"
                  ,   "CA담보환산금액"
                  ,  신용공여한도
                  ,  외화신용공여한도
170413            ,   "BS기준한도"
               FROM   DB2DBA.THKJL0127
              WHERE  그룹회사코드  = :WK-H-I-GROUP-CO-CD
                AND  기준일        = :WK-H-I-BASE-DD
                AND  기준년월      = :WK-H-I-BASE-YM
               WITH UR
           END-EXEC.
