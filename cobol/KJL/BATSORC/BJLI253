      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *@외화여신자료　 SELECT SQL DECLARE
      *@->63-통화（수표매입）외국환
      *@->외국환업무구분＝３１（수표매입）만　여신에　해당
      *@->만기년월일　없음．잔액＞０이면　정상　여신으로　취급
      *@-THKHC0007.관계종료년월일 참고
           EXEC SQL
            DECLARE  THKHC0401_CUR     CURSOR FOR
             SELECT  TAB.테이블명
                  ,  TAB.여신구분
                  ,  TAB.계좌번호
                  ,  TAB.통화코드
                  ,  TAB.상품대분류코드
                  ,  TAB.상품중분류코드
                  ,  TAB.상품템플릿코드
                  ,  TAB.상품번호
                  ,  TAB.고객식별자
                  ,  TAB.고객관리번호
                  ,  TAB.관리부점코드
                  ,  TAB.상품계약상태구분
                  ,  TAB.상품계약약정년월일
                  ,  TAB.상품계약만기년월일
                  ,  TAB.상품계약폐기년월일
                  ,  TAB.한도계좌번호
                  ,  TAB.한도계좌여부
                  ,  TAB.잔액
                  ,  TAB.잔액유형구분
               FROM (
             SELECT  'THKFDPO01'    AS 테이블명
                  ,  '063'          AS 여신구분
                  ,  A.계좌번호
                  ,  C.통화코드
                  ,  A.상품대분류코드
                  ,  A.상품중분류코드
                  ,  A.상품템플릿코드
                  ,  A.상품번호
                  ,  A.고객식별자
                  ,  VALUE(A.고객관리번호,'0000') AS 고객관리번호
                  ,  A.관리부점코드
                  ,  '1'            AS 상품계약상태구분
                  ,  A.매입년월일 AS 상품계약약정년월일
                  ,  '00010101'     AS 상품계약만기년월일
                  ,  '00010101'     AS 상품계약폐기년월일
                  ,  ' '            AS 한도계좌번호
                  ,  '0'            AS 한도계좌여부
                  ,  C.잔액
                  ,  C.잔액유형구분
              FROM  DB2DBA.THKFDPO01 A
                 ,  DB2DBA.THKJL0118 B
                 ,  DB2DBA.THKHDM100 C
             WHERE  A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
               AND  A.국제원장취소구분 IN ('0','7')
               AND  A.외국환업무구분 = '31'
               AND  A.외화잔액       > 0
               AND  A.고객식별자    <> ' '
               AND  A.관리부점코드  <> :WK-H-I-BRNCD
               AND  B.기준년월       = :WK-H-I-BASE-YM
               AND  A.그룹회사코드   = B.그룹회사코드
               AND  A.상품대분류코드 = B.상품대분류코드
               AND  A.상품중분류코드 = B.상품중분류코드
               AND  A.상품템플릿코드 = B.상품템플릿코드
               AND  A.상품번호       = B.상품번호
               AND  A.그룹회사코드   = C.그룹회사코드
               AND  A.계좌번호       = C.계좌번호
               AND  C.잔액 > 0
               AND  SUBSTR(C.금액유형코드,1,2) IN ('41','91')
               AND  C.잔액유형구분 NOT IN ('CD10','CD11','CD12',
                                      'CD13','CD14','CD15','CD16')
      *
      *@->64(수출매입)
      *@- 매입추심구분 = '1'（매입）만　여신에　해당
              UNION  ALL
             SELECT  'THKFF0201'    AS 테이블명
                  ,  '064'          AS 여신구분
                  ,  A.계좌번호
                  ,  C.통화코드   AS 통화코드
                  ,  A.상품대분류코드
                  ,  A.상품중분류코드
                  ,  A.상품템플릿코드
                  ,  A.상품번호
                  ,  A.고객식별자
                  ,  A.고객관리번호
                  ,  A.관리부점코드
                  ,  '1'            AS 상품계약상태구분
