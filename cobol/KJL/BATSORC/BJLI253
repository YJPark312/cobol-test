      *-----------------------------------------------------------------
      *@   계약한도　추출작업（계좌한도인경우만）
      *-----------------------------------------------------------------
       S3310-KHC0007-SELECT-RTN.

           INITIALIZE    WK-KHC0007-ACNO

      *---------------------------------------------------------------
      *@백현정:20100604:모계좌　관계여부（관계종료년월일）체크제외
      *@ -외화는　관계종료년월일이　개설시점에　한번INSERT
      *@  변경사항이　발생해도　관계종료년월일은　변경　적용　없음
      *----------------------------------------------------------------
      *@백현정:20100630:계약관계에서　주계좌번호＝관련계좌번호제외
      *@-주계좌번호＝관련계좌번호　중에　한도계약관계（＇０１＇）존재
      *@-외환계좌　중에　일부　발생（제외로직추가）
      *----------------------------------------------------------------

           EXEC SQL
             SELECT  VALUE(관련계좌번호,' ')
               INTO  :WK-KHC0007-ACNO
               FROM  (
                       SELECT  VALUE(관련계좌번호,' ')
                                 AS 관련계좌번호
                         FROM  DB2DBA.THKHC0007
                        WHERE 그룹회사코드 = :WK-H-I-GROUP-CO-CD
                          AND 주계좌번호   = :WK-H-O-ACNO
                          AND 주계좌번호 <> 관련계좌번호
                          AND 상품계약간관계구분 = '01'
                          AND 상품계약간상태구분 = '1'
                  UNION   ALL
                       SELECT  VALUE(관련계좌번호,' ')
                                 AS 관련계좌번호
                         FROM  DB2DBA.THKHC0007
                        WHERE 그룹회사코드 = :WK-H-I-GROUP-CO-CD
                          AND 주계좌번호 IN  (
                                 SELECT 관련계좌번호
                                   FROM  DB2DBA.THKHC0007
                                  WHERE 그룹회사코드
                                              = :WK-H-I-GROUP-CO-CD
                                    AND 주계좌번호  = :WK-H-O-ACNO
                                    AND 주계좌번호 <> 관련계좌번호
                                    AND 상품계약간관계구분 = '43'
                                    AND 상품계약간상태구분 = '1' )
                          AND 주계좌번호   <> 관련계좌번호
                          AND 상품계약간관계구분 = '01'
                          AND 상품계약간상태구분 = '1'
                     ) A
              WITH  UR FETCH FIRST 1 ROW ONLY
            END-EXEC


           EVALUATE  SQLCODE
               WHEN  CO-OK
      *@            건별여신이면
                     IF  WK-KHC0007-ACNO NOT = SPACE
                     THEN
      *@                TE계좌구분＝２（건별여신）
                         MOVE  CO-CHA-2
                           TO  RJL0125-TE-ACN-DSTCD

      *@                통화한도＝０
                         MOVE  ZERO
                           TO  RJL0125-CRNCY-CLAM

      *@구한도계좌이면　신한도계좌　추출
                      PERFORM  S3311-KHC0007-SELECT-RTN
                         THRU  S3311-KHC0007-SELECT-EXT

                         ADD  CO-NUM-1
                          TO  WK-KHC0007-OK-CNT
                     ELSE
                         ADD  CO-NUM-1
                          TO  WK-KHC0007-NFND-CNT
                     END-IF
               WHEN  CO-NOT-FOUND
      *@              TE계좌구분＝３（개별여신）
                     MOVE  CO-CHA-3
                       TO  RJL0125-TE-ACN-DSTCD

                      ADD  CO-NUM-1
                       TO  WK-KHC0007-NFND-CNT
               WHEN  OTHER
                     MOVE 'KHC0007'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-KHC0007-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   계약한도　추출작업（구한도계좌이면　신한도계좌　추출）
      *-----------------------------------------------------------------
       S3311-KHC0007-SELECT-RTN.

           INITIALIZE    WK-KHC0007-SINACNO

           EXEC SQL
             SELECT  VALUE(A.주계좌번호,' ')
               INTO  :WK-KHC0007-SINACNO
               FROM  DB2DBA.THKHC0007 A
                  ,  DB2DBA.THKHC0401 B
              WHERE  A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  A.관련계좌번호 = :WK-KHC0007-ACNO
                AND  A.주계좌번호   <>  A.관련계좌번호
                AND  A.상품계약간관계구분 = '33'
                AND  A.상품계약간상태구분 = '1'
                AND  A.그룹회사코드 = B.그룹회사코드
                AND  A.주계좌번호   = B.계좌번호
                AND  B.재약정한도계좌구분<> '2'
              ORDER  BY  A.관계시작년월일 DESC
              WITH  UR FETCH FIRST 1 ROW ONLY
            END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
      *@신한도계좌번호가　있으면　한도계좌번호＝신한도계좌번호
                     IF  WK-KHC0007-SINACNO NOT = SPACE
                          MOVE  WK-KHC0007-SINACNO
                            TO  WK-KHC0007-ACNO
                         ADD   CO-NUM-1    TO  WK-KHCGU07-OK-CNT
                     ELSE
                         ADD   CO-NUM-1    TO  WK-KHCGU07-NFND-CNT
                     END-IF
               WHEN  CO-NOT-FOUND
                     ADD   CO-NUM-1    TO  WK-KHCGU07-NFND-CNT
               WHEN  OTHER
                     MOVE 'KHCGU07'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3311-KHC0007-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   건별여신일때　한도계좌번호로　상품정보　추출
      *-----------------------------------------------------------------
       S3310-KHC0401-SELECT-RTN.

           INITIALIZE    WK-LIMT-P-LAG-CLSFI-CD
                         WK-LIMT-PM-CLSFI-CD
                         WK-LIMT-PRDCT-TMPLT-CD
                         WK-LIMT-PRDCT-NO

           EXEC SQL
