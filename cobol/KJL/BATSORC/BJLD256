      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC  SQL
            DECLARE  THKJC0000_CUR     CURSOR FOR
             SELECT   'THKJC0101'
                  ,  A.계좌번호
                  ,  A.가수가지급종류코드
                  ,  A.고객식별자
                  ,  A.고객관리번호
                  ,  A.통화코드
                  ,  A.원장상태구분
                  ,  A.가수금잔액
                  ,  A.신규년월일
                  ,  A.정리년월일
                  ,  A.관리부점코드
                  ,  B.통합계정과목코드
               FROM  DB2DBA.THKJC0101 A
                  ,  DB2DBA.THKJC0104 B
              WHERE  A.그룹회사코드  = :WK-H-I-GROUP-CO-CD
                AND  A.고객식별자   <> ' '
                AND ( A.정리년월일  >= :WK-H-I-BASE-YMD
                 OR   A.정리년월일   = ' ')
                AND  A.원장상태구분 IN ('1','2')
                AND  A.관리부점코드   <> :WK-H-I-BRNCD
                AND  A.가수금잔액 > 0
                AND  A.그룹회사코드      = B.그룹회사코드
                AND  A.가수가지급종류코드= B.가수가지급종류코드
                AND  B.통합계정과목코드
                           IN ( SELECT 통합계정과목코드
                                  FROM  DB2DBA.THKJL0018
                                 WHERE 그룹회사코드
                                         = :WK-H-I-GROUP-CO-CD
                                   AND 기준년월
                                         = :WK-H-I-BASE-YM
                                   AND 상품대분류코드= 'GA'
                                   AND 통합계정과목코드
                                             <> '0000000000000')
              UNION  ALL
             SELECT   'THKJC0102'
                  ,  A.계좌번호
                  ,  A.가수가지급종류코드
                  ,  A.고객식별자
                  ,  A.고객관리번호
                  ,  A.통화코드
                  ,  A.원장상태구분
                  ,  A.가지급잔액
                  ,  A.신규년월일
                  ,  A.정리년월일
                  ,  A.관리부점코드
                  ,  B.통합계정과목코드
               FROM  DB2DBA.THKJC0102 A
                  ,  DB2DBA.THKJC0104 B
              WHERE  A.그룹회사코드  = :WK-H-I-GROUP-CO-CD
                AND  A.고객식별자   <> ' '
                AND ( A.정리년월일  >= :WK-H-I-BASE-YMD
                 OR   A.정리년월일   = ' ')
                AND  A.원장상태구분 IN ('1','2')
                AND  A.관리부점코드   <> :WK-H-I-BRNCD
                AND  A.가지급잔액 > 0
                AND  A.그룹회사코드      = B.그룹회사코드
                AND  A.가수가지급종류코드= B.가수가지급종류코드
                AND  B.통합계정과목코드
                           IN ( SELECT 통합계정과목코드
                                  FROM  DB2DBA.THKJL0018
                                 WHERE 그룹회사코드
                                         = :WK-H-I-GROUP-CO-CD
                                   AND 기준년월
                                         = :WK-H-I-BASE-YM
                                   AND 상품대분류코드= 'GA'
                                   AND 통합계정과목코드
                                             <> '0000000000000')
               WITH UR
           END-EXEC.
