              WHERE  그룹회사코드    = :WK-H-I-GROUP-CO-CD
                AND  기준년월        = :WK-H-I-BASE-YM
                AND  상품대분류코드  = 'GA'
                AND  통합계정과목코드= :WK-H-O-INTGRA-TIACC-CD
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     #USRLOG 'KJL0018 NOT CD : ' WK-H-O-INTGRA-TIACC-CD
