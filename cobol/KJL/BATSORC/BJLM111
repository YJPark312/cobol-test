           EXEC SQL
            DECLARE  THKJL0011_CUR     CURSOR FOR
             SELECT  그룹회사코드
                  ,  고객식별자
                  ,  한도고객구분
                  ,  "TE기업규모구분"
                  ,  고객관리부점코드
                  ,  VALUE(내부신용평가등급구분,'0000')
                  ,  신용평가년월일
                  ,  신표준산업분류코드
                  ,  기준한도
                  ,  기준한도산출년월일
                  ,  관리한도
                  ,  관리한도설정년월일
                  ,  관리한도유효년월일
                  ,  여신성관리한도
                  ,  시장성관리한도
                  ,  외화기준한도
                  ,  외화신용공여한도
                  ,  외화한도설정년월일
                  ,  외화한도유효년월일
               FROM  DB2DBA.THKJL0011
              WHERE  그룹회사코드        = :WK-H-I-GROUP-CO-CD
                AND  기준년월            = :WK-H-I-TTMM-END-YM
                AND  관리한도유효년월일 >= :WK-H-I-MGT-LIMT-VALD-YMD
           END-EXEC.
