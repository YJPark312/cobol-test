      *-----------------------------------------------------------------
      *@   БЙКАРЭНКЦїСЎАшСТИэММ(THKJL0055)ЕюЗЯ
      *-----------------------------------------------------------------
       S3300-KJL0055-INSERT-RTN.

           INITIALIZE    TKJL0055-KEY
                         TRJL0055-REC

      *    БзЗьШИЛчФкЕх
           MOVE  WK-H-I-GROUP-CO-CD
             TO  RJL0055-GROUP-CO-CD

      *    БтСиГтПљРЯ
           MOVE  WK-H-I-BASE-YMD
             TO  RJL0055-BASE-YMD

      *    АшСТЙјШЃЃНХыЧеЦЎЗЙРЬЕхЙјШЃ
           MOVE  WK-H-O-INTGRA-TRD-NO
             TO  RJL0055-ACNO

      *    АшСТСпКЙРЯЗУЙјШЃ
           ADD   CO-NUM-1              TO  WK-SEQ
           MOVE  WK-SEQ
             TO  RJL0055-ACN-DUP-SERNO

      *    АэАДНФКАРк
           MOVE  WK-H-O-CUST-IDNFR
             TO  RJL0055-CUST-IDNFR

      *    АэАДАќИЎЙјШЃ
           MOVE  WK-H-O-CUST-MGT-NO
             TO  RJL0055-CUST-MGT-NO

      *    АшОрЧбЕЕБИКа
           MOVE  CO-CHA-04
             TO  RJL0055-CTRC-LIMT-DSTCD

      *    ЛѓЧАДыКаЗљФкЕх
           MOVE  WK-H-O-PRDCT-LAG-CLSFI-CD
             TO  RJL0055-PRDCT-LAG-CLSFI-CD

      *    ЛѓЧАСпКаЗљФкЕх
           MOVE  WK-H-O-PRDCT-MEDM-CLSFI-CD
             TO  RJL0055-PRDCT-MEDM-CLSFI-CD

      *    ЛѓЧАХлЧУИДФкЕх
           MOVE  WK-H-O-PRDCT-TMPLT-CD
             TO  RJL0055-PRDCT-TMPLT-CD

      *    ЛѓЧАЙјШЃ
           MOVE  WK-H-O-PRDCT-NO
             TO  RJL0055-PRDCT-NO

      *    ДыУтРкАнБИКа
           MOVE  SPACE
             TO  RJL0055-LN-QULFI-DSTCD

      *    БЙАЁФкЕх
           MOVE  WK-H-O-ISO-NATNL-CD
             TO  RJL0055-ISO-NATNL-CD

      *    АќИЎКЮСЁФкЕх
           MOVE  WK-H-O-MGT-BRNCD
             TO  RJL0055-MGT-BRNCD

      *    НУРлГтПљРЯ
           IF  WK-H-O-BUY-YMD = SPACES  OR
               WK-H-O-BUY-YMD = '00000000'
           THEN
               MOVE  '00010101'
                 TO  RJL0055-START-YMD
           ELSE
      *      НУРлГтПљРЯ
               MOVE  WK-H-O-BUY-YMD
                 TO  RJL0055-START-YMD
           END-IF

      *    ИИБтГтПљРЯ
           MOVE  '00010101'
             TO  RJL0055-EXPIR-YMD

      *    СОЗсГтПљРЯ
           MOVE  '00010101'
             TO  RJL0055-END-YMD

      *    АњИёФкЕх
           MOVE  CO-CHA-R01
             TO  RJL0055-SBJCT-CD

      *    ХыШ­ФкЕх
           MOVE  WK-H-O-CNCYCD
             TO  RJL0055-CNCYCD

      *    ХыШ­ЧбЕЕ
           MOVE  WK-H-O-FC-ACBK-AMT
             TO  RJL0055-CRNCY-CLAM

      *    ХыШ­БнРЯРмОз
           MOVE  WK-H-O-FC-ACBK-AMT
             TO  RJL0055-CRNCY-TDD-BAL

      *    USDЧбЕЕ
           MOVE  WK-H-O-USD-ACBK-AMT
             TO  RJL0055-USD-CLAM

210218*   ПЌАсДыЛѓРкШИЛч СжНФРК USDЧбЕЕ = 0 УГИЎ
           IF  WK-H-O-CUST-IDNFR = SPACES
      *        USDЧбЕЕ
               MOVE  WK-H-O-USD-ACBK-AMT
                 TO  RJL0055-USD-CLAM

           ELSE
               PERFORM S3310-KJL0025-SELECT-RTN
                  THRU S3310-KJL0025-SELECT-EXT

               IF  WK-SUB-COMP-YN = '1'
      *            USDЧбЕЕ
                   MOVE  ZERO
                     TO  RJL0055-USD-CLAM
               ELSE
      *            USDЧбЕЕ
                   MOVE  WK-H-O-USD-ACBK-AMT
                     TO  RJL0055-USD-CLAM
               END-IF
           END-IF

      *    USDБнРЯРмОз
           MOVE  WK-H-O-USD-ACBK-AMT
             TO  RJL0055-USD-TDD-BAL

      **DB  LOG  WRITE START
           IF  WK-AC-INSERT-CNT < CO-NUM-1000
               SET  COND-DBIO-CHGLOG-YES  TO TRUE
           ELSE
               SET  COND-DBIO-CHGLOG-NO   TO TRUE
           END-IF

           #DYDBIO  INSERT-CMD-Y TKJL0055-PK TRJL0055-REC

           EVALUATE  TRUE
               WHEN  COND-DBIO-OK
                     ADD   CO-NUM-1    TO  WK-AC-INSERT-CNT
               WHEN  OTHER
                     MOVE 'KJL0055'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'INSERT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  DBIO-SQLCODE
                                       TO  XZUGEROR-I-SQL-CD
                     MOVE 'INSERTНУ ПРЗљАЁ ЙпЛ§ЧпНРДЯДй'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 DBIO-STAT
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *    1000АЧЁЁИЖДйЁЁ COMMIT
           IF  FUNCTION MOD(WK-AC-FETCH-CNT,1000) = CO-NUM-0
           THEN
               #USRLOG '* WK-AC-FETCH-CNT  = ' WK-AC-FETCH-CNT
               EXEC SQL
                 COMMIT
               END-EXEC

      * Commit УГИЎАсАњ SQL-CODEИІ ШЎРЮЧЯПЉ СЄЛѓ/ПРЗљ УГ
               EVALUATE  SQLCODE
                   WHEN  CO-OK
                         CONTINUE
                   WHEN  OTHER
                         MOVE 'KJL0055'    TO  XZUGEROR-I-TBL-ID
                         MOVE 'COMMIT'     TO  XZUGEROR-I-FUNC-CD
                         MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                         MOVE 'DBCommitНУПРЗљАЁЙпЛ§ЧпНРДЯДй '
                                           TO  XZUGEROR-I-MSG
                         #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                         #OKEXIT CO-CHA-08
               END-EVALUATE
           END-IF
           .
       S3300-KJL0055-INSERT-EXT.
           EXIT.

