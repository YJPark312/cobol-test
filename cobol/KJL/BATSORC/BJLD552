           #DYDBIO  SELECT-CMD-Y TKJL0025-PK TRJL0025-REC

           EVALUATE  TRUE
               WHEN  COND-DBIO-OK
                     ADD   CO-NUM-1    TO  WK-AC-SELECT-OK

                     IF    (WK-H-O-PRDCT-LAG-CLSFI-CD  = 'KT'
