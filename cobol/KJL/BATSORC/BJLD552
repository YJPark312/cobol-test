      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKJLR011_CUR     CURSOR WITH HOLD FOR
             SELECT  A.ХыЧеЦЎЗЙРЬЕхЙјШЃ
                  ,  VALUE(A.АэАДНФКАРк,' ')
                  ,  A.АэАДАќИЎЙјШЃ
                  ,  A.ХыШ­ФкЕх
                  ,  A.ПмШ­РхКЮБнОз
                  ,  A.АќИЎКЮСЁФкЕх
                  ,  VALUE(B.ЛѓЧАДыКаЗљФкЕх,' ')
                  ,  VALUE(B.ЛѓЧАСпКаЗљФкЕх,' ')
                  ,  VALUE(B.ЛѓЧАХлЧУИДФкЕх,' ')
                  ,  VALUE(B.ЛѓЧАЙјШЃ,' ')
                  ,  A.ИХРдГтПљРЯ
                  ,  A.ДыЙЬШЏЛъРхКЮБнОз
250626            ,  VALUE(D."ISOБЙАЁФкЕх",A."ISOБЙАЁФкЕх")
                          AS "ISOБЙАЁФкЕх"
                  ,  A.ХыЧеАшСЄАњИёФкЕх
               FROM  DB2DBA.THKJLR011 A --ПмШ­СжНФРмАэЧіШВ
250626               LEFT OUTER JOIN
                     DB2DBA.THKJL0026 D
                 ON  A.БзЗьШИЛчФкЕх     = D.БзЗьШИЛчФкЕх
                AND  A.ХыЧеЦЎЗЙРЬЕхЙјШЃ = D.АшСТЙјШЃ
                  ,  DB2DBA.THKJL0054 B --БЙКААшСЄАњИёФкЕхИёЗЯ
              WHERE  A.БзЗьШИЛчФкЕх = :WK-H-I-GROUP-CO-CD
                AND  A.БтСиГтПљРЯ   = :WK-H-I-BASE-YMD
250626          AND VALUE(D."ISOБЙАЁФкЕх",A."ISOБЙАЁФкЕх") <> 'KR'
                AND  A.АшСЄАњИёФкЕх|| A.АшСЄММАњИёФкЕх
                        NOT IN ('F3250000','F3260000','13802003')
                AND  B.БзЗьШИЛчФкЕх = :WK-H-I-GROUP-CO-CD
                AND  B.БтСиГтПљ     = :WK-H-I-BASE-YM
                AND  B.ЛѓЧАДыКаЗљФкЕх = 'KT'
                AND  A.АшСЄММАњИёФкЕх= B.ЛѓЧАХлЧУИДФкЕх
                AND  A.АшСЄАњИёФкЕх  = B.ЛѓЧАЙјШЃ
                WITH UR
           END-EXEC.

