           DISPLAY '$$ ================================='
           DISPLAY '$$ --  DELETE-CNT2 : ' WK-EDIT-CNT5
           DISPLAY '$$ ================================='

           CLOSE    IN-FILE2

           #OKEXIT  CO-STAT-OK
           .

       S9000-FINAL-EXT.
           EXIT.
