       S3000-PROCESS-RTN.

      *    FILE READ
           PERFORM S3100-READ-FILE-RTN
              THRU S3100-READ-FILE-EXT

      *----LOOPING START
      *   거래종료고객여부　확인
           PERFORM UNTIL WK-FETCH-END   = CO-CY
      *        TABLE DELETE2
               PERFORM S3600-KJL0006-DELETE-RTN
                  THRU S3600-KJL0006-DELETE-EXT

      *        FETCH계속
               PERFORM S3100-READ-FILE-RTN
                  THRU S3100-READ-FILE-EXT

           END-PERFORM
      *----LOOPING END
           .

       S3000-PROCESS-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   READ FILE
      *-----------------------------------------------------------------
       S3100-READ-FILE-RTN.

      *@1  READ FILE
           READ  IN-FILE2      AT  END
           MOVE  CO-CY         TO  WK-FETCH-END
           END-READ

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  WK-IN-FILE-STAT2
               WHEN  ZERO
               WHEN  '04'
                    ADD  CO-N1         TO WK-READ-CNT

      *             KEY MOVE
      *            그룹회사코드
                    MOVE RJL0006-GROUP-CO-CD
                      TO KJL0006-PK-GROUP-CO-CD
      *            한도신청번호
                    MOVE RJL0006-LIMT-APLCN-NO
                      TO KJL0006-PK-LIMT-APLCN-NO
               WHEN  '10'
                     MOVE  CO-CY       TO  WK-FETCH-END
               WHEN  OTHER
                     MOVE 'IN-FILE OPEN ERROR : FILE-ST IS '
                                       TO  XZUGEROR-I-MSG
                     MOVE  WK-IN-FILE-STAT2  TO  XZUGEROR-I-MSG(34:2)
                     #ERROR  CO-EBM02001 CO-UBM02001 WK-IN-FILE-STAT2
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3100-READ-FILE-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  THKJL0006 DELETE2
      *-----------------------------------------------------------------
       S3600-KJL0006-DELETE-RTN.

           EXEC SQL
           DELETE
             FROM DB2DBA.THKJL0006
            WHERE 그룹회사코드        =  :KJL0006-PK-GROUP-CO-CD
              AND 한도신청번호        =  :KJL0006-PK-LIMT-APLCN-NO
           END-EXEC

           EVALUATE SQLCODE
               WHEN ZERO
                    ADD  CO-N1         TO WK-DELETE-CNT2

                    IF FUNCTION MOD(WK-DELETE-CNT2, 500)  =  ZERO
                        EXEC  SQL  COMMIT  END-EXEC
                    END-IF
                    IF FUNCTION MOD(WK-DELETE-CNT2, 10000)  =  ZERO
                        DISPLAY '$$ DELETE CNT2 : ' WK-DELETE-CNT2
                    END-IF

               WHEN OTHER
                    DISPLAY 'SQL DELETE오류입니다.'
                    DISPLAY 'SQLCODE = ' SQLCODE
                    MOVE 'KJL0006'     TO XZUGEROR-I-TBL-ID
                    MOVE 'DELETE'      TO XZUGEROR-I-FUNC-CD
                    MOVE SQLCODE       TO XZUGEROR-I-SQL-CD
                    MOVE 'DELETE ERR ' TO XZUGEROR-I-MSG
           END-EVALUATE
           .

       S3600-KJL0006-DELETE-EXT.
           EXIT.

