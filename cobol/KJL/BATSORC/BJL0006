           ACCEPT  WK-SYSIN  FROM    SYSIN

           DISPLAY '*------------------------------------------*'
           DISPLAY '* BJL0006 PGM START                        *'
           DISPLAY '*------------------------------------------*'
           DISPLAY '* WK-SYSIN      = ' WK-SYSIN

      *    FILE OPEN
           OPEN  INPUT  IN-FILE2

      *    FILE CHECK OUTDATA
           IF WK-IN-FILE-STAT2   NOT = CO-STAT-OK
              DISPLAY 'BJL0006:S1000 IN-F2 OPEN ERROR.'
                       WK-IN-FILE-STAT2
              #ERROR CO-EBM01001 CO-UBM01001 CO-STAT-ERROR
              #OKEXIT CO-CHA-08
           END-IF
