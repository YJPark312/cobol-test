      *@  파생상품거래별평가금액(THKJLR008)등록
      *-----------------------------------------------------------------
       S3300-KJLR008-INSERT-RTN.

      *@   초기화
           INITIALIZE TKJLR008-KEY
                      TRJLR008-REC

      *@   그룹회사코드
           MOVE WK-H-I-GROUP-CO-CD
             TO RJLR008-GROUP-CO-CD

      *@   기준년월일
           MOVE WK-H-I-BASE-YMD
             TO RJLR008-BASE-YMD

      *@   외화거래번호
           MOVE IN-FC-TRAN-NO
             TO RJLR008-FC-TRAN-NO

      *@   파생상품구분
           MOVE IN-DRVT-PRDCT-CD
             TO RJLR008-DRVT-PRDCT-DSTCD

      *@   일련번호<-SEQ+1
           ADD   CO-NUM-1  TO  WK-SEQ
           MOVE  WK-SEQ
             TO  RJLR008-SERNO

      *@   차주번호
           MOVE IN-BRWR-NO
             TO RJLR008-BRWR-NO

      *@   외화고객고유번호
           MOVE IN-FC-CUNIQNO
             TO RJLR008-FC-CUNIQNO

      *@   고객식별자
           MOVE IN-CUST-IDNFR
             TO RJLR008-CUST-IDNFR

      *@   고객관리번호
           MOVE IN-CUST-MGT-NO
             TO RJLR008-CUST-MGT-NO

      *-----------------------------------------------------------------
      *백현정:20100531: 인스턴스코드（여부）Y/N -> 1/0으로　변경
      *-----------------------------------------------------------------
      *@   네팅여부
           IF  IN-NTNG-YN = CO-CHA-Y
           THEN
               MOVE CO-CHA-1
                 TO RJLR008-NTNG-YN
           ELSE
               MOVE CO-CHA-0
                 TO RJLR008-NTNG-YN
           END-IF
      *-----------------------------------------------------------------

      *@   외화상품유형구분
           MOVE IN-PRDCT-PTRN-CD(1:3)
             TO RJLR008-FC-PRDCT-PTRN-DSTCD

      *@   매입매도구분
           MOVE IN-BUY-SELLZ-DSTCD
             TO RJLR008-BUY-SELLZ-DSTCD

      *@   거래년월일
           MOVE IN-TRAN-YMD
             TO RJLR008-TRAN-YMD

      *@   만기년월일
           MOVE IN-EXPIR-YMD
             TO RJLR008-EXPIR-YMD

      *@   거래통화코드
           MOVE IN-TRAN-CNCYCD
             TO RJLR008-TRAN-CNCYCD

      *@   거래통화금액
           MOVE IN-TRAN-CRNCY-AMT
             TO RJLR008-TRAN-CRNCY-AMT

      *@   상대통화코드
           MOVE IN-CNPRT-CNCYCD
             TO RJLR008-CNPRT-CNCYCD

      *@   상대통화금액
           MOVE IN-CNPRT-CRNCY-AMT
             TO RJLR008-CNPRT-CRNCY-AMT

      *@   평가금액
           MOVE IN-VALPR
             TO RJLR008-VALPR

      *@   추가항목금액
           MOVE IN-SUPPL-ITEM-AMT
             TO RJLR008-SUPPL-ITEM-AMT

      *@   영업부점코드
           MOVE IN-BRNCD
             TO RJLR008-BZOPR-BRNCD

      *@   ISO국가코드
           MOVE IN-ISO-NATNL-CD
             TO RJLR008-ISO-NATNL-CD

      *@   DBIO CALL
           #DYDBIO  INSERT-CMD-Y TKJLR008-PK TRJLR008-REC

      *@   결과확인
           EVALUATE TRUE
               WHEN COND-DBIO-OK
                    ADD  CO-NUM-1    TO  WK-AC-INSERT-CNT
               WHEN OTHER
                    MOVE 'KJLR008'   TO  XZUGEROR-I-TBL-ID
                    MOVE 'INSERT'    TO  XZUGEROR-I-FUNC-CD
                    MOVE DBIO-SQLCODE
                      TO XZUGEROR-I-SQL-CD
                    MOVE 'INSERT시 오류가 발생했습니다'
                      TO XZUGEROR-I-MSG
                    #ERROR  CO-EBM02001 CO-UBM02001 DBIO-STAT
                    #USRLOG 'TRAN-NO = ' IN-FC-TRAN-NO
                    #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3300-KJLR008-INSERT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  처리종료
      *-----------------------------------------------------------------
       S9000-FINAL-RTN.

      *@   CLOSE  FILE
           CLOSE  IN-FILE

      *@   파일상태확인
           IF WK-IN-F-ST NOT = CO-STAT-OK
              MOVE 'IN-FILE CLOSE ERROR : FILE-ST IS '
                TO XZUGEROR-I-MSG
              MOVE WK-IN-F-ST  TO  XZUGEROR-I-MSG(34:2)
              #ERROR  CO-EBM02001 CO-UBM02001 WK-IN-F-ST
              #OKEXIT CO-CHA-08
           END-IF

           #USRLOG '*--------------------------------------*'
           #USRLOG '* FILE READ       COUNT  = ' WK-AC-READ-CNT
           #USRLOG '* KJLR008 INSERT  COUNT  = ' WK-AC-INSERT-CNT
           #USRLOG '*--------------------------------------*'
           #USRLOG '* BJLDR81 PGM END                      *'
           #USRLOG '*--------------------------------------*'
           #OKEXIT  CO-CHA-00
           .
       S9000-FINAL-EXT.
           EXIT.
