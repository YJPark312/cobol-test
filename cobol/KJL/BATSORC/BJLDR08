      *-----------------------------------------------------------------
       S3000-KJLR004-DELETE-RTN.

      *@원장을삭제하기전에테이블LOCK
           EXEC SQL
               LOCK TABLE DB2DBA.THKJLR004 IN EXCLUSIVE MODE
           END-EXEC

      *@원장삭제
           EXEC SQL
             DELETE FROM  DB2DBA.THKJLR004
              WHERE 그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND 기준년월일   = :WK-H-I-BASE-YMD
           END-EXEC

      *@삭제결과확인
           EVALUATE SQLCODE
               WHEN CO-OK
               WHEN CO-NOT-FOUND
                    #USRLOG '<< THKJLR004 DELETE 1 OK >>'
               WHEN OTHER
                    MOVE 'KJLR004'    TO  XZUGEROR-I-TBL-ID
                    MOVE 'DELETE'     TO  XZUGEROR-I-FUNC-CD
                    MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                    MOVE 'DELETE시 오류가 발생했습니다'
                      TO  XZUGEROR-I-MSG
      *에러메시지:내부 본 처리
                    #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                    #OKEXIT CO-CHA-08
           END-EVALUATE

           EXEC SQL
             COMMIT
           END-EXEC

      *@Commit 처리결과 SQL-CODE를 확인하여 정상/오류 처리
           EVALUATE SQLCODE
               WHEN CO-OK
                    CONTINUE
               WHEN OTHER
                    MOVE 'KJLR004'   TO  XZUGEROR-I-TBL-ID
                    MOVE 'COMMIT'    TO  XZUGEROR-I-FUNC-CD
                    MOVE SQLCODE     TO  XZUGEROR-I-SQL-CD
                    MOVE 'DB Commit 시 오류가 발생했습니다'
                      TO XZUGEROR-I-MSG
                    #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                    #OKEXIT CO-CHA-08
           END-EVALUATE



      *@  3개월전 과거분 원장삭제
           EXEC SQL
             DELETE FROM  DB2DBA.THKJLR004
              WHERE 그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND 기준년월일   < TO_CHAR(TO_DATE(
                    :WK-H-I-BASE-YMD,'YYYYMMDD') - 3 MONTH,'YYYYMMDD')
           END-EXEC

      *@삭제결과확인
           EVALUATE SQLCODE
