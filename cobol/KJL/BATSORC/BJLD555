      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *@투자금융관련한도의경우별도의한도산출방식을적용함2010.01.24
      *@대분류코드：２５이면서
      *@중분로코드：６１，６２，６３，６４인경우가투자금융외화한도
      *--------------------------------------------------------------
      * 2010.06.28:상품정보등록여신만　국별익스포져대상(THKJL0054)
      *--------------------------------------------------------------
           EXEC SQL
            DECLARE  THKHC0401_CUR   CURSOR  WITH HOLD FOR
             SELECT  A.계좌번호
                  ,  A.통화코드
                  ,  A.상품대분류코드
                  ,  A.상품중분류코드
                  ,  A.상품템플릿코드
                  ,  A.상품번호
                  ,  A.계약자고객식별자
                  ,  A.계약자고객관리번호
                  ,  A.관리부점코드
                  ,  A.상품계약약정년월일
                  ,  A.상품계약만기년월일
                  ,  A.상품계약폐기년월일
                  ,  A.한도계좌여부
                  ,  A.계약금액
                  ,  A.한도사용금액
                  ,  A.대출실행누계금액
                  ,  A.한도계좌관리구분
                  ,  VALUE((SELECT 분할인출가능종료일
                     FROM DB2DBA.THKHC0481
                     WHERE 그룹회사코드 = A.그룹회사코드
                       AND 계좌번호 = A.계좌번호),' ') AS
                     분할인출가능종료일
250626            ,  VALUE(D."ISO국가코드",
                           B."모기업ISO국가코드")
                          AS "ISO국가코드"
               FROM  DB2DBA.THKHC0401 A
250626               LEFT OUTER JOIN
                     DB2DBA.THKJL0026 D
                 ON  A.그룹회사코드 = D.그룹회사코드
                AND  A.계좌번호     = D.계좌번호
                  ,  DB2DBA.THKJL0015 B
                  ,  DB2DBA.THKJL0054 C
              WHERE  A.그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND  A.상품계약상태구분 = '1'
                AND (A.상품계약폐기년월일 >= :WK-H-I-BASE-YMD
                 OR  A.상품계약폐기년월일  = ' ')
                AND  A.그룹회사코드     = B.그룹회사코드
                AND  A.계약자고객식별자 = B.고객식별자
250626          AND VALUE(D."ISO국가코드",
                          B."모기업ISO국가코드") <> 'KR'
                AND  C.그룹회사코드  = :WK-H-I-GROUP-CO-CD
                AND  C.기준년월      = :WK-H-I-BASE-YM
                AND  A.상품대분류코드= C.상품대분류코드
                AND  A.상품중분류코드= C.상품중분류코드
                AND  A.상품템플릿코드= C.상품템플릿코드
                AND  A.상품번호      = C.상품번호
           END-EXEC.

