      *-----------------------------------------------------------------
      *@   CURSOR FETCH
      *-----------------------------------------------------------------
       S3200-KJLR001-FETCH-RTN.

           INITIALIZE    WK-HOST-OUT

           EXEC SQL
              FETCH  THKHC0401_CUR
               INTO  :WK-HOST-OUT
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     ADD   CO-NUM-1    TO  WK-AC-FETCH-CNT
               WHEN  CO-NOT-FOUND
                     SET   EOF-Y       TO  TRUE
               WHEN  OTHER
                     MOVE 'KJLR001'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR FETCH시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3200-KJLR001-FETCH-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   국별익스포져계좌명세(THKJL0055)등록
      *-----------------------------------------------------------------
       S3300-KJL0055-INSERT-RTN.

           INITIALIZE    TKJL0055-KEY
                         TRJL0055-REC

      *    그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  RJL0055-GROUP-CO-CD

      *    기준년월일
           MOVE  WK-H-I-BASE-YMD
             TO  RJL0055-BASE-YMD

      *    계좌번호
           MOVE  WK-H-O-ACNO
             TO  RJL0055-ACNO

      *    계좌중복일련번호
           ADD   CO-NUM-1              TO  WK-SEQ
           MOVE  WK-SEQ
             TO  RJL0055-ACN-DUP-SERNO

      *    고객식별자
           MOVE  WK-H-O-CTCR-CUST-ID
             TO  RJL0055-CUST-IDNFR

      *    고객관리번호
           MOVE  WK-H-O-CTCR-CUST-MGT-NO
             TO  RJL0055-CUST-MGT-NO

      *    관리부점코드
           MOVE  WK-H-O-MGT-BRNCD
             TO  RJL0055-MGT-BRNCD

      *@한도성여신／건별여신　구분
           IF  WK-H-O-LIMT-ACN-YN = CO-CHA-1
           THEN
               ADD  CO-NUM-1
                TO  WK-KHD-CNT
      *@한도성여신이면　계약한도구분 = '01'
      *      계약한도구분
              MOVE  CO-CHA-01
                TO  RJL0055-CTRC-LIMT-DSTCD
           ELSE
      *@건별여신이면　　계약한도구분 = '03'
               ADD  CO-NUM-1
                TO  WK-KTS-CNT
      *      계약한도구분
              MOVE  CO-CHA-03
                TO  RJL0055-CTRC-LIMT-DSTCD
           END-IF

      *    상품대분류코드
           MOVE  WK-H-O-PRDCT-LAG-CLSFI-CD
             TO  RJL0055-PRDCT-LAG-CLSFI-CD

      *    상품중분류코드
           MOVE  WK-H-O-PRDCT-MEDM-CLSFI-CD
             TO  RJL0055-PRDCT-MEDM-CLSFI-CD

      *    상품템플릿코드
           MOVE  WK-H-O-PRDCT-TMPLT-CD
             TO  RJL0055-PRDCT-TMPLT-CD

      *    상품번호
           MOVE  WK-H-O-PRDCT-NO
             TO  RJL0055-PRDCT-NO

      *    대출자격구분
           MOVE  SPACE
             TO  RJL0055-LN-QULFI-DSTCD

      *    국가코드
           MOVE  WK-H-O-ISO-NATNL-CD
             TO  RJL0055-ISO-NATNL-CD

      *    관리부점코드
           MOVE  WK-H-O-MGT-BRNCD
             TO  RJL0055-MGT-BRNCD

      *    시작년월일
           MOVE  WK-H-O-PRDCT-C-CRETN-YMD
             TO  RJL0055-START-YMD

      *    만기년월일
           IF   WK-H-O-PRDCT-C-EXPIR-YMD = SPACES
           THEN
               MOVE  '00010101'
                 TO  RJL0055-EXPIR-YMD
           ELSE
               MOVE  WK-H-O-PRDCT-C-EXPIR-YMD
                 TO  RJL0055-EXPIR-YMD
           END-IF

      *    종료년월일
           MOVE  SPACE
             TO  RJL0055-END-YMD

      *@과목코드　한도성여신= KHD ,건별여신= KTS
           IF  WK-H-O-LIMT-ACN-YN = CO-CHA-1
           THEN
      *       과목코드
               MOVE  CO-CHA-KHD
                 TO  RJL0055-SBJCT-CD
           ELSE
      *       과목코드
               MOVE  CO-CHA-KTS
                 TO  RJL0055-SBJCT-CD
           END-IF

      *    통화코드
           MOVE  WK-H-O-CNCYCD
             TO  RJL0055-CNCYCD

      *@한도성여신일때
           IF  WK-H-O-LIMT-ACN-YN = CO-CHA-1
           THEN
      *@통화한도금액산출요건분기
               IF WK-H-O-PATIN-WA-END-YMD >= WK-H-I-BASE-YMD
               THEN
      *@분할인출가능일이기준일보다크거나같으면
      *@통화한도금액＝계약금액－대출실행누계금액＋한도사용금액
                    COMPUTE  RJL0055-CRNCY-CLAM
                          =  WK-H-O-CNPR -
                             WK-H-O-LN-EXE-CUTAMT +
                             WK-H-O-LIMT-AMUS
               ELSE
      *@건별여신일때
      *@분할인출가능일이지났으면
      *@통화한도금액＝한도사용금액
                    MOVE  WK-H-O-LIMT-AMUS
                      TO  RJL0055-CRNCY-CLAM
               END-IF
      *@통화금일잔액＝０
      *       통화금일잔액
               MOVE  ZERO
                 TO  RJL0055-CRNCY-TDD-BAL
           ELSE
      *@건별여신＝잔액
               PERFORM  S3310-KHDM100-SELECT-RTN
                  THRU  S3310-KHDM100-SELECT-EXT

      *       통화한도= 0
               MOVE  ZERO
                 TO  RJL0055-CRNCY-CLAM

      *       통화금일잔액= THKHDM100잔액
               MOVE  WK-CRNCY-BAL
                 TO  RJL0055-CRNCY-TDD-BAL
           END-IF

      *@  통화한도가USD이면
           IF RJL0055-CNCYCD = CO-CHA-USD
           THEN
      *@  한도성여신이면　통화한도금액
               IF  WK-H-O-LIMT-ACN-YN = CO-CHA-1
               THEN
                   MOVE  RJL0055-CRNCY-CLAM
                     TO  WK-USD-RR-SELL-AMT
      *@  건별여신이면　　통화금일잔액
               ELSE
                   MOVE  RJL0055-CRNCY-TDD-BAL
                     TO  WK-USD-RR-SELL-AMT
               END-IF
           ELSE
      *@  통화한도가USD아니면
      *@   USD금액으로　대미환산금액　추출
      *@  대미환산율조회한다.
               PERFORM  S3320-CJIEX01-CALL-RTN
                  THRU  S3320-CJIEX01-CALL-EXT

      *@  한도성여신이면　통화한도금액
               IF  WK-H-O-LIMT-ACN-YN = CO-CHA-1
               THEN
      *대미환산율＝０이면　역환산　１로　나눔
      * USD역환산매도금액계산한다＝통화한도＊대미환산율／환율고시단위
                   COMPUTE  WK-USD-RR-SELL-AMT
                         =  RJL0055-CRNCY-CLAM
                         *  WK-USD-RT
                         /  WK-HWGSCD
      *@  건별여신이면　　통화금일잔액
               ELSE
      *대미환산율＝０이면　역환산　１로　나눔
      * USD역환산매도금액계산한다＝통화잔액＊대미환산율／환율고시단위
                   COMPUTE  WK-USD-RR-SELL-AMT
                         =  RJL0055-CRNCY-TDD-BAL
                         *  WK-USD-RT
                         /  WK-HWGSCD
               END-IF
           END-IF

      *----------------------------------------------
      *@한도성여신일때
      *@  만기전: 한도(O)      잔액(X)
      *@  만기후: 한도(X)      잔액(X)
      *----------------------------------------------
           EVALUATE  WK-H-O-LIMT-ACN-YN
             WHEN  CO-CHA-1
               IF WK-H-O-PRDCT-C-EXPIR-YMD >= WK-H-I-BASE-YMD OR
                  WK-H-O-PRDCT-C-EXPIR-YMD = '00010101'
               THEN
      *          USD한도
                   MOVE  WK-USD-RR-SELL-AMT
                     TO  RJL0055-USD-CLAM

      *          USD금일잔액
                   MOVE  ZERO
                     TO  RJL0055-USD-TDD-BAL
               ELSE
      *          USD한도
                   MOVE  ZERO
                     TO  RJL0055-USD-CLAM

      *          USD금일잔액
                   MOVE  ZERO
                     TO  RJL0055-USD-TDD-BAL
               END-IF
      *----------------------------------------------
      *@건별여신일때
      *@ USD한도＝대미환산금액, USD금일잔액= 0
      *@   만기전: 한도(X)      잔액(O)
      *@   만기후: 한도(O)   =  잔액(O)
      *----------------------------------------------
             WHEN  OTHER
               IF WK-H-O-PRDCT-C-EXPIR-YMD >= WK-H-I-BASE-YMD OR
                  WK-H-O-PRDCT-C-EXPIR-YMD = '00010101'
               THEN
      *          USD한도
                   MOVE  ZERO
                     TO  RJL0055-USD-CLAM

      *          USD금일잔액
                   MOVE  WK-USD-RR-SELL-AMT
                     TO  RJL0055-USD-TDD-BAL
               ELSE
      *          USD한도
                   MOVE  WK-USD-RR-SELL-AMT
                     TO  RJL0055-USD-CLAM

      *          USD금일잔액
                   MOVE  WK-USD-RR-SELL-AMT
                     TO  RJL0055-USD-TDD-BAL
               END-IF
           END-EVALUATE

           #DYDBIO  INSERT-CMD-Y TKJL0055-PK TRJL0055-REC

           EVALUATE  TRUE
               WHEN  COND-DBIO-OK
                     ADD   CO-NUM-1    TO  WK-AC-INSERT-CNT
               WHEN  OTHER
                     MOVE 'KJL0055'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'INSERT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  DBIO-SQLCODE
                                       TO  XZUGEROR-I-SQL-CD
                     MOVE 'INSERT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 DBIO-STAT
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *    1000건　마다　 COMMIT
           IF  FUNCTION MOD(WK-AC-FETCH-CNT,1000) = CO-NUM-0
           THEN
               #USRLOG '* WK-AC-FETCH-CNT  = ' WK-AC-FETCH-CNT
               EXEC SQL
                 COMMIT
               END-EXEC

      * Commit 처리결과 SQL-CODE를 확인하여 정상/오류 처
               EVALUATE  SQLCODE
                   WHEN  CO-OK
                         CONTINUE
                   WHEN  OTHER
                         MOVE 'KJL0055'    TO  XZUGEROR-I-TBL-ID
                         MOVE 'COMMIT'     TO  XZUGEROR-I-FUNC-CD
                         MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                         MOVE 'DBCommit시오류가발생했습니다 '
                                           TO  XZUGEROR-I-MSG
                         #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                         #OKEXIT CO-CHA-08
               END-EVALUATE
           END-IF
           .
       S3300-KJL0055-INSERT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   정산계좌유형별잔액(THKHDM100) 건별여신　잔액　추출
      *-----------------------------------------------------------------
       S3310-KHDM100-SELECT-RTN.

           INITIALIZE    WK-CRNCY-BAL

           EXEC SQL
             SELECT  VALUE(잔액,0)
               INTO  :WK-CRNCY-BAL
               FROM  DB2DBA.THKHDM100
              WHERE 그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND 계좌번호     = :WK-H-O-ACNO
                AND 잔액 > 0
                AND  SUBSTR(금액유형코드,1,2) IN ('41','91')
                AND 잔액유형구분
                           NOT IN ('CD10','CD11','CD12',
                                   'CD13','CD14','CD15','CD16')
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     ADD  CO-NUM-1
                      TO  WK-DM100-SEL-OK
               WHEN  CO-NOT-FOUND
                     ADD  CO-NUM-1
                      TO  WK-DM100-SEL-NO
                     MOVE  ZERO
                       TO  WK-CRNCY-BAL
               WHEN  OTHER
                     MOVE 'KHDM100'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-KHDM100-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   기준환율(CJIEX01) 조회
      *-----------------------------------------------------------------
       S3320-CJIEX01-CALL-RTN.

           INITIALIZE       XCJIEX01-CA

      *@기준한율　조회할때　입력항목SET
      *@  구분코드<-1:지정통화에대한기준환율정보를조회
           MOVE  CO-CHA-1              TO  XCJIEX01-I-DSTCD
      *   그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD    TO  XCJIEX01-I-GROUP-CO-CD
      *@  출력구분코드<-1:통화코드일련번호순으로오름차순정렬
           MOVE  CO-CHA-1              TO  XCJIEX01-I-OUTPT-DSTCD
      *   유효년월일－기준년월일
           MOVE  WK-H-I-BASE-YMD       TO  XCJIEX01-I-BASE-YMD
      *   통화코드
           MOVE  WK-H-O-CNCYCD         TO  XCJIEX01-I-CNCYCD
      *   환율적용회차
           MOVE  CO-NUM-1              TO  XCJIEX01-I-EXRT-APLY-NTH

      *@공통 UTILITY CALL
          #DYCALL   CJIEX01  YCCOMMON-CA  XCJIEX01-CA

      *@RETURN 정보 확인
           IF  XCJIEX01-R-STAT = ZEROS
           THEN

      *     대미환산율
               MOVE  XCJIEX01-O-USD-RT(1)
                 TO  WK-USD-RT

      *      N100단위통화여부
               MOVE  XCJIEX01-O-N100-UNIT-CRNCY-YN(1)
                 TO  WK-N100-UNIT-CRNCY-YN

      *     환율고시단위구분
               IF  WK-N100-UNIT-CRNCY-YN = '1'
                   MOVE 100       TO WK-HWGSCD
               ELSE
                   MOVE 1         TO WK-HWGSCD
               END-IF

           ELSE
                IF  XCJIEX01-R-STAT = CO-CHA-07
                THEN
                   #USRLOG '<---------------------------------------->'
                   #USRLOG '<1.기준일자의　１회차　환율고시　미게시>'
                   #USRLOG '<2. WK-H-I-BASE-YMD  > ' WK-H-I-BASE-YMD
                   #USRLOG '<3. XCJIEX01-R-STAT  > ' XCJIEX01-R-STAT
      *         대미환산율
                   MOVE  CO-NUM-1
                     TO  WK-USD-RT
      *         환율고시단위구분
                   MOVE  CO-NUM-1
                     TO  WK-HWGSCD
                ELSE
                    STRING 'S3320-CJIEX01-CALL-RTN오류가발생했습니다'
                            WK-H-O-ACNO
                    DELIMITED BY SIZE INTO  XZUGEROR-I-MSG
                    #ERROR  XCJIEX01-R-ERRCD
                            XCJIEX01-R-TREAT-CD
                            XCJIEX01-R-STAT
                    #OKEXIT CO-CHA-08
               END-IF
           END-IF
           .
       S3320-CJIEX01-CALL-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR CLOSE
      *-----------------------------------------------------------------
       S3400-KJLR001-CLOSE-RTN.

           EXEC SQL
              CLOSE  THKHC0401_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJLR001'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'CLOSE'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR CLOSE시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3400-KJLR001-CLOSE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  처리종료
      *-----------------------------------------------------------------
       S9000-FINAL-RTN.

           #USRLOG '*--------------------------------------*'
           #USRLOG '* THKHC0401_CUR   COUNT  = ' WK-AC-FETCH-CNT
