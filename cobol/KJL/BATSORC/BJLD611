      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
241121*   재작업용 삭제대상
           EXEC SQL
            DECLARE  KJL0161_DEL_CUR   CURSOR  WITH HOLD FOR
             SELECT  그룹회사코드
                  ,  기준년월일
                  ,  고객식별자
               FROM  DB2DBA.THKJL0161
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월일   = :WK-H-I-BASE-YMD
           END-EXEC

      *
           EXEC SQL
            DECLARE  THKJL0011_CUR     CURSOR WITH HOLD FOR
             SELECT  고객식별자
                  ,  VALUE(
                      CASE
                       WHEN 관리한도유효년월일 >= :WK-H-I-BASE-YMD
                       THEN 관리한도
                       ELSE 0 END,0) 관리한도
                  ,  VALUE(
                      CASE
                       WHEN 관리한도유효년월일 >= :WK-H-I-BASE-YMD
                       THEN 여신성관리한도
                       ELSE 0 END,0) 여신성관리한도
                  ,  VALUE(
                      CASE
                       WHEN 관리한도유효년월일 >= :WK-H-I-BASE-YMD
                       THEN 시장성관리한도
                       ELSE 0 END,0) 시장성관리한도
               FROM  DB2DBA.THKJL0011
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월     = :WK-H-I-BASE-YM
241121          AND  SUBSTR(고객식별자,1,1) NOT IN ('1','2')
           END-EXEC.
