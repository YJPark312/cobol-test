      *-----------------------------------------------------------------
      *@   직접＋간접　명목한도금액　추출
      *-----------------------------------------------------------------
       S3300-KJL0129-SELECT-RTN.

           INITIALIZE    WK-HOST-OUT2

      *백현정:20101112:직접명목액B2B여신제외함
           EXEC SQL
             SELECT  TAB.차주고객식별자
                  ,  SUM(TAB.직접명목액한도) 직접명목액한도
                  ,  SUM(TAB.명목액기준한도) 명목액기준한도
                  ,  SUM(TAB.명목액기준잔액) 명목액기준잔액
                  ,  SUM(TAB."한도TE")        "한도TE"
                  ,  SUM(TAB."잔액TE")        "잔액TE"
                  ,  SUM(TAB."여신성한도TE")  "여신성한도TE"
                  ,  SUM(TAB."여신성잔액TE")  "여신성잔액TE"
                  ,  SUM(TAB."시장성한도TE")  "시장성한도TE"
                  ,  SUM(TAB."시장성잔액TE")  "시장성잔액TE"
               INTO :WK-HOST-OUT2
               FROM
              (SELECT  A.차주고객식별자 차주고객식별자
                    ,  VALUE(명목액기준한도,0) 직접명목액한도
                    ,  VALUE(명목액기준한도,0) 명목액기준한도
                    ,  VALUE(명목액기준잔액,0) 명목액기준잔액
                    ,  VALUE("한도기준TE금액",0)  "한도TE"
                    ,  VALUE("잔액기준TE금액",0)  "잔액TE"
                    ,  VALUE(CASE WHEN B."TE자산구분" = '1'
                                  THEN "한도기준TE금액"
                                  ELSE 0 END,0)  "여신성한도TE"
                    ,  VALUE(CASE WHEN B."TE자산구분" = '1'
                                  THEN "잔액기준TE금액"
                                  ELSE 0 END,0)  "여신성잔액TE"
                    ,  VALUE(CASE WHEN B."TE자산구분" = '2'
                                  THEN "한도기준TE금액"
                                  ELSE 0 END,0)  "시장성한도TE"
                    ,  VALUE(CASE WHEN B."TE자산구분" = '2'
                                  THEN "잔액기준TE금액"
                                  ELSE 0 END,0)  "시장성잔액TE"
                 FROM  DB2DBA.THKJL0129 A
                    ,  DB2DBA.THKJL0118 B
                WHERE  A.그룹회사코드   = :WK-H-I-GROUP-CO-CD
                  AND  A.기준일         = :WK-H-I-BASE-DD
                  AND  A.기준년월       = :WK-H-I-BASE-YM
                  AND  A.차주고객식별자 = :WK-H-O1-CUST-IDNFR
                  AND  A.상품대분류코드|| A.상품중분류코드||
                       A.상품템플릿코드|| A.상품번호
                          NOT  IN ('CR01A0613401','CR01A1413401',
                                   '2539M71A0002','2539M71A0003' )
                  AND  B.그룹회사코드   = :WK-H-I-GROUP-CO-CD
                  AND  B.기준년월       = :WK-H-I-BASE-YM
                  AND  B.상품대분류코드 = A.상품대분류코드
                  AND  B.상품중분류코드 = A.상품중분류코드
                  AND  B.상품템플릿코드 = A.상품템플릿코드
                  AND  B.상품번호       = A.상품번호
                UNION  ALL
               SELECT  담보보증고객식별자        차주고객식별자
                    ,  0                           직접명목액한도
                    ,  VALUE(간접명목금액,0)     명목액기준한도
                    ,  VALUE(간접명목금액,0)     명목액기준잔액
                    ,  VALUE(간접익스포져금액,0)  "한도TE"
                    ,  VALUE(간접익스포져금액,0)  "잔액TE"
                    ,  VALUE(간접익스포져금액,0)  "여신성한도TE"
                    ,  VALUE(간접익스포져금액,0)  "여신성잔액TE"
                    ,  0                            "시장성한도TE"
                    ,  0                            "시장성잔액TE"
                 FROM  DB2DBA.THKJL0031
                WHERE  그룹회사코드     = :WK-H-I-GROUP-CO-CD
                  AND  기준일           = :WK-H-I-BASE-DD
                  AND  기준년월         = :WK-H-I-BASE-YM
                  AND  담보보증고객식별자 = :WK-H-O1-CUST-IDNFR) TAB
                GROUP  BY  TAB.차주고객식별자
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
      *              차주고객식별자
                     MOVE  SPACE
                       TO  WK-H-O2-BRWR-CUST-IDNFR
      *              직접명목액한도
                     MOVE  ZERO
                       TO  WK-H-O2-JIK-TTL-AMT
      *              명목액기준한도
                     MOVE  ZERO
                       TO  WK-H-O2-TTL-AMT-BASE-CLAM
      *              명목액기준잔액
                     MOVE  ZERO
                       TO  WK-H-O2-TTL-AMT-BASE-BAL
      *              한도기준TE금액
                     MOVE  ZERO
                       TO  WK-H-O2-LIMT-BASE-TE-AMT
      *              잔액기준TE금액
                     MOVE  ZERO
                       TO  WK-H-O2-BAL-BASE-TE-AMT
      *              여신성한도기준TE금액
                     MOVE  ZERO
                       TO  WK-H-O2-LNBZ-ILB-EXPSR-AMT
      *              여신성잔액기준TE금액
                     MOVE  ZERO
                       TO  WK-H-O2-LNBZ-IBB-EXPSR-AMT
      *              시장성한도기준TE금액
                     MOVE  ZERO
                       TO  WK-H-O2-MRKTY-LB-EXPSR-AMT
      *              시장성잔액기준TE금액
                     MOVE  ZERO
                       TO  WK-H-O2-MRKTY-BB-EXPSR-AMT
               WHEN  OTHER
                     MOVE 'KJL0129'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
      *에러메시지:내부 본 처리
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3300-KJL0129-SELECT-EXT.
           EXIT.
