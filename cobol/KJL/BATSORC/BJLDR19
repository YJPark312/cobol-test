      *@  외화타점예치계좌기본수보 전영업일 등록정보 조회
      *-----------------------------------------------------------------
       S3310-KJLR019-SELECT-RTN.

           INITIALIZE                  WK-KB-PIN
                                       WK-REGI-EMPID
                                       WK-REGI-YMS

      *   기준년월일(전영업년월일)
           MOVE XCJIDT16-O-BF-BZOPR-YMD
             TO WK-H-I-BF-BZOPR-YMD
      *   통화코드
           MOVE IN-CNCYCD
             TO WK-H-I-CNCYCD
      *   거래은행BIC코드
           MOVE IN-DEPO
             TO WK-H-I-DEPO

           EXEC SQL
             SELECT  고객식별자
                  ,  등록직원번호
                  ,  등록일시
               INTO  :WK-KB-PIN
                  ,  :WK-REGI-EMPID
                  ,  :WK-REGI-YMS
               FROM  DB2DBA.THKJLR019
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월일   = :WK-H-I-BF-BZOPR-YMD
                AND  통화코드     = :WK-H-I-CNCYCD
                AND  "거래은행BIC코드" = :WK-H-I-DEPO
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
               WHEN  CO-NOT-FOUND
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJLR019'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
