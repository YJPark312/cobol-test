      *-----------------------------------------------------------------
      *@  미등록상품 존재 확인
      *-----------------------------------------------------------------
       S3200-KJL0118-SELECT-RTN.

      *@  상품기본조회
           EXEC SQL
           SELECT COUNT(*) AS 미등록건수
             INTO :WK-H-O-NOT-REGI-NOITM
             FROM DB2DBA.TSPDMMP00 A
            WHERE 그룹회사코드     = :WK-H-I-GROUP-CO-CD
              AND 상품대분류코드  IN ('25','30')
              AND NOT EXISTS
                 (SELECT '등록'
                    FROM DB2DBA.THKJL0118
                   WHERE 그룹회사코드   = A.그룹회사코드
                     AND 기준년월       = SUBSTR(:WK-H-I-BASE-YMD,1,6)
                     AND 상품대분류코드 = A.상품대분류코드
                     AND 상품중분류코드 = A.상품중분류코드
                     AND 상품템플릿코드 = A.상품템플릿코드
                     AND 상품번호       = A.상품번호
                  )
             WITH UR
           END-EXEC

      *@   결과확인
           EVALUATE SQLCODE
               WHEN CO-OK
                    MOVE WK-H-O-NOT-REGI-NOITM
                      TO WK-AC-SELECT-CNT
               WHEN CO-NOT-FOUND
                    MOVE ZEROS        TO  WK-H-O-NOT-REGI-NOITM
                                          WK-AC-SELECT-CNT
               WHEN OTHER
                    MOVE 'KJL0118'    TO  XZUGEROR-I-TBL-ID
                    MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                    MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                    MOVE 'SELECT시 오류가 발생했습니다'
                      TO  XZUGEROR-I-MSG
                    #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                    #OKEXIT CO-CHA-08
           END-EVALUATE
           .

       S3200-KJL0118-SELECT-EXT.
           EXIT.

