      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKJL0011_CUR     CURSOR WITH HOLD FOR
             SELECT 고객식별자
               FROM  DB2DBA.THKJL0011
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월     = :WK-H-I-BASE-YM
           END-EXEC.

           EXEC SQL
            DECLARE  THKJL0129_CUR     CURSOR WITH HOLD FOR
             SELECT  T.차주고객식별자
                  ,  SUM(T."TE금액")
               FROM (SELECT  차주고객식별자     AS 차주고객식별자
                           , "한도기준TE금액" AS "TE금액"
                       FROM  DB2DBA.THKJL0129
                      WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                        AND  기준일       = :WK-H-I-BASE-DD
                        AND  기준년월     = :WK-H-I-BASE-YM
                        AND  상품대분류코드||상품중분류코드||
                             상품템플릿코드||상품번호
                             NOT  IN ('CR01A0613401','CR01A1413401',
                                      '2539M71A0002','2539M71A0003' )
                        AND  차주고객식별자     NOT IN
                                     ('          ', '',
                                      '==========',
                                      '----------')
                      UNION  ALL
                     SELECT  담보보증고객식별자 AS 차주고객식별자
120322                     , 간접익스포져금액   AS "TE금액"
                       FROM  DB2DBA.THKJL0031
                      WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                        AND  기준일       = :WK-H-I-BASE-DD
                        AND  기준년월     = :WK-H-I-BASE-YM
                        AND  담보보증고객식별자  NOT IN
                                     ('          ', '',
                                      '==========',
                                      '----------')
                    ) T
              GROUP  BY T.차주고객식별자
           END-EXEC.

