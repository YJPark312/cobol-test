      *-----------------------------------------------------------------
      *@   채무자정보기초자료 조회
      *-----------------------------------------------------------------
       S6000-KJL0015-SELECT-RTN.

      *   외화신용공여한도
           MOVE  ZERO
             TO  WK-ESKHD

      *   관리한도금액
           MOVE  ZERO
             TO  WK-KHDGM

           INITIALIZE    WK-HOST-OUT3

           EXEC SQL
             SELECT  A.고객식별자
                  ,  A."TE기업규모구분"
                  ,  A.고객관리부점코드
                  ,  A.내부신용평가등급구분
                  ,  A.신용평가년월일
                  ,  A.신표준산업분류코드
                  ,  VALUE(B.기준한도,0)
151007            ,  MAX(VALUE(B.외화기준한도,
                               VALUE(C.자기자본기준금액,0) *
                               CASE A.내부신용평가등급구분
                                    WHEN 'AAA'  THEN 0.10
                                    WHEN 'AA+'  THEN 0.10
                                    WHEN 'AA'   THEN 0.10
                                    WHEN 'AA-'  THEN 0.10
                                    WHEN 'A+'   THEN 0.09
                                    WHEN 'A'    THEN 0.09
                                    WHEN 'A-'   THEN 0.05
                                    WHEN 'BBB+' THEN 0.05
                                    WHEN 'BBB'  THEN 0.05
                                    WHEN 'BBB-' THEN 0.04
                                    WHEN 'BB+'  THEN 0.03
                                    WHEN 'BB'   THEN 0.03
                                    WHEN 'BB-'  THEN 0.03
                                    WHEN 'B+'   THEN 0.03
                                    WHEN 'B'    THEN 0.03
                                    WHEN 'B-'   THEN 0.01
                                    WHEN 'CCC'  THEN 0.01
                                    WHEN 'CC'   THEN 0.005
                                    WHEN 'C'    THEN 0.005
                                    WHEN 'D'    THEN 0.005
                                                ELSE 0.005
                               END),0) AS 외화기준한도
               INTO  :WK-HOST-OUT3
               FROM  DB2DBA.THKJL0015 A LEFT OUTER JOIN
                     DB2DBA.THKJL0001 B
                 ON  B.그룹회사코드 =  A.그룹회사코드
                AND  B.고객식별자   =  A.고객식별자
                AND  B.기준년월     = :WK-H-I-BASE-YM
                     LEFT OUTER JOIN
                     DB2DBA.THKJL0049 C
                 ON  C.그룹회사코드 =  A.그룹회사코드
                AND  C.기준년월     = :WK-H-I-BASE-YM
                AND  C.자기자본구분 = '2'
              WHERE  A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  A.고객식별자   = :WK-SELCM
               WITH  UR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK

      *거래가발생한차주의관리한도금액
                     PERFORM  S6100-KJL0011-SELECT-RTN
                        THRU  S6100-KJL0011-SELECT-EXT
               WHEN  CO-NOT-FOUND
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJL0015'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S6000-KJL0015-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   거래가　발생한　차주의　관리한도금액 조회
      *-----------------------------------------------------------------
       S6100-KJL0011-SELECT-RTN.

           EXEC SQL
             SELECT  VALUE(관리한도,0)
               INTO  :WK-KHDGM
               FROM  DB2DBA.THKJL0011
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월     = :WK-H-I-BASE-YM
                AND  고객식별자   = :WK-SELCM
                AND  관리한도유효년월일 >= :WK-H-I-BASE-YMD
               WITH  UR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE  ZERO
                       TO  WK-KHDGM
           END-EVALUATE

      *외화신용공여한도＝MIN(외화기준한도, TE관리한도)
           IF  WK-H-O3-FC-BASE-CLAM > WK-KHDGM
           THEN
               MOVE  WK-KHDGM
                 TO  WK-ESKHD
           ELSE
               MOVE  WK-H-O3-FC-BASE-CLAM
                 TO  WK-ESKHD
           END-IF

      *관리한도 설정 차주 정보 갱신
