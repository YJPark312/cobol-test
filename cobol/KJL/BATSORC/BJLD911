               EXEC SQL
               SELECT B.대분류업종코드
                 INTO :RJL0015-LAG-CLSFI-BZTYP-CD
                 FROM DB2DBA.THKJL0015 A
                    , DB2DBA.THKJL0044 B
                WHERE A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                  AND A.고객식별자   = :WK-H-O-BRWR-CUST-IDNFR
                  AND A.그룹회사코드      = B.그룹회사코드
                  AND B.기준년월          = :WK-H-I-BASE-YM
                  AND A.신표준산업분류코드= B.신표준산업분류코드
               END-EXEC
           ELSE
170406*       월말재작업
               EXEC SQL
               SELECT B.대분류업종코드
                 INTO :RJL0015-LAG-CLSFI-BZTYP-CD
                 FROM DB2DBA.THKJL0152 A
                    , DB2DBA.THKJL0044 B
                WHERE A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                  AND A.기준년월     = :WK-H-I-BASE-YM
170224            AND A.고객식별자   = :WK-H-O-BRWR-CUST-IDNFR
                  AND A.그룹회사코드      = B.그룹회사코드
