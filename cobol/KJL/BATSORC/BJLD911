      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
           DECLARE  THKJL0131_CUR     CURSOR WITH HOLD FOR
           SELECT A.차주고객식별자
      *          하노이지점 호치민지점으로 합산처리
                 ,REPLACE(A.관리부점코드,'2950','7531')
                         AS 관리부점코드
                 ,B.국외편중관리대상여부
                 ,MAX(SUM(A."한도기준TE금액"),0)
                         AS "한도기준TE금액"
             FROM DB2DBA.THKJL0131 A
                 ,DB2DBA.THKJL0118 B
            WHERE A.그룹회사코드       = B.그룹회사코드
              AND A.기준년월           = B.기준년월
              AND A.한도상품대분류코드 = B.상품대분류코드
              AND A.한도상품중분류코드 = B.상품중분류코드
              AND A.한도상품템플릿코드 = B.상품템플릿코드
              AND A.한도상품번호       = B.상품번호
              AND A.그룹회사코드       = :WK-H-I-GROUP-CO-CD
              AND A.기준일             = :WK-H-I-BASE-DD
              AND A.기준년월           = :WK-H-I-BASE-YM
            GROUP BY A.차주고객식별자
                    ,A.관리부점코드
                    ,B.국외편중관리대상여부
             WITH UR
           END-EXEC.

