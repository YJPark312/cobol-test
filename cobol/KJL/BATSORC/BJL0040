      *    FILE OPEN
           OPEN  INPUT  IN-FILE

      *    FILE CHECK OUTDATA
           IF WK-IN-FILE-STAT   NOT = CO-STAT-OK
              DISPLAY 'BJL0040:S1000 IN FILE OPEN ERROR.'
                       WK-IN-FILE-STAT
              #ERROR CO-EBM01001 CO-UBM01001 CO-STAT-ERROR
              #OKEXIT CO-CHA-08
           END-IF

