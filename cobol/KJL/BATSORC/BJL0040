       S3000-PROCESS-RTN.

      *    TABLE  FETCH
           PERFORM S3100-READ-FILE-RTN
              THRU S3100-READ-FILE-EXT

      *----LOOPING START
      *   АХЗЁСОЗсАэАДПЉКЮЁЁШЎРЮ
           PERFORM UNTIL WK-FETCH-END   = CO-CY
      *        TABLE DELETE1
               PERFORM S3400-KJL0040-DELETE-RTN
                  THRU S3400-KJL0040-DELETE-EXT

      *        FETCHАшМг
               PERFORM S3100-READ-FILE-RTN
                  THRU S3100-READ-FILE-EXT

           END-PERFORM
      *----LOOPING END
           .

       S3000-PROCESS-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   READ FILE
      *-----------------------------------------------------------------
       S3100-READ-FILE-RTN.

      *@1  READ FILE
           READ  IN-FILE      AT  END
           MOVE  CO-CY         TO  WK-FETCH-END
           END-READ

      *   ИЎХЯФкЕхАЁ СЄЛѓРЬ ОЦДЯИщ ПЁЗЏУГИЎ
           EVALUATE  WK-IN-FILE-STAT
               WHEN  ZERO
               WHEN  '04'
                    ADD  CO-N1         TO WK-READ-CNT
      *             KEY MOVE
      *            БзЗьШИЛчФкЕх
                    MOVE RJL0040-GROUP-CO-CD
                      TO KJL0040-PK-GROUP-CO-CD
      *            БтСиГтПљРЯ
                    MOVE RJL0040-BASE-YMD
                      TO KJL0040-PK-BASE-YMD
      *            ЧбЕЕБИКа
                    MOVE RJL0040-LIMT-DSTCD
                      TO KJL0040-PK-LIMT-DSTCD
      *            ТїСжЙјШЃ
                    MOVE RJL0040-BRWR-NO
                      TO KJL0040-PK-BRWR-NO
               WHEN  '10'
                     MOVE  CO-CY       TO  WK-FETCH-END
               WHEN  OTHER
                     MOVE 'IN-FILE OPEN ERROR : FILE-ST IS '
                                       TO  XZUGEROR-I-MSG
                     MOVE  WK-IN-FILE-STAT  TO  XZUGEROR-I-MSG(34:2)
                     #ERROR  CO-EBM02001 CO-UBM02001 WK-IN-FILE-STAT
                     #OKEXIT CO-CHA-08
           END-EVALUATE

           .
       S3100-READ-FILE-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  THKJL0040 DELETE
      *-----------------------------------------------------------------
       S3400-KJL0040-DELETE-RTN.

           EXEC SQL
           DELETE
             FROM DB2DBA.THKJL0040
            WHERE БзЗьШИЛчФкЕх        =  :KJL0040-PK-GROUP-CO-CD
              AND БтСиГтПљРЯ          =  :KJL0040-PK-BASE-YMD
              AND ЧбЕЕБИКа            =  :KJL0040-PK-LIMT-DSTCD
              AND ТїСжЙјШЃ            =  :KJL0040-PK-BRWR-NO
           END-EXEC

           EVALUATE SQLCODE
               WHEN ZERO
                    ADD  CO-N1         TO WK-DELETE-CNT

                    IF FUNCTION MOD(WK-DELETE-CNT, 500)  =  ZERO
                        EXEC  SQL  COMMIT  END-EXEC
                    END-IF
                    IF FUNCTION MOD(WK-DELETE-CNT, 10000)  =  ZERO
                        DISPLAY '$$ DELETE CNT : ' WK-DELETE-CNT
                    END-IF

               WHEN OTHER
                    DISPLAY 'SQL DELETEПРЗљРдДЯДй.'
                    DISPLAY 'SQLCODE = ' SQLCODE
                    MOVE 'KJL0040'     TO XZUGEROR-I-TBL-ID
                    MOVE 'DELETE'      TO XZUGEROR-I-FUNC-CD
                    MOVE SQLCODE       TO XZUGEROR-I-SQL-CD
                    MOVE 'DELETE ERR ' TO XZUGEROR-I-MSG
           END-EVALUATE
           .

       S3400-KJL0040-DELETE-EXT.
           EXIT.

