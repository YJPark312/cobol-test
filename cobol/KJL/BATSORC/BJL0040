           DISPLAY '$$ ================================='
           DISPLAY '$$ --  DELETE-CNT  : ' WK-EDIT-CNT4
           DISPLAY '$$ ================================='

           CLOSE    IN-FILE

           #OKEXIT  CO-STAT-OK
           .

       S9000-FINAL-EXT.
           EXIT.
