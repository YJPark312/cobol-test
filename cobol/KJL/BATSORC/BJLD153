      *@ 매출액／총자산
      *@  THKJL0001참조
      *-----------------------------------------------------------------
       S3210-KJL0001-SELECT-RTN.

           EXEC SQL
             SELECT  VALUE(내부신용평가등급구분,'0000')
                  ,  신용평가년월일
                  ,  신용평가유효년월일
                  ,  VALUE(매출액,0)
                  ,  VALUE(총자산,0)
               INTO  :WK-H-O-INTNL-CV-GRD-DSTCD
                  ,  :WK-H-O-CRDT-VALUA-YMD
                  ,  :WK-H-O-CRDT-VALUA-VALD-YMD
                  ,  :WK-H-O-SALEPR
                  ,  :WK-H-O-TOTAL-ASST
               FROM  DB2DBA.THKJL0001
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
170224          AND  고객식별자   = :WK-CUST-IDNFR
                AND  기준년월     = :WK-H-I-BASE-YM
               WITH  UR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     ADD   CO-NUM-1    TO  WK-SELOK01-CNT
               WHEN  CO-NOT-FOUND
                     ADD   CO-NUM-1    TO  WK-SELNO01-CNT
      *한신평 자료가 없으면 내부신용등급　자료　사용함
      *              내부신용평가등급구분
                     MOVE  IN-INTNL-CV-GRD-DSTCD
                       TO  WK-H-O-INTNL-CV-GRD-DSTCD
      *              신용평가년월일
                     MOVE  IN-CRDT-VALUA-YMD
                       TO  WK-H-O-CRDT-VALUA-YMD
      *              신용평가유효년월일
                     MOVE  IN-CRDT-VALUA-VALD-YMD
                       TO  WK-H-O-CRDT-VALUA-VALD-YMD
      *              매출액
                     MOVE  CO-NUM-0    TO  WK-H-O-SALEPR
      *              총자산
                     MOVE  CO-NUM-0    TO  WK-H-O-TOTAL-ASST
               WHEN  OTHER
                     #USRLOG ' ERROR - WK-CUST-IDNFR : ' WK-CUST-IDNFR
                     MOVE 'KJL0001'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'DATA-SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .

       S3210-KJL0001-SELECT-EXT.
           EXIT.

