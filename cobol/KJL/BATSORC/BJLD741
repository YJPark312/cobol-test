                  AS "미사용보증담보환산4"
                 ,"미사용보증담보금액5" *
                  DOUBLE("미사용한도CCF환산율") / 100
                  AS "미사용보증담보환산5"
                 ,"미사용보증담보금액6" *
                  DOUBLE("미사용한도CCF환산율") / 100
                  AS "미사용보증담보환산6"
                 ,"미사용보증담보금액7" *
                  DOUBLE("미사용한도CCF환산율") / 100
                  AS "미사용보증담보환산7"
                 ,"미사용보증담보금액8" *
                  DOUBLE("미사용한도CCF환산율") / 100
                  AS "미사용보증담보환산8"
                 ,"미사용보증담보금액9" *
                  DOUBLE("미사용한도CCF환산율") / 100
                  AS "미사용보증담보환산9"
                 ,신용공여기관구분
             FROM (
           SELECT B.그룹회사코드
                 ,B.기준일
                 ,B.기준년월
                 ,B.차주고객식별자
                 ,B.한도계좌번호
                 ,B.한도상품대분류코드
                 ,B.한도상품중분류코드
                 ,B.한도상품템플릿코드
                 ,B.한도상품번호
                 ,B.시작년월일
                 ,B.만기년월일
                 ,B.종료년월일
                 ,B.통화코드
                 ,B.통화한도
                 ,B.통화잔액
                 ,B.통합계정과목코드
                 ,VALUE(L0119.신용공여대상구분,'2')
                  AS 신용공여대상구분
                 ,B.원만기구분
                 ,B.잔존만기구분
                 ,B."BS기준한도"
                 ,B.기준환율
                 ,B.신용공여보증비율
                 ,B.신용공여담보비율
                 ,B."BS기준한도" - B."BS기준잔액" AS 미사용한도
150904           ,CASE B.원만기구분 WHEN '1' THEN 50
150904                                WHEN '2' THEN 20
                  END AS "미사용한도CCF환산율"
                 ,CASE VALUE(D."CA보증담보비율1",0) WHEN 0
                       THEN 0
                       ELSE ("BS기준한도" - "BS기준잔액") *
                            DOUBLE(D."CA보증담보비율1") / 100
                  END AS "미사용보증담보금액1"
                 ,CASE VALUE(D."CA보증담보비율2",0) WHEN 0
                       THEN 0
                       ELSE ("BS기준한도" - "BS기준잔액") *
                            DOUBLE(D."CA보증담보비율2") / 100
                  END AS "미사용보증담보금액2"
                 ,CASE VALUE(D."CA보증담보비율3",0) WHEN 0
                       THEN 0
                       ELSE ("BS기준한도" - "BS기준잔액") *
                            DOUBLE(D."CA보증담보비율3") / 100
                  END AS "미사용보증담보금액3"
                 ,CASE VALUE(D."CA보증담보비율4",0) WHEN 0
                       THEN 0
                       ELSE ("BS기준한도" - "BS기준잔액") *
                            DOUBLE(D."CA보증담보비율4") / 100
                  END AS "미사용보증담보금액4"
                 ,CASE VALUE(D."CA보증담보비율5",0) WHEN 0
                       THEN 0
                       ELSE ("BS기준한도" - "BS기준잔액") *
                            DOUBLE(D."CA보증담보비율5") / 100
                  END AS "미사용보증담보금액5"
                 ,CASE 잔존만기구분 WHEN '2' THEN
                       CASE VALUE(D."CA보증담보비율6",0) WHEN 0
                            THEN 0
                            ELSE ("BS기준한도" - "BS기준잔액") *
                                 DOUBLE(D."CA보증담보비율6") / 100
                       END
                       ELSE 0
                  END AS "미사용보증담보금액6"
                 ,CASE VALUE(D."CA보증담보비율7",0) WHEN 0
                       THEN 0
                       ELSE ("BS기준한도" - "BS기준잔액") *
                            DOUBLE(D."CA보증담보비율7") / 100
                  END AS "미사용보증담보금액7"
                 ,CASE VALUE(D."CA보증담보비율8",0) WHEN 0
                       THEN 0
                       ELSE ("BS기준한도" - "BS기준잔액") *
                            DOUBLE(D."CA보증담보비율8") / 100
                  END AS "미사용보증담보금액8"
                 ,CASE VALUE(D."CA보증담보비율9",0) WHEN 0
                       THEN 0
                       ELSE ("BS기준한도" - "BS기준잔액") *
                            DOUBLE(D."CA보증담보비율9") / 100
                  END AS "미사용보증담보금액9"
                 ,신용공여기관구분
             FROM (
           SELECT A.그룹회사코드
                 ,A.기준일
                 ,A.기준년월
                 ,A.기준년월||A.기준일 AS 기준년월일
                 ,A.차주고객식별자
                 ,A.한도계좌번호
                 ,A.한도상품대분류코드
                 ,A.한도상품중분류코드
                 ,A.한도상품템플릿코드
                 ,A.한도상품번호
                 ,A.시작년월일
                 ,A.만기년월일
                 ,A.종료년월일
                 ,A.통화코드
                 ,A.통화한도
                 ,A.통화잔액
                 ,VALUE(CASE WHEN A.관련테이블명 IN ('THKFDPO01'
                                                      ,'THKFE0000'
                                                      ,'THKFE0010'
                                                      ,'THKFF0201'
                                                      ,'THKFFA101'
                                                      ,'THKFFA201'
                                                      ,'THKHC0401')
                       THEN REPLACE(R013.통합계정과목코드,' ','0')
                       WHEN A.관련테이블명 = 'THKJLR005'
                       THEN R005.통합계정과목코드
                       WHEN A.관련테이블명 = 'THKJLR006'
                       THEN R006.통합계정과목코드
                       WHEN A.관련테이블명 = 'THKJLR011'
                       THEN R011.통합계정과목코드
                       WHEN A.관련테이블명 = 'THKJLR012'
                       THEN R012.통합계정과목코드
                       ELSE '0000000000000'
                  END,'0000000000000') AS 통합계정과목코드
                 ,CASE WHEN A.시작년월일 = '' OR
                            A.만기년월일 = ''         THEN '1'
                       WHEN A.시작년월일 = '99991231' THEN '2'
                       ELSE
                  CASE WHEN TO_CHAR(TO_DATE(
                            A.시작년월일,'YYYYMMDD') +
                            1 YEAR,'YYYYMMDD') < A.만기년월일
                                 THEN '1'
                                 ELSE '2'
                            END
                  END AS 원만기구분
                 ,CASE WHEN A.만기년월일 = '' THEN '1'
                       ELSE CASE WHEN HEX(CURRENT DATE + 1 YEAR) <
                                      A.만기년월일
                                 THEN '1'
                                 ELSE '2'
                            END
                  END AS 잔존만기구분
170404           ,CASE WHEN A.통화코드 IN ('KRW','MMK')
150904                 THEN A.명목액기준한도
130109                 ELSE CASE WHEN EX04."N100단위통화여부" = '1'
                                 THEN ROUND(VALUE(EX04.매매기준환율,0)
150904                              * DOUBLE(A.명목액기준한도)
150904                              / VALUE(EX04.전신환매도환율,1)
                                    / 100, 0)
                                 ELSE ROUND(VALUE(EX04.매매기준환율,0)
150904                              * DOUBLE(A.명목액기준한도)
150904                              / VALUE(EX04.전신환매도환율,1)
                                         , 0)
                            END
                  END AS "BS기준한도"
                 ,CASE WHEN A.통화코드 = 'KRW'
                       THEN 0
                       ELSE VALUE(EX04.매매기준환율,0)
                  END AS 기준환율
                 ,0   AS 신용공여보증비율
                 ,0   AS 신용공여담보비율
                 ,A."BS기준잔액"
                 ,''  AS 신용공여기관구분
             FROM (
           SELECT 그룹회사코드
                 ,기준일
                 ,기준년월
                 ,차주고객식별자
                 ,한도계좌번호
                 ,한도상품대분류코드
                 ,한도상품중분류코드
                 ,한도상품템플릿코드
                 ,한도상품번호
                 ,MAX(CASE WHEN "TE계좌구분" IN ('1','3','4')
                           THEN 시작년월일
                           ELSE ' '
                      END) AS 시작년월일
                 ,MAX(CASE WHEN "TE계좌구분" IN ('1','3','4')
                           THEN 만기년월일
                           ELSE ' '
                      END) AS 만기년월일
                 ,MAX(CASE WHEN "TE계좌구분" IN ('1','3','4')
                           THEN 종료년월일
                           ELSE ' '
                      END) AS 종료년월일
                 ,MAX(CASE WHEN "TE계좌구분" IN ('1','3','4')
                           THEN 통화코드
                           ELSE ' '
                      END) AS 통화코드
                 ,MAX(CASE WHEN "TE계좌구분" IN ('1','3','4')
                           THEN 관련테이블명
                           ELSE ' '
                      END) AS 관련테이블명
                 ,SUM(통화한도)     AS 통화한도
                 ,SUM(통화잔액)     AS 통화잔액
                 ,SUM("BS기준잔액") AS "BS기준잔액"
150904           ,SUM(명목액기준한도) AS 명목액기준한도
             FROM DB2DBA.THKJL0125
            WHERE 그룹회사코드  = :WK-H-I-GROUP-CO-CD
              AND 기준일        = :WK-H-I-BASE-DD
              AND 기준년월      = :WK-H-I-BASE-YM
              AND "TE계좌고객구분" NOT IN ('3','4','6','7','9')
              AND 차주고객식별자 NOT IN ('          ', '',
                                     '==========','----------')
              AND NOT (한도상품대분류코드 = ' ' OR
                       한도상품중분류코드 = ' ' OR
                       한도상품템플릿코드 = ' ' OR
                       한도상품번호       = ' ')
            GROUP BY 그룹회사코드
                    ,기준일
                    ,기준년월
                    ,차주고객식별자
                    ,한도계좌번호
                    ,한도상품대분류코드
                    ,한도상품중분류코드
                    ,한도상품템플릿코드
                    ,한도상품번호
                   ) A LEFT OUTER JOIN
                  (SELECT 그룹회사코드
                         ,계좌번호
                         ,SUBSTR(MAX(DIGITS(상품계약회차)||
                                            통합계정과목코드
150904                               ),8,13) AS 통합계정과목코드
                     FROM DB2DBA.THKJLR013
                    GROUP BY 그룹회사코드,계좌번호
                   ) R013
               ON A.그룹회사코드 = R013.그룹회사코드
              AND A.한도계좌번호 = R013.계좌번호
                  LEFT OUTER JOIN
                  (SELECT 그룹회사코드
                         ,계좌번호
                         ,SUBSTR(MAX(기준년월일||
                         통합계정과목코드),9,13) AS 통합계정과목코드
                     FROM DB2DBA.THKJLR005
                    GROUP BY 그룹회사코드,계좌번호
                   ) R005
               ON A.그룹회사코드 = R005.그룹회사코드
              AND A.한도계좌번호 = R005.계좌번호
                  LEFT OUTER JOIN
                  (SELECT 그룹회사코드
                         ,종목코드번호
                         ,SUBSTR(MAX(기준년월일||DIGITS(일련번호)||
                          통합계정과목코드),16,13)
                          AS 통합계정과목코드
                     FROM DB2DBA.THKJLR006
                    GROUP BY 그룹회사코드,종목코드번호
                   ) R006
               ON A.그룹회사코드 = R006.그룹회사코드
              AND A.한도계좌번호 = R006.종목코드번호
                  LEFT OUTER JOIN
                  DB2DBA.THKJLR011 R011
               ON A.그룹회사코드         = R011.그룹회사코드
              AND A.기준년월||A.기준일 = R011.기준년월일
              AND A.한도계좌번호         = R011.통합트레이드번호
                  LEFT OUTER JOIN
                  DB2DBA.THKJLR012 R012
               ON A.그룹회사코드         = R012.그룹회사코드
              AND A.기준년월||A.기준일 = R012.기준년월일
              AND SUBSTR(A.한도계좌번호,1, 3) =
                  R012.외화상품유형구분
              AND SUBSTR(A.한도계좌번호,4,16) =
                  R012.통합트레이드번호
                  LEFT OUTER JOIN
                  DB2DBA.THKJIEX04 EX04
               ON A.그룹회사코드         = EX04.그룹회사코드
              AND A.통화코드             = EX04.통화코드
              AND A.기준년월||A.기준일 = EX04.기준년월일
              AND 1                        = EX04.환율적용회차
                   ) B
                  LEFT OUTER JOIN
                  DB2DBA.THKJL0119 L0119
               ON B.그룹회사코드     = L0119.그룹회사코드
              AND B.기준년월         = L0119.기준년월
              AND B.통합계정과목코드 = L0119.통합계정과목코드
                  LEFT OUTER JOIN
                  DB2DBA.THKJLR014 D
               ON B.그룹회사코드     = D.그룹회사코드
              AND B.기준년월일       = D.기준년월일
              AND B.한도계좌번호     = D.담보여신계좌번호
140819      WHERE B.그룹회사코드  = :WK-H-I-GROUP-CO-CD
              AND B.기준년월      = :WK-H-I-BASE-YM
                   ) TBL
             WITH UR

           END-EXEC

