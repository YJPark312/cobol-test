      *-----------------------------------------------------------------
      *@   CURSOR FETCH
      *-----------------------------------------------------------------
       S4100-KJL0125-FETCH-RTN.

           INITIALIZE    WK-HOST-SEL
           EXEC SQL
              FETCH  THKJL0125_CUR
               INTO  :WK-HOST-SEL
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-SQL-OK
                     ADD   CO-NUM-1    TO  WK-AC-FETCH-CNT

      *    1000 건　마다　 COMMIT & USRLOG
                     IF  (FUNCTION MOD(WK-AC-FETCH-CNT, 1000)
                         = CO-NUM-0)
                         #USRLOG  '**' WK-AC-FETCH-CNT
                     END-IF

               WHEN  CO-SQL-NTFND
                     SET   EOF-Y       TO  TRUE
               WHEN  OTHER
                     MOVE 'KJL0125'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
