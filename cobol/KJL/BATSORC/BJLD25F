               WHEN  WK-EXP-DAYS < 365
                          COMPUTE  WK-H-O-LCAL-C-LNAMT-AMT
                                =  WK-TMP-AMT * 0.01
                                +  WK-H-O-FX-PFT-AMT
               WHEN  (WK-EXP-DAYS >= 365   AND
                      WK-EXP-DAYS < 1825)
                          COMPUTE  WK-H-O-LCAL-C-LNAMT-AMT
                                =  WK-TMP-AMT * 0.05
                                +  WK-H-O-FX-PFT-AMT
               WHEN  WK-EXP-DAYS >= 1825
                          COMPUTE  WK-H-O-LCAL-C-LNAMT-AMT
                                =  WK-TMP-AMT * 0.75
                                +  WK-H-O-FX-PFT-AMT
