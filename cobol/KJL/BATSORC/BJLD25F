      *@   합성선물환－해더（BS금액추출）
      *-----------------------------------------------------------------
       S3310-BS-AMT-RTN.

           INITIALIZE    WK-IMSI-BS-BAL

      *    #USRLOG ' <<  1>> ' WK-H-I-GROUP-CO-CD
      *    #USRLOG ' <<  2>> ' WK-H-I-BASE-YMD
      *    #USRLOG ' <<  3>> ' WK-H-O-FC-PRDCT-PTRN-DSTCD
      *    #USRLOG ' <<  4>> ' WK-H-O-FC-TRAN-NO

           EXEC SQL
             SELECT  VALUE(현지통화대출금액,0)
               INTO  :WK-IMSI-BS-BAL
               FROM  DB2DBA.THKJLR003
              WHERE  그룹회사코드       = :WK-H-I-GROUP-CO-CD
                AND  기준년월일         = :WK-H-I-BASE-YMD
                AND  외화상품유형구분   = :WK-H-O-FC-PRDCT-PTRN-DSTCD
                AND  외화거래번호       = :WK-H-O-FC-TRAN-NO
      *         AND  상품대분류코드     = :WK-H-O-PRDCT-LAG-CLSFI-CD
      *         AND  상품중분류코드     = :WK-H-O-PRDCT-MEDM-CLSFI-CD
      *         AND  상품템플릿코드     = :WK-H-O-PRDCT-TMPLT-CD
      *         AND  상품번호           = :WK-H-O-PRDCT-NO
      *         AND  통합계정과목코드   =
      *               SUBSTR(:WK-H-O-INTGRA-TIACC-CD,1,5) || '000'
-->   * '000'SOLAND  통합계정과목코드  = '000'해결
                AND  "CMBS과목중분류구분" = '01'
                AND  "CMBS세분류구분"     = '12'
                AND  상계처리등록여부    <> '1'
           END-EXEC.

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  ZERO
                       TO  WK-IMSI-BS-BAL
               WHEN  OTHER
                     MOVE 'KJLR003'
                       TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'
                       TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE
                       TO  XZUGEROR-I-SQL-CD
                     MOVE 'BS금액　추출시　오류가 발생했습니다'
                       TO  XZUGEROR-I-MSG
      *에러메시지:내부 본 처리
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-BS-AMT-EXT.
           EXIT.
