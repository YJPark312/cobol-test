      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKJLR003_CUR     CURSOR FOR
             SELECT  A.외화상품유형구분
                  ,  A.외화거래번호
                  ,  B.상품대분류코드
                  ,  B.상품중분류코드
                  ,  B.상품템플릿코드
                  ,  B.상품번호
                  ,  A.신규년월일
                  ,  A.만기년월일
                  ,  A.현지통화코드
                  ,  A.현지통화대출금액
                  ,  A.외환매매익금액
                  ,  A."CMBS과목중분류구분"
                  ,  A.발행법인등록번호
                  ,  A.관리부점코드
                  ,  A.매입매도구분
               FROM  DB2DBA.THKJLR003  A
                  ,  DB2DBA.THKJL0018  B
              WHERE  A.그룹회사코드      = :WK-H-I-GROUP-CO-CD
                AND  A.기준년월일        = :WK-H-I-BASE-YMD
                AND  A."CMBS과목중분류구분" = '01'
                AND  A."CMBS세분류구분"     = '13'
                AND  A.상계처리등록여부 <> '1'
                AND  B.기준년월          = :WK-H-I-BASE-YM
                AND  A.그룹회사코드      =  B.그룹회사코드
                AND  A.통합계정과목코드  =  B.통합계정과목코드
           END-EXEC.
