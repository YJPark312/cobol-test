      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *@  차주익스포져 일집계 산출시
      *@  TE계좌고객구분 중
      *@  비대상          3:국민은행(국내)
      *@                  4:해외점포(차주:국민은행)
      *@                  6:해외법인(차주:국민은행)
      *@                  7:개인여신
      *@                  9:기타
      *@  대상
      *@                  0:해당무
      *@                  1:법인여신
      *@                  2:개인사업자
      *@                  5:해외법인(차주:기타)
      *@                  8:대한민국정부

           EXEC SQL
           DECLARE  THKJL0125_CUR     CURSOR WITH HOLD FOR
      *   전체대상
           WITH TBL1 AS (
           SELECT A.계좌번호
                 ,A.차주고객식별자
                 ,REPLACE(VALUE(A.관리부점코드,'0000'),'    ','0000')
                  AS 관리부점코드
                 ,A.한도계좌번호
                 ,A.한도상품대분류코드
                 ,A.한도상품중분류코드
                 ,A.한도상품템플릿코드
                 ,A.한도상품번호
                 ,A.명목액기준한도
                 ,A.명목액기준잔액
                 ,VALUE(B."한도기준TE환산율" ,0)
                       AS "한도기준TE환산율"
             FROM DB2DBA.THKJL0125 A LEFT OUTER JOIN
                  DB2DBA.THKJL0118 B
               ON A.그룹회사코드       = B.그룹회사코드
              AND A.기준년월           = B.기준년월
              AND A.한도상품대분류코드 = B.상품대분류코드
              AND A.한도상품중분류코드 = B.상품중분류코드
              AND A.한도상품템플릿코드 = B.상품템플릿코드
              AND A.한도상품번호       = B.상품번호
            WHERE A.그룹회사코드       = :WK-H-I-GROUP-CO-CD
              AND A.기준일             = :WK-H-I-BASE-DD
              AND A.기준년월           = :WK-H-I-BASE-YM
              AND A.한도상품대분류코드 = 'FI'
              AND A."TE계좌고객구분" NOT IN ('3','4','6','7','9')
              AND A.차주고객식별자   NOT IN
                 (SELECT 고객식별자
                    FROM DB2DBA.THKJL0059
                   WHERE 그룹회사코드     = :WK-H-I-GROUP-CO-CD
                     AND 한도관리제외구분 = '1'
                  )
              AND A.차주고객식별자   NOT IN
                      ('          ', '',
                       '==========','----------')
              AND NOT (A.한도상품대분류코드= ' ' OR
                       A.한도상품중분류코드= ' ' OR
                       A.한도상품템플릿코드= ' ' OR
                       A.한도상품번호      = ' ' )
200102        AND NOT EXISTS (SELECT 1
      *      지급보증신용장번호가 있는 해외여신을 제외
                                FROM DB2DBA.THKJL0125
                               WHERE 그룹회사코드 = A.그룹회사코드
                                 AND 기준일       = A.기준일
                                 AND 기준년월     = A.기준년월
                                 AND 계좌번호 = A.지급보증신용장번호
                              )
200220*      지급보증신용장번호를 가지고 있는 해외여신의
      *      해외한도계좌는 제외
              AND NOT EXISTS (SELECT 1
                                FROM DB2DBA.THKJL0125 C
                               WHERE C.그룹회사코드 = A.그룹회사코드
                                 AND C.기준일       = A.기준일
                                 AND C.기준년월     = A.기준년월
                                 AND C.한도계좌번호 = A.계좌번호
                                 AND A.한도계좌여부 = '1'
                                 AND A."TE계좌구분" = '1'
                                 AND C."TE계좌구분" = '2'
                                 AND EXISTS (SELECT 1
                                               FROM DB2DBA.THKJL0125
                                              WHERE 그룹회사코드 =
                                                  C.그룹회사코드
                                                AND 기준일       =
                                                  C.기준일
                                                AND 기준년월     =
                                                  C.기준년월
                                                AND 계좌번호     =
                                                  C.지급보증신용장번호
                                             )
                              )
           )
      *    한도계좌별 원래 한도기준TE금액 산출
           ,TBL22 AS (
           SELECT 차주고객식별자
                 ,한도계좌번호
                 ,한도상품대분류코드
                 ,한도상품중분류코드
                 ,한도상품템플릿코드
                 ,한도상품번호
                 ,SUM(명목액기준한도) AS 명목액기준한도
                 ,SUM(명목액기준잔액) AS 명목액기준잔액
             FROM TBL1
            GROUP BY 차주고객식별자
                    ,한도계좌번호
                    ,한도상품대분류코드
                    ,한도상품중분류코드
                    ,한도상품템플릿코드
                    ,한도상품번호
           )
      *    관리부점별 한도기준TE금액 산출
           ,TBL2 AS (
           SELECT 차주고객식별자
                 ,관리부점코드
                 ,한도계좌번호
                 ,한도상품대분류코드
                 ,한도상품중분류코드
                 ,한도상품템플릿코드
                 ,한도상품번호
                 ,SUM(명목액기준잔액) *
                      DOUBLE(VALUE(MAX("한도기준TE환산율"),0))
                      / 100 AS "한도기준TE금액"
             FROM TBL1 A
            WHERE EXISTS (SELECT 1
                            FROM TBL22
                           WHERE 차주고객식별자 = A.차주고객식별자
                             AND 한도계좌번호   = A.한도계좌번호
                             AND 한도상품대분류코드 =
                               A.한도상품대분류코드
                             AND 한도상품중분류코드 =
                               A.한도상품중분류코드
                             AND 한도상품템플릿코드 =
                               A.한도상품템플릿코드
                             AND 한도상품번호       = A.한도상품번호
                             AND 명목액기준한도 = 0
                             AND 명목액기준잔액 > 0
                          )
            GROUP BY 차주고객식별자
                    ,관리부점코드
                    ,한도계좌번호
                    ,한도상품대분류코드
                    ,한도상품중분류코드
                    ,한도상품템플릿코드
                    ,한도상품번호
           UNION ALL
           SELECT 차주고객식별자
                 ,관리부점코드
                 ,한도계좌번호
                 ,한도상품대분류코드
                 ,한도상품중분류코드
                 ,한도상품템플릿코드
                 ,한도상품번호
                 ,SUM(명목액기준한도) *
                      DOUBLE(VALUE(MAX("한도기준TE환산율"),0))
                      / 100 AS "한도기준TE금액"
             FROM TBL1 A
            WHERE EXISTS (SELECT 1
                            FROM TBL22
                           WHERE 차주고객식별자 = A.차주고객식별자
                             AND 한도계좌번호   = A.한도계좌번호
                             AND 한도상품대분류코드 =
                               A.한도상품대분류코드
                             AND 한도상품중분류코드 =
                               A.한도상품중분류코드
                             AND 한도상품템플릿코드 =
                               A.한도상품템플릿코드
                             AND 한도상품번호       = A.한도상품번호
                             AND 명목액기준한도 > 0
                          )
            GROUP BY 차주고객식별자
                    ,관리부점코드
                    ,한도계좌번호
                    ,한도상품대분류코드
                    ,한도상품중분류코드
                    ,한도상품템플릿코드
                    ,한도상품번호
           )
           SELECT    차주고객식별자
                    ,관리부점코드
                    ,한도계좌번호
                    ,한도상품대분류코드
                    ,한도상품중분류코드
                    ,한도상품템플릿코드
                    ,한도상품번호
                    ,MAX(SUM(TRUNC("한도기준TE금액")),0)
                     AS "한도기준TE금액"
             FROM TBL2
            GROUP BY 차주고객식별자
                    ,관리부점코드
                    ,한도계좌번호
                    ,한도상품대분류코드
                    ,한도상품중분류코드
                    ,한도상품템플릿코드
                    ,한도상품번호
             WITH UR
           END-EXEC.

           EXEC SQL
            DECLARE  THKJL0131_CUR   CURSOR  WITH HOLD FOR
             SELECT  그룹회사코드
                  ,  기준년월
                  ,  차주고객식별자
                  ,  관리부점코드
                  ,  한도계좌번호
                  ,  한도상품대분류코드
                  ,  한도상품중분류코드
                  ,  한도상품템플릿코드
                  ,  한도상품번호
                  , "한도기준TE금액"
               FROM   DB2DBA.THKJL0131
              WHERE  그룹회사코드  = :WK-H-I-GROUP-CO-CD
                AND  기준일        = :WK-H-I-BASE-DD
                AND  기준년월      = :WK-H-I-BASE-YM
               WITH UR
           END-EXEC.
