       S3310-KJL0069-UPDATE-RTN.


           EVALUATE  WK-GUBUN
               WHEN  CO-CHA-1
      *              지역별익스포져금액
                 EXEC SQL
                  UPDATE  DB2DBA.THKJL0069
                     SET  지역별익스포져금액 = :WK-H-O-SUB-CLAM
                        , 시스템최종처리일시   = :BICOM-TRAN-START-YMS
                        , 시스템최종사용자번호 = :BICOM-USER-EMPID
                   WHERE  그룹회사코드    = :WK-H-I-GROUP-CO-CD
                     AND  기준년월일      = :WK-H-I-BASE-YMD
                     AND  대분류업종코드  = :WK-H-O-LAG-CLSFI-BZTYP-CD
                     AND  지역구분        = :WK-H-O-AREA-DSTCD
                 END-EXEC

               WHEN  CO-CHA-2
      *              전년도말익스포져금액
                 EXEC SQL
                  UPDATE  DB2DBA.THKJL0069
                     SET  전년도말익스포져금액 = :WK-H-O-SUB-CLAM
                        , 시스템최종처리일시   = :BICOM-TRAN-START-YMS
                        , 시스템최종사용자번호 = :BICOM-USER-EMPID
                   WHERE  그룹회사코드    = :WK-H-I-GROUP-CO-CD
                     AND  기준년월일      = :WK-H-I-BASE-YMD
                     AND  대분류업종코드  = :WK-H-O-LAG-CLSFI-BZTYP-CD
                     AND  지역구분        = :WK-H-O-AREA-DSTCD
                 END-EXEC

               WHEN  CO-CHA-3
      *              증가익스포져금액
                 EXEC SQL
                  UPDATE  DB2DBA.THKJL0069
                     SET  증가익스포져금액 = :WK-H-O-SUB-CLAM
                        , 시스템최종처리일시   = :BICOM-TRAN-START-YMS
                        , 시스템최종사용자번호 = :BICOM-USER-EMPID
                   WHERE  그룹회사코드    = :WK-H-I-GROUP-CO-CD
                     AND  기준년월일      = :WK-H-I-BASE-YMD
                     AND  대분류업종코드  = :WK-H-O-LAG-CLSFI-BZTYP-CD
                     AND  지역구분        = :WK-H-O-AREA-DSTCD
                 END-EXEC

               WHEN  CO-CHA-4
      *              지역별SUB한도금액
                 EXEC SQL
                  UPDATE  DB2DBA.THKJL0069
                     SET "지역별SUB한도"  = :WK-H-O-SUB-CLAM
                        , 시스템최종처리일시   = :BICOM-TRAN-START-YMS
                        , 시스템최종사용자번호 = :BICOM-USER-EMPID
                   WHERE  그룹회사코드    = :WK-H-I-GROUP-CO-CD
                     AND  기준년월일      = :WK-H-I-BASE-YMD
                     AND  대분류업종코드  = :WK-H-O-LAG-CLSFI-BZTYP-CD
                     AND  지역구분        = :WK-H-O-AREA-DSTCD
                 END-EXEC
           END-EVALUATE


