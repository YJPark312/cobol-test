      *@   당일 지역별 TE 조회
           EXEC SQL
            DECLARE  THKJL0069_CUR1    CURSOR FOR
            SELECT VALUE(T044.대분류업종코드,'000')
                 , CASE WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                             ('3348','3364','3555','3982','4945'
                             ,'4958','4987','5447','7201','7214')
                        THEN '31'
                        WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                             ('3814','3827','5038','5041')
                        THEN '21'
                        WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                             ('3885','4974')
                        THEN '22'
                        WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                             ('3940','5009')
                        THEN '33'
                        WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                             ('3830','5012')
                        THEN '35'
                        ELSE '11'
                   END 지역별
                 , SUM(S125."한도기준TE금액")
                         AS "한도기준TE금액"
            FROM (
              SELECT T125.그룹회사코드
                   , T125.기준일
                   , T125.기준년월
170224             , T125.차주고객식별자
                   , T125.한도계좌번호
                   , T125.한도상품대분류코드
                   , T125.한도상품중분류코드
                   , T125.한도상품템플릿코드
                   , T125.한도상품번호
                   , T125.관리부점코드
                   , CASE WHEN (CASE WHEN T125.명목액기준한도 = 0
                                      AND T125.명목액기준잔액 > 0
                                     THEN T125.명목액기준잔액
                                     ELSE T125.명목액기준한도
                                END ) = 0
                                OR  T118."한도기준TE환산율"  =  0
                          THEN 0
                          ELSE TRUNC(DOUBLE(
                               CASE WHEN T125.명목액기준한도 = 0
                                     AND T125.명목액기준잔액 > 0
                                    THEN T125.명목액기준잔액
                                    ELSE T125.명목액기준한도
                               END ) * T118."한도기준TE환산율"
                                     / 100 ,0)
                     END  AS "한도기준TE금액"
              FROM ( SELECT A.그룹회사코드
                          , A.기준일
                          , A.기준년월
170224                    , A.차주고객식별자
                          , A.한도계좌번호
                          , A.한도상품대분류코드
                          , A.한도상품중분류코드
                          , A.한도상품템플릿코드
                          , A.한도상품번호
170224                    , A.관리부점코드
                          , SUM(A.명목액기준한도) AS 명목액기준한도
                          , SUM(A.명목액기준잔액) AS 명목액기준잔액
                     FROM   DB2DBA.THKJL0125 A
                    WHERE  A.그룹회사코드  = :WK-H-I-GROUP-CO-CD
                      AND  A.기준일        = :WK-H-I-BASE-DD
                      AND  A.기준년월      = :WK-H-I-BASE-YM
                      AND  A."TE계좌고객구분"  NOT
                           IN ('3','4','6','7','9')
170224                AND  A.차주고객식별자 NOT IN
                              ('          ', '',
                               '==========','----------')
                      AND  NOT ( A.한도상품대분류코드= ' ' OR
                                 A.한도상품중분류코드= ' ' OR
                                 A.한도상품템플릿코드= ' ' OR
                                 A.한도상품번호 = ' ' )
                    GROUP BY  A.그룹회사코드
                            , A.기준일
                            , A.기준년월
170224                      , A.차주고객식별자
                            , A.한도계좌번호
                            , A.한도상품대분류코드
                            , A.한도상품중분류코드
                            , A.한도상품템플릿코드
                            , A.한도상품번호
170224                      , A.관리부점코드
                    ) T125
                     , DB2DBA.THKJL0118 T118
              WHERE  T125.그룹회사코드        = T118.그룹회사코드
                AND  T125.기준년월            = T118.기준년월
                AND  T125.한도상품대분류코드  = T118.상품대분류코드
                AND  T125.한도상품중분류코드  = T118.상품중분류코드
                AND  T125.한도상품템플릿코드  = T118.상품템플릿코드
                AND  T125.한도상품번호        = T118.상품번호
              ) S125 LEFT OUTER JOIN
              (SELECT 부점코드, 영업지원본부부점코드
                 FROM DB2DBA.THKJIBR01 E
                WHERE 그룹회사코드   = :WK-H-I-GROUP-CO-CD
                  AND 지주회사구분   = '01'
                  AND 적용종료년월일 >= :WK-H-I-BASE-YMD
                  AND 적용시작년월일 = (SELECT 적용시작년월일
                                          FROM DB2DBA.THKJIBR01
                                         WHERE 그룹회사코드
                                             = E.그룹회사코드
                                           AND 부점코드
                                             = E.부점코드
                                           AND 적용시작년월일
                                            <= :WK-H-I-BASE-YMD
                                         ORDER BY 적용시작년월일 DESC
                                         FETCH FIRST 1 ROW ONLY)) BR01
               ON  S125.관리부점코드  = BR01.부점코드
            , DB2DBA.THKJL0015  T015 LEFT OUTER JOIN
		       DB2DBA.THKJL0044  T044
	                             ON  T015.그룹회사코드
	                               = T044.그룹회사코드
	                            AND  T015.신표준산업분류코드
	                               = T044.신표준산업분류코드
	                            AND  T044.기준년월
	                               = :WK-H-I-BASE-YM
              WHERE  S125.그룹회사코드   = T015.그룹회사코드
170224          AND  S125.차주고객식별자 = T015.고객식별자
              GROUP BY VALUE(T044.대분류업종코드,'000')
                   , CASE WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                                ('3348','3364','3555','3982','4945'
                                ,'4958','4987','5447','7201','7214')
                              THEN '31'
                          WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                                ('3814','3827','5038','5041')
                              THEN '21'
                          WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                                ('3885','4974')
                              THEN '22'
                          WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                                ('3940','5009')
                              THEN '33'
                          WHEN VALUE(BR01.영업지원본부부점코드,'') IN
                                ('3830','5012')
                              THEN '35'
                          ELSE  '11'
                     END
              WITH UR
           END-EXEC.

      *@   전년도말 지역별 TE 조회
           EXEC SQL
            DECLARE  THKJL0069_CUR2    CURSOR FOR
            SELECT VALUE(T044.대분류업종코드,'000')
                 , CASE WHEN VALUE(BR01.영업지원본부부점코드,
                             VALUE(BR02.영업지원본부부점코드,'')) IN
                             ('3348','3364','3555','3982','4945'
                             ,'4958','4987','5447','7201','7214')
                        THEN '31'
                        WHEN VALUE(BR01.영업지원본부부점코드,
                             VALUE(BR02.영업지원본부부점코드,'')) IN
                             ('3814','3827','5038','5041')
                        THEN '21'
                        WHEN VALUE(BR01.영업지원본부부점코드,
                             VALUE(BR02.영업지원본부부점코드,'')) IN
                             ('3885','4974')
                        THEN '22'
                        WHEN VALUE(BR01.영업지원본부부점코드,
                             VALUE(BR02.영업지원본부부점코드,'')) IN
                             ('3940','5009')
                        THEN '33'
                        WHEN VALUE(BR01.영업지원본부부점코드,
                             VALUE(BR02.영업지원본부부점코드,'')) IN
                             ('3830','5012')
                        THEN '35'
                        ELSE '11'
                   END 지역별
                 , SUM(S126."한도기준TE금액")
                         AS "한도기준TE금액"
            FROM (
              SELECT T126.그룹회사코드
                   , T126.기준년월
170224             , T126.차주고객식별자
                   , T126.한도계좌번호
                   , T126.한도상품대분류코드
                   , T126.한도상품중분류코드
                   , T126.한도상품템플릿코드
                   , T126.한도상품번호
                   , T126.관리부점코드
                   , CASE WHEN (CASE WHEN T126.명목액기준한도 = 0
                                      AND T126.명목액기준잔액 > 0
                                     THEN T126.명목액기준잔액
                                     ELSE T126.명목액기준한도
                                END ) = 0
                                OR  T118."한도기준TE환산율"  =  0
                          THEN 0
                          ELSE TRUNC(DOUBLE(
                               CASE WHEN T126.명목액기준한도 = 0
                                     AND T126.명목액기준잔액 > 0
                                    THEN T126.명목액기준잔액
                                    ELSE T126.명목액기준한도
                               END ) * T118."한도기준TE환산율"
                                     / 100 ,0)
                     END  AS "한도기준TE금액"
              FROM ( SELECT A.그룹회사코드
                          , A.기준년월
170224                    , A.차주고객식별자
