                    GROUP BY  A.그룹회사코드
                            , A.기준년월
170224                      , A.차주고객식별자
                            , A.한도계좌번호
                            , A.한도상품대분류코드
                            , A.한도상품중분류코드
                            , A.한도상품템플릿코드
                            , A.한도상품번호
170224                      , A.관리부점코드
                    ) T126
                     , DB2DBA.THKJL0118 T118
              WHERE  T126.그룹회사코드        = T118.그룹회사코드
