      *@   지역본부별 한도 조회
           EXEC SQL
           DECLARE  THKJL0080_CUR    CURSOR WITH HOLD FOR
           SELECT A.대분류업종코드
                 ,A.지역본부코드
                 ,A.전년도말익스포져금액
                 ,VALUE(B."지역본부SUB한도",0)
                       AS "지역본부SUB한도"
                 ,VALUE(B."지역본부SUB한도",0) -
                  A.전년도말익스포져금액 AS 지역본부순증한도
                 ,A.지역본부익스포져금액
                 ,VALUE(B."지역본부SUB한도",0) -
                  A.지역본부익스포져금액 AS 지역본부한도여유
190110           ,MAX(MIN(ROUND(
                  CASE WHEN VALUE(B."지역본부SUB한도",0) = 0 THEN 0
                       ELSE DOUBLE(A.지역본부익스포져금액) /
                            DOUBLE(B."지역본부SUB한도" ) * 100
                  END,2),999.99),0) AS 지역본부소진율
                 ,VALUE(B.지역본부예외승인한도,0)
                       AS 지역본부예외승인한도
                 ,A.지역본부예외승인금액
                 ,VALUE(B.지역본부예외승인한도,0) -
                  A.지역본부예외승인금액 AS 지역예외승인여유금액
190110           ,MAX(MIN(ROUND(
                  CASE WHEN VALUE(B.지역본부예외승인한도,0) = 0 THEN 0
                       ELSE DOUBLE(A.지역본부예외승인금액) /
                            DOUBLE(B.지역본부예외승인한도) * 100
                  END,2),999.99),0)  AS 지역본부예외소진율
                 ,VALUE(B.지역본부기준소진율,0)
                       AS 지역본부기준소진율
             FROM  DB2DBA.THKJL0070 A  LEFT OUTER JOIN
                   DB2DBA.THKJL0080 B
               ON  A.그룹회사코드   = B.그룹회사코드
              AND  SUBSTR(A.기준년월일,1,6) = B.기준년월
              AND  A.대분류업종코드 = B.대분류업종코드
              AND  A.지역본부코드   = B.지역본부코드
            WHERE  A.그룹회사코드   = :WK-H-I-GROUP-CO-CD
              AND  A.기준년월일     = :WK-H-I-BASE-YMD
             WITH  UR
           END-EXEC.


