                                 IN (:WK-H-I-BRNCD2
                                    ,:WK-H-I-BRNCD3
                                    ,:WK-H-I-BRNCD4)
170119                         THEN  :WK-H-I-BRNCD1
                               WHEN 부점구분 IN ('06','07')
180117                         THEN  :WK-H-I-BRNCD8
                               WHEN 부점코드
                                 IN (:WK-H-I-BRNCD5
                                    ,:WK-H-I-BRNCD6
                                    ,:WK-H-I-BRNCD7)
170119                         THEN 부점코드
                               ELSE 영업지원본부부점코드
                          END,'    ','0000')
             INTO  :WK-H-O-AREA-HQ-CD
             FROM DB2DBA.THKJIBR01 E
            WHERE 그룹회사코드    = :WK-H-I-GROUP-CO-CD
              AND 부점코드        = :WK-H-O-MGT-BRNCD
              AND 적용종료년월일 >= :WK-H-I-BASE-YMD
              AND 적용시작년월일  =
                 (SELECT 적용시작년월일
                    FROM DB2DBA.THKJIBR01
                   WHERE 그룹회사코드    = E.그룹회사코드
                     AND 부점코드        = E.부점코드
                     AND 적용시작년월일 <= :WK-H-I-BASE-YMD
                   ORDER BY 적용시작년월일 DESC
                   FETCH FIRST 1 ROW ONLY
