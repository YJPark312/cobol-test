                      ('          ', '',
                       '==========','----------')
              AND NOT (A.한도상품대분류코드= ' ' OR
                       A.한도상품중분류코드= ' ' OR
                       A.한도상품템플릿코드= ' ' OR
                       A.한도상품번호      = ' ' )
200102        AND NOT EXISTS (SELECT 1
      *      지급보증신용장번호가 있는 해외여신을 제외
                                FROM DB2DBA.THKJL0126
