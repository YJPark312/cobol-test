      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKHC0433_CUR     CURSOR FOR
             SELECT  A.그룹회사코드
                  ,  B.고객식별자
                  ,  A.법인등록번호
                  ,  A.법인명
                  ,  A.지정업체등록상태구분
                  ,  A.지정업체자격구분
                  ,  A.할인제한구분
                  ,  A.어음등급구분
                  ,  A.유효년월일
                  ,  A.대출한도
                  ,  A.취급잔액
                  ,  A.취급제한사유내용
                  ,  A.관리부점코드
                  ,  A.등록년월일
                  ,  A.등록부점코드
                  ,  A.시스템최종처리일시
                  ,  A.시스템최종사용자번호
               FROM  DB2DBA.THKHC0433  A
                  ,  DB2DBA.THKAABPCB  B
              WHERE  A.그룹회사코드 =  B.그룹회사코드
                AND  A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  A.법인등록번호 =  B.고객고유번호
                AND  A.어음등급구분 BETWEEN '01' AND '09'
                AND  A.대출한도     > 0
                AND  A.할인제한구분 = '1'
                AND  A.지정업체등록상태구분 IN ('1','2')
                AND  B.고객유형분류구분 = '3'
               WITH UR
           END-EXEC.
