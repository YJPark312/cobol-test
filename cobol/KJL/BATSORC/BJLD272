           MOVE  CO-CHA-07
             TO  RJL0027-GRNR-CUST-DSTCD

      *          담보보증차주번호
           MOVE  SPACES
             TO  RJL0027-SCURTY-G-BRWR-NO

      *          차주번호
           MOVE  SPACE
             TO  RJL0027-BRWR-NO

      *          채무자구분
           MOVE  SPACE
             TO  RJL0027-DBTR-DSTCD

      *             담보구분
            STRING  CO-CHA-0
                    WK-H-O-NOTE-GRD-DSTCD
            DELIMITED  BY SIZE  INTO  RJL0027-SCURTY-DSTCD

      *    상품대분류코드
           MOVE  'GJ'
             TO  RJL0027-PRDCT-LAG-CLSFI-CD

      *    상품중분류코드
           MOVE  '04'
             TO  RJL0027-PRDCT-MEDM-CLSFI-CD

      *    상품템플릿코드
           MOVE  'DEN'
             TO  RJL0027-PRDCT-TMPLT-CD

      *    상품번호
           MOVE  '00001'
             TO  RJL0027-PRDCT-NO

      *    대출자격구분
           MOVE  SPACE
             TO  RJL0027-LN-QULFI-DSTCD

      *          간접중분류구분
           MOVE  '04'
             TO  RJL0027-INDR-M-CLSFI-DSTCD

      *          과목코드
           MOVE  'BIL'
             TO  RJL0027-SBJCT-CD

      *          통화코드
           MOVE  'KRW'
             TO  RJL0027-CNCYCD

      *          통화설정금액
           MOVE  WK-H-O-LN-CLAM
             TO  RJL0027-CRNCY-SETAMT

      *          원화환산금액
           MOVE  WK-H-O-LN-CLAM
             TO  RJL0027-WONC-AUC

      *          간접명목금액
           MOVE  WK-H-O-LN-CLAM
             TO  RJL0027-INDR-TTL-AMT

      *간접TE환산율조회
           PERFORM  S3310-KJL0019-SELECT-RTN
              THRU  S3310-KJL0019-SELECT-EXT

           INITIALIZE        WK-INDR-EXPSR-AMT
           COMPUTE  WK-INDR-EXPSR-AMT
                 =  WK-H-O-LN-CLAM
                 *  (WK-INDR-TE-UTCRT / 100)

           MOVE  WK-INDR-EXPSR-AMT
             TO  RJL0027-INDR-EXPSR-AMT

      *          관련테이블명
           MOVE  CO-TBL-ID
             TO  RJL0027-RELATD-TBL-NAME

      *          담보계약식별자
           MOVE  WK-H-O-CUST-IDNFR
             TO  RJL0027-SCURTY-CTRC-IDNFR

      *          담보계약계좌번호
           MOVE  WK-H-O-CUST-IDNFR
             TO  RJL0027-SCURTY-CTRC-ACNO

      *          시스템최종처리일시
           MOVE  BICOM-TRAN-BASE-YMS
             TO  RJL0027-SYS-LAST-PRCSS-YMS

      *          시스템최종사용자번호
           MOVE  BICOM-USER-EMPID
             TO  RJL0027-SYS-LAST-UNO

           .
       S3300-DATA-MOVE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  간접익스포져계정코드목록(THKJL0019) 조회
      *-----------------------------------------------------------------
       S3310-KJL0019-SELECT-RTN.

           INITIALIZE    TKJL0019-KEY
                         WK-INDR-TE-UTCRT

      *          그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  KJL0019-PK-GROUP-CO-CD

      *          기준년월
           MOVE  WK-H-I-BASE-YM
             TO  KJL0019-PK-BASE-YM

      *         상품대분류코드
           MOVE  RJL0027-PRDCT-LAG-CLSFI-CD
             TO  KJL0019-PK-PRDCT-LAG-CLSFI-CD

      *         상품중분류코드
           MOVE  RJL0027-PRDCT-MEDM-CLSFI-CD
             TO  KJL0019-PK-PRDCT-MEDM-CLSFI-CD

      *         상품템플릿코드
           MOVE  RJL0027-PRDCT-TMPLT-CD
             TO  KJL0019-PK-PRDCT-TMPLT-CD

      *         상품번호
           MOVE  RJL0027-PRDCT-NO
             TO  KJL0019-PK-PRDCT-NO

           EXEC SQL
             SELECT  VALUE("간접TE환산율",0)
               INTO  :WK-INDR-TE-UTCRT
               FROM  DB2DBA.THKJL0019
              WHERE  그룹회사코드   = :KJL0019-PK-GROUP-CO-CD
                AND  기준년월       = :KJL0019-PK-BASE-YM
                AND  상품대분류코드 = :KJL0019-PK-PRDCT-LAG-CLSFI-CD
                AND  상품중분류코드 = :KJL0019-PK-PRDCT-MEDM-CLSFI-CD
                AND  상품템플릿코드 = :KJL0019-PK-PRDCT-TMPLT-CD
                AND  상품번호       = :KJL0019-PK-PRDCT-NO
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  ZERO        TO  WK-INDR-TE-UTCRT
               WHEN  OTHER
                     MOVE 'KJL0019'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
            END-EVALUATE
           .
       S3310-KJL0019-SELECT-EXT.
           EXIT.
