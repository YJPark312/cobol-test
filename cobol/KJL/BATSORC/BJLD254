      *-----------------------------------------------------------------
      *@  계좌적용구분－순수개인　구분
      *@  - BJLD25H에서　순수개인을　분류　할수　없어서　여기서　처리
      *@  - WHY? : THKJL0015에는　순수개인정보가　없어서　처리　못함
      *-----------------------------------------------------------------
       S3310-KAABPDC-SELECT-RTN.

      *   거래자구분＝＇０１＇－－＞　개인　AS-IS그대로이행
      *   세부고객유형분류구분＝＇１１＇－－＞　개인　TO-BE기준
      *   세부고객유형분류구분으로　개인구분이　더　정확함

           INITIALIZE    WK-DTALS-CPC-DSTCD

           EXEC SQL
             SELECT  VALUE(세부고객유형분류구분,'00')
               INTO  :WK-DTALS-CPC-DSTCD
               FROM  DB2DBA.THKAABPDC
              WHERE  그룹회사코드    = :WK-H-I-GROUP-CO-CD
                AND  고객식별자      = :WK-H-O-CTCR-CUST-ID
                AND  고객관리번호    = :WK-H-O-CTCR-CUST-MGT-NO
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
      *             세부고객유형분류구분＝＇１１＇－－＞　개인
                     IF  WK-DTALS-CPC-DSTCD = CO-CHA-11
                     THEN
      *                 계좌적용구분
                         MOVE  CO-CHA-7  TO  RJL0025-ACN-APLY-DSTCD
                     ELSE
      *                 계좌적용구분
                         MOVE  CO-CHA-0  TO  RJL0025-ACN-APLY-DSTCD
                     END-IF
               WHEN  CO-NOT-FOUND
      *                 계좌적용구분
                         MOVE  CO-CHA-0  TO  RJL0025-ACN-APLY-DSTCD
               WHEN  OTHER
                     MOVE 'KAABPDC'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT S3310시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-KAABPDC-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  자동대출：대출잔액은　수신계좌번호로　정산에서　추출
      *-----------------------------------------------------------------
       S3310-KHDM100-SELECT-RTN.

           INITIALIZE    WK-CRNCY-BAL

           EXEC SQL
             SELECT  VALUE(잔액* -1 ,0)
               INTO  :WK-CRNCY-BAL
               FROM  DB2DBA.THKHDM100
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  계좌번호     = :WK-H-O-ACNO
                AND  잔액    < 0
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
      *@한도만기일이경과했을경우
      *@통장자동대출의경우잔액을한도로본다
                     IF RJL0025-EXPIR-YMD < WK-H-I-BASE-YMD
                     THEN
                         MOVE WK-CRNCY-BAL
                           TO RJL0025-CRNCY-CLAM
                     END-IF
                     MOVE  WK-CRNCY-BAL TO  RJL0025-CRNCY-BAL
                     ADD   CO-NUM-1     TO  WK-KHDM100-OK-CNT
               WHEN  CO-NOT-FOUND
                     MOVE  ZERO         TO  RJL0025-CRNCY-BAL
                     ADD   CO-NUM-1     TO  WK-KHDM100-NFND-CNT
               WHEN  OTHER
                     #USRLOG ' 계좌번호: ' WK-H-O-ACNO
                     MOVE 'KHDM100'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT S3320시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-KHDM100-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@만기일이　지났을경우는　한도사용금액을　한도로본다
      *@ -단，외국환일때는THKHC0414(외국환여신한도기본)사용
      *@ -한도사용금액　＝（무역금융누계잔액　＋　수입누계잔액　＋
      *@                    수출누계잔액　　　＋　외화수표누계잔액）
      *-----------------------------------------------------------------
       S3310-KHC0414-SELECT-RTN.

           INITIALIZE    WK-HANDO-CD
                         WK-HANDO-BAL

           EXEC SQL
             SELECT  VALUE(통화코드,' ')
                  ,  VALUE(무역금융누계잔액 +
                           수입누계잔액     +
                           수출누계잔액     +
                           외화수표누계잔액 , 0 )
               INTO  :WK-HANDO-CD
                  ,  :WK-HANDO-BAL
               FROM  DB2DBA.THKHC0414
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  계좌번호     = :WK-H-O-ACNO
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
      *@ 외국환이면  통화한도<-합계금액    (THKHC0414)
                     MOVE  WK-HANDO-BAL TO  RJL0025-CRNCY-CLAM
      *@ 외국환기본에　통화코드사용(THKHC0414)
                     MOVE  WK-HANDO-CD  TO  RJL0025-CNCYCD
      *@ 잔액합산＞０이면
                     IF  WK-HANDO-BAL > 0
                     THEN
                         ADD  CO-NUM-1
                          TO  WK-KHC0414-ZEROOK-CNT
                     END-IF
                     ADD   CO-NUM-1     TO  WK-KHC0414-OK-CNT
               WHEN  CO-NOT-FOUND
      *@ 외국환아니면　통화한도<-한도사용금액(THKHC0401)
                     MOVE  WK-H-O-LIMT-AMUS  TO  RJL0025-CRNCY-CLAM
                     ADD   CO-NUM-1          TO  WK-KHC0414-NFND-CNT
               WHEN  OTHER
                     #USRLOG ' 계좌번호: ' WK-H-O-ACNO
                     MOVE 'KHC0414'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT S3320시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-KHC0414-SELECT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  여신이개인으로분류된것중개인사업자정보가있는지확인
      *@  고객식별자로　법인고객식별자(차주고객식별자) 조회
      *-----------------------------------------------------------------
       S3310-KAABPCB-SELECT-RTN.

      *@   고객정보 초기화
           INITIALIZE    WK-COPR-CUST-IDNFR

      *@   고객고유번호구분= 02:사업자등록번호의
      *@                      법인고객식별자조회
           EXEC SQL
             SELECT  B.법인고객식별자
               INTO :WK-COPR-CUST-IDNFR
               FROM  DB2DBA.THKAABPCB A
                    ,DB2DBA.THKAABPCO B
              WHERE  A.그룹회사코드     = B.그룹회사코드
                AND  A.고객식별자       = B.고객식별자
                AND  A.그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND  A.고객식별자       = :WK-H-O-CTCR-CUST-ID
                AND  A.고객고유번호구분 = '02'
               WITH  UR
           END-EXEC

      *@   SQLCODE CHECK

           EVALUATE  SQLCODE
               WHEN  CO-OK
      *@법인사업자(THKAABPCO) 법인고객식별자조회
                     CONTINUE
               WHEN  CO-NOT-FOUND
      *@법인사업자(THKAABPCB)외의　고객고유번호조회
                     MOVE  WK-H-O-CTCR-CUST-ID
                       TO  WK-COPR-CUST-IDNFR
               WHEN  OTHER
                     MOVE 'KAABPCB'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT S3310시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-KAABPCB-SELECT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   통화별원화환산금액 CALCURATER
      *-----------------------------------------------------------------
       S3320-BJLTGEX-CALL-RTN.

           INITIALIZE    XBJLTGEX-CA

      *    처리구분(1:통화별환산2:외환매매익　역환산)
           MOVE  CO-CHA-1
             TO  XBJLTGEX-I-GBCD

      *    유효년월일－기준년월일
           MOVE  WK-H-I-BASE-YMD
             TO  XBJLTGEX-I-BASE-YMD

      *    통화코드
           MOVE  RJL0025-CNCYCD
             TO  XBJLTGEX-I-CNCYCD

      *    통화한도금액
           MOVE  RJL0025-CRNCY-CLAM
             TO  XBJLTGEX-I-CRNCY-CLAM

      *    통화기준잔액
           MOVE  RJL0025-CRNCY-BAL
             TO  XBJLTGEX-I-CRNCY-BAL

           #DYCALL  BJLTGEX YCCOMMON-CA XBJLTGEX-CA

           IF  XBJLTGEX-R-STAT = CO-STAT-OK

      *        BS기준잔액
               MOVE  XBJLTGEX-O-BS-BASE-BAL
                 TO  RJL0025-BS-BASE-BAL

      *        명목액기준한도
               MOVE  XBJLTGEX-O-TTL-AMT-BASE-CLAM
                 TO  RJL0025-TTL-AMT-BASE-CLAM

      *        명목액기준잔액
               MOVE  XBJLTGEX-O-TTL-AMT-BASE-BAL
                 TO  RJL0025-TTL-AMT-BASE-BAL

           ELSE

      *        BS기준잔액
               MOVE  ZERO
                 TO  RJL0025-BS-BASE-BAL

      *        명목액기준한도
               MOVE  ZERO
                 TO  RJL0025-TTL-AMT-BASE-CLAM

      *        명목액기준잔액
               MOVE  ZERO
                 TO  RJL0025-TTL-AMT-BASE-BAL

           END-IF
           .
       S3320-BJLTGEX-CALL-EXT.
           EXIT.
      *-----------------------------------------------------------------
