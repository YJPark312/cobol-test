      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *@재약정한도계좌구분：＇２＇（구한도）제외
           EXEC SQL
            DECLARE  THKHC0401_CUR     CURSOR FOR
             SELECT CASE WHEN  A.한도계좌관리구분 = '3'
                         THEN  A.자동대출수신계좌번호
                         ELSE  A.계좌번호
                     END 계좌번호
                  ,  A.통화코드
                  ,  A.상품대분류코드
                  ,  A.상품중분류코드
                  ,  A.상품템플릿코드
                  ,  A.상품번호
                  ,  A.계약자고객식별자
                  ,  A.계약자고객관리번호
                  ,  A.관리부점코드
                  ,  A.상품계약상태구분
                  ,  A.상품계약약정년월일
                  ,  A.상품계약만기년월일
                  ,  A.상품계약폐기년월일
                  ,  A.한도계좌여부
                  ,  A.한도사용금액
                  ,  A.계약금액
                  ,  A.대출실행누계금액
                  ,  A.한도계좌관리구분
                  ,  VALUE((SELECT 분할인출가능종료일
                     FROM DB2DBA.THKHC0481
                     WHERE 그룹회사코드 = A.그룹회사코드
                       AND 계좌번호 = A.계좌번호),' ') AS
                     분할인출가능종료일
               FROM  DB2DBA.THKHC0401 A
                  ,  DB2DBA.THKJL0018 B
              WHERE  A.그룹회사코드    = :WK-H-I-GROUP-CO-CD
                AND  A.한도계좌여부    = '1'
                AND  A.그룹회사코드    = B.그룹회사코드
                AND  B.기준년월        = :WK-H-I-BASE-YM
                AND  A.상품대분류코드  = B.상품대분류코드
                AND  A.상품중분류코드  = B.상품중분류코드
                AND  A.상품템플릿코드  = B.상품템플릿코드
                AND  A.상품번호        = B.상품번호
                AND  A.재약정한도계좌구분 <> '2'
                AND  A.상품계약상태구분    = '1'
                AND  A.관리부점코드       <> :WK-H-I-BRNCD
                AND  A.계약금액 > 0
               WITH  UR
           END-EXEC.

