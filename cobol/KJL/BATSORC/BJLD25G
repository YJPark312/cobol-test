                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR FETCH시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
      *에러메시지:내부 본 처리
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3200-TKJLR003-FETCH-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   파생상품네팅　상계대상계좌 DATA MOVE
      *-----------------------------------------------------------------
       S3300-DATA-MOVE-RTN.

           INITIALIZE    OT-REC

      *    THKJL0015 고객번호추출
           PERFORM  S3310-SELECT-GOGAKEX-RTN
              THRU  S3310-SELECT-GOGAKEX-EXT

      *    그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  RJL0025-GROUP-CO-CD

      *    계좌번호
           MOVE  'PS NET '             TO  RJL0025-ACNO(1:7)
           MOVE  WK-H-O1-FC-TRAN-NO
             TO  RJL0025-ACNO(8:10)

      *    기준일
           MOVE  WK-H-I-BASE-DD
             TO  RJL0025-BASE-DD

      *    기준년월
           MOVE  WK-H-I-BASE-YM
             TO  RJL0025-BASE-YM

      *    계좌중복일련번호
           MOVE  WK-AC-FE-CNT1
             TO  RJL0025-ACN-DUP-SERNO

      *    고객식별자
           MOVE  WK-H-O1-ISSU-CPRNO(1:10)
             TO  RJL0025-CUST-IDNFR

      *    고객관리번호
           MOVE  WK-H-O1-ISSU-CPRNO(11:3)
             TO  RJL0025-CUST-MGT-NO

      *    해외현지법인여부
           MOVE  XBJLCUST-O-HWGB
             TO  RJL0025-OVSES-LCAL-COPR-YN

      *    차주번호
           MOVE  XBJLCUST-O-MAMA-CORPNO
             TO  RJL0025-BRWR-NO

      *    관리부점코드
           MOVE  WK-H-O1-MGT-BRNCD
             TO  RJL0025-MGT-BRNCD

      *    계좌적용구분
           MOVE  XBJLCUST-O-GJGB
             TO  RJL0025-ACN-APLY-DSTCD

      *    한도계좌여부
           MOVE  CO-CHA-0
             TO  RJL0025-LIMT-ACN-YN

      *    상품대분류코드
           MOVE  WK-H-O1-PRDCT-LAG-CLSFI-CD
             TO  RJL0025-PRDCT-LAG-CLSFI-CD

      *    상품중분류코드
           MOVE  WK-H-O1-PRDCT-MEDM-CLSFI-CD
             TO  RJL0025-PRDCT-MEDM-CLSFI-CD

      *    상품템플릿코드
           MOVE  WK-H-O1-PRDCT-TMPLT-CD
             TO  RJL0025-PRDCT-TMPLT-CD

      *    상품번호
           MOVE  WK-H-O1-PRDCT-NO
             TO  RJL0025-PRDCT-NO

      *    대출자격구분
           MOVE  SPACE
             TO  RJL0025-LN-QULFI-DSTCD

      *    시작년월일
           MOVE  WK-H-O1-NEW-YMD
             TO  RJL0025-START-YMD

      *    만기년월일
           MOVE  WK-H-O1-EXPIR-YMD
             TO  RJL0025-EXPIR-YMD

      *    종료년월일
           MOVE  SPACE
             TO  RJL0025-END-YMD

      *    상품계약상태구분
           MOVE  CO-CHA-3
             TO  RJL0025-PRDCT-C-STUS-DSTCD

      *    통화코드
           MOVE  WK-H-O1-LCAL-CNCYCD
             TO  RJL0025-CNCYCD

      *    통화한도
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  RJL0025-CRNCY-CLAM

      *    통화잔액
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  RJL0025-CRNCY-BAL

      *   합성선물환BS금액은해더옵션－현지통화대출금액으로대체
           IF  WK-H-O1-CMBS-SM-CLSFI-DSTCD  = '01' AND
               WK-H-O1-CMBS-DTCLS-DSTCD = '13'
           THEN
               PERFORM  S3320-BS-AMT-RTN
                  THRU  S3320-BS-AMT-EXT

               MOVE  WK-BSKJE          TO  WK-TM-HJTDGM

           ELSE
      *        현지통화대출금액을임시로
               MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
                 TO  WK-TM-HJTDGM
           END-IF

      *    통화별환산
      *    통화코드가원화
           IF  WK-H-O1-LCAL-CNCYCD = CO-CHA-KRW
           THEN
               MOVE  WK-TM-HJTDGM      TO  WK-CUTE-JAN
      *        BS기준잔액
               MOVE  WK-TM-HJTDGM      TO  RJL0025-BS-BASE-BAL
           ELSE
      *        통화별　원화환산금액CALCURATER
               PERFORM  S3330-BJLTGEX-CALL-RTN
                  THRU  S3330-BJLTGEX-CALL-EXT
           END-IF

      *    잔존기간별　신용환산율　추출
      *    잔존만기일　추출
           PERFORM  S3340-CJIIL01-CALL-RTN
              THRU  S3340-CJIIL01-CALL-EXT

           EVALUATE  WK-H-O1-CMBS-SM-CLSFI-DSTCD
      *        통화인　경우
               WHEN  '01'
                     EVALUATE  TRUE
                         WHEN  WK-REMAIN < 365
                               MOVE  0.01
                                 TO  WK-SYHYUL
                         WHEN  WK-REMAIN >= 365 AND WK-REMAIN < 1825
                               MOVE  0.05
                                 TO  WK-SYHYUL
                         WHEN  WK-REMAIN >= 1825
                               MOVE  0.0075
                                 TO  WK-SYHYUL
                         WHEN OTHER
                              CONTINUE
                     END-EVALUATE
      *        이자율인　경우
               WHEN  '02'
                     EVALUATE  TRUE
                         WHEN  WK-REMAIN < 365
                               MOVE  0
                                 TO  WK-SYHYUL
                         WHEN  WK-REMAIN >= 365 AND WK-REMAIN < 1825
                               MOVE  0.005
                                 TO  WK-SYHYUL
                         WHEN  WK-REMAIN >= 1825
                               MOVE  0.0015
                                 TO  WK-SYHYUL
                         WHEN OTHER
                              CONTINUE
                     END-EVALUATE
      *        주가지수인　경우
               WHEN  '03'
                     EVALUATE  TRUE
                         WHEN  WK-REMAIN < 365
                               MOVE  0.06
                                 TO  WK-SYHYUL
                         WHEN  WK-REMAIN >= 365 AND WK-REMAIN < 1825
                               MOVE  0.08
                                 TO  WK-SYHYUL
                         WHEN  WK-REMAIN >= 1825
                               MOVE  0.1
                                 TO  WK-SYHYUL
                         WHEN OTHER
                              CONTINUE
                     END-EVALUATE
               WHEN  OTHER
                     EVALUATE  TRUE
                         WHEN  WK-REMAIN < 365
                               MOVE  0.10
                                 TO  WK-SYHYUL
                         WHEN  WK-REMAIN >= 365 AND WK-REMAIN < 1825
                               MOVE  0.12
                                 TO  WK-SYHYUL
                         WHEN  WK-REMAIN >= 1825
                               MOVE  0.15
                                 TO  WK-SYHYUL
                         WHEN OTHER
                              CONTINUE
                     END-EVALUATE
           END-EVALUATE

      *차주의　순대체비용／총대체비용　추출
           PERFORM  S3350-KJL0023-SELECT-RTN
              THRU  S3350-KJL0023-SELECT-EXT

      *( 계약금액Ⅹ신용환산율 ) Ⅹ
      *                 | 0.4+0.6 Ⅹ ( 순대체비용 / 총대체비용 )

           IF  RJL0023-NET-TRFER-CST = ZERO
           THEN
               COMPUTE  WK-H-O1-LCAL-C-LNAMT-AMT
                     = (WK-CUTE-JAN * WK-SYHYUL)
                     *  0.4
           ELSE
               COMPUTE  WK-H-O1-LCAL-C-LNAMT-AMT
                     = (WK-CUTE-JAN * WK-SYHYUL)
                     * (0.4 + 0.6
                     * (RJL0023-NET-TRFER-CST
                     /  RJL0023-TOTAL-TRFER-CST))
           END-IF

           MOVE  WK-SYHYUL             TO  WK-TEMP
      *     #USRLOG '* WK-REMAIN             = ' WK-REMAIN
      *     #USRLOG '* RJL0025-ACNO          = ' RJL0025-ACNO
      *     #USRLOG '* WK-CUTE-JAN           = ' WK-CUTE-JAN
      *     #USRLOG '* WK-SYHYUL             = ' WK-TEMP

      *파생상품네팅계좌는계정별환산율무시하고명목액금액그대로사용
      *    명목액기준한도
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  RJL0025-TTL-AMT-BASE-CLAM

      *    명목액기준잔액
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  RJL0025-TTL-AMT-BASE-BAL

      *    TE한도환산금액
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  RJL0025-TE-LIMT-AUC

      *    TE잔액환산금액
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  RJL0025-TE-BAL-AUC

      *차주의　신표준산업분류코드　추출
           PERFORM  S3360-KJL0015-SELECT-RTN
              THRU  S3360-KJL0015-SELECT-EXT

      *금융기관인경우　환산율을　다르게　적용
      *신표준산업분류
           EVALUATE  RJL0015-NEW-SI-CLSFI-CD(1:2)
      *        통화인　경우
               WHEN '64'
               WHEN '65'
               WHEN '66'
      *              CP한도환산금액
                     MOVE  ZERO
                       TO  RJL0025-INLS-GRCR-LIMT-AUC

      *              CP잔액환산금액
                     MOVE  ZERO
                       TO  RJL0025-INLS-GRCR-BAL-AUC
               WHEN  OTHER
      *              CP한도환산금액
                     MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
                       TO  RJL0025-INLS-GRCR-LIMT-AUC

      *              CP잔액환산금액
                     MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
                       TO  RJL0025-INLS-GRCR-BAL-AUC
           END-EVALUATE

      *    CA담보제외금액
           MOVE  ZERO
             TO  RJL0025-CA-SCURTY-ECLUD-AMT

      *    CA담보환산금액
           MOVE  ZERO
             TO  RJL0025-CA-SCURTY-AUC

      *    관련테이블명
           MOVE  'TKJLR003'
             TO  RJL0025-RELATD-TBL-NAME

      *    과목코드
           MOVE  CO-CHA-NET
             TO  RJL0025-SBJCT-CD

      *    시스템최종처리일시
           MOVE  BICOM-TRAN-BASE-YMS
             TO  RJL0025-SYS-LAST-PRCSS-YMS

      *    시스템최종사용자번호
           MOVE  BICOM-USER-EMPID
             TO  RJL0025-SYS-LAST-UNO
           .
       S3300-DATA-MOVE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   채무고객정보추출
      *-----------------------------------------------------------------
       S3310-SELECT-GOGAKEX-RTN.

           INITIALIZE    XBJLCUST-CA

      *--  그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  XBJLCUST-I-GROUP-CO-CD

      *--  여신종류구분
           MOVE  '2'
             TO  XBJLCUST-I-YSGB

      *--  관리부실점코드
           MOVE  WK-H-O1-MGT-BRNCD
             TO  XBJLCUST-I-BRCD

      *--  주민번호및법인등록번호
           MOVE  WK-H-O1-ISSU-CPRNO
             TO  XBJLCUST-I-BRWR-NO

      *주민번호및법인등록번호가없으면＇기타＇로　적용
           IF  WK-H-O1-ISSU-CPRNO = SPACES
           THEN
      *        계좌적용구분
               MOVE  '9'
                 TO  RJL0025-ACN-APLY-DSTCD

      *        해외현지법인여부
               MOVE  '0'
                 TO  RJL0025-OVSES-LCAL-COPR-YN

           ELSE

               #DYCALL  BJLCUST YCCOMMON-CA XBJLCUST-CA

               IF  NOT COND-XBJLCUST-OK
                   #ERROR  XBJLCUST-R-ERRCD
                           XBJLCUST-R-TREAT-CD
                           XBJLCUST-R-STAT
                   #OKEXIT CO-CHA-08
               END-IF

      *        차주번호
               MOVE  XBJLCUST-O-MAMA-CORPNO
                 TO  RJL0025-BRWR-NO

      *        계좌적용구분
               MOVE  XBJLCUST-O-GJGB
                 TO  RJL0025-ACN-APLY-DSTCD

      *        해외현지법인여부
               MOVE  XBJLCUST-O-HWGB
                 TO  RJL0025-OVSES-LCAL-COPR-YN
           END-IF
           .
       S3310-SELECT-GOGAKEX-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   합성선물환－해더（BS금액추출）
      *-----------------------------------------------------------------
       S3320-BS-AMT-RTN.

           EXEC SQL
             SELECT  VALUE(현지통화대출금액,0)
               INTO  :WK-BSKJE
               FROM  DB2DBA.THKJLR003
              WHERE  그룹회사코드      = :WK-H-I-GROUP-CO-CD
                AND  기준년월일        = :WK-H-I-BASE-YMD
                AND  외화상품유형구분  = :WK-H-O1-FC-PRDCT-PTRN-DSTCD
                AND  외화거래번호      = :WK-H-O1-FC-TRAN-NO
      *         AND  상품대분류코드    = :WK-H-O1-PRDCT-LAG-CLSFI-CD
      *         AND  상품중분류코드    = :WK-H-O1-PRDCT-MEDM-CLSFI-CD
      *         AND  상품템플릿코드    = :WK-H-O1-PRDCT-TMPLT-CD
      *         AND  상품번호          = :WK-H-O1-PRDCT-NO
                AND  "CMBS과목중분류구분" = '01'
                AND  "CMBS세분류구분"     = '12'
                AND  상계처리등록여부     = '1'
           END-EXEC.

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  RJL0025-CRNCY-BAL
                       TO  WK-BSKJE
               WHEN  OTHER
                     MOVE 'KJLR003'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'BS금액　추출시　오류가 발생했습니다'
                       TO  XZUGEROR-I-MSG
      *에러메시지:내부 본 처리
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3320-BS-AMT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   통화별　원화환산금액 CALCURATER
      *-----------------------------------------------------------------
       S3330-BJLTGEX-CALL-RTN.

           INITIALIZE    XBJLTGEX-CA

      *    처리구분(1:통화별환산2:외환매매익역환산)
           MOVE  CO-CHA-1
             TO  XBJLTGEX-I-GBCD

      *    기준년월일
           MOVE  WK-H-I-BASE-YMD
             TO  XBJLTGEX-I-BASE-YMD

      *    통화코드
           MOVE  WK-H-O1-LCAL-CNCYCD
             TO  XBJLTGEX-I-CNCYCD


      *    현지통화대출금액->통화한도금액
           MOVE  WK-H-O1-LCAL-C-LNAMT-AMT
             TO  XBJLTGEX-I-CRNCY-CLAM

      *    통화기준잔액
           MOVE  WK-TM-HJTDGM
             TO  XBJLTGEX-I-CRNCY-BAL

           MOVE  XBJLTGEX-I-CRNCY-CLAM  TO WK-TEMP1
           MOVE  XBJLTGEX-I-CRNCY-CLAM  TO WK-TEMP2
      *     #USRLOG  'XBJLTGEX-I-CNCYCD     : ' XBJLTGEX-I-CNCYCD
      *     #USRLOG  'XBJLTGEX-I-CRNCY-CLAM : ' WK-TEMP1
      *     #USRLOG  'XBJLTGEX-I-CRNCY-BAL  : ' WK-TEMP2

           #DYCALL  BJLTGEX YCCOMMON-CA XBJLTGEX-CA

           IF  XBJLTGEX-R-STAT = CO-STAT-OK

      *        잔액->BS잔액
               MOVE  XBJLTGEX-O-BS-BASE-BAL
                 TO  RJL0025-BS-BASE-BAL

      *        전신환매도율환산한도액
               MOVE  XBJLTGEX-O-TTL-AMT-BASE-CLAM
                 TO  WK-CUTE-JAN
           ELSE
      *        통화별　원화환산금액 NULL OR SYSTEM ERR
               MOVE  ZERO
                 TO  RJL0025-BS-BASE-BAL

      *        전신환매도율환산한도액
               MOVE  ZERO
                 TO  WK-CUTE-JAN
           END-IF

           MOVE  XBJLTGEX-O-BS-BAL  TO WK-TEMP3
           MOVE  XBJLTGEX-O-TTL-AMT-BASE-CLAM  TO WK-TEMP4
      *     #USRLOG  'XBJLTGEX-O-BS-BAL            : ' WK-TEMP3
      *     #USRLOG  'XBJLTGEX-O-TTL-AMT-BASE-CLAM : ' WK-TEMP4
           .
       S3330-BJLTGEX-CALL-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@ 양일자간의일수（잔존만기일）추출
      *-----------------------------------------------------------------
       S3340-CJIIL01-CALL-RTN.

           INITIALIZE    XCJIIL01-CA

      *   그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  XCJIIL01-I-GROUP-CO-CD

      *   구분:일수/월수/윤년일수 산출
           MOVE  CO-CHA-1
             TO  XCJIIL01-I-DSTCD

      *   시작년월일
           MOVE  WK-H-I-BASE-YMD
             TO  XCJIIL01-I-START-YMD

      *   종료년월일
           MOVE  WK-H-O1-EXPIR-YMD
             TO  XCJIIL01-I-END-YMD

