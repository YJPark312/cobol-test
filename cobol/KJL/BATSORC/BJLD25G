      *-----------------------------------------------------------------
      *@    차주파생상품네팅비용(THKJL0023)조회
      *-----------------------------------------------------------------
       S3350-KJL0023-SELECT-RTN.

           INITIALIZE    TKJL0023-KEY
                         TRJL0023-REC

           EXEC SQL
             SELECT  VALUE(SUM(순대체비용 ),0)
                  ,  VALUE(SUM(총대체비용 ),0)
               INTO  :RJL0023-NET-TRFER-CST
                  ,  :RJL0023-TOTAL-TRFER-CST
               FROM  DB2DBA.THKJL0023
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월일   = :WK-H-I-BASE-YMD
                AND  차주번호     = :XBJLCUST-O-MAMA-CORPNO
           END-EXEC.

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  ZERO
                       TO  RJL0023-NET-TRFER-CST
                     MOVE  ZERO
                       TO  RJL0023-TOTAL-TRFER-CST
               WHEN  OTHER
                     MOVE 'KJL0023'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
      *에러메시지:내부 본 처리
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3350-KJL0023-SELECT-EXT.
           EXIT.
