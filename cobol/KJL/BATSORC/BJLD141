      * SQL CURSOR DECLARE
      * THKABCB01.법인등록번호 대체번호컬럼 : 고객식별자
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKABCB01_CUR     CURSOR FOR
             SELECT  C.고객식별자
                  ,  A.한신평기업규모구분
                  ,  A.한신평업체약어명
                  ,  A.한신평그룹코드
               FROM  DB2DBA.THKABCB01 A
                    ,DB2DBA.THKAAADET B
                    ,DB2DBA.THKAABPCB C
              WHERE  A.그룹회사코드   = B.그룹회사코드
                AND  A.그룹회사코드   = C.그룹회사코드
                AND  A.그룹회사코드   = 'KB0'
                AND  A.고객식별자     = B.대체번호
170810          AND  B.양방향고객암호화번호 = C.양방향고객암호화번호
                AND  A.한신평업체코드 =
                 (SELECT
                   SUBSTR(MAX(최종변경년월일||한신평업체코드),9,6)
                    FROM DB2DBA.THKABCB01
                   WHERE 그룹회사코드 = A.그룹회사코드
                     AND 고객식별자   = A.고객식별자
                     )
                AND  A.한신평그룹코드 NOT IN
                                      (' ','  ','   ','0','00','000')
170810          AND  NOT EXISTS
                     (SELECT 1
                        FROM DB2DBA.THKJL0024
                       WHERE 그룹회사코드 = C.그룹회사코드
                         AND 고객식별자   = C.고객식별자
                         AND 계열적용구분 = '1'
                      )
               WITH  UR
           END-EXEC.
