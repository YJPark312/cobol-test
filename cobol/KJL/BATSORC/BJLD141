           EXIT.
      *-----------------------------------------------------------------
      *@   DATA WRITE
      *-----------------------------------------------------------------
       S3400-DATA-WRITE-RTN.

           WRITE OT-REC

           IF  WK-OT-F-ST NOT = CO-STAT-OK
               MOVE 'OT-FILE WRITE ERROR : FILE-ST IS '
                                       TO  XZUGEROR-I-MSG
               MOVE  WK-OT-F-ST        TO  XZUGEROR-I-MSG(34:2)
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

           ADD   CO-NUM-1              TO  WK-AC-WT-CNT
           .
       S3400-DATA-WRITE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR CLOSE
      *-----------------------------------------------------------------
       S3500-KABCB01-CLOSE-RTN.

           EXEC SQL
              CLOSE  THKABCB01_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KABCB01'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'CLOSE'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR CLOSE시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3500-KABCB01-CLOSE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  전반자　변환
      *------------------------------------------------------------
       S8000-IEA9000-PROCESS-RTN.

           INITIALIZE                     XIEA9000-IN
           MOVE  CO-CHA-01             TO XIEA9000-I-PRCSS-DSTIC
           MOVE  WK-HJ-DATA            TO XIEA9000-I-INPT-DATA
           MOVE  WK-LENGTH             TO XIEA9000-I-OUTPT-RQST-LEN

      *@  전반자　변환
           #DYCALL  IEA9000  YCCOMMON-CA  XIEA9000-CA

      *@  전반자　변환결과
           IF  COND-XIEA9000-OK
               MOVE XIEA9000-O-OUTPT-DATA
                 TO WK-HH-DATA
           ELSE
               MOVE WK-HJ-DATA
                 TO WK-HH-DATA
           END-IF
           .
       S8000-IEA9000-PROCESS-EXT.
           EXIT.

