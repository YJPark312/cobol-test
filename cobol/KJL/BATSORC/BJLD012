                AND  한신평그룹코드   = :WK-AFFLT-CORP-GROUP-CD
                AND  결산년           = :WK-STLACC-YR
                AND  한신평작업시기구분 = :WK-JOB-TIMG-DSTCD
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
               WHEN  CO-NOT-FOUND
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KABCA04'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'GIJUN-DATA-03시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *@1 기준년월일 기준 전년월일 산출
           PERFORM  S3211-CJIIL03-CALL-RTN
              THRU  S3211-CJIIL03-CALL-EXT
