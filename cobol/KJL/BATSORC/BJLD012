      *@1  HOST INPUT에 값 SET

      *   그룹회사구분코드
           MOVE  WK-SYSIN-GROUP-CD
             TO  WK-H-I-GROUP-CO-CD

      *   기준일
           MOVE  WK-SYSIN-BASE-YMD(7:2)
             TO  WK-H-I-BASE-DD

      *   기준년월
           MOVE  WK-SYSIN-BASE-YMD(1:6)
             TO  WK-H-I-BASE-YM
           .
       S3000-SYSDATA-MOVE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   업무처리
      *-----------------------------------------------------------------
       S3000-PROCESS-RTN.

      *@1  READ FILE
           PERFORM  S3100-READ-FILE-RTN
              THRU  S3100-READ-FILE-EXT

      *@1  NOT FOUND일때까지 처리
           PERFORM  UNTIL  IN-EOF-Y

      *@2          포괄신용공여한도대상업체제무재표조회
                    PERFORM  S3200-DATA-GIJUN-RTN
                       THRU  S3200-DATA-GIJUN-EXT

      *@2           DATA MOVE
                    PERFORM  S3300-DATA-MOVE-RTN
                       THRU  S3300-DATA-MOVE-EXT

      *@2           DATA WRITE
                    PERFORM  S3400-DATA-WRITE-RTN
                       THRU  S3400-DATA-WRITE-EXT

      *@2           READ FILE
                    PERFORM  S3100-READ-FILE-RTN
                       THRU  S3100-READ-FILE-EXT
           END-PERFORM
           .
       S3000-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   READ FILE
      *-----------------------------------------------------------------
       S3100-READ-FILE-RTN.

      *   초기화
           INITIALIZE    WK-AREA

      *@1  READ FILE
           READ  IN-FILE     AT  END
            SET  IN-EOF-Y    TO  TRUE
           END-READ

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  WK-IN-F-ST
               WHEN  ZERO
               WHEN  CO-CHA-04
                     MOVE  IN-AFFLT-CORP-GROUP-CD(3:3)
                       TO  WK-AFFLT-CORP-GROUP-CD

                     ADD   CO-NUM-1    TO  WK-AC-READ-CNT
               WHEN  CO-CHA-10
                     SET   IN-EOF-Y    TO  TRUE
               WHEN  OTHER
                     MOVE 'IN-FILE OPEN ERROR : FILE-ST IS '
                                       TO  XZUGEROR-I-MSG
                     MOVE  WK-IN-F-ST  TO  XZUGEROR-I-MSG(34:2)
                     #ERROR  CO-EBM02001 CO-UBM02001 WK-IN-F-ST
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3100-READ-FILE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  포괄신용공여한도대상업체제무재표조회
      *-----------------------------------------------------------------
       S3200-DATA-GIJUN-RTN.

      *   초기화
           INITIALIZE    WK-STLACC-YR

      *-----------------------------------------------------------------
      *@1 결산년월일 조회
      *-----------------------------------------------------------------
      *@2 조건항목:그룹회사코드,한신평업체코드,
      *@한신평결산자료구분(K:결산)
      *@2 한국신용평가그룹합산재무제표(THKABCA04) SELECT
      *@2 출력항목:결산년
           EXEC SQL
             SELECT  VALUE(MAX(결산년),'0001')
               INTO  :WK-STLACC-YR
               FROM  DB2DBA.THKABCA04
              WHERE  그룹회사코드   = :WK-H-I-GROUP-CO-CD
                AND  한신평그룹코드 = :WK-AFFLT-CORP-GROUP-CD
                AND  한신평결산자료구분 = 'K'
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
      *#1           결산년이 '0001' 아닌 경우
                     IF WK-STLACC-YR NOT = '0001'
      *@2              한신평그룹합산제무자료조회
                        PERFORM  S3210-GIJUN-DATE-SELECT-RTN
                           THRU  S3210-GIJUN-DATE-SELECT-EXT

      *@2              그룹제무재표조회
                        PERFORM  S3220-KABCA04-SELECT-RTN
                           THRU  S3220-KABCA04-SELECT-EXT
                     END-IF
               WHEN  CO-NOT-FOUND
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KABCA04'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'GIJUN-DATA-01시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3200-DATA-GIJUN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  한신평그룹합산제무자료조회
      *-----------------------------------------------------------------
       S3210-GIJUN-DATE-SELECT-RTN.

      *-----------------------------------------------------------------
      *@1 기준년 한신평작업시기구분 조회
      *-----------------------------------------------------------------
      *@2 조건항목:그룹회사코드,한신평그룹코드,결산년
      *@(기준년),한신평결산자료구분(K:결산),
      *@2 한국신용평가그룹합산재무제표(THKABCA04) SELECT
      *@2 출력항목:한신평작업시기구분

      *   초기화
           INITIALIZE    WK-JOB-TIMG-DSTCD

           EXEC SQL
             SELECT  MAX(한신평작업시기구분)
