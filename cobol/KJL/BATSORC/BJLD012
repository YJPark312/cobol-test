                                    ELSE  0
                               END),0)
               INTO  :WK-IJS-AMT
                    ,:WK-IJS-AMT-1
                    ,:WK-IJS-AMT-2
               FROM  DB2DBA.THKABCA04
              WHERE  그룹회사코드        = :WK-H-I-GROUP-CO-CD
                AND  한신평그룹코드      = :WK-AFFLT-CORP-GROUP-CD
                AND  결산년             IN (:WK-STLACC-YR,
                                              :WK-STLACC-YR-1,
                                              :WK-STLACC-YR-2)
                AND  한신평작업시기구분  = :WK-JOB-TIMG-DSTCD
                AND  외부감사대상여부구분= :WK-EXADIT-TAGET-YN
                AND  한신평결산자료구분  = 'K'
                AND  한신평보고서구분    = '12'
                AND  한신평재무항목코드  = '5101'
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     COMPUTE  WK-IJS-AMT   =  WK-IJS-AMT   * 1000000
                     COMPUTE  WK-IJS-AMT-1 =  WK-IJS-AMT-1 * 1000000
                     COMPUTE  WK-IJS-AMT-2 =  WK-IJS-AMT-2 * 1000000
               WHEN  CO-NOT-FOUND
                     MOVE  0           TO  WK-IJS-AMT
                     MOVE  0           TO  WK-IJS-AMT-1
                     MOVE  0           TO  WK-IJS-AMT-2
               WHEN  OTHER
                     MOVE 'KABCA04'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'DATA-SEL-02시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *-----------------------------------------------------------------
      *@1 감가상각비 조회
      *-----------------------------------------------------------------
      *@2 조건항목:그룹회사코드,한신평그룹코드,결산년
      *@한신평작업시기구분,외부감사대상여부구분,
      *@한신평결산자료구분(K),한신평보고서구분(16),
      *@한신평재무항목코드(1211,1212)
      *@2 한국신용평가그룹합산재무제표(THKABCA04) SELECT
      *@2 출력항목:그룹합계재무금액

      *   초기화
           INITIALIZE    WK-GGS-AMT
                         WK-GGS-AMT-1
                         WK-GGS-AMT-2

           EXEC SQL
             SELECT  VALUE(SUM(CASE WHEN 결산년 = :WK-STLACC-YR
                                    THEN 그룹합계재무금액
                                    ELSE  0
                               END),0)
                    ,VALUE(SUM(CASE WHEN 결산년 = :WK-STLACC-YR-1
                                    THEN 그룹합계재무금액
                                    ELSE  0
                               END),0)
                    ,VALUE(SUM(CASE WHEN 결산년 = :WK-STLACC-YR-2
                                    THEN 그룹합계재무금액
                                    ELSE  0
                               END),0)
               INTO  :WK-GGS-AMT
                    ,:WK-GGS-AMT-1
                    ,:WK-GGS-AMT-2
               FROM  DB2DBA.THKABCA04
              WHERE  그룹회사코드        = :WK-H-I-GROUP-CO-CD
                AND  한신평그룹코드      = :WK-AFFLT-CORP-GROUP-CD
                AND  결산년             IN (:WK-STLACC-YR,
