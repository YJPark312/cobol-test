           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     COMPUTE  WK-JJB-AMT   = WK-JJB-AMT   * 1000000
                     COMPUTE  WK-JJB-AMT-1 = WK-JJB-AMT-1 * 1000000
                     COMPUTE  WK-JJB-AMT-2 = WK-JJB-AMT-2 * 1000000
               WHEN  CO-NOT-FOUND
                     MOVE  0           TO  WK-JJB-AMT
                     MOVE  0           TO  WK-JJB-AMT-1
                     MOVE  0           TO  WK-JJB-AMT-2
               WHEN  OTHER
                     MOVE 'KABCA04'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'DATA-SEL-22시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .

       S3220-KABCA04-SELECT-EXT.
           EXIT.

