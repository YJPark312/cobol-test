      *-----------------------------------------------------------------
      *@   SUB-LIMIT추출
      *-----------------------------------------------------------------
       S3200-KJL0063-SELECT-RTN.

           INITIALIZE   WK-SUB-CLAM

           EXEC SQL
             SELECT VALUE("SUB한도",0) AS "유가증권매입약정한도"
               INTO :WK-SUB-CLAM
               FROM DB2DBA.THKJL0063
              WHERE 그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND 기준년월         = SUBSTR(:WK-H-I-BASE-YMD,1,6)
                AND "SUB한도구분"    = '4'
               WITH UR FETCH FIRST 1 ROWS ONLY
           END-EXEC

      *@   결과확인
           EVALUATE SQLCODE
               WHEN CO-OK
                    CONTINUE
               WHEN CO-NOT-FOUND
      *       유가증권매입약정한도
                    MOVE  ZERO        TO  WK-SUB-CLAM
               WHEN OTHER
                    MOVE 'KJL0063'    TO  XZUGEROR-I-TBL-ID
                    MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                    MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                    MOVE 'SELECT시 오류가 발생했습니다'
                      TO  XZUGEROR-I-MSG
                    #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                    #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3200-KJL0063-SELECT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   SUB-LIMIT－부동산PF잔액　추출
      *-----------------------------------------------------------------
       S3300-KJLR009-SELECT-RTN.

           INITIALIZE   WK-SUB-BAL

           EXEC SQL
             SELECT  SUM(TMP.대출잔액)
               INTO  :WK-SUB-BAL
               FROM
                ( SELECT  SUM(A.명목액기준한도) AS 대출잔액
                    FROM  DB2DBA.THKJL0125 A
                         ,DB2DBA.THKJL0118 B
                   WHERE  A.그룹회사코드 = B.그룹회사코드
                     AND  A.기준년월     = B.기준년월
                     AND  A.상품대분류코드 = B.상품대분류코드
                     AND  A.상품중분류코드 = B.상품중분류코드
                     AND  A.상품템플릿코드 = B.상품템플릿코드
                     AND  A.상품번호       = B.상품번호
                     AND  A.그룹회사코드   = :WK-H-I-GROUP-CO-CD
                     AND  A.기준년월       =
                                      SUBSTR(:WK-H-I-BASE-YMD,1,6)
                     AND  A.기준일         =
                                      SUBSTR(:WK-H-I-BASE-YMD,7,2)
                     AND  B."TE자산구분"   = '1'
                     AND  A.상품대분류코드 IN ('25','FI')
                     AND  A.시작년월일 <> '99991231'
                     AND  A.만기년월일 <> '99991231'
                     AND  (MONTHS_BETWEEN
                       (TO_DATE(SUBSTR(A.만기년월일,1,6),'YYYYMM'),
                        TO_DATE(SUBSTR(A.시작년월일,1,6),'YYYYMM')))
                        > 120
                UNION ALL
                  SELECT  SUM(매입약정금액 )  AS 대출잔액
                    FROM  DB2DBA.THKJLR009
                   WHERE  그룹회사코드 = 'KB0'
                     AND  기준년월일   = :WK-H-I-BASE-YMD
                     AND  종료년월일   = '99991231'
                     AND (MONTHS_BETWEEN
                       (TO_DATE(SUBSTR(만기년월일,1,6),'YYYYMM'),
                        TO_DATE(SUBSTR(신규년월일,1,6),'YYYYMM')))
                        > 120
                ) TMP
                WITH UR
           END-EXEC

      *@   결과확인
           EVALUATE SQLCODE
               WHEN CO-OK
                    CONTINUE
               WHEN CO-NOT-FOUND
      *
                    MOVE  ZERO        TO  WK-SUB-BAL
               WHEN OTHER
                    MOVE 'KJLR009'    TO  XZUGEROR-I-TBL-ID
                    MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                    MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                    MOVE 'SELECT시 오류가 발생했습니다'
                      TO  XZUGEROR-I-MSG
                    #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                    #OKEXIT CO-CHA-08
           END-EVALUATE
