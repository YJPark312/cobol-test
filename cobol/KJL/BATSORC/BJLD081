      *한신평자료중　대기업법인+포괄신용공여한도대상차주SELECT

230915* (TBL3)기업신용평가기본(THKIIK110)
      *  모형규모구분  IN (P:LCRS,Q:CRS1,9:공공기관,
      *                      L:(구)공공기관')
      * ==> 외감,공공기관 및 대기업 판단 기준됨
      *    (외감, 공공기관 보완 로직)


           EXEC SQL
           DECLARE   THKABCB01_CUR     CURSOR FOR
120201     WITH TBL1 AS
           (SELECT VALUE(H.그룹회사코드,D.그룹회사코드)
                   AS 그룹회사코드
                  ,VALUE(H.한신평업체코드,'')
                   AS 한신평업체코드
                  ,VALUE(H.고객식별자,D.고객식별자)
                   AS 고객식별자
                  ,VALUE(H.한신평산업코드,'')
                   AS 한신평산업코드
                  ,VALUE(H.한신평기업공개구분,'')
                   AS 한신평기업공개구분
                  ,VALUE(D.포괄한도관리대상구분,'9')
                   AS 포괄한도관리대상구분
              FROM (SELECT C.그룹회사코드
                          ,SUBSTR(MAX(A.최종변경년월일||
                                      A.한신평업체코드||
                                      A.한신평산업코드||
                                      A.한신평기업공개구분),9,6)
                           AS 한신평업체코드
                          ,C.고객식별자
                          ,SUBSTR(MAX(A.최종변경년월일||
                                      A.한신평업체코드||
                                      A.한신평산업코드||
                                      A.한신평기업공개구분),15,5)
                           AS 한신평산업코드
                          ,SUBSTR(MAX(A.최종변경년월일||
                                      A.한신평업체코드||
                                      A.한신평산업코드||
                                      A.한신평기업공개구분),20,2)
                           AS 한신평기업공개구분
                      FROM DB2DBA.THKABCB01 A
170224                    ,DB2DBA.THKAAADET B
170224                    ,DB2DBA.THKAABPCB C
                     WHERE A.그룹회사코드  = B.그룹회사코드
                       AND A.고객식별자    = B.대체번호
                       AND B.그룹회사코드  = C.그룹회사코드
170810                 AND B.양방향고객암호화번호 =
170810                     C.양방향고객암호화번호
                       AND A.그룹회사코드  = :WK-H-I-GROUP-CO-CD
                       AND A.고객식별자   <> ''
                     GROUP BY C.그룹회사코드
                             ,C.고객식별자
                    ) H FULL OUTER JOIN
140818             DB2DBA.THKJL0062 D
                ON H.그룹회사코드 = D.그룹회사코드
               AND H.고객식별자   = D.고객식별자
             WHERE VALUE(H.그룹회사코드,D.그룹회사코드) =
                   :WK-H-I-GROUP-CO-CD
               AND ((H.고객식별자           IS NOT NULL
               AND   D.고객식별자           IS     NULL)
                OR  (H.고객식별자           IS NOT NULL
               AND   D.포괄한도관리대상구분 IN ('2','3'))
                OR  (D.포괄한도관리대상구분  = '1'))
            )
           ,TBL2 AS
           (SELECT A.그룹회사코드
                  ,A.심사고객식별자
                  ,SUBSTR(MAX(CASE WHEN A.신용평가구분 IN
                                        ('02','13','15','22')
                                   THEN '1'
                                   ELSE '2'
                              END                   ||
                              A.평가년월일        ||
                              A.신용평가보고서번호||
140721                        CASE WHEN A.영업신용등급구분 IN
                                        ('    ','0000')
                                   THEN A.최종신용등급구분
                                   ELSE A.영업신용등급구분
                              END),23,4)
                   AS 영업신용등급구분
              FROM TBL1
                  ,DB2DBA.THKIIK616 A
             WHERE A.그룹회사코드       =  TBL1.그룹회사코드
               AND A.심사고객식별자     =  TBL1.고객식별자
               AND A.유효년월일         > :WK-SYSIN-BASE-YMD
               AND A.신용평가구분IN ('01','03','04','05',
                                       '06','07','08','09',
                                       '10','11','14','16',
                                       '17','18','19','20','99',
                                       '02','13','15','22')
             GROUP BY A.그룹회사코드,A.심사고객식별자
            )
           ,TBL3 AS
           (SELECT B.그룹회사코드
                  ,B.심사고객식별자
                  ,'1' AS 외감기업여부
              FROM TBL1
                  ,DB2DBA.THKIIK110 B
             WHERE B.그룹회사코드   = TBL1.그룹회사코드
               AND B.심사고객식별자 = TBL1.고객식별자
               AND B.처리단계구분   = '99'
170810         AND B.모형규모구분   IN ('P','Q','9','L')
             GROUP BY B.그룹회사코드,B.심사고객식별자
            )
           SELECT TBL4.한신평업체코드
                 ,TBL4.고객식별자
                 ,TBL4.한신평산업코드
                 ,TBL4.영업신용등급구분
                 ,TBL4.지원비율
                 ,TBL4.설정대상차주구분
             FROM (
           SELECT TBL1.한신평업체코드
                 ,TBL1.고객식별자
                 ,TBL1.한신평산업코드
                 ,VALUE(TBL2.영업신용등급구분,'0000')
                  AS 영업신용등급구분
                 ,VALUE(C.지원비율 / 100,0) AS 지원비율
                 ,CASE TBL1.포괄한도관리대상구분
      *                '1':공공기관
                       WHEN '1' THEN
                       CASE WHEN VALUE(TBL2.영업신용등급구분,'0000')
140721                           IN ('AAA','AA+','AA','AA-',
180405                               'A+','A')
                            THEN '3'
                            ELSE '0'
                       END
                       ELSE
                       CASE WHEN VALUE(TBL2.영업신용등급구분,'0000')
140721                           IN ('AAA','AA+','AA','AA-',
180405                               'A+','A')
                             AND (VALUE(TBL3.외감기업여부,'0') = '1'
                              OR  TBL1.한신평기업공개구분 IN
170810                            ('10','15','20','30'))
                            THEN '1'
                            ELSE '0'
                       END
                  END AS 설정대상차주구분
             FROM TBL1 LEFT OUTER JOIN
                  TBL2
               ON TBL2.그룹회사코드   = TBL1.그룹회사코드
              AND TBL2.심사고객식별자 = TBL1.고객식별자
                  LEFT OUTER JOIN
                  TBL3
               ON TBL3.그룹회사코드   = TBL1.그룹회사코드
              AND TBL3.심사고객식별자 = TBL1.고객식별자
                  LEFT OUTER JOIN
140721            DB2DBA.THKJL0045 C
               ON C.그룹회사코드         = TBL2.그룹회사코드
              AND C.기준년월             = :WK-H-I-BASE-YM
              AND C.한도기업구분         = '5'
              AND C.내부신용평가등급구분 = TBL2.영업신용등급구분
                  ) TBL4
            WHERE 설정대상차주구분 IN ('1','3')
             WITH UR
           END-EXEC.
