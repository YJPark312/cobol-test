      *-----------------------------------------------------------------
      *@1 결산년월일 조회
      *-----------------------------------------------------------------
      *@2 조건항목:그룹회사코드,한신평업체코드,
      *@한신평결산자료구분(K:결산)
      *@2 한국신용평가재무제표(THKABCC26) SELECT
      *@2 출력항목:결산년월일

           EXEC SQL
             SELECT  VALUE(MAX(결산년월일),'00010101')
               INTO  :WK-STLACC-YMD
               FROM  DB2DBA.THKABCC26
              WHERE  그룹회사코드   = :WK-H-I-GROUP-CO-CD
                AND  한신평업체코드 = :WK-H-O-ENTP-CD
                AND  한신평결산자료구분 = 'K'
               WITH  UR
            END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
      *#1           결산년월일이 '00010101' 아닌 경우
                     IF WK-STLACC-YMD NOT = '00010101'
                     THEN
      *@2               결산년월일기준으로 전년월일산출
                         PERFORM  S7000-CJIIL03-CALL-RTN
                            THRU  S7000-CJIIL03-CALL-EXT

      *@2               한신평재무업종구분별재무재표정보조회
                         PERFORM  S3710-KABCC26-SELECT-RTN
                            THRU  S3710-KABCC26-SELECT-EXT
                     END-IF
               WHEN  CO-NOT-FOUND
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KABCC26'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT-DATA-01시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3700-KABCC26-GIJUN-SELE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  포괄신용공여한도대상업체제무재표DATA SELECT
      *-----------------------------------------------------------------
       S3710-KABCC26-SELECT-RTN.

      *-----------------------------------------------------------------
      *@1 자산총계,매출액,자기자본,금융비용발생차입금,
      *@영업활동현금흐름액,이자비용,사채이자 조회
      *-----------------------------------------------------------------
      *@2 조건항목:그룹회사코드,한신평업체코드,
      *@한신평결산자료구분(K:결산),결산년월일
      *@2 한국신용평가재무제표(THKABCC26) SELECT
      *@2 출력항목: 재무제표항목금액
      *@ 1. 자산총계
      *@         AND  한신평보고서구분    = '11'
      *@         AND  한신평재무항목코드  = '5000'
      *@ 2. 매출액
      *@         AND  한신평보고서구분    = '12'
      *@         AND  한신평재무항목코드  = '1000'
      *@ 3. 자기자본
      *@         AND  한신평보고서구분    = '11'
      *@         AND  한신평재무항목코드  = '8900'
      *@ 4. 금융비용발생차입금
      *@         AND  한신평보고서구분    = '11'
      *@         AND  한신평재무항목코드 IN ('5130','5190','6200',
      *@                                       '6050','6260','5400',
      *@                                       '5185','6515')
      *@ 5. 영업활동현금흐름액
      *@         AND  한신평보고서구분    = '16'
      *@         AND  한신평재무항목코드  = '1000'
      *@ 6. 이자비용
      *@         AND  한신평보고서구분    = '12'
      *@         AND  한신평재무항목코드  = '6110'
      *@ 7. 사채이자
      *@         AND  한신평보고서구분    = '12'
      *@         AND  한신평재무항목코드  = '6120'

           EXEC SQL
             SELECT  VALUE(SUM(CASE WHEN 한신평보고서구분 = '11'
                                     AND 한신평재무항목코드 = '5000'
                                    THEN 재무제표항목금액
                                    ELSE  0
                     END),0) * 1000
                  ,  VALUE(SUM(CASE WHEN 한신평보고서구분 = '12'
                                     AND 한신평재무항목코드 = '1000'
                                    THEN 재무제표항목금액
                                    ELSE  0
                     END),0) * 1000
                  ,  VALUE(SUM(CASE WHEN 한신평보고서구분 = '11'
                                     AND 한신평재무항목코드 = '8900'
                                    THEN 재무제표항목금액
                                    ELSE  0
                     END),0) * 1000
                  ,  VALUE(SUM(CASE WHEN 한신평보고서구분 = '11'
                                     AND (한신평재무항목코드 = '5130'
                                      OR  한신평재무항목코드 = '5190'
                                      OR  한신평재무항목코드 = '6200'
                                      OR  한신평재무항목코드 = '6050'
                                      OR  한신평재무항목코드 = '6260'
                                      OR  한신평재무항목코드 = '5400'
                                      OR  한신평재무항목코드 = '5185'
                                      OR  한신평재무항목코드 = '6515')
                                    THEN 재무제표항목금액
                                    ELSE  0
                     END),0) * 1000
                  ,  VALUE(SUM(CASE WHEN 한신평보고서구분 = '16'
                                     AND 한신평재무항목코드 = '1000'
                                    THEN 재무제표항목금액
                                    ELSE  0
                     END),0) * 1000
                  ,  VALUE(SUM(CASE WHEN 한신평보고서구분 = '12'
                                     AND 한신평재무항목코드 = '6110'
                                    THEN 재무제표항목금액
                                    ELSE  0
                     END),0) * 1000
                  ,  VALUE(SUM(CASE WHEN 한신평보고서구분 = '12'
                                     AND 한신평재무항목코드 = '6120'
                                    THEN 재무제표항목금액
                                    ELSE  0
                     END),0) * 1000
               INTO  :WK-JSC-AMT
                  ,  :WK-MCA-AMT
                  ,  :WK-JGJ-AMT
                  ,  :WK-GBC-AMT
                  ,  :WK-YHH-AMT
                  ,  :WK-IJB-AMT
                  ,  :WK-SJB-AMT
               FROM  DB2DBA.THKABCC26
              WHERE  그룹회사코드   = :WK-H-I-GROUP-CO-CD
                AND  한신평업체코드 = :WK-H-O-ENTP-CD
                AND  한신평결산자료구분  = 'K'
                AND  결산년월일     = :WK-STLACC-YMD
               WITH  UR
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
      *              1. 자산총계
                     MOVE  0           TO  WK-JSC-AMT
      *              2. 매출액
                     MOVE  0           TO  WK-MCA-AMT
      *              3. 자기자본
                     MOVE  0           TO  WK-JGJ-AMT
      *              4. 금융비용발생차입금
                     MOVE  0           TO  WK-GBC-AMT
      *              5. 영업활동현금흐름액
                     MOVE  0           TO  WK-YHH-AMT
      *              6. 이자비용
                     MOVE  0           TO  WK-IJB-AMT
      *              7. 사채이자
                     MOVE  0           TO  WK-SJB-AMT
               WHEN  OTHER
                     MOVE 'KABCC26'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT-DATA-01시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *-----------------------------------------------------------------
      *@1 전년도금융비용발생차입금조회
      *-----------------------------------------------------------------
      *@2 조건항목:그룹회사코드,한신평업체코드,
      *@한신평결산자료구분(K:결산),결산년월일,
      *@한신평보고서구분(11:제조업대차대조표),
      *@한신평재무항목코드(5130,5190,6200,6050,6260,5400,5185,6515)
      *@2 한국신용평가재무제표(THKABCC26) SELECT
      *@2 출력항목:재무제표항목금액

      *   초기화
           INITIALIZE    WK-GBC-AMT-1

           EXEC SQL
             SELECT  VALUE(SUM(재무제표항목금액),0) * 1000
               INTO  :WK-GBC-AMT-1
               FROM  DB2DBA.THKABCC26
              WHERE  그룹회사코드   = :WK-H-I-GROUP-CO-CD
                AND  한신평업체코드 = :WK-H-O-ENTP-CD
                AND  한신평결산자료구분 = 'K'
                AND  결산년월일     = :WK-STLACC-YMD-1
                AND  한신평보고서구분    = '11'
                AND  한신평재무항목코드 IN ('5130','5190','6200',
                                              '6050','6260','5400',
                                              '5185','6515')
               WITH  UR
           END-EXEC

      *   리턴코드가 정상이 아니면 에러처리
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE  0           TO  WK-GBC-AMT-1
               WHEN  OTHER
                     MOVE 'KABCC26'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT-DATA-08오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3710-KABCC26-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  결산년월일기준으로 전년월일산출
      *-----------------------------------------------------------------
       S7000-CJIIL03-CALL-RTN.

      *   초기화
           INITIALIZE    WK-STLACC-YMD-1
                         XCJIIL03-CA

      *@2 입력파라미터 조립
      *@ (그룹회사코드,구분코드:4,기준년월일,월수:12)

      *   그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD    TO  XCJIIL03-I-GROUP-CO-CD
      *   구분코드
           MOVE '4'                    TO  XCJIIL03-I-DSTCD
      *   기준년월일
           MOVE  WK-STLACC-YMD         TO  XCJIIL03-I-YMD
      *   월수
           MOVE  12                    TO  XCJIIL03-I-NODAY-NOMN

      *@2 프로그램호출:전년월일 산출
           #DYCALL   CJIIL03   YCCOMMON-CA   XCJIIL03-CA.

      *   리턴코드가 정상이 아니면 에러처리
           IF  XCJIIL03-R-STAT = ZEROS
           THEN
               MOVE  XCJIIL03-O-YMD    TO  WK-STLACC-YMD-1
           ELSE
               #ERROR  XCJIIL03-R-ERRCD
                       XCJIIL03-R-TREAT-CD
                       XCJIIL03-R-STAT
               #OKEXIT CO-CHA-08
           END-IF
           .
       S7000-CJIIL03-CALL-EXT.
           EXIT.
