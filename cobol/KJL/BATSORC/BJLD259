      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC  SQL
           DECLARE   THKJL0022_CUR     CURSOR FOR
             SELECT  A.카드여신식별자
                  ,  B.상품대분류코드
                  ,  B.상품중분류코드
                  ,  B.상품템플릿코드
                  ,  B.상품번호
                  ,  A.차주번호
                  ,  A.차주번호구분
                  ,  A.대출한도
                  ,  A.총대출잔액
               FROM  DB2DBA.THKJL0022 A
                  ,  DB2DBA.THKJL0018 B
              WHERE  A.그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND  A.기준일           = :WK-H-I-BASE-DD
                AND  A.기준년월         = :WK-H-I-BASE-YM
                AND  A.그룹회사코드     =  B.그룹회사코드
                AND  A.기준년월         =  B.기준년월
                AND  A.통합계정과목코드 =  B.통합계정과목코드
                AND  B.상품대분류코드   = 'CR'
                AND  A.차주번호    <> ' '
           END-EXEC.
