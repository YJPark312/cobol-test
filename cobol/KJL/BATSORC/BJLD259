      *-----------------------------------------------------------------
      *@  카드고객수신기본(THKJL0021) 조회
      *-----------------------------------------------------------------
       S3310-KJL0021-SELECT-RTN.

           INITIALIZE    TRJL0021-REC
                         WK-BZNO

      *   사업자등록번호１０자리MOVE
           MOVE  WK-H-O-BRWR-NO(1:10)
             TO  WK-BZNO

           EXEC SQL
             SELECT  VALUE(차주번호,'-------------')
               INTO  :RJL0021-BRWR-NO
               FROM  DB2DBA.THKJL0021
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  사업자번호   = :WK-BZNO
                AND  차주번호구분 = :WK-H-O-BRWR-NO-DSTCD
              ORDER  BY 신규등록년월일 DESC
              FETCH  FIRST 1 ROW ONLY
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
                     MOVE '-------------'   TO  RJL0021-BRWR-NO
                     #USRLOG '사업자등록번호SEL ERR 100 '
                             WK-BZNO
               WHEN  OTHER
                     MOVE '*************'   TO  RJL0021-BRWR-NO
                     #USRLOG '사업자등록번호SEL ERR OTHER '
                             WK-BZNO

           END-EVALUATE
           .
       S3310-KJL0021-SELECT-EXT.
           EXIT.
