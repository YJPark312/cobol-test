240605*@  기업집단평가기본수보(THKJLR018) 조회
      *-----------------------------------------------------------------
       S3500-KJLR018-SELECT-RTN.

           INITIALIZE                   WK-LAST-C-CLCT-CRTDSCD
                                        WK-VALUA-YMD

           EXEC SQL
           SELECT  VALUE(최종집단등급구분,'000')
                ,  VALUE(평가년월일,'        ')
             INTO :WK-LAST-C-CLCT-CRTDSCD
                , :WK-VALUA-YMD
             FROM  DB2DBA.THKJLR018 R018
            WHERE  그룹회사코드     = :WK-H-I-GROUP-CO-CD
              AND  기업집단그룹코드 = :WK-H-O-KIS-GROUP-CD
              AND  기업집단등록코드 = 'GRS'
              AND  평가년월일
                =  (SELECT MAX(평가년월일)
                     FROM DB2DBA.THKJLR018
                    WHERE 그룹회사코드     = R018.그룹회사코드
                      AND 기업집단그룹코드 = R018.기업집단그룹코드
                      AND 기업집단등록코드 = R018.기업집단등록코드
                      AND 기업집단처리단계구분 = '6'
                  )
            FETCH FIRST 1 ROWS ONLY
             WITH UR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  CO-NOT-FOUND
      *              최종집단등급구분
                     MOVE '000'        TO  WK-LAST-C-CLCT-CRTDSCD
               WHEN  OTHER
               DISPLAY "THKJLR018 SELECT ERROR! ========"
               DISPLAY "기업집단그룹코드:" WK-H-O-KIS-GROUP-CD
                     MOVE 'KJLR018'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE '최종집단신용등급조회시오류가발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

           .
       S3500-KJLR018-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   DATA MOVE
      *-----------------------------------------------------------------
       S3600-DATA-MOVE-RTN.

           INITIALIZE    OT-REC

      *          그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  OT-GROUP-CO-CD

      *          기준년월
           MOVE  WK-H-I-BASE-YM
             TO  OT-BASE-YM

      *          계열적용구분
           MOVE  CO-CHA-1
             TO  OT-AFFLT-APLY-DSTCD

      *          계열기업군코드
           MOVE  CO-CHA-00
             TO  OT-AFFLT-CORP-GROUP-CD(1:2)
           MOVE  WK-H-O-KIS-GROUP-CD
             TO  OT-AFFLT-CORP-GROUP-CD(3:3)

      *          계열기업순위
           MOVE  CO-NUM-999
             TO  OT-AFFLT-CORP-RANKG

      *          주채권은행코드
           MOVE  WK-H-O-KIS-P-BNK-DSTCD
             TO  OT-MAIN-BND-BNK-CD

      *          계열기업군명
170224     IF  WK-H-O-KIS-H-GROUP-NAME(43:) = SPACE
               MOVE  WK-H-O-KIS-H-GROUP-NAME(1:42)
                 TO  OT-AFFLT-C-GROUP-NAME
           ELSE
               INITIALIZE               XCJIOT01-IN

               MOVE  WK-H-O-KIS-H-GROUP-NAME
                 TO  XCJIOT01-I-INPT-DATA
               MOVE  42
                 TO  XCJIOT01-I-OUTPT-RQST-LEN

      *@1     한글길이요청 프로그램 호출
               #DYCALL  CJIOT01
                        YCCOMMON-CA
                        XCJIOT01-CA

      *       호출결과 확인
               EVALUATE  XCJIOT01-R-STAT
               WHEN '00'
                   MOVE  XCJIOT01-O-OUTPT-DATA(1:42)
                     TO  OT-AFFLT-C-GROUP-NAME
               WHEN OTHER
                   MOVE  WK-H-O-KIS-H-GROUP-NAME
                     TO  OT-AFFLT-C-GROUP-NAME
               END-EVALUATE
           END-IF

      *          그룹사신용등급구분
           MOVE  WK-LAST-C-CLCT-CRTDSCD
             TO  OT-CMGR-CRTDSCD

      *          등록직원번호
           MOVE  WK-JOB-EMPID
             TO  OT-REGI-EMPID

      *          등록년월일
           MOVE  BICOM-TRAN-BASE-YMD
             TO  OT-REGI-YMD

      *          시스템최종처리일시
           MOVE  BICOM-TRAN-BASE-YMS
             TO  OT-SYS-LAST-PRCSS-YMS

      *          시스템최종사용자번호
           MOVE  BICOM-USER-EMPID
             TO  OT-SYS-LAST-UNO
           .
       S3600-DATA-MOVE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   DATA WRITE
      *-----------------------------------------------------------------
       S3700-DATA-WRITE-RTN.

           WRITE OT-REC

           IF  WK-OT-F-ST NOT = CO-STAT-OK
               MOVE 'OT-FILE WRITE ERROR : FILE-ST IS '
                                       TO  XZUGEROR-I-MSG
               MOVE  WK-OT-F-ST        TO  XZUGEROR-I-MSG(34:2)
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

           ADD   CO-NUM-1              TO  WK-AC-WT-CNT
           .
       S3700-DATA-WRITE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR CLOSE
      *-----------------------------------------------------------------
       S3800-KABCA01-CLOSE-RTN.

           EXEC SQL
              CLOSE  THKABCA01_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KABCA01'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'CLOSE'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR CLOSE시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3800-KABCA01-CLOSE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  처리종료
      *-----------------------------------------------------------------
       S9000-FINAL-RTN.

           CLOSE     OT-FILE

           IF  WK-OT-F-ST NOT = CO-STAT-OK
               MOVE 'OT-FILE CLOSE ERROR : FILE-ST IS '
                                      TO  XZUGEROR-I-MSG
               MOVE  WK-OT-F-ST       TO  XZUGEROR-I-MSG(34:2)
               #ERROR  CO-EBM02001 CO-UBM02001 CO-STAT-ERROR
               #OKEXIT CO-CHA-08
           END-IF

           #USRLOG '*--------------------------------------*'
           #USRLOG '* THKABCA01_CUR   COUNT  = ' WK-AC-FE-CNT
           #USRLOG '* SKIP            COUNT  = ' WK-AC-SKIP-CNT
           #USRLOG '* WRITE           COUNT  = ' WK-AC-WT-CNT
           #USRLOG '*--------------------------------------*'
           #USRLOG '* BJLD131 PGM END                      *'
           #USRLOG '*--------------------------------------*'
           #OKEXIT  CO-CHA-00
           .
       S9000-FINAL-EXT.
           EXIT.
