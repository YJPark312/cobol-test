      *@   한신평 그룹정보 조회
           EXEC SQL
            DECLARE  THKABCA01_CUR     CURSOR FOR
             SELECT  한신평그룹코드
                  ,  한신평한글그룹명
                  ,  한신평주거래은행구분
               FROM  DB2DBA.THKABCA01
              WHERE  그룹회사코드    = :WK-H-I-GROUP-CO-CD
                AND  한신평그룹코드  IS NOT NULL
           END-EXEC.
