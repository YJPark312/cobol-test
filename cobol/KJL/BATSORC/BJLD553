       S3000-KJL0055-PROCESS-RTN.

           PERFORM  S3100-KJLR012-OPEN-RTN
              THRU  S3100-KJLR012-OPEN-EXT

           PERFORM  S3200-KJLR012-FETCH-RTN
              THRU  S3200-KJLR012-FETCH-EXT

           PERFORM  UNTIL EOF-Y

                    PERFORM  S3300-KJL0055-INSERT-RTN
                       THRU  S3300-KJL0055-INSERT-EXT

                    PERFORM  S3200-KJLR012-FETCH-RTN
                       THRU  S3200-KJLR012-FETCH-EXT
           END-PERFORM

           PERFORM  S3400-KJLR012-CLOSE-RTN
              THRU  S3400-KJLR012-CLOSE-EXT
           .
       S3000-KJL0055-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR OPEN
      *-----------------------------------------------------------------
       S3100-KJLR012-OPEN-RTN.

           INITIALIZE    WK-SWITCHES

           EXEC SQL
               OPEN  THKJLR012_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJLR012'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'OPEN'       TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR OPEN시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3100-KJLR012-OPEN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR FETCH
      *-----------------------------------------------------------------
       S3200-KJLR012-FETCH-RTN.

           EXEC SQL
              FETCH  THKJLR012_CUR
               INTO  :WK-HOST-OUT
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     ADD   CO-NUM-1    TO  WK-AC-FETCH-CNT
               WHEN  CO-NOT-FOUND
                     SET   EOF-Y       TO  TRUE
               WHEN  OTHER
                     MOVE 'KJLR012'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR FETCH시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3200-KJLR012-FETCH-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@    국별익스포져계좌명세(THKJL0055)등록
      *-----------------------------------------------------------------
       S3300-KJL0055-INSERT-RTN.

           INITIALIZE    TKJL0055-KEY
                         TRJL0055-REC

      *    그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  RJL0055-GROUP-CO-CD

      *    기준년월일
           MOVE  WK-H-I-BASE-YMD
             TO  RJL0055-BASE-YMD

      *    계좌번호＝통합트레이드번호
           MOVE  WK-H-O-FC-PRDCT-PTRN-DSTCD
             TO  RJL0055-ACNO(1:3)
           MOVE  WK-H-O-INTGRA-TRD-NO
             TO  RJL0055-ACNO(4:14)

      *    계좌중복일련번호
           ADD   CO-NUM-1              TO  WK-SEQ
           MOVE  WK-SEQ
             TO  RJL0055-ACN-DUP-SERNO

170224*    고객식별자
           MOVE  WK-H-O-CUST-IDNFR
             TO  RJL0055-CUST-IDNFR

170224*     고객관리번호
           MOVE  WK-H-O-CUST-MGT-NO
             TO  RJL0055-CUST-MGT-NO

      *--------------------------------------------------------------
      * 2010.06.28:상품정보등록여신만　국별익스포져대상으로　주석처리
      *--------------------------------------------------------------
      *상품정보　미매핑이면　국별원장(THKJL0054) SELECT
      *    IF WK-H-O-PRDCT-LAG-CLSFI-CD  = SPACE  AND
      *       WK-H-O-PRDCT-MEDM-CLSFI-CD = SPACE  AND
      *       WK-H-O-PRDCT-TMPLT-CD      = SPACE  AND
      *       WK-H-O-PRDCT-NO            = SPACE
      *    THEN
      *       PERFORM  S3310-KJL0054-SELECT-RTN
      *          THRU  S3310-KJL0054-SELECT-EXT
      *    END-IF
      *--------------------------------------------------------------

      *    상품대분류코드
           MOVE  WK-H-O-PRDCT-LAG-CLSFI-CD
             TO  RJL0055-PRDCT-LAG-CLSFI-CD

      *    상품중분류코드
           MOVE  WK-H-O-PRDCT-MEDM-CLSFI-CD
             TO  RJL0055-PRDCT-MEDM-CLSFI-CD

      *    상품템플릿코드
           MOVE  WK-H-O-PRDCT-TMPLT-CD
             TO  RJL0055-PRDCT-TMPLT-CD

      *    상품번호
           MOVE  WK-H-O-PRDCT-NO
             TO  RJL0055-PRDCT-NO

      *    대출자격구분
           MOVE  SPACE
             TO  RJL0055-LN-QULFI-DSTCD

      *    국가코드
           MOVE  WK-H-O-ISO-NATNL-CD
             TO  RJL0055-ISO-NATNL-CD

      *    관리부점코드
           MOVE  WK-H-O-MGT-BRNCD
             TO  RJL0055-MGT-BRNCD

      *    시작년월일
           IF  WK-H-O-BUY-YMD = SPACES  OR
               WK-H-O-BUY-YMD = '00000000'
           THEN
               MOVE  '00010101'
                 TO  RJL0055-START-YMD
           ELSE
      *      시작년월일
               MOVE  WK-H-O-BUY-YMD
                 TO  RJL0055-START-YMD
           END-IF

      *    만기년월일
           IF  WK-H-O-EXPIR-YMD = SPACES OR
               WK-H-O-EXPIR-YMD = '00000000'
           THEN
               MOVE  '00010101'
                 TO  RJL0055-EXPIR-YMD
           ELSE
      *      만기년월일
               MOVE  WK-H-O-EXPIR-YMD
                 TO  RJL0055-EXPIR-YMD
           END-IF

      *    종료년월일
           MOVE  '00010101'
             TO  RJL0055-END-YMD

      *    과목코드
           MOVE  CO-CHA-R02
             TO  RJL0055-SBJCT-CD

      *    통화코드
           MOVE  WK-H-O-CNCYCD
             TO  RJL0055-CNCYCD

      *-----------------------------------------------------------------
      * 계약한도구분으로　한도계좌를　구분한다
      *-----------------------------------------------------------------
           IF  WK-H-O-CTRC-LIMT-DSTCD = SPACE OR '00'
           THEN
      *        통화한도
               MOVE  WK-H-O-FC-ACBK-AMT
                 TO  RJL0055-CRNCY-CLAM

      *        통화금일잔액
               MOVE  WK-H-O-FC-ACBK-AMT
                 TO  RJL0055-CRNCY-TDD-BAL
           ELSE
      *        통화한도
               MOVE  WK-H-O-TOTAL-FX-LNBZ-AMT
                 TO  RJL0055-CRNCY-CLAM

      *        통화금일잔액
               MOVE  ZERO
                 TO  RJL0055-CRNCY-TDD-BAL
           END-IF

      *----------------------------------------------------------------
      * 한도여신　관리방법에　따라　금액　재　확정
      * 2005.05.10 신용기획팀　하영규　대리（문서번호：신용기획팀370)
      *----------------------------------------------------------------
      * 국제한도구분 :  새로신설됨 (200505)
           EVALUATE  WK-H-O-INTN-LIMT-DSTCD
               WHEN  CO-CHA-1
      * 한도여신------------------------------------------------------
      * 만기전：한도 RJL0055-USD-CLAM(O),잔액 RJL0055-USD-TDD-BAL(X)
      * 만기후：한도 RJL0055-USD-CLAM(X),잔액 RJL0055-USD-TDD-BAL(X)
      *-----------------------------------------------------------------
      *              계약한도구분
                     MOVE  CO-CHA-01
                       TO  RJL0055-CTRC-LIMT-DSTCD

                     IF  RJL0055-EXPIR-YMD >= WK-H-I-BASE-YMD OR
                         RJL0055-EXPIR-YMD  = '00010101'
                     THEN
      *                  USD한도
                         MOVE  WK-H-O-USDZ-CLAM
                           TO  RJL0055-USD-CLAM
      *                  USD금일잔액
                         MOVE  ZERO
                           TO  RJL0055-USD-TDD-BAL
                     ELSE
      *                  USD한도
                         MOVE  ZERO
                           TO  RJL0055-USD-CLAM
      *                  USD금일잔액
                         MOVE  ZERO
                           TO  RJL0055-USD-TDD-BAL
                     END-IF
               WHEN  CO-CHA-3
      * 건별여신------------------------------------------------------
      * 만기전：한도 RJL0055-USD-CLAM(X),잔액 RJL0055-USD-TDD-BAL(O)
      * 만기후：한도 RJL0055-USD-CLAM(O)=잔액 RJL0055-USD-TDD-BAL(O)
      *-----------------------------------------------------------------
      *              계약한도구분
                     MOVE  CO-CHA-03
                       TO  RJL0055-CTRC-LIMT-DSTCD

                     IF  RJL0055-EXPIR-YMD >= WK-H-I-BASE-YMD OR
                         RJL0055-EXPIR-YMD  = '00010101'
                     THEN
      *                  USD한도
                         MOVE  ZERO
                           TO  RJL0055-USD-CLAM
      *                  USD금일잔액
                         MOVE  WK-H-O-USD-ACBK-AMT
                           TO  RJL0055-USD-TDD-BAL
                     ELSE
      *                  USD한도
                         MOVE  WK-H-O-USD-ACBK-AMT
                           TO  RJL0055-USD-CLAM
      *                  USD금일잔액
                         MOVE  WK-H-O-USD-ACBK-AMT
                           TO  RJL0055-USD-TDD-BAL
                     END-IF
               WHEN  CO-CHA-4
      * 개별여신------------------------------------------------------
      * 만기전：한도 RJL0055-USD-CLAM(O)=잔액 RJL0055-USD-TDD-BAL(O)
      * 만기후：한도 RJL0055-USD-CLAM(O)=잔액 RJL0055-USD-TDD-BAL(O)
      *-----------------------------------------------------------------
      *              계약한도구분
                     MOVE  CO-CHA-04
                       TO  RJL0055-CTRC-LIMT-DSTCD

      *              USD한도
                     MOVE  WK-H-O-USD-ACBK-AMT
                       TO  RJL0055-USD-CLAM
      *              USD금일잔액
                     MOVE  WK-H-O-USD-ACBK-AMT
                       TO  RJL0055-USD-TDD-BAL
               WHEN  OTHER
      * 개별여신------------------------------------------------------
      * 만기전：한도 RJL0055-USD-CLAM(X),잔액 RJL0055-USD-TDD-BAL(X)
      * 만기후：한도 RJL0055-USD-CLAM(X),잔액 RJL0055-USD-TDD-BAL(X)
      *-----------------------------------------------------------------
      *              계약한도구분
                     MOVE  CO-CHA-02
                       TO  RJL0055-CTRC-LIMT-DSTCD
                     MOVE  ZERO
                       TO  RJL0055-USD-CLAM
                     MOVE  ZERO
                       TO  RJL0055-USD-TDD-BAL
           END-EVALUATE

           #DYDBIO  INSERT-CMD-Y TKJL0055-PK TRJL0055-REC

           EVALUATE  TRUE
               WHEN  COND-DBIO-OK
                     ADD   CO-NUM-1    TO  WK-AC-INSERT-CNT
               WHEN  OTHER
                     MOVE 'KJL0055'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'INSERT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  DBIO-SQLCODE
                                       TO  XZUGEROR-I-SQL-CD
                     MOVE 'INSERT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 DBIO-STAT
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *    1000건　마다　 COMMIT
           IF  FUNCTION MOD(WK-AC-FETCH-CNT,1000) = CO-NUM-0
           THEN
               #USRLOG '* WK-AC-FETCH-CNT  = ' WK-AC-FETCH-CNT
               EXEC SQL
                 COMMIT
               END-EXEC

      * Commit 처리결과 SQL-CODE를 확인하여 정상/오류 처
               EVALUATE  SQLCODE
                   WHEN  CO-OK
                         CONTINUE
                   WHEN  OTHER
                         MOVE 'KJL0055'    TO  XZUGEROR-I-TBL-ID
                         MOVE 'COMMIT'     TO  XZUGEROR-I-FUNC-CD
                         MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                         MOVE 'DBCommit시오류가발생했습니다 '
                                           TO  XZUGEROR-I-MSG
                         #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                         #OKEXIT CO-CHA-08
               END-EVALUATE
           END-IF
           .
       S3300-KJL0055-INSERT-EXT.
           EXIT.

