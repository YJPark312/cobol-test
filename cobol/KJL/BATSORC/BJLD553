      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKJLR012_CUR     CURSOR WITH HOLD FOR
             SELECT  A.외화상품유형구분
                  ,  A.통합트레이드번호
                  ,  VALUE(B.상품대분류코드,' ')
                  ,  VALUE(B.상품중분류코드,' ')
                  ,  VALUE(B.상품템플릿코드,' ')
                  ,  VALUE(B.상품번호,' ')
                  ,  A.고객식별자
                  ,  A.고객관리번호
                  ,  A.매입년월일
                  ,  A.통화코드
                  ,  A.외화장부금액
                  ,  A.만기년월일
                  ,  A.관리부점코드
                  ,  A.총외환여신금액
250626            ,  VALUE(D."ISO국가코드",A."ISO국가코드")
                          AS "ISO국가코드"
                  ,  A.계약한도구분
                  ,  A.국제한도구분
                  ,  A.대미환산장부금액
                  ,  A.대미환산한도
                  ,  A.통합계정과목코드
               FROM  DB2DBA.THKJLR012 A --외화채권잔고현황
250626               LEFT OUTER JOIN
                     DB2DBA.THKJL0026 D
                 ON  A.그룹회사코드     = D.그룹회사코드
                AND  A.외화상품유형구분||
                     A.통합트레이드번호 = D.계좌번호
                  ,  DB2DBA.THKJL0054 B --국별계정과목코드목록
              WHERE  A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  A.기준년월일   = :WK-H-I-BASE-YMD
250626          AND VALUE(D."ISO국가코드",A."ISO국가코드") <> 'KR'
                AND  A.계정과목코드|| A.계정세과목코드
                        NOT IN ('F3250000','F3260000','13802003')
                AND  B.그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  B.기준년월     = :WK-H-I-BASE-YM
                AND  B.상품대분류코드 = 'KT'
                AND  A.계정세과목코드= B.상품템플릿코드
                AND  A.계정과목코드  = B.상품번호
           END-EXEC.
