                     SET   IN-EOF-Y    TO  TRUE
               WHEN  OTHER
                     MOVE 'KJL0153'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
