           IF  FUNCTION MOD(WK-AC-FE-CNT, 100) = CO-NUM-0
               PERFORM  S8000-SQL-COMMIT-RTN
                  THRU  S8000-SQL-COMMIT-EXT
           END-IF
           .

       S3200-KJL0153-FETCH-EXT.
           EXIT.

