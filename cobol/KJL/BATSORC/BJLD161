      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
           EXEC SQL
            DECLARE  THKJL0153_CUR     CURSOR WITH HOLD FOR
             SELECT  A.그룹회사코드
                  ,  A.고객식별자
                  ,  A.신표준산업분류코드
                  ,  B."TEPEER구분"
                  ,  B.대분류업종코드
                  ,  B.산업평가등급구분
180416         FROM  DB2DBA.THKJL0153 A,
                     DB2DBA.THKJL0044 B
              WHERE  B.그룹회사코드  = :WK-H-I-GROUP-CO-CD
                AND  B.기준년월      = :WK-H-I-BASE-YM
                AND  B.그룹회사코드      = A.그룹회사코드
                AND  B.신표준산업분류코드= A.신표준산업분류코드
               WITH  UR
           END-EXEC.
