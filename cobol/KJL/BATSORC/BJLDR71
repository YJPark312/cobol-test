           MOVE IN-RELATD-BRNCD1
             TO RJLR007-RELATD-BRNCD

      *@   ISO국가코드
           MOVE IN-ISO-NATNL-CD
             TO RJLR007-ISO-NATNL-CD

      *@   DBIO CALL
           #DYDBIO  INSERT-CMD-Y TKJLR007-PK TRJLR007-REC

      *@   결과확인
           EVALUATE TRUE
               WHEN COND-DBIO-OK
                    ADD  CO-NUM-1    TO  WK-AC-INSERT-CNT
               WHEN OTHER
                    MOVE 'KJLR007'   TO  XZUGEROR-I-TBL-ID
                    MOVE 'INSERT'    TO  XZUGEROR-I-FUNC-CD
                    MOVE DBIO-SQLCODE
                      TO XZUGEROR-I-SQL-CD
                    MOVE 'INSERT시 오류가 발생했습니다'
                      TO XZUGEROR-I-MSG
                    #ERROR  CO-EBM02001 CO-UBM02001 DBIO-STAT
                    #OKEXIT CO-CHA-08
           END-EVALUATE

      *@1  1000건마다 DISPLAY & COMMIT처리
           IF  FUNCTION MOD(WK-AC-INSERT-CNT, 1000) = CO-NUM-0
               #USRLOG 'WK-AC-INSERT-CNT : ' WK-AC-INSERT-CNT

               EXEC SQL
                    COMMIT
               END-EXEC

      *       리턴코드가 정상이 아니면 에러처리
               EVALUATE  SQLCODE
                   WHEN  ZERO
                         CONTINUE
                   WHEN  OTHER
                         MOVE 'KJLR007'    TO  XZUGEROR-I-TBL-ID
                         MOVE 'COMMIT'     TO  XZUGEROR-I-FUNC-CD
                         MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                         MOVE 'DBCommit시오류가발생했습니다 '
                                           TO  XZUGEROR-I-MSG
                         #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                         #OKEXIT CO-CHA-08
               END-EVALUATE
           END-IF

