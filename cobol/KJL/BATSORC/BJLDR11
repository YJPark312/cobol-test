      *@   SAM FILE READ LOOP
           PERFORM UNTIL IN-EOF-Y
      *@     기준년월일（１０바이트）＝＞기준년월일（８바이트）
             STRING IN-BASE-YMD(1:4)
                    IN-BASE-YMD(6:2)
                    IN-BASE-YMD(9:2)
             DELIMITED BY SIZE INTO WK-BASE-YMD

      *@     기준년월일＝자료기준일자　일치　확인
             IF WK-SYSIN-BASE-YMD NOT = WK-BASE-YMD
                #USRLOG '*--------------------------------------*'
                #USRLOG '작업기준일자／자료기준일자　불일치.'
                #USRLOG 'SYSIN  DATE = ' WK-SYSIN-BASE-YMD
                #USRLOG 'INFILE DATE = ' WK-BASE-YMD
      *@미일치시처리종료
                PERFORM S9000-FINAL-RTN
                   THRU S9000-FINAL-EXT
             END-IF

      *@     THKJLR011 INSERT ROUTINE
             PERFORM S3300-KJLR011-INSERT-RTN
                THRU S3300-KJLR011-INSERT-EXT

      *      SAM FILE READ ROUTINE CALL
             PERFORM  S3200-READ-FILE-RTN
                THRU  S3200-READ-FILE-EXT
           END-PERFORM
           .
       S3000-KJLR011-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *  READ FILE
      *-----------------------------------------------------------------
       S3200-READ-FILE-RTN.

      *    READ FILE
           READ IN-FILE  AT END
            SET IN-EOF-Y TO TRUE
           END-READ

      *    결과확인
           EVALUATE WK-IN-F-ST
               WHEN ZERO
               WHEN CO-CHA-04
                    ADD CO-NUM-1 TO WK-AC-READ-CNT
               WHEN CO-CHA-10
                    SET IN-EOF-Y TO TRUE
               WHEN OTHER
                    MOVE 'IN-FILE OPEN ERROR : FILE-ST IS '
                      TO XZUGEROR-I-MSG
                    MOVE WK-IN-F-ST
                      TO XZUGEROR-I-MSG(34:2)
                    #ERROR  CO-EBM02001 CO-UBM02001 WK-IN-F-ST
                    #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3200-READ-FILE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  외화주식상품정보(THKJLR011)등록
      *-----------------------------------------------------------------
       S3300-KJLR011-INSERT-RTN.

      *    초기화
           INITIALIZE TKJLR011-KEY
                      TRJLR011-REC

      *    그룹회사코드
           MOVE WK-H-I-GROUP-CO-CD
             TO RJLR011-GROUP-CO-CD

      *    기준년월일
           STRING IN-BASE-YMD(1:4)
                  IN-BASE-YMD(6:2)
                  IN-BASE-YMD(9:2)
           DELIMITED BY SIZE INTO RJLR011-BASE-YMD

      *    통합트레이드번호
           MOVE IN-INTGRA-TRD-NO
             TO RJLR011-INTGRA-TRD-NO

      *    고객식별자
           MOVE IN-CUST-IDNFR
             TO RJLR011-CUST-IDNFR

      *    고객관리번호
           MOVE IN-CUST-MGT-NO
             TO RJLR011-CUST-MGT-NO

      *    고객고유번호
           MOVE IN-CUST-UNIQ-NO
             TO RJLR011-CUNIQNO

      *    법인등록번호
           MOVE IN-CPRNO
             TO RJLR011-CPRNO

      *    통화코드
           MOVE IN-CNCYCD
             TO RJLR011-CNCYCD

      *    외화장부금액
           MOVE IN-FC-ACBK-AMT
             TO RJLR011-FC-ACBK-AMT

      *    관리부점코드
           MOVE IN-MGT-BRNCD(1:4)
             TO RJLR011-MGT-BRNCD

      *=======================================================
      *@통합계정과목을이용하여계정과목찾기

      *    통합계정과목코드
           MOVE IN-INTGRA-TIACC-CD
             TO WK-H-I-INTGRA-TIACC-CD

      *@계정과목／세과목추출
           PERFORM S3310-KJL0118-SELECT-RTN
              THRU S3310-KJL0118-SELECT-EXT

      *    계정과목코드
           MOVE WK-H-O-TIACC-CD
             TO RJLR011-TIACC-CD

      *    계정세과목코드
           MOVE WK-H-O-DACITM
             TO RJLR011-DACITM
      *=======================================================

      *    통합계정과목코드
           MOVE IN-INTGRA-TIACC-CD
             TO RJLR011-INTGRA-TIACC-CD

      *    원화환산장부가
           MOVE IN-WON-CUT-CNGBK-VAL
             TO RJLR011-WONC-UTCNG-BKVAL

      *    매입년월일
           STRING IN-BUY-YMD(1:4)
                  IN-BUY-YMD(6:2)
                  IN-BUY-YMD(9:2)
           DELIMITED BY SIZE INTO RJLR011-BUY-YMD

      *    대미환산장부금액
           MOVE IN-USD-ACBK-AMT
             TO RJLR011-USD-ACBK-AMT

      *    ISO국가코드
           MOVE IN-ISO-NATNL-CD
             TO RJLR011-ISO-NATNL-CD

      *    DBIO CALL
           #DYDBIO INSERT-CMD-Y TKJLR011-PK TRJLR011-REC

      *    결과확인
           EVALUATE TRUE
               WHEN COND-DBIO-OK
                    ADD CO-NUM-1 TO WK-AC-INSERT-CNT
               WHEN OTHER
                    MOVE 'KJLR011'    TO  XZUGEROR-I-TBL-ID
                    MOVE 'INSERT'     TO  XZUGEROR-I-FUNC-CD
                    MOVE DBIO-SQLCODE
                      TO XZUGEROR-I-SQL-CD
                    MOVE 'INSERT시 오류가 발생했습니다'
                      TO XZUGEROR-I-MSG
                    #ERROR   CO-EBM02001 CO-UBM02001 DBIO-STAT
                    #OKEXIT CO-CHA-08
           END-EVALUATE

      *@   1000 건　마다　 COMMIT & USRLOG
           IF  FUNCTION MOD(WK-AC-INSERT-CNT, 1000) = CO-NUM-0

               #USRLOG '* WK-AC-INSERT-CNT = ' WK-AC-INSERT-CNT

               EXEC SQL
                 COMMIT
               END-EXEC

      *@ Commit 처리결과 SQL-CODE를 확인하여 정상/오류 처리
               EVALUATE  SQLCODE
                   WHEN  CO-OK
                         CONTINUE
                   WHEN  OTHER
                         MOVE 'KJLR011'    TO  XZUGEROR-I-TBL-ID
                         MOVE 'COMMIT'     TO  XZUGEROR-I-FUNC-CD
                         MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                         MOVE 'DBCommit시오류가발생했습니다 '
                                           TO  XZUGEROR-I-MSG
                         #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                         #OKEXIT CO-CHA-08
               END-EVALUATE
           END-IF
           .
       S3300-KJLR011-INSERT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  계정과목코드＆세과목코드　추출
      *-----------------------------------------------------------------
       S3310-KJL0118-SELECT-RTN.

      *@계정과목코드＆세과목코드조회
           EXEC SQL
             SELECT VALUE(상품번호,' ') ,
                    VALUE(상품템플릿코드,' ')
               INTO :WK-H-O-TIACC-CD ,
                    :WK-H-O-DACITM
               FROM DB2DBA.THKJL0118
              WHERE 그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND 기준년월         = SUBSTR(:WK-H-I-BASE-YMD,1,6)
                AND 상품대분류코드   = 'KT'
                AND 통합계정과목코드 = :WK-H-I-INTGRA-TIACC-CD
               WITH UR FETCH FIRST 1 ROWS ONLY
           END-EXEC

      *@   결과확인
           EVALUATE SQLCODE
               WHEN CO-OK
                    CONTINUE
               WHEN CO-NOT-FOUND
                    MOVE CO-CHA-00000 TO  WK-H-O-TIACC-CD
                    MOVE CO-CHA-000   TO  WK-H-O-DACITM
               WHEN OTHER
                    MOVE 'KJL0118'    TO  XZUGEROR-I-TBL-ID
                    MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                    MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                    MOVE 'SELECT시 오류가 발생했습니다'
                      TO  XZUGEROR-I-MSG
                    #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                    #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-KJL0118-SELECT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  처리종료
      *-----------------------------------------------------------------
       S9000-FINAL-RTN.

      *    FILE CLOSE
           CLOSE IN-FILE

           IF WK-IN-F-ST NOT = CO-STAT-OK
              MOVE 'IN-FILE CLOSE ERROR : FILE-ST IS '
                TO XZUGEROR-I-MSG
              MOVE WK-IN-F-ST TO XZUGEROR-I-MSG(34:2)
              #ERROR  CO-EBM02001 CO-UBM02001 WK-IN-F-ST
              #OKEXIT CO-CHA-08
           END-IF

           #USRLOG '*--------------------------------------*'
           #USRLOG '* FILE READ       COUNT  = ' WK-AC-READ-CNT
           #USRLOG '* KJLR011 INSERT  COUNT  = ' WK-AC-INSERT-CNT
           #USRLOG '*--------------------------------------*'
           #USRLOG '* BJLDR11 PGM END                      *'
           #USRLOG '*--------------------------------------*'
           #OKEXIT  CO-CHA-00
           .
       S9000-FINAL-EXT.
           EXIT.
