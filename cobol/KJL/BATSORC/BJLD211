      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *   재작업용 삭제대상
           EXEC SQL
            DECLARE  KJL0021_DEL_CUR   CURSOR  WITH HOLD FOR
             SELECT  그룹회사코드
                  ,  기준년월일
                  ,  계좌번호
               FROM  DB2DBA.THKJL0021
              WHERE  그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND  기준년월일       = :WK-H-I-BASE-YMD
           END-EXEC

           EXEC SQL
            DECLARE  THKJL0125_CUR   CURSOR  WITH HOLD FOR
             SELECT  A.기준년월||기준일 AS 기준년월일
                  ,  A.계좌번호
                  ,  A.차주고객식별자
               FROM  DB2DBA.THKJL0125 A
                  ,  DB2DBA.THKJL0118 B
              WHERE  A.그룹회사코드     =  B.그룹회사코드
                AND  A.기준년월         =  B.기준년월
                AND  A.상품대분류코드   =  B.상품대분류코드
                AND  A.상품중분류코드   =  B.상품중분류코드
                AND  A.상품템플릿코드   =  B.상품템플릿코드
                AND  A.상품번호         =  B.상품번호
                AND  A.그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND  A.기준일           = :WK-H-I-BASE-DD
                AND  A.기준년월         = :WK-H-I-BASE-YM
                AND  A.계좌번호        != ''
                AND  A."TE계좌고객구분" NOT IN ('3','4','6','7')
                AND  B."CP대상계정여부" = '1'
               WITH UR
           END-EXEC.


