                        THRU  S8000-COMMIT-PROCESS-EXT

               WHEN  CO-SQL-NTFND
                     #USRLOG '<< THKJL0021 DELETE OK >>'
               WHEN  OTHER
                     MOVE 'KJL0021'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'DELETE'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'DELETE시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
      *@에러메시지:내부 본 처리
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .

       S3300-KJL0021-DELETE-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   CURSOR CLOSE
      *-----------------------------------------------------------------
       S3400-KJL0021-CLOSE-RTN.

           EXEC SQL
              CLOSE  KJL0021_DEL_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-SQL-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJL0021'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'CLOSE'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR CLOSE시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .

       S3400-KJL0021-CLOSE-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   업무처리
      *-----------------------------------------------------------------
       S3000-KJL0125-PROCESS-RTN.

           PERFORM  S3100-KJL0125-OPEN-RTN
              THRU  S3100-KJL0125-OPEN-EXT

           PERFORM  S3200-KJL0125-FETCH-RTN
              THRU  S3200-KJL0125-FETCH-EXT

           PERFORM  UNTIL  EOF-Y

                    PERFORM  S3300-IINE001-CALL-RTN
                       THRU  S3300-IINE001-CALL-EXT


                    IF  XIINE001-O-SEPA-APAT-APLY-YN = '1'
                        PERFORM  S3300-KJL0021-INSERT-RTN
                           THRU  S3300-KJL0021-INSERT-EXT
                    END-IF

                    PERFORM  S3200-KJL0125-FETCH-RTN
                       THRU  S3200-KJL0125-FETCH-EXT
           END-PERFORM

           PERFORM  S3400-KJL0125-CLOSE-RTN
              THRU  S3400-KJL0125-CLOSE-EXT
           .
       S3000-KJL0125-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR OPEN
      *-----------------------------------------------------------------
       S3100-KJL0125-OPEN-RTN.

           INITIALIZE    WK-SWITCHES

           EXEC SQL
               OPEN  THKJL0125_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-SQL-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJL0125'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'OPEN'       TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR OPEN시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3100-KJL0125-OPEN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR FETCH
      *-----------------------------------------------------------------
       S3200-KJL0125-FETCH-RTN.

           EXEC SQL
              FETCH  THKJL0125_CUR
               INTO  :WK-HOST-OUT
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-SQL-OK
                     ADD   CO-NUM-1    TO  WK-AC-FE-CNT1
               WHEN  CO-SQL-NTFND
                     SET   EOF-Y       TO  TRUE
               WHEN  OTHER
                     MOVE 'KJL0125'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR FETCH시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *    1000건　마다　 DISPLAY
           IF  FUNCTION MOD(WK-AC-FE-CNT1, 50000) = CO-NUM-0
               #USRLOG '*  WK-AC-FE-CNT1  = '  WK-AC-FE-CNT1
           END-IF
           .
       S3200-KJL0125-FETCH-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   별도전결권제외여부 조회
      *-----------------------------------------------------------------
       S3300-IINE001-CALL-RTN.

           INITIALIZE    XIINE001-CA

      *    처리구분코드
           MOVE  CO-CHA-R1
             TO  XIINE001-I-PRCSS-DSTCD

      *    담보연결여신계좌번호
           MOVE  WK-H-O-ACNO
             TO  XIINE001-I-SCURTY-L-LNBZ-ACNO

           #DYCALL  IINE001  YCCOMMON-CA  XIINE001-CA

           IF  XIINE001-R-STAT NOT = CO-STAT-OK

               #USRLOG '* ERR IINE001 ACNO  = ' WK-H-O-ACNO
                   ' - '  XIINE001-O-SEPA-APAT-APLY-YN

               #ERROR  XIINE001-R-ERRCD
                       XIINE001-R-TREAT-CD
                       XIINE001-R-STAT
               #OKEXIT CO-CHA-08
           END-IF

           .
       S3300-IINE001-CALL-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   포괄대상계좌관리(THKJL0021)등록
      *-----------------------------------------------------------------
       S3300-KJL0021-INSERT-RTN.

           INITIALIZE    TKJL0021-KEY
                         TRJL0021-REC

      *    그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  RJL0021-GROUP-CO-CD

      *    계좌번호
           MOVE  WK-H-O-ACNO
             TO  RJL0021-ACNO

      *    기준년월일
           MOVE  WK-H-I-BASE-YMD
             TO  RJL0021-BASE-YMD

      *    별도전결권적용여부
           MOVE  XIINE001-O-SEPA-APAT-APLY-YN
             TO  RJL0021-SEPA-DAR-APLY-YN

      *    차주고객식별자
           MOVE  WK-H-O-BRWR-CUST-IDNFR
             TO  RJL0021-BRWR-CUST-IDNFR

      **DB  LOG  WRITE START
           IF  WK-AC-INT-CNT1 < CO-NUM-1000
               SET  COND-DBIO-CHGLOG-YES  TO TRUE
           ELSE
               SET  COND-DBIO-CHGLOG-NO   TO TRUE
           END-IF

           #DYDBIO  INSERT-CMD-Y TKJL0021-PK TRJL0021-REC

           EVALUATE  TRUE
               WHEN  COND-DBIO-OK
                     ADD   CO-NUM-1    TO  WK-AC-INT-CNT1
               WHEN  OTHER
                     #USRLOG '* ERR WK-H-O-ACNO  = ' WK-H-O-ACNO
                     MOVE 'KJL0021'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'INSERT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  DBIO-SQLCODE
                                       TO  XZUGEROR-I-SQL-CD
                     MOVE 'INSERT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM02001 CO-UBM02001 DBIO-STAT
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *    1000건　마다　 DISPLAY
           IF  FUNCTION MOD(WK-AC-INT-CNT1, 1000) = CO-NUM-0
               #USRLOG '* WK-AC-INT-CNT1  = ' WK-AC-INT-CNT1
           END-IF

      *    10건　마다 COMMIT
           IF  FUNCTION MOD(WK-AC-INT-CNT1, 10) = CO-NUM-0

               EXEC SQL
                 COMMIT
               END-EXEC

      * Commit 처리결과 SQL-CODE를 확인하여 정상/오류 처
               EVALUATE  SQLCODE
                   WHEN  CO-SQL-OK
                         CONTINUE
                   WHEN  OTHER
                         MOVE 'KJL0021'    TO  XZUGEROR-I-TBL-ID
                         MOVE 'COMMIT'     TO  XZUGEROR-I-FUNC-CD
                         MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                         MOVE 'DBCommit시오류가발생했습니다 '
                                           TO  XZUGEROR-I-MSG
                         #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                         #OKEXIT CO-CHA-08
               END-EVALUATE
           END-IF
           .
       S3300-KJL0021-INSERT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR CLOSE
      *-----------------------------------------------------------------
       S3400-KJL0125-CLOSE-RTN.

           EXEC SQL
              CLOSE  THKJL0125_CUR
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-SQL-OK
