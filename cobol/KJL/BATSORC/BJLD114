      *-----------------------------------------------------------------
      * SQL CURSOR DECLARE
      *-----------------------------------------------------------------
      *@
           EXEC SQL
            DECLARE  THKJL0042_CUR     CURSOR FOR
            SELECT A.고객식별자           AS 차주고객식별자
                  ,B.모기업법인고객식별자 AS 모기업고객식별자
                  ,A.자회사대주주구분
                  ,A.등록년월일
                  ,A.해제년월일
              FROM DB2DBA.THKJL0042 A
                  ,DB2DBA.THKJL0015 B
             WHERE A.그룹회사코드 = B.그룹회사코드
               AND A.그룹회사코드 = :WK-H-I-GROUP-CO-CD
               AND A.고객식별자   = B.고객식별자
               AND A.기준년월     = SUBSTR(:WK-H-I-BASE-YMD,1,6)
           WITH UR
           END-EXEC.

