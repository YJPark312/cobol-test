      **** 전체 ****
           EXEC SQL
           DECLARE  THKJL0055_CUR1    CURSOR FOR
           SELECT A."ISO국가코드"
                 ,VALUE(SUM(대출        ),0) AS 대출
                 ,VALUE(SUM(지급보증    ),0) AS 지급보증
                 ,VALUE(SUM(회사채      ),0) AS 회사채
                 ,VALUE(SUM(주식        ),0) AS 주식
                 ,VALUE(SUM(기타유가증권),0) AS 기타유가증권
                 ,VALUE(SUM(예치금      ),0) AS 예치금
                 ,VALUE(SUM(파생상품    ),0) AS 파생상품
                 ,VALUE(SUM(기타        ),0) AS 기타
                 ,VALUE(SUM(합계        ),0) AS 합계
             FROM DB2DBA.THKJL0056 A LEFT OUTER JOIN
                  (SELECT A.그룹회사코드
                        , A."ISO국가코드"
                        , CASE WHEN B."TE중분류구분" = '001'
                               THEN A."USD한도"
                               ELSE 0
                          END AS 대출
                        , CASE WHEN B."TE중분류구분" = '002'
                               THEN A."USD한도"
                               ELSE 0
                          END AS 지급보증
                        , CASE WHEN B."TE중분류구분" = '003'
                               THEN A."USD한도"
                               ELSE 0
                          END AS 회사채
                        , CASE WHEN B."TE중분류구분" = '004'
                               THEN A."USD한도"
                               ELSE 0
                          END AS 주식
                        , CASE WHEN B."TE중분류구분" = '005'
                               THEN A."USD한도"
                               ELSE 0
                          END AS 기타유가증권
                        , CASE WHEN B."TE중분류구분" = '006'
                               THEN A."USD한도"
                               ELSE 0
                          END AS 예치금
                        , CASE WHEN B."TE중분류구분" = '007'
                               THEN A."USD한도"
                               ELSE 0
                          END AS 파생상품
                        , CASE WHEN B."TE중분류구분"
                                 IN ('001','002','003','004','005',
                                     '006','007')
                               THEN 0
                               ELSE A."USD한도"
                          END AS 기타
                        , A."USD한도" AS 합계
                     FROM DB2DBA.THKJL0055 A
                        , DB2DBA.THKJL0054 B
                    WHERE A.그룹회사코드   = B.그룹회사코드
                      AND A.상품대분류코드 = B.상품대분류코드
                      AND A.상품중분류코드 = B.상품중분류코드
                      AND A.상품템플릿코드 = B.상품템플릿코드
                      AND A.상품번호       = B.상품번호
                      AND A.그룹회사코드   = :WK-H-I-GROUP-CO-CD
                      AND A.기준년월일     = :WK-H-I-BASE-YMD
                      AND B.기준년월       = :WK-H-I-BASE-YM
                      AND A."USD한도"      > 0
                   ) C
               ON A.그룹회사코드  = C.그룹회사코드
              AND A."ISO국가코드" = C."ISO국가코드"
            WHERE A.그룹회사코드  = :WK-H-I-GROUP-CO-CD
              AND A.기준년월      = :WK-H-I-BASE-YM
            GROUP BY A."ISO국가코드"
             WITH UR
           END-EXEC.

