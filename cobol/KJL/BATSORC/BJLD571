      *-----------------------------------------------------------------
      *@   국별부점별신용공여집계(THKJL0057)삭제
      *-----------------------------------------------------------------
       S3000-KJL0057-DELETE-RTN.

           EXEC SQL
               LOCK TABLE DB2DBA.THKJL0057 IN EXCLUSIVE MODE
           END-EXEC

           EXEC SQL
             DELETE  FROM  DB2DBA.THKJL0057
              WHERE  그룹회사코드 = :WK-H-I-GROUP-CO-CD
                AND  기준년월일   = :WK-H-I-BASE-YMD
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
               WHEN  CO-NOT-FOUND
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJL0057'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'DELETE'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'DELETE시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
      *에러메시지:내부 본 처리
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

           EXEC SQL
             COMMIT
           END-EXEC

      * Commit 처리결과 SQL-CODE를 확인하여 정상/오
           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJL0057'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'COMMIT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'DB  Commit 시   오류가   발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3000-KJL0057-DELETE-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  업무처리
      *-----------------------------------------------------------------
       S3000-KJL0057-PROCESS-RTN.

           PERFORM  S3100-KJL0055-OPEN-RTN
              THRU  S3100-KJL0055-OPEN-EXT

           PERFORM  S3200-KJL0055-FETCH-RTN
              THRU  S3200-KJL0055-FETCH-EXT

           PERFORM  UNTIL EOF-Y

                    PERFORM  S3300-KJL0057-INSERT-RTN
                       THRU  S3300-KJL0057-INSERT-EXT

                    PERFORM  S3200-KJL0055-FETCH-RTN
                       THRU  S3200-KJL0055-FETCH-EXT
           END-PERFORM

           PERFORM  S3400-KJL0055-CLOSE-RTN
              THRU  S3400-KJL0055-CLOSE-EXT
           .
       S3000-KJL0057-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR OPEN
      *-----------------------------------------------------------------
       S3100-KJL0055-OPEN-RTN.

           EVALUATE  WK-GUBUN
               WHEN  CO-CHA-1
      *             전체
                     EXEC SQL
                          OPEN  THKJL0055_CUR1
                     END-EXEC
               WHEN  OTHER
      *             부점
                     EXEC SQL
                          OPEN  THKJL0055_CUR3
                     END-EXEC
           END-EVALUATE

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
                     MOVE 'KJL0055'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'OPEN'       TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR OPEN시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3100-KJL0055-OPEN-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   CURSOR FETCH
      *-----------------------------------------------------------------
       S3200-KJL0055-FETCH-RTN.

           INITIALIZE    WK-MGT-BRNCD
                         WK-HOST-OUT

           EVALUATE  WK-GUBUN
               WHEN  CO-CHA-1
      *             전체
                     EXEC SQL
                        FETCH  THKJL0055_CUR1
                         INTO  :WK-HOST-OUT
                     END-EXEC
                     MOVE  CO-CHA-9999
                       TO  WK-MGT-BRNCD
               WHEN  OTHER
      *             부점
                     EXEC SQL
                        FETCH  THKJL0055_CUR3
                         INTO  :WK-MGT-BRNCD
                            ,  :WK-HOST-OUT
                     END-EXEC
           END-EVALUATE

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     ADD   CO-NUM-1    TO  WK-AC-FE-CNT
               WHEN  CO-NOT-FOUND
                     SET   EOF-Y       TO  TRUE
               WHEN  OTHER
                     MOVE 'KJL0055'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'FETCH'      TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'CURSOR FETCH시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM03001 CO-UBM03001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3200-KJL0055-FETCH-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   국별부점별신용공여집계(THKJL0057)등록
      *-----------------------------------------------------------------
       S3300-KJL0057-INSERT-RTN.

           INITIALIZE    TKJL0057-KEY
                         TRJL0057-REC

      *    그룹회사코드
           MOVE  WK-H-I-GROUP-CO-CD
             TO  RJL0057-GROUP-CO-CD

      *    기준년월일
           MOVE  WK-H-I-BASE-YMD
             TO  RJL0057-BASE-YMD

      *    관리부점코드
           MOVE  WK-MGT-BRNCD
             TO  RJL0057-MGT-BRNCD

      *    ISO국가코드
           MOVE  WK-H-O-ISO-NATNL-CD
             TO  RJL0057-ISO-NATNL-CD

      *   영문국가명/국가별관리한도　추출
           PERFORM  S3310-KJL0056-SELECT-RTN
              THRU  S3310-KJL0056-SELECT-EXT

      *    영문국가명
           MOVE  RJL0056-ENG-NATNL-NAME
             TO  RJL0057-ENG-NATNL-NAME

      *    국가별관리한도
           MOVE  WK-NATNL-PER-MGT-CLAM
             TO  RJL0057-NATNL-PER-MGT-CLAM

      *    대출잔액
           MOVE  WK-H-O-LN-BAL
             TO  RJL0057-LN-BAL

      *    지급보증잔액
           MOVE  WK-H-O-PYGRNT-BAL
             TO  RJL0057-PYGRNT-BAL

      *    회사채잔액
           MOVE  WK-H-O-COBND-BAL
             TO  RJL0057-COBND-BAL

      *    주식잔액
           MOVE  WK-H-O-STCK-BAL
             TO  RJL0057-STCK-BAL

      *    유가증권잔액
           MOVE  WK-H-O-SECTS-BAL
             TO  RJL0057-SECTS-BAL

      *    예치금잔액
           MOVE  WK-H-O-DTMN-BAL
             TO  RJL0057-DTMN-BAL

      *    파생상품잔액
           MOVE  WK-H-O-DRVT-PRDCT-BAL
             TO  RJL0057-DRVT-PRDCT-BAL

      *    기타잔액
           MOVE  WK-H-O-ETC-BAL
             TO  RJL0057-ETC-BAL

      *    합계잔액
           MOVE  WK-H-O-BALSUM
             TO  RJL0057-BALSUM

      *    당행국가신용등급구분
           MOVE  WK-OWBNK-NC-GRD-DSTCD
             TO  RJL0057-OWBNK-NC-GRD-DSTCD

      *    국가전체공통한도여부
           MOVE  WK-NATNL-W-CMN-LIMT-YN
             TO  RJL0057-NATNL-W-CMN-LIMT-YN

      *    국가위험수준구분
           MOVE  WK-NATNL-R-LVEL-DSTCD
             TO  RJL0057-NATNL-R-LVEL-DSTCD

      *    국가지역별 관리한도 추출
           PERFORM  S3320-KJL0053-SELECT-RTN
              THRU  S3320-KJL0053-SELECT-EXT

      *    지역관리한도금액
           MOVE  WK-AREA-MGT-CLAM
             TO  RJL0057-AREA-MGT-CLAM

      *    국가전체공통한도 추출
           PERFORM  S3330-KJL0053-SELECT-RTN
              THRU  S3330-KJL0053-SELECT-EXT

      *    국가전체공통한도여부
           MOVE  WK-NATNL-WHOL-CMN-CLAM
             TO  RJL0057-NATNL-WHOL-CMN-CLAM

      *    한도관리지역구분
           MOVE  WK-LIMT-MGT-AREA-DSTCD
             TO  RJL0057-LIMT-MGT-AREA-DSTCD


           #DYDBIO  INSERT-CMD-Y TKJL0057-PK TRJL0057-REC

           EVALUATE  TRUE
               WHEN  COND-DBIO-OK
                     ADD   CO-NUM-1    TO  WK-AC-INT-CNT
               WHEN  OTHER

                     #USRLOG 'INSERT ERROR ' WK-MGT-BRNCD '=='
                                             WK-H-O-ISO-NATNL-CD
                     MOVE 'KJL0057'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'INSERT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  DBIO-SQLCODE
                                       TO  XZUGEROR-I-SQL-CD
                     MOVE 'INSERT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 DBIO-STAT
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3300-KJL0057-INSERT-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@   국별부점별한도기본(THKJL0056) 조회
      *-----------------------------------------------------------------
       S3310-KJL0056-SELECT-RTN.

           INITIALIZE    TRJL0056-REC

           EXEC SQL
             SELECT  VALUE(영문국가명          , ' ')
                  ,  VALUE(전체관리한도        ,  0 )
                  ,  VALUE(한도관리지역구분    , ' ')
                  ,  VALUE(당행국가신용등급구분, ' ')
                  ,  VALUE(국가전체공통한도여부, ' ')
                  ,  VALUE(국가위험수준구분    , ' ')
               INTO  :RJL0056-ENG-NATNL-NAME
                  ,  :RJL0056-WHOL-MGT-CLAM
                  ,  :RJL0056-LIMT-MGT-AREA-DSTCD
                  ,  :RJL0056-OWBNK-NC-GRD-DSTCD
                  ,  :RJL0056-NATNL-W-CMN-LIMT-YN
                  ,  :RJL0056-NATNL-R-LVEL-DSTCD
               FROM  DB2DBA.THKJL0056
              WHERE  그룹회사코드  = :WK-H-I-GROUP-CO-CD
                AND  기준년월      = :WK-H-I-BASE-YM
                AND  "ISO국가코드" = :WK-H-O-ISO-NATNL-CD
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     EVALUATE  WK-MGT-BRNCD
                         WHEN  '9999'
                               MOVE  RJL0056-WHOL-MGT-CLAM
                                 TO  WK-NATNL-PER-MGT-CLAM

      *                       한도관리지역구분
                               MOVE  RJL0056-LIMT-MGT-AREA-DSTCD
                                 TO  WK-LIMT-MGT-AREA-DSTCD

      *                       당행국가신용등급구분
                               MOVE  RJL0056-OWBNK-NC-GRD-DSTCD
                                 TO  WK-OWBNK-NC-GRD-DSTCD

      *                       국가전체공통한도여부
                               MOVE  RJL0056-NATNL-W-CMN-LIMT-YN
                                 TO  WK-NATNL-W-CMN-LIMT-YN

      *                       국가위험수준구분
                               MOVE  RJL0056-NATNL-R-LVEL-DSTCD
                                 TO  WK-NATNL-R-LVEL-DSTCD

                         WHEN  OTHER
                               MOVE  ZERO
                                 TO  WK-NATNL-PER-MGT-CLAM

      *                       한도관리지역구분
                               MOVE  SPACES
                                 TO  WK-LIMT-MGT-AREA-DSTCD

      *                       당행국가신용등급구분
                               MOVE  SPACES
                                 TO  WK-OWBNK-NC-GRD-DSTCD

      *                       국가전체공통한도여부
                               MOVE  SPACES
                                 TO  WK-NATNL-W-CMN-LIMT-YN

      *                       국가위험수준구분
                               MOVE  SPACES
                                 TO  WK-NATNL-R-LVEL-DSTCD
                     END-EVALUATE

               WHEN  CO-NOT-FOUND
      *              영문국가명
                     MOVE  WK-H-O-ISO-NATNL-CD
                       TO  RJL0056-ENG-NATNL-NAME
      *              전체관리한도
                     MOVE  ZERO
                       TO  WK-NATNL-PER-MGT-CLAM

      *              한도관리지역구분
                     MOVE  SPACES
                       TO  WK-LIMT-MGT-AREA-DSTCD

      *              당행국가신용등급구분
                     MOVE  SPACES
                       TO  WK-OWBNK-NC-GRD-DSTCD

      *              국가전체공통한도여부
                     MOVE  SPACES
                       TO  WK-NATNL-W-CMN-LIMT-YN

      *              국가위험수준구분
                     MOVE  SPACES
                       TO  WK-NATNL-R-LVEL-DSTCD

               WHEN  OTHER
                     MOVE 'KJL0056'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3310-KJL0056-SELECT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@   국가지역별한도관리(THKJL0053) 조회
      *-----------------------------------------------------------------
       S3320-KJL0053-SELECT-RTN.

           INITIALIZE    TRJL0053-REC

           EXEC SQL
             SELECT  VALUE(지역관리한도금액    ,   0)
               INTO  :RJL0053-AREA-MGT-CLAM
               FROM  DB2DBA.THKJL0053
              WHERE  그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND  기준년월         = :WK-H-I-BASE-YM
                AND  한도관리지역구분 = :WK-LIMT-MGT-AREA-DSTCD
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     EVALUATE  WK-MGT-BRNCD
                         WHEN  '9999'

      *                       지역관리한도금액
                               MOVE  RJL0053-AREA-MGT-CLAM
                                 TO  WK-AREA-MGT-CLAM

                         WHEN  OTHER
      *                       지역관리한도금액
                               MOVE  ZERO
                                 TO  WK-AREA-MGT-CLAM

                     END-EVALUATE

               WHEN  CO-NOT-FOUND
      *              지역관리한도금액
                     MOVE  ZERO
                       TO  WK-AREA-MGT-CLAM

               WHEN  OTHER
                     MOVE 'KJL0053'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE
           .
       S3320-KJL0053-SELECT-EXT.
           EXIT.


      *-----------------------------------------------------------------
      *@   국가전체공통한도(THKJL0053) 조회
      *-----------------------------------------------------------------
       S3330-KJL0053-SELECT-RTN.

           INITIALIZE    TRJL0053-REC

           EXEC SQL
             SELECT  VALUE(지역관리한도금액    ,   0)
               INTO  :RJL0053-AREA-MGT-CLAM
               FROM  DB2DBA.THKJL0053
              WHERE  그룹회사코드     = :WK-H-I-GROUP-CO-CD
                AND  기준년월         = :WK-H-I-BASE-YM
                AND  한도관리지역구분 = '9'
           END-EXEC

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     EVALUATE  WK-MGT-BRNCD
                         WHEN  '9999'

      *                       지역관리한도금액= 국가전체공통한도금액
                               MOVE  RJL0053-AREA-MGT-CLAM
                                 TO  WK-AREA-MGT-CLAM

                         WHEN  OTHER
      *                       지역관리한도금액
                               MOVE  ZERO
                                 TO  WK-AREA-MGT-CLAM

                     END-EVALUATE

               WHEN  CO-NOT-FOUND
      *              지역관리한도금액
                     MOVE  ZERO
                       TO  WK-AREA-MGT-CLAM

               WHEN  OTHER
                     MOVE 'KJL0053'    TO  XZUGEROR-I-TBL-ID
                     MOVE 'SELECT'     TO  XZUGEROR-I-FUNC-CD
                     MOVE  SQLCODE     TO  XZUGEROR-I-SQL-CD
                     MOVE 'SELECT시 오류가 발생했습니다'
                                       TO  XZUGEROR-I-MSG
                     #ERROR  CO-EBM05001 CO-UBM05001 CO-STAT-ERROR
                     #OKEXIT CO-CHA-08
           END-EVALUATE

      *    당행국가신용등급구분 = AAA, AA, A 이고
      *    국가전체공통한도여부 = 1:여 인경우 국가전체공통한도
      *    부여

           IF  ((WK-OWBNK-NC-GRD-DSTCD = ('AAA' OR
                                          'AA'  OR
                                          'A'     )) AND
                 WK-NATNL-W-CMN-LIMT-YN = '1'     )

                MOVE  WK-AREA-MGT-CLAM
                  TO  WK-NATNL-WHOL-CMN-CLAM
           ELSE
                MOVE  ZEROS
                  TO  WK-NATNL-WHOL-CMN-CLAM
           END-IF
           .
       S3330-KJL0053-SELECT-EXT.
           EXIT.


      *-----------------------------------------------------------------
      *@   CURSOR CLOSE
      *-----------------------------------------------------------------
       S3400-KJL0055-CLOSE-RTN.

           EVALUATE  WK-GUBUN
               WHEN  CO-CHA-1
      *             전체
                     EXEC SQL
                          CLOSE THKJL0055_CUR1
                     END-EXEC
               WHEN  OTHER
      *             부점
                     EXEC SQL
                          CLOSE THKJL0055_CUR3
                     END-EXEC
           END-EVALUATE

           EVALUATE  SQLCODE
               WHEN  CO-OK
                     CONTINUE
               WHEN  OTHER
