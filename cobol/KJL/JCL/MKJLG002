//SYSDBOUT DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSUDUMP DD DUMMY
//SYSIN    DD *
  SELECT 기준년월
        ,CHAR(',')
        ,그룹회사코드
        ,CHAR(',')
        ,CHAR(VALUE((SELECT 양방향고객암호화번호
                      FROM  DB2DBA.THKAABPCB
                     WHERE 그룹회사코드 = A.그룹회사코드
                       AND 고객식별자   = A.차주고객식별자
                     ),SPACE(44)),44) AS 차주번호
        ,CHAR(',')
        ,한도계좌번호
        ,CHAR(',')
        ,한도상품대분류코드
        ,CHAR(',')
        ,한도상품중분류코드
        ,CHAR(',')
        ,한도상품템플릿코드
        ,CHAR(',')
        ,한도상품번호
        ,CHAR(',')
        ,CHAR(DIGITS("BS기준잔액"))
        ,CHAR(',')
        ,CHAR(DIGITS(명목액기준한도))
        ,CHAR(',')
        ,CHAR(DIGITS(명목액기준잔액))
        ,CHAR(',')
        ,CHAR(DIGITS("EAD한도"))
        ,CHAR(',')
        ,CHAR(DIGITS("명목잔액CCF환산금액"))
        ,CHAR(',')
        ,CHAR(DIGITS("EAD한도CCF환산금액"))
        ,CHAR(',')
        ,CHAR(DIGITS("한도기준TE금액"))
        ,CHAR(',')
        ,CHAR(DIGITS("잔액기준TE금액"))
        ,CHAR(',')
        ,CHAR(DIGITS("CA담보제외금액"))
        ,CHAR(',')
        ,CHAR(DIGITS("CA담보환산금액"))
        ,CHAR(',')
        ,CHAR(DIGITS(신용공여한도))
        ,CHAR(',')
        ,CHAR(DIGITS(외화신용공여한도))
        ,CHAR(',')
        ,CHAR(REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE('.'||DIGITS(CAST(
         ROW_NUMBER() OVER (ORDER BY 그룹회사코드
                                    ,기준년월
                                    ,차주고객식별자
                                    ,한도계좌번호
                                    ,한도상품대분류코드
                                    ,한도상품중분류코드
                                    ,한도상품템플릿코드
                                    ,한도상품번호) AS DEC(10)))
                      ,'.000000000','         ')
                      ,'.00000000' ,'        ' )
                      ,'.0000000'  ,'       '  )
                      ,'.000000'   ,'      '   )
                      ,'.00000'    ,'     '    )
                      ,'.0000'     ,'    '     )
                      ,'.000'      ,'   '      )
                      ,'.00'       ,'  '       )
                      ,'.0'        ,' '        )
                      ,'.'         ,''         ))
    FROM DB2DBA.THKJL0128  A
   WHERE 그룹회사코드 = 'KB0'
     AND 기준년월     = '%%B'
     AND  EXISTS  (SELECT 1
                     FROM DB2DBA.THKJL0015
                    WHERE 그룹회사코드 = A.그룹회사코드
                      AND 고객식별자   = A.차주고객식별자
                      AND 차주번호구분 NOT IN ('1','2'))
    WITH  UR;
