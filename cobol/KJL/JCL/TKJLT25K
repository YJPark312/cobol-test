//*  EAD 한도관리계좌삭제작업（업무코드별삭제）－　국외FHD
//*********************************************************************
//STEP12  EXEC JZBDEXEC,MBR=BJLT25L,OPT=&SYSUID
//SYSIN     DD *
KB0-%%A-MKJLT25K-001-NORBAT-KB STAR-%%A-FHD
