/*
//********************************************************************/
//*   그룹신용공여일집계원장UNLOAD - DW제공자료                  */
//********************************************************************/
//STEP11   EXEC PGM=INZUTILB,REGION=0M,DYNAMNBR=99,
//         PARM='DAPG,KJL0037'
//STEPLIB  DD  DSN=DB2APS.DSND10.SDSNEXIT,DISP=SHR
//         DD  DSN=DB2APS.DSND10.SDSNLOAD,DISP=SHR
//UNLDDN1  DD  DSN=KJL.SD.SHRRMS.SKJL0037.P10071,
//             DISP=(NEW,CATLG,CATLG),UNIT=3390,
//             SPACE=(CYL,(500,100),RLSE),VOL=SER=ZAPUTD
//LOADDDN1 DD  SYSOUT=*
//*
//SYSPRINT DD  SYSOUT=*
//SYSIN    DD  *
     UNLOAD TABLESPACE
     DB2 NO LOCK NO
     QUIESCE NO  QUIESCECAT NO
     OPTIONS LENGTHBYTE NO
      SELECT 그룹회사코드
           , 기준년월|| '30'
           , 계열기업군코드
           , 상품대분류코드
           , 상품중분류코드
           , 상품템플릿코드
           , 상품번호
           ,  SUBSTR(CHAR("BS기준잔액"),2,15)
           ,  SUBSTR(CHAR("CA담보환산금액"),2,15)
           ,  SUBSTR(CHAR(제외자산금액),2,15)
           , 시스템최종처리일시
           , 시스템최종사용자번호
        FROM  DB2DBA.THKJL0038
       WHERE 그룹회사코드= 'KB0'
         AND 기준년월  = '201007'
     OUTDDN (UNLDDN1)
      FORMAT USER()
