/*
//SYSABOUT DD SYSOUT=*
//SYSDBOUT DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSUDUMP DD DUMMY
//SYSIN    DD *
  SELECT CHAR('%%A')
        ,CHAR(',')
        ,그룹회사코드
        ,CHAR(',')
        ,CHAR(VALUE((SELECT 양방향고객암호화번호
                      FROM  DB2DBA.THKAABPCB
                     WHERE 그룹회사코드 = A.그룹회사코드
                       AND 고객식별자   = A.고객식별자
                     ),SPACE(44)),44) AS 차주번호
        ,CHAR(',')
        ,CHAR(VALUE((SELECT 양방향고객암호화번호
                      FROM  DB2DBA.THKAABPCB
                     WHERE 그룹회사코드 = A.그룹회사코드
                       AND 고객식별자   = A.고객식별자
                     ),SPACE(44)),44) AS 법인등록번호
        ,CHAR(',')
        ,차주번호구분
        ,CHAR(',')
        ,고객식별자
        ,CHAR(',')
        ,신표준산업분류코드
        ,CHAR(',')
        ,내부신용평가등급구분
        ,CHAR(',')
        ,신용평가년월일
        ,CHAR(',')
        ,신용평가유효년월일                              T
        ,CHAR(',')
        ,고객관리부점코드
        ,CHAR(',')
        ,"TE기업규모구분"
        ,CHAR(',')
        ,"TEPEER구분"
        ,CHAR(',')
        ,대분류업종코드
        ,CHAR(',')
        ,산업평가등급구분
        ,CHAR(',')
        ,CHAR(CASE 차주번호구분
                  WHEN '1' THEN ' '
                           ELSE REPLACE(채무자명  ,',',' ')
              END) AS 채무자명
        ,CHAR(',')
        ,계열기업군코드
        ,CHAR(',')
        ,CHAR(REPLACE(계열기업군명  ,',',' '))
        ,CHAR(',')
        ,CHAR(SPACE(10)) AS 대표사업자번호
        ,CHAR(',')
        ,CHAR(DIGITS(매출액))
        ,CHAR(',')
        ,CHAR(DIGITS(총자산))
        ,CHAR(',')
        ,한도고객구분
        ,CHAR(',')
        ,CHAR(SPACE(13)) AS 모기업법인등록번호
        ,CHAR(',')
        ,"모기업ISO국가코드"
        ,CHAR(',')
        ,CHAR(SPACE(6)) AS 연합회차주번호
        ,CHAR(',')
        ,"고객ID구분"
        ,CHAR(',')
        ,한도그룹번호
        ,CHAR(',')
        ,그룹사신용등급구분
        ,CHAR(',')
        ,CHAR(SPACE(52)) AS 차주대표자명
        ,CHAR(',')
        ,CHAR(REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE('.'||DIGITS(CAST(
         ROW_NUMBER() OVER (ORDER BY 그룹회사코드
                                    ,고객식별자) AS DEC(10)))
                      ,'.000000000','         ')
                      ,'.00000000' ,'        ' )
                      ,'.0000000'  ,'       '  )
                      ,'.000000'   ,'      '   )
                      ,'.00000'    ,'     '    )
                      ,'.0000'     ,'    '     )
                      ,'.000'      ,'   '      )
                      ,'.00'       ,'  '       )
                      ,'.0'        ,' '        )
                      ,'.'         ,''         ))
    FROM DB2DBA.THKJL0015   A
   WHERE 그룹회사코드 = 'KB0'
     AND 차주번호구분 NOT IN ('1','2')
    WITH  UR;
