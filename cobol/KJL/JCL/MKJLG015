/*
//SYSABOUT DD SYSOUT=*
//SYSDBOUT DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSUDUMP DD DUMMY
//SYSIN    DD *
  SELECT 기준년월일
        ,CHAR(',')
        ,그룹회사코드
        ,CHAR(',')
        ,계좌번호
        ,CHAR(',')
        ,CHAR(DIGITS(계좌중복일련번호))
        ,CHAR(',')
        ,고객식별자
        ,CHAR(',')
        ,고객관리번호
        ,CHAR(',')
        ,CHAR(VALUE((SELECT 양방향고객암호화번호
                      FROM  DB2DBA.THKAABPCB
                     WHERE 그룹회사코드 = A.그룹회사코드
                       AND 고객식별자   = A.고객식별자
                     ),SPACE(44)),44) AS 차주번호
        ,CHAR(',')
        ,계약한도구분
        ,CHAR(',')
        ,상품대분류코드
        ,CHAR(',')
        ,상품중분류코드
        ,CHAR(',')
        ,상품템플릿코드
        ,CHAR(',')
        ,상품번호
        ,CHAR(',')
        ,대출자격구분
        ,CHAR(',')
        ,"ISO국가코드"
        ,CHAR(',')
        ,관리부점코드
        ,CHAR(',')
        ,시작년월일
        ,CHAR(',')
        ,만기년월일
        ,CHAR(',')
        ,종료년월일
        ,CHAR(',')
        ,과목코드
        ,CHAR(',')
        ,통화코드
        ,CHAR(',')
        ,CHAR(DIGITS(통화한도))
        ,CHAR(',')
        ,CHAR(DIGITS(통화금일잔액))
        ,CHAR(',')
        ,CHAR(DIGITS("USD한도"))
        ,CHAR(',')
        ,CHAR(DIGITS("USD금일잔액"))
        ,CHAR(',')
        ,CHAR(REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE(
              REPLACE('.'||DIGITS(CAST(
         ROW_NUMBER() OVER (ORDER BY 그룹회사코드
                                    ,기준년월일
                                    ,계좌번호
                                    ,계좌중복일련번호) AS DEC(10)))
                      ,'.000000000','         ')
                      ,'.00000000' ,'        ' )
                      ,'.0000000'  ,'       '  )
                      ,'.000000'   ,'      '   )
                      ,'.00000'    ,'     '    )
                      ,'.0000'     ,'    '     )
                      ,'.000'      ,'   '      )
                      ,'.00'       ,'  '       )
                      ,'.0'        ,' '        )
                      ,'.'         ,''         ))
    FROM DB2DBA.THKJL0055  A
   WHERE 그룹회사코드 = 'KB0'
     AND 기준년월일   = '%%A'
     AND  EXISTS  (SELECT 1
                     FROM DB2DBA.THKJL0015
                    WHERE 그룹회사코드 = A.그룹회사코드
                      AND 고객식별자   = A.고객식별자
                      AND 차주번호구분 NOT IN ('1','2'))
    WITH  UR;
