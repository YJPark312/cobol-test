//DFSPARM  DD  DSN=SYS1.PARMLIB(DFSPARMH),DISP=SHR
//SORTWK01 DD  UNIT=SYSDA,SPACE=(CYL,(2000,200),RLSE)
//SORTWK02 DD  UNIT=SYSDA,SPACE=(CYL,(2000,200),RLSE)
//SORTWK03 DD  UNIT=SYSDA,SPACE=(CYL,(2000,200),RLSE)
//SORTWK04 DD  UNIT=SYSDA,SPACE=(CYL,(2000,200),RLSE)
//SYSUT1   DD  UNIT=SYSDA,SPACE=(CYL,(1000,100),RLSE)
//SORTOUT  DD  UNIT=SYSDA,SPACE=(CYL,(1000,100),RLSE)
//SYSPRINT DD  SYSOUT=*
//SYSREC01 DD  DSN=KJL.SD.SHRTAA.SKJL0072.P00002,DISP=SHR
//SYSIN    DD *
  LOAD DATA LOG NO
  NOCOPYPEND
  RESUME YES
  INDDN SYSREC01 INTO TABLE
      DB2DBA.THKJL0072
/*
