//*배치작업기준일 : 수시작업
//*수시작업명     :  계좌별 신용공여한도 산출
//*********************************************************************
//*주의!!!!!
//*이　작업　수행시  테이블　해당　파티션　데이터　삭제
//*대상 TABLE : THKJL0072
//*  %%GLOBAL  PARMGLB1
//*  %%SET %%A = %%MEND%%$OYEAR.%%OMONTH
//*  %%SET %%B = %%SUBSTR %%A 7 2
//*  %%SET %%C = %%SUBSTR %%A 1 6
//*********************************************************************
//*  데이터셋 삭제
//*********************************************************************
//DELETE   EXEC PGM=IDCAMS
//SYSPRINT DD   SYSOUT=*
//SYSIN    DD   *
  DELETE  'KJL.SD.SHRTAA.SKJL0072.P00002'
  DELETE  'KJL.SD.SHRTAA.SKJL0073.P00002'
  DELETE  'KJL.SD.UNLOAD.SKJL0073.ALL'

  SET MAXCC=00
/*
//*********************************************************************
//*  테이블　해당　파티션　데이터　삭제
//*********************************************************************
//STEP01   EXEC PGM=DSNUTILB,PARM='DAPG,THKJL0072',COND=(4,LT)
//STEPLIB  DD DSN=DB2APS.DSND10.SDSNLOAD,DISP=SHR
//SW01WK01 DD UNIT=SYSALLDA,SPACE=(CYL,(3000,200),,,ROUND)
//SW02WK01 DD UNIT=SYSALLDA,SPACE=(CYL,(3000,200),,,ROUND)
//SW03WK01 DD UNIT=SYSALLDA,SPACE=(CYL,(3000,200),,,ROUND)
//SYSUT1   DD UNIT=SYSALLDA,SPACE=(CYL,(3000,200),,,ROUND)
//SORTOUT  DD UNIT=SYSALLDA,SPACE=(CYL,(3000,200),,,ROUND)
//PARTKJL  DD DUMMY
//SYSPRINT DD SYSOUT=*
//UTPRINT  DD SYSOUT=*
//SYSIN    DD *
  LOAD DATA
  LOG NO  NOCOPYPEND KEEPDICTIONARY
  INTO TABLE DB2DBA.THKJL0072
                   PART %%B INDDN PARTKJL RESUME NO REPLACE
/*
//*********************************************************************
//*신용공여계좌정보생성 THKJL0072(일)/THKJL0073(월)
