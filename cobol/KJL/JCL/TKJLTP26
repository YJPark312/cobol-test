//STEP02   EXEC JZBDEXEC,MBR=BJLD721,OPT=&SYSUID
//OTFILE   DD DSN=KJL.SD.SHRTAA.SKJL0072.P00002,
//            UNIT=SYSPA,
//            DISP=(NEW,CATLG,CATLG),
//            SPACE=(CYL,(0500,0100),RLSE)
//SYSIN    DD *
KB0-%%A-TKJLTP26-001-ONLBAT-KB STAR-%%A-Y
//*자료기준년월일-원장삭제구분
//*********************************************************************
//*THKJL0072(일) LOAD
//*********************************************************************
//STEP03   EXEC DSNUPROC,PARM='DAPG,KJL0072',COND=(4,LT)
//DSNTRACE DD  SYSOUT=*
