       ,A.시스템최종사용자번호
 FROM  DB2DBA.THKJL0001 A
WHERE  A.그룹회사코드 = 'KB0'
  AND  LENGTH(TRIM(A.차주번호)) <= 6
  AND  A.차주번호               != ''
UNION ALL
SELECT  A.그룹회사코드
       ,B.고객식별자
       ,A.기준년월
       ,CHAR('             ') AS 차주번호
       ,A.신표준산업분류코드
       ,A.한신평재무업종구분
       ,A.결산년월
       ,A.업종평균적용년
       ,A.내부신용평가등급구분
       ,A.신용평가년월일
       ,A.신용평가유효년월일
       ,A.신용등급지원비율
