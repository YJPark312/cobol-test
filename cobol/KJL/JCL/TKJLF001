       ,A.단기차입금
       ,A.단기차입금상환금액
       ,A.업종가중평균율
       ,A.업체총차입금
       ,A.총자산
       ,A.매출액
       ,A.현금흐름기준금액
       ,A.전전년자기자본금
       ,A.전년자기자본금
       ,A.기준년자기자본금
       ,A.금융자기자본비율
       ,A.차입금자기자본율
       ,A.자기자본기준금액
       ,A.상환능력기준한도
       ,A.차입금매출액비율
       ,A.차입금총자산비율
       ,A.규모기준한도
       ,A.기준한도
       ,A.외화기준한도
       ,A.시스템최종처리일시
       ,A.시스템최종사용자번호
 FROM  DB2DBA.THKJL0001 A
      ,DB2DBA.THKJL0015 B
WHERE  A.그룹회사코드 = B.그룹회사코드
  AND  A.차주번호     = B.차주번호
  AND  LENGTH(TRIM(A.차주번호)) > 6
WITH UR;
