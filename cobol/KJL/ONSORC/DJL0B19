           #DYDBIO  OPEN-CMD-1 TKJL0002-PK TRJL0002-REC

      *#1  DBIO 호출결과 확인
           IF NOT COND-DBIO-OK
              #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
           END-IF

           PERFORM VARYING WK-I FROM 1 BY 1
                     UNTIL COND-DBIO-MRNF

               #DYDBIO  FETCH-CMD-1 TKJL0002-PK TRJL0002-REC

      *#1      DBIO 호출결과 확인
               IF NOT COND-DBIO-OK   AND
                  NOT COND-DBIO-MRNF THEN
                  #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
               END-IF

               IF NOT COND-DBIO-MRNF THEN
      *            그룹회사코드
                   MOVE BICOM-GROUP-CO-CD
                     TO KJL0002-PK-GROUP-CO-CD

      *            한도신청번호
                   MOVE XDJL0B19-I-LIMT-APLCN-NO
                     TO KJL0002-PK-LIMT-APLCN-NO

      *            첨부파일일련번호
                   MOVE RJL0002-APNDX-FILE-SERNO
                     TO KJL0002-PK-APNDX-FILE-SERNO

                   #DYDBIO SELECT-CMD-Y TKJL0002-PK TRJL0002-REC

                   IF NOT COND-DBIO-OK   AND
                      NOT COND-DBIO-MRNF THEN
                      #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
                   END-IF

                   #DYDBIO DELETE-CMD-Y TKJL0002-PK TRJL0002-REC

                   IF NOT COND-DBIO-OK   AND
                      NOT COND-DBIO-MRNF THEN
                      #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
                   END-IF

               END-IF
           END-PERFORM

           #DYDBIO  CLOSE-CMD-1 TKJL0002-PK TRJL0002-REC

           IF NOT COND-DBIO-OK   AND
              NOT COND-DBIO-MRNF THEN
               #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
           END-IF

