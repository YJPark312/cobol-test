       S3400-QJL1241-CALL-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@ QJL1241 OUTPUT SET
      *-----------------------------------------------------------------
       S3410-QJL1241-OUTPUT-RTN.

      *@   기준년월일
           MOVE JICOM-BF-BZOPR-YMD
             TO XDJL0418-O-BASE-YMD

      *@   OUTPUT DATA PUT LOOP
           PERFORM VARYING WK-I FROM 1 BY 1
                   UNTIL   WK-I > DBSQL-SELECT-CNT

      *@       부점코드
               MOVE XQJL1241-O-BRNCD(WK-I)
                 TO XDJL0418-O-BBRN-CD

      *@       부점명
               MOVE XQJL1241-O-BRN-NAME(WK-I)
                 TO XDJL0418-O-BRN-NAME

      *@       차주번호
               MOVE XQJL1241-O-CUST-IDNFR(WK-I)
                 TO XDJL0418-O-CUST-IDNFR

      *@       차주명
               MOVE XQJL1241-O-BRWR-NAME(WK-I)
                 TO XDJL0418-O-BRWR-NAME

      *@       그룹명
               MOVE XQJL1241-O-GROUP-NAME(WK-I)
                 TO XDJL0418-O-GROUP-NAME

      *@       신용등급（신청시）
               MOVE XQJL1241-O-CRDRAT1(WK-I)
                 TO XDJL0418-O-APLCN-CRDRAT

      *@       신용등급（최근）
               MOVE XQJL1241-O-CRDRAT2(WK-I)
                 TO XDJL0418-O-CRDRAT

      *@       그룹등급（신청시）
               MOVE XQJL1241-O-GROUP-GRD1(WK-I)
                 TO XDJL0418-O-APLCN-GROUP-GRD

      *@       그룹등급（최근）
               MOVE XQJL1241-O-GROUP-GRD2(WK-I)
                 TO XDJL0418-O-GROUP-GRD

      *@       관리한도설정년월일
               MOVE XQJL1241-O-MGT-LIMT-STUP-YMD(WK-I)
                 TO XDJL0418-O-MGT-LIMT-STUP-YMD

      *@       설정상태
               MOVE XQJL1241-O-STUP-STUS(WK-I)
                 TO XDJL0418-O-STUP-STUS

      *@       관리한도유효년월일
               MOVE XQJL1241-O-MGT-LIMT-VALD-YMD(WK-I)
                 TO XDJL0418-O-VALD-FXDT

220324*    포괄신용관리한도가 0이 아니면(설정상태:설정)이면
               IF XQJL1241-O-INLS-LIMT(WK-I) NOT = ZERO
      *@           여신성자산최고한도＝여신성한도－간접익스포져
                   COMPUTE XDJL0418-O-LNBZ-INCLIN-LIMT
                         = FUNCTION MAX(
                           XQJL1241-O-LNBZ-IA-HGST-LIMT(WK-I) / 1000000,
                           0)

      *@           포괄한도
                   COMPUTE WK-TEMP-INLS-LIMT
                         = XQJL1241-O-INLS-LIMT(WK-I) / 1000000

      *@           2011.06.03추가
      *@          최종포괄한도= MIN(여신성최고한도,포괄한도)
                   COMPUTE XDJL0418-O-INLS-LIMT
                         = FUNCTION MAX(
                           FUNCTION MIN(
                           XDJL0418-O-LNBZ-INCLIN-LIMT,
                           WK-TEMP-INLS-LIMT), 0)

220324*@           기사용액 = MIN(사용액, 최종적용 포괄신용공여한도)
                   COMPUTE XDJL0418-O-USE-AMT
                         = FUNCTION MAX(
                           FUNCTION MIN(
                           XQJL1241-O-PRVIUS-AMUS(WK-I) / 1000000,
                           XDJL0418-O-INLS-LIMT), 0)

      *@            2011.06.03변경
      *@           소진율=최고포괄한도로　소진율　계산으로　변경
                   INITIALIZE WK-TEMP-EXHS-RT

                   IF XDJL0418-O-INLS-LIMT > 0
                       COMPUTE WK-TEMP-EXHS-RT
                             = XDJL0418-O-USE-AMT /
                               XDJL0418-O-INLS-LIMT

                       COMPUTE XDJL0418-O-EXHS-RT
                             = FUNCTION MAX(
                               FUNCTION MIN(
                               WK-TEMP-EXHS-RT * 100, 999.99), 0)
      *@           그렇지않은경우　０으로　산출
                   ELSE
                       MOVE ZERO
                         TO XDJL0418-O-EXHS-RT
                   END-IF
               END-IF
           END-PERFORM

           .
       S3410-QJL1241-OUTPUT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@ THKJL0005 : 결의록 조회
      *-----------------------------------------------------------------
       S3500-QJL2754-CALL-RTN.

           INITIALIZE                  XQJL2754-IN

      *    그룹회사코드
           MOVE  BICOM-GROUP-CO-CD
             TO  XQJL2754-I-GROUP-CO-CD
      *    한도신청번호
           MOVE  WK-LIMT-APLCN-NO
             TO  XQJL2754-I-LIMT-APLCN-NO

      *@3  프로그램 호출
           #DYSQLA  QJL2754  XQJL2754-CA

      *@3  호출결과 확인
           EVALUATE  TRUE
           WHEN  COND-DBSQL-OK
               PERFORM S3610-QJL2754-OUTPUT-RTN
                  THRU S3610-QJL2754-OUTPUT-EXT
           WHEN  COND-DBSQL-MRNF
