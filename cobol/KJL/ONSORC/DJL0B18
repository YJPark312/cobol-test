      *@1.1 조회결과확인
      *@처리내용 : IF 조회 error 이면 에러처리
           EVALUATE TRUE
           WHEN COND-DBIO-OK
               PERFORM VARYING WK-I FROM 1 BY 1 UNTIL WK-I > 10
                            OR COND-DBIO-MRNF

                   #DYDBIO  FETCH-CMD-1 TKJL0005-PK TRJL0005-REC

                   EVALUATE TRUE
                   WHEN COND-DBIO-OK
      *                     승인위원직원번호
                       MOVE RJL0005-ATHOR-CMMB-EMPID
                         TO KJL0005-PK-ATHOR-CMMB-EMPID

                       #DYDBIO DELETE-CMD-Y TKJL0005-PK TRJL0005-REC

                       EVALUATE TRUE
                       WHEN COND-DBIO-OK
                       WHEN COND-DBIO-MRNF
                           CONTINUE
                       WHEN OTHER
      *@                  원장삭제오류일경우
                           #ERROR CO-B4200219 CO-UKJL0036 CO-STAT-ERROR
                       END-EVALUATE
                   WHEN COND-DBIO-MRNF
                       CONTINUE
                   END-EVALUATE
               END-PERFORM
           WHEN COND-DBIO-MRNF
               CONTINUE
           WHEN OTHER
      *       원장에러일경우　에러처리
               #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
           END-EVALUATE

           #USRLOG  " <<< S3210-THKJL0005-DELETE-EXT >>> "
           .
       S3210-THKJL0005-DELETE-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@ 한도승인결의록이력　삽입(위원저장)
      *-----------------------------------------------------------------
       S3220-THKJL0005-INSERT-RTN.

           #USRLOG  " <<< S3220-THKJL0005-INSERT-RTN >>> "

      *@2.1변수초기화
           INITIALIZE TKJL0005-KEY
                      TRJL0005-REC

      *@3.1  원장등록
      *@  그룹회사코드
           MOVE BICOM-GROUP-CO-CD
             TO RJL0005-GROUP-CO-CD
      *@  한도신청번호
           IF   WK-BIT                 = CO-CHA-1
                MOVE WK-N-LIMT-APLCN-NO
                  TO RJL0005-LIMT-APLCN-NO
           ELSE
                MOVE WK-LIMT-APLCN-NO
                  TO RJL0005-LIMT-APLCN-NO
           END-IF

           #USRLOG  "=================================================="
           #USRLOG  " 한도신청번호   : " RJL0005-LIMT-APLCN-NO
           #USRLOG  "=================================================="

           PERFORM VARYING WK-J FROM 1 BY 1 UNTIL WK-J > 10
                        OR WK-J > XDJL0B18-I-TOTAL-LINE-CNT1
      *@      승인위원직원번호
               MOVE XDJL0B18-I-EMPID(WK-J)
                 TO RJL0005-ATHOR-CMMB-EMPID
      *@      승인위원구분 (2:합의심사역)
               MOVE CO-CHA-2
                 TO RJL0005-ATHOR-CMMB-DSTCD
      *@      한도승인구분 (0:해당무)
               MOVE CO-CHA-0
                 TO RJL0005-LIMT-ATHOR-DSTCD

      *@3.2DBIO CALL
               #DYDBIO INSERT-CMD-Y TKJL0005-PK TRJL0005-REC

      *@3.3처리결과확인
               EVALUATE TRUE
               WHEN COND-DBIO-OK
                    CONTINUE
               WHEN OTHER
      *@원장등록오류일경우
      *@에러메세지 : 테이블 INSERT 오류입니다．
      *@조치메세지 : 전산업무담당자에게　문의바랍니다.
                        #ERROR CO-B4200221 CO-UKJL0036 CO-STAT-ERROR
               END-EVALUATE
           END-PERFORM

           #USRLOG  " <<< S3220-THKJL0005-INSERT-EXT >>> "

           .
       S3220-THKJL0005-INSERT-EXT.
           EXIT.

