           IF XDJL4093-I-AMND-WGHTG-AVG-IRT = ZERO
               COMPUTE XDJL4093-O-AMND-CSFW-BASE-AMT
                     = FUNCTION MAX(
                       (((XDJL4093-I-AMND-OPRFT
                     +    XDJL4093-I-AMND-IMPRT-INT
                     +    XDJL4093-I-AMND-DPRC-CST) * 0.7
                     -   (XDJL4093-I-AMND-FNCS
                     +    XDJL4093-O-AMND-AR-ANTICI-AMT)))
                     * (XDJL4093-O-AMND-FNCS-WGHT-VAL / 100), 0)
           ELSE
               COMPUTE XDJL4093-O-AMND-CSFW-BASE-AMT
                     = FUNCTION MAX(
                       (((XDJL4093-I-AMND-OPRFT
                     +    XDJL4093-I-AMND-IMPRT-INT
                     +    XDJL4093-I-AMND-DPRC-CST) * 0.7
                     -   (XDJL4093-I-AMND-FNCS
                     +    XDJL4093-O-AMND-AR-ANTICI-AMT))
