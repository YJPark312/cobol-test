            AND XDJL4093-I-AMND-FTZ-CST-RATO > 2
               COMPUTE XDJL4093-O-AMND-FNCS-WGHT-VAL
                     = 0.9 * CO-NUM-100
           WHEN OTHER
               COMPUTE XDJL4093-O-AMND-FNCS-WGHT-VAL
                     = 1.0 * CO-NUM-100
           END-EVALUATE

           COMPUTE WK-TEMP2
                 = XDJL4093-I-AMND-WGHTG-AVG-IRT / 100

