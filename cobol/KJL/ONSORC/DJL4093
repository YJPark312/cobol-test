           WHEN XDJL4093-I-AMND-TOTAL-AMBR   = ZERO
            AND XDJL4093-I-AMND-ONCP         > ZERO
            AND XDJL4093-I-AMND-AMBR-ONCP-RT = ZERO
               COMPUTE XDJL4093-O-AMND-AC-WGHT-VAL
                     = 1.0 * CO-NUM-100
           WHEN XDJL4093-I-AMND-TOTAL-AMBR   = ZERO
            AND XDJL4093-I-AMND-ONCP         > ZERO
            AND XDJL4093-I-AMND-AMBR-ONCP-RT > ZERO
               COMPUTE XDJL4093-O-AMND-AC-WGHT-VAL
                     = 1.3 * CO-NUM-100
           WHEN XDJL4093-I-AMND-TOTAL-AMBR   > ZERO
            AND XDJL4093-I-AMND-ONCP         > ZERO
            AND XDJL4093-I-AMND-AMBR-ONCP-RT = ZERO
               COMPUTE XDJL4093-O-AMND-AC-WGHT-VAL
                     = 1.0 * CO-NUM-100
           WHEN XDJL4093-I-AMND-TOTAL-AMBR   = ZERO
            AND XDJL4093-I-AMND-ONCP        <= ZERO
               COMPUTE XDJL4093-O-AMND-AC-WGHT-VAL
                     = 1.0 * CO-NUM-100
           WHEN XDJL4093-I-AMND-TOTAL-AMBR   > ZERO
            AND XDJL4093-I-AMND-ONCP        <= ZERO
               COMPUTE XDJL4093-O-AMND-AC-WGHT-VAL
                     = 0.7 * CO-NUM-100
           WHEN XDJL4093-O-AMND-TA-ONCP-RATO = ZERO
               COMPUTE XDJL4093-O-AMND-AC-WGHT-VAL
                     = 1.3 * CO-NUM-100
           WHEN OTHER
               COMPUTE XDJL4093-O-AMND-AC-WGHT-VAL
                     = FUNCTION MIN(
                       FUNCTION MAX(
                       (XDJL4093-I-AMND-AMBR-ONCP-RT / 100.0000)
                     / (XDJL4093-O-AMND-TA-ONCP-RATO / 100.0000),
                       0.7000), 1.3000) * 100.0000
           END-EVALUATE

