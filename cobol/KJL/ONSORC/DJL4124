                   COMPUTE XDJL4124-O-LAST-INLS-LIMT(WK-CUR-CNT)
                         = FUNCTION MAX(
                           FUNCTION MIN(
                           XDJL4124-O-LNBZ-IA-HGST-LIMT(WK-CUR-CNT),
                           XDJL4124-O-INLS-LIMT(WK-CUR-CNT)), 0)

