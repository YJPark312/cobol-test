      *-----------------------------------------------------------------
      *@  산업취급관리검색
      *-----------------------------------------------------------------
       S3100-INSERT-PROC-RTN.

      *@1 MAX일련번호 조회
           PERFORM S3110-QJL6101-CALL-RTN
              THRU S3110-QJL6101-CALL-EXT

      *  카피북초기화
           INITIALIZE TKJL0061-KEY
                      TRJL0061-REC

      *@1 입력파라미터　조립
      *   그룹회사코드
           MOVE BICOM-GROUP-CO-CD
             TO KJL0061-PK-GROUP-CO-CD
      *   대분류업종코드
           MOVE XDJLB068-I-LAG-CLSFI-BZTYP-CD1
             TO KJL0061-PK-LAG-CLSFI-BZTYP-CD
      *   일련번호
           MOVE XQJL6101-O-SERNO
             TO KJL0061-PK-SERNO

      *@1  DBIO프로그램　호출
           #DYDBIO SELECT-CMD-Y TKJL0061-PK TRJL0061-REC

      *   호출결과확인
           EVALUATE TRUE
           WHEN COND-DBIO-OK
      *#1     원장에 존재할 경우
               EVALUATE RJL0061-LIMT-EIRR-DSTCD
      *       등록해제구분코드(1:등록요청)
               WHEN CO-CHA-1
      *@1         산업취급수정
                   PERFORM S3140-THKJL0061-UPDATE-RTN
                      THRU S3140-THKJL0061-UPDATE-EXT
               WHEN CO-CHA-4
      *       등록해제구분코드(4:해제결재)
      *@1         산업취급등록
                   PERFORM S3130-THKJL0061-INSERT-RTN
                      THRU S3130-THKJL0061-INSERT-EXT
               END-EVALUATE
           WHEN COND-DBIO-MRNF
      *#1     원장에존재하지않을경우
      *@1     산업취급등록
               PERFORM S3130-THKJL0061-INSERT-RTN
                  THRU S3130-THKJL0061-INSERT-EXT
           WHEN OTHER
      *       원장에러일경우　에러처리
               #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
           END-EVALUATE
           .

       S3100-INSERT-PROC-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  MAX일련번호 조회
      *-----------------------------------------------------------------
       S3110-QJL6101-CALL-RTN.

           INITIALIZE       XQJL6101-IN

      *   그룹회사코드
           MOVE BICOM-GROUP-CO-CD
             TO XQJL6101-I-GROUP-CO-CD
      *   대분류업종코드
           MOVE XDJLB068-I-LAG-CLSFI-BZTYP-CD1
             TO XQJL6101-I-LAG-CLSFI-BZTYP-CD

      *@1 MAX일련번호 취득 READ SQLIO호출
           #DYSQLA QJL6101 SELECT XQJL6101-CA

      * 1.1 조회결과확인
      * 처리내용 : IF 조회 error 이면 에러처리
           EVALUATE TRUE
           WHEN COND-DBSQL-OK
           WHEN COND-DBSQL-MRNF
               CONTINUE
           WHEN OTHER
      *       원장상태 오류입니다.
               #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
           END-EVALUATE
           .

       S3110-QJL6101-CALL-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  산업별규모별SUB한도관리등록
      *-----------------------------------------------------------------
       S3130-THKJL0061-INSERT-RTN.

           INITIALIZE                  TRJL0061-REC

      *@1 입력값조립
      *   그룹회사코드
           MOVE BICOM-GROUP-CO-CD
             TO RJL0061-GROUP-CO-CD
      *   대분류업종코드
           MOVE XDJLB068-I-LAG-CLSFI-BZTYP-CD1
             TO RJL0061-LAG-CLSFI-BZTYP-CD
      *   일련번호
           COMPUTE RJL0061-SERNO =
                   XQJL6101-O-SERNO + 1
      *   취급중단년월일
           MOVE XDJLB068-I-HNDLN-DSCN-YMD
             TO RJL0061-HNDLN-DSCN-YMD
      *   예외적용년월일
           MOVE XDJLB068-I-ECEPT-APLY-YMD
             TO RJL0061-ECEPT-APLY-YMD
      *   산업등록해제구분
           MOVE CO-CHA-1
             TO RJL0061-LIMT-EIRR-DSTCD
      *   등록직원번호
           MOVE BICOM-USER-EMPID
             TO RJL0061-REGI-EMPID
      *   등록년월일
           MOVE BICOM-TRAN-BASE-YMD
             TO RJL0061-REGI-YMD

      *@1 산업취급등록 프로그램호출
           #DYDBIO INSERT-CMD-Y TKJL0061-PK TRJL0061-REC

      *    DBIO호출결과확인
           EVALUATE TRUE
           WHEN COND-DBIO-OK
               CONTINUE
           WHEN OTHER
               #ERROR CO-B4200221 CO-UKJL0036 CO-STAT-ERROR
           END-EVALUATE
           .

       S3130-THKJL0061-INSERT-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  산업별TE한도초과기준일이력관리수정
      *-----------------------------------------------------------------
       S3140-THKJL0061-UPDATE-RTN.

           EVALUATE XDJLB068-I-PRCSS-DSTIC
      *#1 처리구분이 ０２등록인 경우
           WHEN CO-CHA-02
      *       취급중단년월일
               MOVE XDJLB068-I-HNDLN-DSCN-YMD
                 TO RJL0061-HNDLN-DSCN-YMD
      *       예외적용년월일
               MOVE XDJLB068-I-ECEPT-APLY-YMD
                 TO RJL0061-ECEPT-APLY-YMD
      *       산업등록해제구분
               MOVE CO-CHA-1
                 TO RJL0061-LIMT-EIRR-DSTCD
      *       등록직원번호
               MOVE BICOM-USER-EMPID
                 TO RJL0061-REGI-EMPID
      *       등록년월일
               MOVE BICOM-TRAN-BASE-YMD
                 TO RJL0061-REGI-YMD
      *#1 처리구분이 03등록결재인 경우
           WHEN CO-CHA-03
      *       산업등록해제구분
               MOVE CO-CHA-2
                 TO RJL0061-LIMT-EIRR-DSTCD
      *       등록결재직원번호
               MOVE BICOM-USER-EMPID
                 TO RJL0061-REGI-APRVAL-EMPID
      *       등록결재년월일
               MOVE BICOM-TRAN-BASE-YMD
                 TO RJL0061-REGI-APRVAL-YMD
      *#1 처리구분이 04해제요청인 경우
           WHEN CO-CHA-04
      *       산업등록해제구분
               MOVE CO-CHA-3
                 TO RJL0061-LIMT-EIRR-DSTCD
      *       해제직원번호
               MOVE BICOM-USER-EMPID
                 TO RJL0061-REVOC-EMPID
      *       해제년월일
               MOVE BICOM-TRAN-BASE-YMD
                 TO RJL0061-REVOC-YMD
      *#1 처리구분이 05해제결재인 경우
           WHEN CO-CHA-05
      *       산업등록해제구분
               MOVE CO-CHA-4
                 TO RJL0061-LIMT-EIRR-DSTCD
      *       해제결재직원번호
               MOVE BICOM-USER-EMPID
                 TO RJL0061-REVOC-APRVAL-EMPID
      *       해제결재년월일
               MOVE BICOM-TRAN-BASE-YMD
                 TO RJL0061-REVOC-APRVAL-YMD
           END-EVALUATE

      *@1 산업취급수정 프로그램호출
           #DYDBIO UPDATE-CMD-Y TKJL0061-PK TRJL0061-REC

      *   처리결과확인
           EVALUATE TRUE
           WHEN COND-DBIO-OK
               CONTINUE
           WHEN OTHER
               #ERROR CO-B4200224 CO-UKJL0036 CO-STAT-ERROR
           END-EVALUATE
           .

       S3140-THKJL0061-UPDATE-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  등록/해제/결재 처리
      *-----------------------------------------------------------------
       S3200-UPDATE-PROC-RTN.

      *@1  결재대상 다건처리
           PERFORM VARYING WK-I FROM 1 BY 1 UNTIL WK-I > 1000
                        OR WK-I > XDJLB068-I-TOTAL-LINE-CNT

      *       카피북초기화
               INITIALIZE TKJL0061-KEY
                          TRJL0061-REC

      *@1     입력파라미터　조립
      *       그룹회사코드
               MOVE BICOM-GROUP-CO-CD
                 TO KJL0061-PK-GROUP-CO-CD
      *       대분류업종코드
               MOVE XDJLB068-I-LAG-CLSFI-BZTYP-CD2(WK-I)
                 TO KJL0061-PK-LAG-CLSFI-BZTYP-CD
      *       일련번호
               MOVE XDJLB068-I-SERNO2(WK-I)
                 TO KJL0061-PK-SERNO

      *@1      DBIO프로그램　호출
               #DYDBIO SELECT-CMD-Y  TKJL0061-PK TRJL0061-REC

      *       호출결과확인
               EVALUATE TRUE
               WHEN COND-DBIO-OK
      *#1         원장에 존재할 경우
      *@1         산업취급이력수정
                   PERFORM S3140-THKJL0061-UPDATE-RTN
                      THRU S3140-THKJL0061-UPDATE-EXT

                   EVALUATE RJL0061-LIMT-EIRR-DSTCD
      *           등록해제구분코드(2:등록결재/3:해제요청/4:해제결재)
                   WHEN CO-CHA-2
      *@1             산업취급등록
                       PERFORM S4100-INSERT-PROC-RTN
                          THRU S4100-INSERT-PROC-EXT
                   WHEN CO-CHA-3
                       IF WK-I = 1
                           MOVE XDJLB068-I-LAG-C-BZTYP-CD-NM2(WK-I)
                             TO WK-MSNM-IN-BODY
                       ELSE
                           INITIALIZE  WK-LEN

      *                   업종명 공백을 카운트한다
                           INSPECT FUNCTION
                                   REVERSE(WK-MSNM-IN-BODY)
                           TALLYING WK-LEN FOR LEADING SPACE

                           MOVE CO-CHAR-LF
                             TO WK-MSNM-IN-BODY(500 - WK-LEN + 1:)
                           MOVE XDJLB068-I-LAG-C-BZTYP-CD-NM2(WK-I)
                             TO WK-MSNM-IN-BODY(500 - WK-LEN + 2:)
                       END-IF
                       #USRLOG %T WK-MSNM-IN-BODY
                   WHEN CO-CHA-4
      *@1             산업취급삭제
                       PERFORM S4200-DELETE-PROC-RTN
                          THRU S4200-DELETE-PROC-EXT
                   END-EVALUATE
               WHEN COND-DBIO-MRNF
      *#1         원장에존재하지않을경우
                   #ERROR CO-B4200066 CO-UKJL0036 CO-STAT-ERROR
               WHEN OTHER
      *           원장에러일경우　에러처리
                   #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
               END-EVALUATE
           END-PERFORM
           .

       S3200-UPDATE-PROC-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  메신저처리 수신대상조회
      *-----------------------------------------------------------------
       S3500-MESSENGER-SEND-RTN.

      *@  수신자직원번호를　조회한다
      *@   SQLIO COPYBOOK 초기화
           INITIALIZE XQJLHR01-IN

      *@   그룹회사코드
           MOVE BICOM-GROUP-CO-CD
             TO XQJLHR01-I-GROUP-CO-CD

      *@   SQLIO CALL
           #DYSQLA QJLHR01 XQJLHR01-CA

      *@   호출결과확인
           EVALUATE TRUE
           WHEN COND-DBSQL-OK
      *@1      메신저처리
               PERFORM S3510-MESSENGER-SEND-RTN
                  THRU S3510-MESSENGER-SEND-EXT
           WHEN COND-DBSQL-MRNF
               CONTINUE
           WHEN OTHER
      *@원장조회오류일경우
      *@에러메세지 : 테이블 SELECT 오류입니다．
      *@조치메세지 : 전산업무담당자에게　문의바랍니다
               #ERROR CO-B3900009 CO-UKJL0036 CO-STAT-ERROR
           END-EVALUATE
           .

       S3500-MESSENGER-SEND-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  메신저처리 수신대상조회
      *-----------------------------------------------------------------
       S3510-MESSENGER-SEND-RTN.

           MOVE DBSQL-SELECT-CNT
             TO WK-SQL-SELECT-CNT

      *    등록요청시는 업종명을 읽어오고
      *    해제요청시는 화면에서 가져온다.
           IF XDJLB068-I-PRCSS-DSTIC = CO-CHA-02
      *@1     대분류업종명조회
               PERFORM S3511-QJL6801-CALL-RTN
                  THRU S3511-QJL6801-CALL-EXT
           END-IF

      *@  메신저 조립
           PERFORM VARYING WK-I FROM 1 BY 1 UNTIL WK-I > 100
                        OR WK-I > WK-SQL-SELECT-CNT
      *@       메신저처리
      *@       COPYBOOK 초기화
               INITIALIZE XZUGMSNM-IN

      *        유틸리티　파라미터 MOVE
      *@       서비스유형
               MOVE CO-CHA-0
                 TO XZUGMSNM-IN-SERVTYPE

      *@       수신직원번호
               MOVE XQJLHR01-O-EMPID(WK-I)
                 TO XZUGMSNM-IN-REMPNO

      *@       발신직원번호
               MOVE BICOM-USER-EMPID
                 TO XZUGMSNM-IN-SENDNO

               IF XDJLB068-I-PRCSS-DSTIC = CO-CHA-02
      *@          쪽지제목
                   MOVE '한도초과산업등록 신청'
                     TO XZUGMSNM-IN-TITLE

      *@          쪽지본문
