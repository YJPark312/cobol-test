           IF XDJL409C-I-LIMT-APLCN-DSTIC = CO-CHA-1 OR CO-CHA-8
      *@      개별기업관리한도
              COMPUTE XDJL409C-O-IDIVI-CORP-MGT-LIMT
                    = RJL0003-CORP-TE-MGT-CLAM / 1000000
      *@      개별기업익스포져
              COMPUTE XDJL409C-O-IDIVI-CORP-EXPSR
                    = RJL0003-CORP-TE-AMT / 1000000
      *@      그룹관리한도
              COMPUTE XDJL409C-O-GROUP-MGT-LIMT
                    = RJL0003-GROUP-TE-MGT-CLAM / 1000000
      *@      그룹익스포져
              COMPUTE XDJL409C-O-GROUP-EXPSR
                    = RJL0003-GROUP-TE-AMT / 1000000
