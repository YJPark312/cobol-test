               WHEN COND-DBSQL-OK
                    CONTINUE
               WHEN COND-DBSQL-MRNF
                    MOVE '해당사항없음'
                      TO XQJL009I-O-LAG-C-BZTYP-CD-NAME
                    MOVE ZERO
                      TO XQJL009I-O-IDSTRY-MGT-CLAM
                    MOVE ZERO
                      TO XQJL009I-O-TE-LIMT-AUC
               WHEN OTHER
