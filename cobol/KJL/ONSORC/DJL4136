                   PERFORM S5000-CJIDT16-CALL-RTN
                      THRU S5000-CJIDT16-CALL-EXT

                   MOVE  XCJIDT16-O-BF-BZOPR-YMD
                     TO  XCJIEX01-I-BASE-YMD
                   MOVE  XDJL4136-O-CNCYCD1(WK-I)
                     TO  XCJIEX01-I-CNCYCD
                   MOVE  1
                     TO  XCJIEX01-I-EXRT-APLY-NTH

      * 공통 UTILITY CALL
                   #DYCALL   CJIEX01  YCCOMMON-CA  XCJIEX01-CA

      * RETURN 정보 확인
                   IF XCJIEX01-R-STAT    =  ZEROS

                       MOVE XCJIEX01-O-DEAL-BASE-EXRT(1)
                         TO WK-DEAL-BASE-EXRT
                       MOVE XCJIEX01-O-N100-UNIT-CRNCY-YN(1)
                         TO WK-N100-UNIT-CRNCY-YN
                   ELSE
                       MOVE 0
                         TO WK-DEAL-BASE-EXRT

                       MOVE '0'
                         TO WK-N100-UNIT-CRNCY-YN
                   END-IF
               ELSE
                   #ERROR CO-B4400002 CO-UKJL0036 CO-STAT-ERROR
               END-IF

           END-IF

      *환율고시단위구분
           IF  WK-N100-UNIT-CRNCY-YN = '1'
               MOVE 100       TO WK-HWGSCD
           ELSE
               MOVE 1         TO WK-HWGSCD
           END-IF

      * 매매기준율환산 ( 이사회승인원화환산금액)
           COMPUTE   WK-BRDC-ATHOR-WONC-AUC
                  =  WK-BRDC-ATHOR-AMT
                  *  WK-DEAL-BASE-EXRT
                  /  WK-HWGSCD

           .
       S4000-CJIEX01-CALL-EXT.
           EXIT.

      *-----------------------------------------------------------------
      *@  전영업년월일을 구한다.
      *-----------------------------------------------------------------
       S5000-CJIDT16-CALL-RTN.

      *@    초기화
           INITIALIZE XCJIDT16-IN
      *@    호출변수 MOVE
      *@   그룹회사코드
           MOVE BICOM-GROUP-CO-CD         TO XCJIDT16-I-GROUP-CO-CD
      *@   기준년월일
           MOVE XDJL4136-I-BASE-YMD       TO XCJIDT16-I-YMD
      *@   구분코드
           MOVE CO-CHA-1                  TO XCJIDT16-I-DSTCD
      *@   공통 UTILITY CALL
           #DYCALL CJIDT16 YCCOMMON-CA XCJIDT16-CA
      *@    호출결과　확인
           IF XCJIDT16-R-STAT = ZEROS
              CONTINUE
           ELSE
              #ERROR XCJIDT16-R-ERRCD
                     XCJIDT16-R-TREAT-CD
                     XCJIDT16-R-STAT
           END-IF
           .
       S5000-CJIDT16-CALL-EXT.
           EXIT.

