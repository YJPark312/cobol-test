              THRU S3100-CJIIL03-CALL-EXT

           #USRLOG 'HYH TEST WK-BASEYMD:           ' WK-BASEYMD
           #USRLOG 'HYH TEST WXDJL4136-I-BASE-YMD: ' XDJL4136-I-BASE-YMD

           IF WK-BASEYMD < XDJL4136-I-BASE-YMD

           #USRLOG 'HYH TEST 일데이터'
      *@2      대주주(특수관계인 포함)에
