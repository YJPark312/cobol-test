              THRU S3100-CJIIL09-CALL-EXT

      *@   전월　추출
           PERFORM S3200-CJIDT17-CALL-RTN
              THRU S3200-CJIDT17-CALL-EXT

      *@1  동일차주별신용공여（헤더）조회
           PERFORM S3300-QJL0331-CALL-RTN
              THRU S3300-QJL0331-CALL-EXT

      *@2  동일차주별신용공여　조회
           IF XDJL4033-I-INQURY-DSTIC = CO-CHA-1
      *@      은행기준
              PERFORM S3400-QJL0332-CALL-RTN
                 THRU S3400-QJL0332-CALL-EXT
           ELSE
      *@      금감원기준
              PERFORM S3500-QJL0333-CALL-RTN
                 THRU S3500-QJL0333-CALL-EXT
           END-IF
           .
       S3000-PROCESS-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@ 전년말구하기
      *-----------------------------------------------------------------
       S3100-CJIIL09-CALL-RTN.

      *@   초기화
           INITIALIZE XCJIIL09-IN

      *@   산출조건 DATA MOVE
      *@   그룹회사코드
           MOVE BICOM-GROUP-CO-CD
             TO XCJIIL09-I-GROUP-CO-CD
      *@   구분코드 - 1 : 증월, 2 : 감월
           MOVE CO-CHA-2
             TO XCJIIL09-I-DSTCD
      *@   기준년월일
           MOVE XDJL4033-I-BASE-YM
             TO XCJIIL09-I-YMD(1:6)
           MOVE CO-CHA-01
             TO XCJIIL09-I-YMD(7:2)
      *@   가산월／감산월
           MOVE CO-NUM-12
             TO XCJIIL09-I-PLS-SBTR-MN

      *@    공통UTILITY CALL
           #DYCALL CJIIL09 YCCOMMON-CA XCJIIL09-CA

      *@    호출결과확인
           IF XCJIIL09-R-STAT = ZERO
              CONTINUE
           ELSE
              #ERROR XCJIIL09-R-ERRCD
                     XCJIIL09-R-TREAT-CD
                     XCJIIL09-R-STAT
           END-IF
           .
       S3100-CJIIL09-CALL-EXT.
           EXIT.
      *-----------------------------------------------------------------
      *@  일자산출－전월
      *-----------------------------------------------------------------
       S3200-CJIDT17-CALL-RTN.

      *@   변수초기화
           INITIALIZE XCJIDT17-IN
      *@   변수 MOVE
           MOVE XDJL4033-I-BASE-YM TO XCJIDT17-I-YMD(1:6)
           MOVE CO-CHA-01          TO XCJIDT17-I-YMD(7:2)
           MOVE CO-CHA-1           TO XCJIDT17-I-DSTCD
      *@   프로그램　호출
           #DYCALL CJIDT17 YCCOMMON-CA XCJIDT17-CA
      *@   호출결과확인
           IF XCJIDT17-R-STAT = ZEROS
              CONTINUE
           ELSE
              #ERROR XCJIDT17-R-ERRCD
                     XCJIDT17-R-TREAT-CD
                     XCJIDT17-R-STAT
           END-IF
           .
       S3200-CJIDT17-CALL-EXT.
           EXIT.
